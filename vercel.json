{
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.youtube.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https://img.youtube.com https://i.ytimg.com https://www.fulfillmentmtp.com.ua data:; font-src 'self' https://fonts.gstatic.com; frame-src https://www.youtube.com https://www.google.com; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com https://api.telegram.org" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "fulfillmentmtp.com.ua" }],
      "destination": "https://www.fulfillmentmtp.com.ua/:path*",
      "permanent": true
    },
    {
      "source": "/ua",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/tpost/:slug*",
      "destination": "/blog/tpost/:slug*",
      "permanent": true
    },
    {
      "source": "/ru/blog/tpost/:slug*",
      "destination": "/blog/tpost/:slug*",
      "permanent": true
    },
    {
      "source": "/ua/fulfilment-dlya-marketpleysov/",
      "destination": "/ua/fulfilment-dlya-marketpleysiv/",
      "permanent": true
    },
    {
      "source": "/about/",
      "destination": "/ru/about/",
      "permanent": true
    },
    {
      "source": "/calculator/",
      "destination": "/ru/calculator/",
      "permanent": true
    },
    {
      "source": "/fulfilment-dlya-internet-magazynu/",
      "destination": "/ru/fulfilment-dlya-internet-magazynu/",
      "permanent": true
    },
    {
      "source": "/fulfilment-dlya-marketpleysov/",
      "destination": "/ru/fulfilment-dlya-marketpleysov/",
      "permanent": true
    },
    {
      "source": "/fulfilment-kiev/",
      "destination": "/ru/fulfilment-kiev/",
      "permanent": true
    },
    {
      "source": "/fulfilment-vazhkykh-tovariv/",
      "destination": "/ru/fulfilment-vazhkykh-tovariv/",
      "permanent": true
    },
    {
      "source": "/guide/",
      "destination": "/ru/guide/",
      "permanent": true
    },
    {
      "source": "/recalls/",
      "destination": "/ru/recalls/",
      "permanent": true
    },
    {
      "source": "/services/",
      "destination": "/ru/services/",
      "permanent": true
    },
    {
      "source": "/skladski-poslugy/",
      "destination": "/ru/skladski-poslugy/",
      "permanent": true
    },
    {
      "source": "/tsenu/",
      "destination": "/ru/tsenu/",
      "permanent": true
    }
  ],
  "trailingSlash": true
}
