---
interface Props {
  lang?: 'uk' | 'ru' | 'en';
  datePublished?: string;
  dateModified?: string;
  readingTime?: string;
}

const {
  lang = 'uk',
  datePublished = '',
  dateModified = '',
  readingTime = '',
} = Astro.props;

const i18n = {
  uk: {
    name: 'Микола Лящук',
    role: 'Засновник MTP Group Fulfillment · 11+ років у логістиці e-commerce',
    by: 'Автор',
    about: '/ua/about/',
    published: 'Опубліковано',
    updated: 'Оновлено',
    readTime: 'хв читання',
    alt: 'Микола Лящук — засновник MTP Group',
  },
  ru: {
    name: 'Николай Лящук',
    role: 'Основатель MTP Group Fulfillment · 11+ лет в e-commerce логистике',
    by: 'Автор',
    about: '/ru/about/',
    published: 'Опубликовано',
    updated: 'Обновлено',
    readTime: 'мин чтения',
    alt: 'Николай Лящук — основатель MTP Group',
  },
  en: {
    name: 'Mykola Liashchuk',
    role: 'Founder, MTP Group Fulfillment · 11+ years in e-commerce logistics',
    by: 'By',
    about: '/en/about/',
    published: 'Published',
    updated: 'Updated',
    readTime: 'min read',
    alt: 'Mykola Liashchuk, founder of MTP Group',
  },
} as const;

const t = i18n[lang];

const fmtDate = (iso: string) => {
  if (!iso) return '';
  try {
    const d = new Date(iso);
    const locale = lang === 'uk' ? 'uk-UA' : lang === 'ru' ? 'ru-RU' : 'en-US';
    return d.toLocaleDateString(locale, { year: 'numeric', month: 'long', day: 'numeric' });
  } catch {
    return iso;
  }
};
---
<aside class="author-byline" itemscope itemtype="https://schema.org/Person">
  <a href={t.about} class="author-byline__avatar" aria-label={t.alt}>
    <img
      src="/images/mykola-liashchuk.jpg"
      alt={t.alt}
      width="56"
      height="56"
      loading="lazy"
      decoding="async"
      itemprop="image"
    />
  </a>
  <div class="author-byline__body">
    <div class="author-byline__name">
      <span class="author-byline__by">{t.by}</span>
      <a href={t.about} itemprop="url"><span itemprop="name">{t.name}</span></a>
    </div>
    <div class="author-byline__role" itemprop="description">{t.role}</div>
    {(datePublished || readingTime) && (
      <div class="author-byline__meta">
        {datePublished && (
          <>
            <time itemprop="datePublished" datetime={datePublished}>{t.published}: {fmtDate(datePublished)}</time>
            {dateModified && dateModified !== datePublished && (
              <>
                <span class="author-byline__sep" aria-hidden="true">·</span>
                <time itemprop="dateModified" datetime={dateModified}>{t.updated}: {fmtDate(dateModified)}</time>
              </>
            )}
          </>
        )}
        {readingTime && (
          <>
            {datePublished && <span class="author-byline__sep" aria-hidden="true">·</span>}
            <span>{readingTime} {t.readTime}</span>
          </>
        )}
      </div>
    )}
  </div>
</aside>

<style is:global>
.author-byline {
  display: flex;
  gap: 16px;
  align-items: center;
  padding: 16px 20px;
  margin: 20px 0 32px;
  border: 1px solid #eee;
  border-radius: 12px;
  background: #fafafa;
  font-family: var(--fb, 'DM Sans', sans-serif);
}
.author-byline__avatar {
  flex-shrink: 0;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  overflow: hidden;
  display: block;
  border: 2px solid #fff;
  box-shadow: 0 1px 3px rgba(0, 0, 0, .1);
}
.author-byline__avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.author-byline__body {
  flex: 1;
  min-width: 0;
}
.author-byline__name {
  font-size: 15px;
  font-weight: 500;
  color: #000;
  line-height: 1.3;
}
.author-byline__name a {
  color: #000;
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: border-color .15s;
}
.author-byline__name a:hover {
  border-bottom-color: #e63329;
}
.author-byline__by {
  color: #666;
  font-weight: 400;
  margin-right: 4px;
}
.author-byline__role {
  font-size: 13px;
  color: #666;
  margin-top: 2px;
  line-height: 1.4;
}
.author-byline__meta {
  font-size: 12px;
  color: #888;
  margin-top: 6px;
  line-height: 1.4;
}
.author-byline__meta time {
  color: inherit;
}
.author-byline__sep {
  margin: 0 6px;
  color: #ccc;
}
@media (max-width: 500px) {
  .author-byline { padding: 14px 16px; gap: 12px; }
  .author-byline__avatar { width: 48px; height: 48px; }
  .author-byline__role { font-size: 12px; }
}
</style>
