---
interface Props { lang: 'uk' | 'ru' | 'en'; }
const { lang } = Astro.props;

const p = lang === 'uk' ? '/ua' : lang === 'en' ? '/en' : '';
const home = lang === 'uk' ? '/' : lang === 'en' ? '/en/' : '/ru/';

const t = {
  uk: { about:'Про нас', reviews:'Відгуки', services:'Послуги', tips:'Поради', blog:'Блог',
        allSvc:'Всі послуги', shops:'Для інтернет-магазинів', heavy:'Важкі товари',
        calc:'Калькулятор', prices:'Ціни', warehouse:'Складські послуги' },
  ru: { about:'О нас', reviews:'Отзывы', services:'Услуги', tips:'Советы', blog:'Блог',
        allSvc:'Все услуги', shops:'Для интернет-магазинов', heavy:'Тяжёлые товары',
        calc:'Калькулятор', prices:'Цены', warehouse:'Складские услуги' },
  en: { about:'About', reviews:'Reviews', services:'Services', tips:'Tips', blog:'Blog',
        allSvc:'All services', shops:'For online stores', heavy:'Heavy goods',
        calc:'Calculator', prices:'Prices', warehouse:'Warehouse services' },
}[lang];

const svcPrefix = lang === 'ru' ? '' : p;
const calcSlug = lang === 'en' ? 'calculator' : 'calculator';
const priceSlug = lang === 'en' ? 'prices' : lang === 'ru' ? 'tsenu' : 'tsiny';
const shopSlug = lang === 'en' ? 'fulfillment-for-online-stores' : 'fulfilment-dlya-internet-magazynu';
const heavySlug = lang === 'en' ? 'heavy-goods' : 'fulfilment-vazhkykh-tovariv';
const warehouseSlug = lang === 'en' ? 'warehouse-services' : 'skladski-poslugy';
---
<nav class="nav"><div class="nav-inner">
<a href={home} class="nav-logo"><span>MTP</span> GROUP</a>
<div class="nav-center" id="navLinks">
  <a href={`${p}/about/`}>{t.about}</a>
  <a href={`${p}/recalls/`}>{t.reviews}</a>
  <div class="nav-dropdown">
    <a href={`${svcPrefix}/services/`} class="nav-dropdown-trigger">{t.services} <span class="nav-dropdown-arrow">&#9662;</span></a>
    <div class="nav-dropdown-menu">
      <a href={`${svcPrefix}/services/`}>{t.allSvc}</a>
      <a href={`${svcPrefix}/${shopSlug}/`}>{t.shops}</a>
      <a href={`${svcPrefix}/${heavySlug}/`}>{t.heavy}</a>
      <a href={`${svcPrefix}/${warehouseSlug}/`}>{t.warehouse}</a>
      <a href={`${svcPrefix}/${calcSlug}/`}>{t.calc}</a>
      <a href={`${svcPrefix}/${priceSlug}/`}>{t.prices}</a>
    </div>
  </div>
  <a href={`${p}/guide/`}>{t.tips}</a>
  <a href={`${p}/blog/`}>{t.blog}</a>
</div>
<div class="nav-right" id="langSwitcher">
  <a href="/" class:list={[{active: lang === 'uk'}]} data-lang="ua">UA</a>
  <a href="/ru/" class:list={[{active: lang === 'ru'}]} data-lang="ru">RU</a>
  <a href="/en/" class:list={[{active: lang === 'en'}]} data-lang="en">EN</a>
  <a href="tel:+380501444645" class="nav-phone">+38(050) 144-46-45</a>
</div>
<div class="nav-burger" id="navBurger"><span></span><span></span><span></span></div>
</div></nav>

<script is:inline>
(function(){
var b=document.getElementById('navBurger'),l=document.getElementById('navLinks'),nav=document.querySelector('nav.nav,.nav');
if(b&&l){
  // Overlay for mobile menu
  var ov=document.createElement('div');
  ov.style.cssText='display:none;position:fixed;top:0;left:0;width:100%;height:100vh;background:rgba(0,0,0,.6);z-index:9999;cursor:pointer';
  if(nav)nav.appendChild(ov);
  function syncOverlay(){var open=l.classList.contains('open');ov.style.display=open?'block':'none';document.body.style.overflow=open?'hidden':'';}
  ov.addEventListener('click',function(){l.classList.remove('open');b.classList.remove('open');syncOverlay();});

  b.addEventListener('click',function(){b.classList.toggle('open');l.classList.toggle('open');syncOverlay();});
  l.addEventListener('click',function(e){if(e.target.tagName==='A'){b.classList.remove('open');l.classList.remove('open');syncOverlay();}});
  document.querySelectorAll('.nav-dropdown').forEach(function(dd){
    var timer,menu=dd.querySelector('.nav-dropdown-menu');if(!menu)return;
    dd.addEventListener('mouseenter',function(){clearTimeout(timer);menu.style.display='block';});
    dd.addEventListener('mouseleave',function(){timer=setTimeout(function(){menu.style.display='';},300);});
  });
  document.querySelectorAll('.nav-dropdown-trigger').forEach(function(t){
    t.addEventListener('click',function(e){if(window.innerWidth<=900){e.preventDefault();this.closest('.nav-dropdown').classList.toggle('mobile-open');}});
  });
}
})();

// Smart language switcher — redirects to same page in other language
(function(){
  var path = location.pathname;
  var map = {
    // UA↔RU↔EN slug mappings
    'tsiny': {ru:'tsenu', en:'prices'},
    'tsenu': {ua:'tsiny', en:'prices'},
    'prices': {ua:'tsiny', ru:'tsenu'},
    'fulfilment-dlya-internet-magazynu': {ru:'fulfilment-dlya-internet-magazynu', en:'fulfillment-for-online-stores'},
    'fulfillment-for-online-stores': {ua:'fulfilment-dlya-internet-magazynu', ru:'fulfilment-dlya-internet-magazynu'},
    'fulfilment-vazhkykh-tovariv': {ru:'fulfilment-vazhkykh-tovariv', en:'heavy-goods'},
    'heavy-goods': {ua:'fulfilment-vazhkykh-tovariv', ru:'fulfilment-vazhkykh-tovariv'},
    'skladski-poslugy': {ru:'skladski-poslugy', en:'warehouse-services'},
    'warehouse-services': {ua:'skladski-poslugy', ru:'skladski-poslugy'},
  };

  document.querySelectorAll('#langSwitcher a[data-lang]').forEach(function(a){
    var targetLang = a.dataset.lang;
    var newPath = '/';

    // Detect current page slug
    var slug = path.replace(/^\/(?:ua|en|ru)\//, '/').replace(/^\//, '').replace(/\/$/, '');

    // Homepage
    if(!slug || slug === 'ru') {
      if(targetLang === 'ua') newPath = '/';
      else if(targetLang === 'ru') newPath = '/ru/';
      else newPath = '/en/';
    }
    // Blog index
    else if(slug === 'blog' || slug.match(/^(?:ua\/)?blog$/)) {
      if(targetLang === 'ua') newPath = '/ua/blog/';
      else if(targetLang === 'ru') newPath = '/blog/';
      else newPath = '/en/blog/';
    }
    // Known pages with different slugs
    else {
      var baseSlug = slug.split('/').pop();
      var mapped = map[baseSlug];
      var targetSlug = mapped ? mapped[targetLang] || baseSlug : baseSlug;

      if(targetLang === 'ua') newPath = '/ua/' + targetSlug + '/';
      else if(targetLang === 'en') newPath = '/en/' + targetSlug + '/';
      else newPath = '/' + targetSlug + '/'; // RU = root
    }

    a.href = newPath;
  });
})();
</script>
