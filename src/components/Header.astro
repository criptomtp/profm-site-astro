---
interface Props { lang: 'uk' | 'ru' | 'en'; }
const { lang } = Astro.props;

const p = lang === 'uk' ? '/ua' : lang === 'en' ? '/en' : '';
const home = lang === 'uk' ? '/' : lang === 'en' ? '/en/' : '/ru/';

const t = {
  uk: { about:'Про нас', reviews:'Відгуки', services:'Послуги', tips:'Поради', blog:'Блог', phone:'+38(050) 144-46-45' },
  ru: { about:'О нас', reviews:'Отзывы', services:'Услуги', tips:'Советы', blog:'Блог', phone:'+38(050) 144-46-45' },
  en: { about:'About', reviews:'Reviews', services:'Services', tips:'Tips', blog:'Blog', phone:'+38(050) 144-46-45' },
}[lang];

// Mega-menu: 3 columns
const mega = {
  uk: {
    col1: { title: 'За нішею', items: [
      { href: '/ua/fulfilment-dlya-internet-magazynu/', label: 'Інтернет-магазини' },
      { href: '/ua/fulfilment-vazhkykh-tovariv/', label: 'Важкі товари 50+ кг' },
      { href: '/ua/skladski-poslugy/', label: 'Складські послуги' },
    ]},
    col2: { title: 'Інструменти', items: [
      { href: '/ua/calculator/', label: 'Калькулятор' },
      { href: '/ua/tsiny/', label: 'Ціни' },
    ]},
    col3: { title: '', items: [
      { href: '/ua/services/', label: 'Всі послуги →' },
    ]},
  },
  ru: {
    col1: { title: 'По нише', items: [
      { href: '/fulfilment-dlya-internet-magazynu/', label: 'Интернет-магазины' },
      { href: '/fulfilment-vazhkykh-tovariv/', label: 'Тяжёлые товары 50+ кг' },
      { href: '/skladski-poslugy/', label: 'Складские услуги' },
    ]},
    col2: { title: 'Инструменты', items: [
      { href: '/calculator/', label: 'Калькулятор' },
      { href: '/tsenu/', label: 'Цены' },
    ]},
    col3: { title: '', items: [
      { href: '/services/', label: 'Все услуги →' },
    ]},
  },
  en: {
    col1: { title: 'By niche', items: [
      { href: '/en/heavy-goods/', label: 'Heavy goods 50+ kg' },
      { href: '/en/warehouse-services/', label: 'Warehouse services' },
    ]},
    col2: { title: 'Tools', items: [
      { href: '/en/calculator/', label: 'Calculator' },
      { href: '/en/prices/', label: 'Prices' },
    ]},
    col3: { title: '', items: [
      { href: '/en/services/', label: 'All services →' },
    ]},
  },
}[lang];
---

<header class="hdr">
  <div class="hdr-inner">
    <a href={home} class="hdr-logo"><span class="hdr-logo-mtp">MTP</span> GROUP</a>

    <nav class="hdr-nav" id="hdrNav">
      <a href={`${p}/about/`}>{t.about}</a>
      <a href={`${p}/recalls/`}>{t.reviews}</a>

      <div class="hdr-dd">
        <button class="hdr-dd-trigger" id="ddTrigger">{t.services} <span class="hdr-arrow">▾</span></button>
        <div class="hdr-mega" id="hdrMega">
          <div class="hdr-mega-col">
            <span class="hdr-mega-title">{mega.col1.title}</span>
            {mega.col1.items.map(i => <a href={i.href}>{i.label}</a>)}
          </div>
          <div class="hdr-mega-col">
            <span class="hdr-mega-title">{mega.col2.title}</span>
            {mega.col2.items.map(i => <a href={i.href}>{i.label}</a>)}
          </div>
          <div class="hdr-mega-col">
            {mega.col3.items.map(i => <a href={i.href} class="hdr-mega-cta">{i.label}</a>)}
          </div>
        </div>
      </div>

      <a href={`${p}/guide/`}>{t.tips}</a>
      <a href={`${p}/blog/`}>{t.blog}</a>
    </nav>

    <div class="hdr-right" id="langSwitcher">
      <a href="/" data-lang="ua" class:list={[{active: lang === 'uk'}]}>UA</a>
      <a href="/ru/" data-lang="ru" class:list={[{active: lang === 'ru'}]}>RU</a>
      <a href="/en/" data-lang="en" class:list={[{active: lang === 'en'}]}>EN</a>
      <a href="tel:+380501444645" class="hdr-phone">{t.phone}</a>
    </div>

    <button class="hdr-burger" id="hdrBurger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
<div class="hdr-overlay" id="hdrOverlay"></div>

<style is:global>
/* ============ HEADER — single source of truth ============ */
.hdr{position:fixed;top:0;left:0;right:0;height:64px;background:#000;z-index:10000;display:flex;align-items:center;padding:0 24px}
.hdr-inner{display:flex;align-items:center;justify-content:space-between;max-width:1400px;width:100%;margin:0 auto}
.hdr-logo{font-family:'DM Serif Display',serif;font-size:20px;color:#fff;text-decoration:none;white-space:nowrap}
.hdr-logo-mtp{color:#e63329}

/* Desktop nav */
.hdr-nav{display:flex;align-items:center;gap:24px}
.hdr-nav>a{color:rgba(255,255,255,.85);font-size:13px;text-decoration:none;transition:color .2s;font-family:'DM Sans',sans-serif}
.hdr-nav>a:hover{color:#fff}

/* Dropdown trigger */
.hdr-dd{position:relative}
.hdr-dd-trigger{background:none;border:none;color:rgba(255,255,255,.85);font-size:13px;cursor:pointer;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:4px;padding:0}
.hdr-dd-trigger:hover{color:#fff}
.hdr-arrow{font-size:10px;transition:transform .2s}
.hdr-dd.open .hdr-arrow{transform:rotate(180deg)}

/* Mega menu — 3 columns */
.hdr-mega{display:none;position:absolute;top:calc(100% + 16px);left:50%;transform:translateX(-50%);background:#111;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:20px 24px;min-width:420px;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:10001}
.hdr-mega::before{content:'';position:absolute;top:-6px;left:50%;transform:translateX(-50%);border:6px solid transparent;border-bottom-color:rgba(255,255,255,.1);border-top:none}
.hdr-dd.open .hdr-mega{display:grid;grid-template-columns:1fr 1fr auto;gap:0}
.hdr-mega-col{padding:0 16px;border-right:1px solid rgba(255,255,255,.08)}
.hdr-mega-col:first-child{padding-left:0}
.hdr-mega-col:last-child{padding-right:0;border-right:none}
.hdr-mega-title{display:block;font-size:10px;color:#e63329;text-transform:uppercase;letter-spacing:2px;margin:0 0 8px;font-weight:600}
.hdr-mega-col a{display:block;padding:5px 0;font-size:13px;color:rgba(255,255,255,.75);white-space:nowrap;text-decoration:none;transition:color .2s}
.hdr-mega-col a:hover{color:#fff}
.hdr-mega-cta{font-weight:500;color:#e63329 !important}
/* Hover bridge */
.hdr-dd::after{content:'';position:absolute;top:100%;left:0;right:0;height:20px}

/* Language switcher */
.hdr-right{display:flex;align-items:center;gap:16px}
.hdr-right a{color:rgba(255,255,255,.7);font-size:13px;text-decoration:none;transition:color .2s;font-family:'DM Sans',sans-serif}
.hdr-right a:hover,.hdr-right a.active{color:#fff}
.hdr-phone{white-space:nowrap;font-variant-numeric:tabular-nums}

/* Burger — hidden on desktop */
.hdr-burger{display:none;background:none;border:none;cursor:pointer;padding:8px;flex-direction:column;gap:5px;z-index:10001}
.hdr-burger span{display:block;width:22px;height:2px;background:#fff;transition:transform .3s,opacity .3s}
.hdr-burger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.hdr-burger.open span:nth-child(2){opacity:0}
.hdr-burger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}

/* Overlay */
.hdr-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999}
.hdr-overlay.open{display:block}

/* ============ MOBILE (≤900px) ============ */
@media(max-width:900px){
  .hdr-burger{display:flex}
  .hdr-phone{display:none}
  .hdr-nav{
    position:fixed;top:0;right:-280px;width:280px;height:100vh;
    background:#111;flex-direction:column;align-items:flex-start;
    padding:90px 32px 40px;gap:0;z-index:10000;
    transition:right .3s ease;overflow-y:auto;
    box-shadow:-4px 0 20px rgba(0,0,0,.5)
  }
  .hdr-nav.open{right:0}
  .hdr-nav>a{font-size:18px;padding:14px 0;width:100%;border-bottom:1px solid rgba(255,255,255,.1)}
  .hdr-dd{width:100%}
  .hdr-dd-trigger{font-size:18px;padding:14px 0;width:100%;border-bottom:1px solid rgba(255,255,255,.1);justify-content:space-between}
  .hdr-mega{position:static;transform:none;min-width:auto;display:none;border:none;box-shadow:none;background:rgba(255,255,255,.05);border-radius:0;padding:8px 0 8px 20px;margin:0}
  .hdr-mega::before{display:none}
  .hdr-dd.open .hdr-mega{display:block;grid-template-columns:1fr}
  .hdr-mega-col{padding:6px 0;border-right:none;border-bottom:1px solid rgba(255,255,255,.06)}
  .hdr-mega-col:last-child{border-bottom:none}
  .hdr-mega-col a{font-size:15px;padding:8px 0}
  .hdr-right{gap:12px}
  .hdr-right a{font-size:13px;min-width:32px;min-height:44px;display:inline-flex;align-items:center;justify-content:center}
}

/* Content offset for fixed header */
main{padding-top:64px}
</style>

<script is:inline>
(function(){
  var burger = document.getElementById('hdrBurger');
  var nav = document.getElementById('hdrNav');
  var overlay = document.getElementById('hdrOverlay');
  var ddTrigger = document.getElementById('ddTrigger');
  var dd = ddTrigger ? ddTrigger.closest('.hdr-dd') : null;

  if(!burger || !nav) return;

  // Burger toggle
  burger.addEventListener('click', function(){
    burger.classList.toggle('open');
    nav.classList.toggle('open');
    overlay.classList.toggle('open');
    document.body.style.overflow = nav.classList.contains('open') ? 'hidden' : '';
  });

  // Close on overlay click
  overlay.addEventListener('click', function(){
    burger.classList.remove('open');
    nav.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  });

  // Close on link click (mobile)
  nav.addEventListener('click', function(e){
    if(e.target.tagName === 'A'){
      burger.classList.remove('open');
      nav.classList.remove('open');
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }
  });

  // Dropdown (mega-menu)
  if(dd && ddTrigger){
    var timer;
    // Desktop: hover
    dd.addEventListener('mouseenter', function(){ clearTimeout(timer); dd.classList.add('open'); });
    dd.addEventListener('mouseleave', function(){ timer = setTimeout(function(){ dd.classList.remove('open'); }, 250); });
    // Mobile: tap
    ddTrigger.addEventListener('click', function(e){
      if(window.innerWidth <= 900){ e.preventDefault(); dd.classList.toggle('open'); }
    });
  }

  // Smart language switcher
  var path = location.pathname;
  var map = {
    'tsiny':{ru:'tsenu',en:'prices'},'tsenu':{ua:'tsiny',en:'prices'},'prices':{ua:'tsiny',ru:'tsenu'},
    'fulfilment-dlya-internet-magazynu':{ru:'fulfilment-dlya-internet-magazynu',en:'fulfillment-for-online-stores'},
    'fulfillment-for-online-stores':{ua:'fulfilment-dlya-internet-magazynu',ru:'fulfilment-dlya-internet-magazynu'},
    'fulfilment-vazhkykh-tovariv':{ru:'fulfilment-vazhkykh-tovariv',en:'heavy-goods'},
    'heavy-goods':{ua:'fulfilment-vazhkykh-tovariv',ru:'fulfilment-vazhkykh-tovariv'},
    'skladski-poslugy':{ru:'skladski-poslugy',en:'warehouse-services'},
    'warehouse-services':{ua:'skladski-poslugy',ru:'skladski-poslugy'},
  };
  document.querySelectorAll('#langSwitcher a[data-lang]').forEach(function(a){
    var tl = a.dataset.lang;
    var slug = path.replace(/^\/(?:ua|en|ru)\//,'/').replace(/^\//,'').replace(/\/$/,'');
    var newPath='/';
    if(!slug||slug==='ru'){newPath=tl==='ua'?'/':tl==='ru'?'/ru/':'/en/';}
    else if(slug==='blog'||slug.match(/^(?:ua\/)?blog$/)){newPath=tl==='ua'?'/ua/blog/':tl==='ru'?'/blog/':'/en/blog/';}
    else{var bs=slug.split('/').pop();var m=map[bs];var ts=m?m[tl]||bs:bs;newPath=tl==='ua'?'/ua/'+ts+'/':tl==='en'?'/en/'+ts+'/':'/'+ts+'/';}
    a.href=newPath;
  });
})();
</script>
