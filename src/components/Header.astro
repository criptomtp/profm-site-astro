---
interface Props { lang: 'uk' | 'ru' | 'en'; }
const { lang } = Astro.props;

const p = lang === 'uk' ? '/ua' : lang === 'en' ? '/en' : '';
const home = lang === 'uk' ? '/' : lang === 'en' ? '/en/' : '/ru/';

const t = {
  uk: { about:'Про нас', reviews:'Відгуки', services:'Послуги', tips:'Поради', blog:'Блог', phone:'+38(050) 144-46-45' },
  ru: { about:'О нас', reviews:'Отзывы', services:'Услуги', tips:'Советы', blog:'Блог', phone:'+38(050) 144-46-45' },
  en: { about:'About', reviews:'Reviews', services:'Services', tips:'Tips', blog:'Blog', phone:'+38(050) 144-46-45' },
}[lang];

const mega = {
  uk: {
    col1: { title: 'За нішею', items: [
      { href: '/ua/fulfilment-dlya-internet-magazynu/', label: 'Інтернет-магазини' },
      { href: '/ua/fulfilment-vazhkykh-tovariv/', label: 'Важкі товари 50+ кг' },
      { href: '/ua/skladski-poslugy/', label: 'Складські послуги' },
    ]},
    col2: { title: 'Інструменти', items: [
      { href: '/ua/calculator/', label: 'Калькулятор' },
      { href: '/ua/tsiny/', label: 'Ціни' },
    ]},
    col3: { title: '', items: [
      { href: '/ua/services/', label: 'Всі послуги →' },
    ]},
  },
  ru: {
    col1: { title: 'По нише', items: [
      { href: '/fulfilment-dlya-internet-magazynu/', label: 'Интернет-магазины' },
      { href: '/fulfilment-vazhkykh-tovariv/', label: 'Тяжёлые товары 50+ кг' },
      { href: '/skladski-poslugy/', label: 'Складские услуги' },
    ]},
    col2: { title: 'Инструменты', items: [
      { href: '/calculator/', label: 'Калькулятор' },
      { href: '/tsenu/', label: 'Цены' },
    ]},
    col3: { title: '', items: [
      { href: '/services/', label: 'Все услуги →' },
    ]},
  },
  en: {
    col1: { title: 'By niche', items: [
      { href: '/en/heavy-goods/', label: 'Heavy goods 50+ kg' },
      { href: '/en/warehouse-services/', label: 'Warehouse services' },
    ]},
    col2: { title: 'Tools', items: [
      { href: '/en/calculator/', label: 'Calculator' },
      { href: '/en/prices/', label: 'Prices' },
    ]},
    col3: { title: '', items: [
      { href: '/en/services/', label: 'All services →' },
    ]},
  },
}[lang];
---

<header class="hdr">
  <div class="hdr-inner">
    <a href={home} class="hdr-logo"><span class="hdr-logo-mtp">MTP</span> GROUP</a>

    <nav class="hdr-nav" id="hdrNav">
      <a href={`${p}/about/`}>{t.about}</a>
      <a href={`${p}/recalls/`}>{t.reviews}</a>

      <div class="hdr-dd">
        <button class="hdr-dd-trigger" id="ddTrigger">{t.services} <span class="hdr-arrow">▾</span></button>
        <div class="hdr-mega" id="hdrMega">
          <div class="hdr-mega-col">
            <span class="hdr-mega-title">{mega.col1.title}</span>
            {mega.col1.items.map(i => <a href={i.href}>{i.label}</a>)}
          </div>
          <div class="hdr-mega-col">
            <span class="hdr-mega-title">{mega.col2.title}</span>
            {mega.col2.items.map(i => <a href={i.href}>{i.label}</a>)}
          </div>
          <div class="hdr-mega-col hdr-mega-col--cta">
            {mega.col3.items.map(i => <a href={i.href} class="hdr-mega-cta">{i.label}</a>)}
          </div>
        </div>
      </div>

      <a href={`${p}/guide/`}>{t.tips}</a>
      <a href={`${p}/blog/`}>{t.blog}</a>

      <!-- Mobile-only: lang + phone inside nav -->
      <div class="hdr-mobile-bottom">
        <div class="hdr-mobile-langs">
          <a href="/" data-lang="ua" class:list={['hdr-lang-btn', {active: lang === 'uk'}]}>UA</a>
          <a href="/ru/" data-lang="ru" class:list={['hdr-lang-btn', {active: lang === 'ru'}]}>RU</a>
          <a href="/en/" data-lang="en" class:list={['hdr-lang-btn', {active: lang === 'en'}]}>EN</a>
        </div>
        <a href="tel:+380501444645" class="hdr-mobile-phone">+38(050) 144-46-45</a>
      </div>
    </nav>

    <div class="hdr-right" id="langSwitcher">
      <a href="/" data-lang="ua" class:list={[{active: lang === 'uk'}]}>UA</a>
      <a href="/ru/" data-lang="ru" class:list={[{active: lang === 'ru'}]}>RU</a>
      <a href="/en/" data-lang="en" class:list={[{active: lang === 'en'}]}>EN</a>
      <a href="tel:+380501444645" class="hdr-phone">{t.phone}</a>
    </div>

    <button class="hdr-burger" id="hdrBurger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>
<div class="hdr-overlay" id="hdrOverlay"></div>
<div class="hdr-spacer"></div>

<style is:global>
.hdr-spacer{height:64px;background:#000}
/* ============ HEADER ============ */
.hdr{position:fixed;top:0;left:0;right:0;height:64px;background:#000;z-index:10000;display:flex;align-items:center;padding:0 24px;border-bottom:1px solid rgba(255,255,255,.06)}
.hdr-inner{display:flex;align-items:center;justify-content:space-between;max-width:1400px;width:100%;margin:0 auto}
.hdr-logo{font-family:'DM Serif Display',serif;font-size:20px;color:#fff;text-decoration:none;white-space:nowrap;letter-spacing:1px}
.hdr-logo-mtp{color:#e63329;font-weight:700}

/* Desktop nav */
.hdr-nav{display:flex;align-items:center;gap:28px}
.hdr-nav>a{color:rgba(255,255,255,.85);font-size:14px;text-decoration:none;transition:color .2s;font-family:'DM Sans',sans-serif;letter-spacing:.3px}
.hdr-nav>a:hover{color:#fff}

/* Dropdown trigger */
.hdr-dd{position:relative}
.hdr-dd-trigger{background:none;border:none;color:rgba(255,255,255,.85);font-size:14px;cursor:pointer;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:4px;padding:0;letter-spacing:.3px}
.hdr-dd-trigger:hover{color:#fff}
.hdr-arrow{font-size:10px;transition:transform .2s}
.hdr-dd.open .hdr-arrow{transform:rotate(180deg)}

/* ============ MEGA MENU — 3 columns ============ */
.hdr-mega{display:none;position:absolute;top:calc(100% + 14px);left:50%;transform:translateX(-50%);background:#0a0a0a;border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:24px 28px;min-width:460px;box-shadow:0 12px 48px rgba(0,0,0,.6);z-index:10001}
.hdr-mega::before{content:'';position:absolute;top:-6px;left:50%;transform:translateX(-50%);border:6px solid transparent;border-bottom-color:rgba(255,255,255,.08);border-top:none}
.hdr-dd.open .hdr-mega{display:grid;grid-template-columns:1fr 1fr auto;gap:0}
.hdr-mega-col{padding:0 20px;border-right:1px solid rgba(255,255,255,.06)}
.hdr-mega-col:first-child{padding-left:0}
.hdr-mega-col:last-child{padding-right:0;border-right:none}
.hdr-mega-col--cta{display:flex;align-items:flex-end}
.hdr-mega-title{display:block;font-size:10px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:2.5px;margin:0 0 10px;font-weight:600}
.hdr-mega-col a{display:block;padding:6px 0;font-size:14px;color:rgba(255,255,255,.85);white-space:nowrap;text-decoration:none;transition:color .2s,padding-left .2s}
.hdr-mega-col a:hover{color:#fff;padding-left:4px}
.hdr-mega-cta{font-weight:600;color:#fff !important;font-size:13px !important;padding:10px 20px !important;background:rgba(255,255,255,.08);border-radius:8px;text-align:center;transition:background .2s !important}
.hdr-mega-cta:hover{background:rgba(255,255,255,.15) !important;padding-left:20px !important}
.hdr-dd::after{content:'';position:absolute;top:100%;left:0;right:0;height:18px}

/* Language switcher (desktop) */
.hdr-right{display:flex;align-items:center;gap:16px}
.hdr-right a{color:rgba(255,255,255,.6);font-size:13px;text-decoration:none;transition:color .2s;font-family:'DM Sans',sans-serif;padding:4px 2px}
.hdr-right a:hover,.hdr-right a.active{color:#fff}
.hdr-phone{white-space:nowrap;font-variant-numeric:tabular-nums;color:rgba(255,255,255,.5) !important;font-size:12px !important}

/* Burger — hidden on desktop */
.hdr-burger{display:none;background:none;border:none;cursor:pointer;padding:12px;flex-direction:column;gap:5px;z-index:10001;-webkit-tap-highlight-color:transparent}
.hdr-burger span{display:block;width:24px;height:2px;background:#fff;transition:transform .3s,opacity .3s;border-radius:2px}
.hdr-burger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.hdr-burger.open span:nth-child(2){opacity:0}
.hdr-burger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}

/* Overlay */
.hdr-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)}
.hdr-overlay.open{display:block}

/* Mobile-only elements — hidden on desktop */
.hdr-mobile-bottom{display:none}

/* Body offset for fixed header — NO white gap */
body{padding-top:0;margin:0}

/* ============ MOBILE (≤900px) ============ */
@media(max-width:900px){
  .hdr{padding:0 16px}
  .hdr-burger{display:flex}
  .hdr-right{display:none}

  /* Slide-in panel */
  .hdr-nav{
    position:fixed;top:0;right:-300px;width:300px;max-width:85vw;height:100%;
    background:#111;flex-direction:column;align-items:stretch;
    padding:80px 24px 120px;gap:0;z-index:10000;
    transition:right .3s ease;overflow-y:auto;
    box-shadow:-4px 0 24px rgba(0,0,0,.6);
    -webkit-overflow-scrolling:touch
  }
  .hdr-nav.open{right:0}

  /* Nav links */
  .hdr-nav>a{
    font-size:17px;padding:16px 0;width:100%;
    border-bottom:1px solid rgba(255,255,255,.08);
    color:#fff
  }

  /* Dropdown */
  .hdr-dd{width:100%}
  .hdr-dd-trigger{
    font-size:17px;padding:16px 0;width:100%;
    border-bottom:1px solid rgba(255,255,255,.08);
    justify-content:space-between;color:#fff
  }

  /* Mega-menu on mobile = simple list */
  .hdr-mega{
    position:static;transform:none;min-width:auto;
    display:none;border:none;box-shadow:none;
    background:rgba(255,255,255,.04);border-radius:8px;
    padding:12px 16px;margin:8px 0
  }
  .hdr-mega::before{display:none}
  .hdr-dd.open .hdr-mega{display:block}
  .hdr-mega-col{padding:8px 0;border-right:none;border-bottom:1px solid rgba(255,255,255,.04)}
  .hdr-mega-col:last-child{border-bottom:none}
  .hdr-mega-col a{font-size:15px;padding:10px 0;color:rgba(255,255,255,.8)}
  .hdr-mega-cta{background:rgba(230,51,41,.15);margin-top:8px;text-align:center;border-radius:6px;padding:12px 16px !important}
  .hdr-mega-col--cta{display:block}

  /* Mobile bottom: langs + phone */
  .hdr-mobile-bottom{
    display:flex;flex-direction:column;gap:12px;
    margin-top:auto;padding:24px 0 env(safe-area-inset-bottom,16px);
    border-top:1px solid rgba(255,255,255,.08)
  }
  .hdr-mobile-langs{display:flex;gap:12px}
  .hdr-lang-btn{
    display:inline-flex;align-items:center;justify-content:center;
    width:44px;height:44px;border-radius:8px;
    background:rgba(255,255,255,.06);color:rgba(255,255,255,.7);
    font-size:14px;font-weight:500;text-decoration:none;
    transition:background .2s
  }
  .hdr-lang-btn.active{background:#e63329;color:#fff}
  .hdr-lang-btn:hover{background:rgba(255,255,255,.12)}
  .hdr-mobile-phone{
    display:block;text-align:center;padding:14px;
    background:rgba(255,255,255,.06);border-radius:8px;
    color:#fff;text-decoration:none;font-size:16px;
    font-variant-numeric:tabular-nums
  }
}
</style>

<script is:inline>
(function(){
  var burger = document.getElementById('hdrBurger');
  var nav = document.getElementById('hdrNav');
  var overlay = document.getElementById('hdrOverlay');
  var ddTrigger = document.getElementById('ddTrigger');
  var dd = ddTrigger ? ddTrigger.closest('.hdr-dd') : null;

  if(!burger || !nav) return;

  function closeMenu(){
    burger.classList.remove('open');
    nav.classList.remove('open');
    overlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  burger.addEventListener('click', function(){
    var isOpen = nav.classList.contains('open');
    if(isOpen) closeMenu();
    else {
      burger.classList.add('open');
      nav.classList.add('open');
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
  });

  overlay.addEventListener('click', closeMenu);
  nav.addEventListener('click', function(e){ if(e.target.tagName === 'A') closeMenu(); });

  // Dropdown
  if(dd && ddTrigger){
    var timer;
    dd.addEventListener('mouseenter', function(){ if(window.innerWidth>900){clearTimeout(timer);dd.classList.add('open');} });
    dd.addEventListener('mouseleave', function(){ if(window.innerWidth>900){timer=setTimeout(function(){dd.classList.remove('open');},250);} });
    ddTrigger.addEventListener('click', function(e){ if(window.innerWidth<=900){e.preventDefault();dd.classList.toggle('open');} });
  }

  // Smart language switcher
  var path = location.pathname;
  var map = {
    'tsiny':{ru:'tsenu',en:'prices'},'tsenu':{ua:'tsiny',en:'prices'},'prices':{ua:'tsiny',ru:'tsenu'},
    'fulfilment-dlya-internet-magazynu':{ru:'fulfilment-dlya-internet-magazynu',en:'fulfillment-for-online-stores'},
    'fulfillment-for-online-stores':{ua:'fulfilment-dlya-internet-magazynu',ru:'fulfilment-dlya-internet-magazynu'},
    'fulfilment-vazhkykh-tovariv':{ru:'fulfilment-vazhkykh-tovariv',en:'heavy-goods'},
    'heavy-goods':{ua:'fulfilment-vazhkykh-tovariv',ru:'fulfilment-vazhkykh-tovariv'},
    'skladski-poslugy':{ru:'skladski-poslugy',en:'warehouse-services'},
    'warehouse-services':{ua:'skladski-poslugy',ru:'skladski-poslugy'},
  };
  document.querySelectorAll('[data-lang]').forEach(function(a){
    var tl=a.dataset.lang;
    var slug=path.replace(/^\/(?:ua|en|ru)\//,'/').replace(/^\//,'').replace(/\/$/,'');
    var np='/';
    if(!slug||slug==='ru'){np=tl==='ua'?'/':tl==='ru'?'/ru/':'/en/';}
    else if(slug==='blog'||slug.match(/^(?:ua\/)?blog$/)){np=tl==='ua'?'/ua/blog/':tl==='ru'?'/blog/':'/en/blog/';}
    else{var bs=slug.split('/').pop();var m=map[bs];var ts=m?m[tl]||bs:bs;np=tl==='ua'?'/ua/'+ts+'/':tl==='en'?'/en/'+ts+'/':'/'+ts+'/';}
    a.href=np;
  });
})();
</script>
