---
interface Props { lang: 'uk' | 'ru' | 'en'; }
const { lang } = Astro.props;

const p = lang === 'uk' ? '/ua' : lang === 'en' ? '/en' : '';
const home = lang === 'uk' ? '/' : lang === 'en' ? '/en/' : '/ru/';

const t = {
  uk: { about:'Про нас', reviews:'Відгуки', services:'Послуги', tips:'Поради', blog:'Блог', phone:'+38(050) 144-46-45' },
  ru: { about:'О нас', reviews:'Отзывы', services:'Услуги', tips:'Советы', blog:'Блог', phone:'+38(050) 144-46-45' },
  en: { about:'About', reviews:'Reviews', services:'Services', tips:'Tips', blog:'Blog', phone:'+38(050) 144-46-45' },
}[lang];

const mega = {
  uk: {
    col1: { title: 'За типом бізнесу', items: [
      { href: '/ua/fulfilment-dlya-internet-magazynu/', label: 'Інтернет-магазини' },
      { href: '/ua/fulfilment-dlya-marketpleysiv/', label: 'Маркетплейси' },
      { href: '/ua/fulfilment-dlya-maloho-biznesu/', label: 'Малий бізнес' },
    ]},
    col2: { title: 'Спеціалізація', items: [
      { href: '/ua/fulfilment-vazhkykh-tovariv/', label: 'Важкі товари 50+ кг' },
      { href: '/ua/skladski-poslugy/', label: 'Складські послуги' },
      { href: '/ua/paletne-zberigannya/', label: 'Палетне зберігання' },
      { href: '/ua/3pl-logistyka/', label: '3PL логістика' },
      { href: '/ua/fulfilment-kyiv/', label: 'Фулфілмент Київ' },
    ]},
    col3: { title: 'Інструменти', items: [
      { href: '/ua/calculator/', label: 'Калькулятор' },
      { href: '/ua/tsiny/', label: 'Ціни' },
    ], cta: { href: '/ua/services/', label: 'Всі послуги →' }},
  },
  ru: {
    col1: { title: 'По типу бизнеса', items: [
      { href: '/ru/fulfilment-dlya-internet-magazynu/', label: 'Интернет-магазины' },
      { href: '/ru/fulfilment-dlya-marketpleysov/', label: 'Маркетплейсы' },
      { href: '/ru/fulfilment-dlya-malogo-biznesa/', label: 'Малый бизнес' },
    ]},
    col2: { title: 'Специализация', items: [
      { href: '/ru/fulfilment-vazhkykh-tovariv/', label: 'Тяжёлые товары 50+ кг' },
      { href: '/ru/skladski-poslugy/', label: 'Складские услуги' },
      { href: '/ru/paletnoe-khranenie/', label: 'Паллетное хранение' },
      { href: '/ru/3pl-logistika/', label: '3PL логистика' },
      { href: '/ru/fulfilment-kiev/', label: 'Фулфилмент Киев' },
    ]},
    col3: { title: 'Инструменты', items: [
      { href: '/ru/calculator/', label: 'Калькулятор' },
      { href: '/ru/tsenu/', label: 'Цены' },
    ], cta: { href: '/ru/services/', label: 'Все услуги →' }},
  },
  en: {
    col1: { title: 'By business type', items: [
      { href: '/en/fulfillment-for-online-stores/', label: 'Online stores' },
      { href: '/en/fulfillment-for-marketplaces/', label: 'Marketplaces' },
      { href: '/en/fulfillment-for-small-business/', label: 'Small business' },
    ]},
    col2: { title: 'Specialization', items: [
      { href: '/en/heavy-goods/', label: 'Heavy goods 50+ kg' },
      { href: '/en/warehouse-services/', label: 'Warehouse services' },
      { href: '/en/pallet-storage/', label: 'Pallet storage' },
      { href: '/en/3pl-logistics/', label: '3PL logistics' },
      { href: '/en/fulfillment-kyiv/', label: 'Fulfillment Kyiv' },
    ]},
    col3: { title: 'Tools', items: [
      { href: '/en/calculator/', label: 'Calculator' },
      { href: '/en/prices/', label: 'Prices' },
    ], cta: { href: '/en/services/', label: 'All services →' }},
