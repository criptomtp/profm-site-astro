  'best-business-ideas-ukraine':                  { img: 'business-ideas-ukraine.webp', uk: 'Який бізнес відкрити в Україні: ідеї для початківця', ru: 'Какой бизнес открыть в Украине: идеи для новичка', en: 'Best business ideas in Ukraine for beginners' },
  'business-in-ukraine-during-war':               { img: 'business-ukraine-wartime.webp', uk: 'Бізнес в Україні під час війни: виклики та можливості', ru: 'Бизнес в Украине во время войны: вызовы и возможности', en: 'Doing business in Ukraine during the war' },
  'ecommerce-logistics-during-war':               { img: 'fulfillment-warehouse-operations.webp', uk: 'Як інтернет-магазину працювати в умовах війни', ru: 'Как интернет-магазину работать в условиях войны', en: 'Ecommerce logistics during the war' },
  'ecommerce-trends-2022':                        { img: 'fulfillment-ecommerce-trends.webp', uk: '7 трендів інтернет-торгівлі: що потрібно знати', ru: '7 трендов интернет-торговли: что нужно знать', en: 'Ecommerce trends to watch in 2022 and beyond' },
  'expand-to-european-marketplaces':              { img: 'fulfillment-warehouse-operations.webp', uk: 'Як вийти на європейські маркетплейси під час війни', ru: 'Как выйти на европейские маркетплейсы во время войны', en: 'How to expand to European marketplaces during war' },
