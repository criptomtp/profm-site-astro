  'fulfillment-vs-own-warehouse-2025':            { img: 'fulfillment-vs-own-warehouse-2025.webp', uk: 'Fulfillment vs власний склад 2025', ru: 'Фулфилмент vs свой склад 2025', en: 'Fulfillment vs own warehouse 2025' },
  'how-fulfillment-works-ukraine-2025':           { img: 'fulfillment-ukraine-guide.webp', uk: 'Як працює фулфілмент в Україні у 2025', ru: 'Как работает фулфилмент в Украине в 2025', en: 'How fulfillment works in Ukraine in 2025' },
  'how-to-choose-fulfillment-operator':           { img: 'fulfillment-operator-selection.webp', uk: 'Як вибрати фулфілмент-оператора: чек-лист', ru: 'Как выбрать фулфилмент-оператора: чек-лист', en: 'How to choose a fulfillment operator: 25 criteria' },
  'how-to-handle-customer-reviews':               { img: 'fulfillment-warehouse-shipping.webp', uk: 'Як працювати з відгуками: покроковий алгоритм', ru: 'Как работать с отзывами: пошаговый алгоритм', en: 'How to handle customer reviews step-by-step' },
  'how-to-start-online-store-ukraine':            { img: 'otkryt-biznes-onlajn.webp', uk: 'Як відкрити інтернет-магазин в Україні', ru: 'Как открыть интернет-магазин в Украине', en: 'How to start an online store in Ukraine' },
  'mtp-group-best-fulfillment-operators':         { img: 'mtp-fast-liquidation-service.webp', uk: 'MTP Group — найкращі фулфілмент-оператори', ru: 'MTP Group — лучшие фулфилмент-операторы', en: 'MTP Group — best fulfillment operators in Ukraine' },
  'mtp-group-fast-product-liquidation':           { img: 'fulfillment-how-it-works-2025.webp', uk: 'MTP Group — швидка реалізація товарних залишків', ru: 'MTP Group — быстрая реализация товарных остатков', en: 'MTP Group — fast product liquidation service' },
  'online-buyer-behavior-insights':               { img: 'customer-behavior-insights.webp', uk: 'Поведінка покупців в інтернеті: як збільшити продажі', ru: 'Поведение покупателей в интернете: как увеличить продажи', en: 'Online buyer behavior insights' },
  'online-store-during-wartime':                  { img: 'online-store-wartime-2022.webp', uk: 'Як відкрити інтернет-магазин під час війни', ru: 'Как открыть интернет-магазин во время войны', en: 'Starting an online store during wartime' },
  'peak-season-logistics-mistakes':               { img: 'logistics-seasonal-mistakes.webp', uk: 'Топ-5 помилок у логістиці на сезонні розпродажі', ru: 'Топ-5 ошибок логистики в сезон распродаж', en: 'Top peak-season logistics mistakes' },
  'prepare-online-store-march-8':                 { img: 'fulfillment-order-processing.webp', uk: 'Як підготувати магазин до 8 березня', ru: 'Как подготовить магазин к 8 марта', en: 'Prepare your online store for March 8' },
  'prepare-store-for-holidays':                   { img: 'fulfillment-warehouse-operations.webp', uk: 'Як підготувати магазин до новорічних свят', ru: 'Как подготовить магазин к новогодним праздникам', en: 'Prepare your online store for the holidays' },
  'prepare-store-valentines-day':                 { img: 'valentines-day-ecommerce.webp', uk: 'Підготовка магазину до Дня Валентина', ru: 'Подготовка магазина ко Дню Валентина', en: 'Prepare your store for Valentine\'s Day' },
  'product-business-ukraine-guide':               { img: 'product-business-ukraine.webp', uk: 'Товарний бізнес в Україні: з чого почати', ru: 'Товарный бизнес в Украине: с чего начать', en: 'Starting a product business in Ukraine' },
  'protect-store-from-fraud':                     { img: 'ecommerce-fraud-protection.webp', uk: 'Як захиститися від шахрайства покупців', ru: 'Как защититься от мошенничества покупателей', en: 'How to protect your store from buyer fraud' },
  'reduce-product-returns-ecommerce':             { img: 'fulfillment-product-returns.webp', uk: 'Як скоротити кількість повернень: 8 порад', ru: 'Как сократить количество возвратов: 8 советов', en: 'How to reduce product returns in ecommerce' },
  'replace-russian-services-ukraine-checklist':   { img: 'replace-russian-services-ukraine.webp', uk: 'Чим замінити російські сервіси: чек-лист', ru: 'Чем заменить российские сервисы: чек-лист', en: 'Replacing Russian services in Ukraine: checklist' },
  'top-5-logistics-mistakes-ecommerce':           { img: 'ecommerce-logistics-guide.webp', uk: 'ТОП-5 помилок логістики інтернет-магазину', ru: 'Топ-5 ошибок логистики интернет-магазина', en: 'Top-5 ecommerce logistics mistakes' },
  'what-is-fulfillment-7-services':               { img: 'fulfillment-warehouse-packing.webp', uk: 'Що таке фулфілмент: 7 основних послуг', ru: 'Что такое фулфилмент: 7 основных услуг', en: 'What is fulfillment: 7 core services' },
  'what-is-sku-article-number':                   { img: 'ecommerce-fiscal-register.webp', uk: 'Що таке артикул товару (SKU)', ru: 'Что такое артикул товара (SKU)', en: 'What is SKU and article number' },
  'what-is-sla-in-logistics':                     { img: 'sla-logistics-fulfillment.webp', uk: 'Що таке SLA в логістиці: KPI та приклад', ru: 'Что такое SLA в логистике: KPI и пример', en: 'What is SLA in logistics: KPI and example' },
  'where-online-store-loses-money':               { img: 'ecommerce-profit-optimization.webp', uk: 'Де втрачає гроші інтернет-магазин', ru: 'Где теряет деньги интернет-магазин', en: 'Where online stores lose money' },
  'why-audit-warehouse-in-summer':                { img: 'warehouse-audit-summer.webp', uk: 'Липень — найкращий час для аудиту складу', ru: 'Июль — лучшее время для аудита склада', en: 'Why summer is the best time for a warehouse audit' },
};

// UA modern overrides: 7 topics where modern UA exists at a different slug.
const UA_OVERRIDE = {
  'how-to-choose-fulfillment-operator': 'yak-vybrati-fulfilment',
  'what-is-sla-in-logistics': 'scho-take-sla',
  'what-is-sku-article-number': 'scho-take-artikul',
  'fulfillment-vs-own-warehouse': 'fulfilment-vs-vlasnyy-sklad',
  'fulfillment-vs-own-warehouse-2025': 'chomu-fulfilment-deshevshyy',
  'fulfillment-cost-guide': 'vartist-fulfilmentu-2026',
  'how-fulfillment-works-ukraine-2025': 'rinok-fulfilmentu-ukraina',
};

// RU has no version of these (skip for ru)
const RU_MISSING = new Set(['mtp-group-best-fulfillment-operators', 'mtp-group-fast-product-liquidation', 'what-is-sku-article-number']);

function buildUrl(targetSlug, targetLang) {
  if (targetLang === 'uk') {
    const useSlug = UA_OVERRIDE[targetSlug] || targetSlug;
    return `/ua/blog/${useSlug}/`;
  }
  if (targetLang === 'ru') {
    if (RU_MISSING.has(targetSlug)) return null;
    return `/blog/${targetSlug}/`;
  }
  if (targetLang === 'en') {
    return `/en/blog/post/${targetSlug}/`;
  }
  return null;
}

const cluster = PRIMARY[slug];
const peers = (CLUSTERS[cluster] || []).filter(s => s !== slug);

const heading = lang === 'uk' ? 'Читайте також' : lang === 'ru' ? 'Читайте также' : 'Related articles';
const cta = lang === 'uk' ? 'Читати →' : lang === 'ru' ? 'Читать →' : 'Read →';

const cards = peers.slice(0, 4).map(s => {
  const url = buildUrl(s, lang);
  const meta = META[s];
  if (!url || !meta) return null;
  return { url, title: meta[lang] || meta.en, img: meta.img };
}).filter(Boolean);
---

{cards.length > 0 && (
  <section class="related-articles" aria-label={heading}>
    <div class="related-articles__inner">
      <h2 class="related-articles__title">{heading}</h2>
      <div class="related-articles__grid">
        {cards.map(card => (
          <a href={card.url} class="related-card">
            <div class="related-card__img" style={`background-image:url('/images/blog/${card.img}')`}></div>
            <div class="related-card__body">
              <h3>{card.title}</h3>
              <span class="related-card__cta">{cta}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
.related-articles { padding: 60px 24px; background: #f7f7f7; border-top: 1px solid #ececec; }
.related-articles__inner { max-width: 1100px; margin: 0 auto; }
.related-articles__title { font-family: 'DM Serif Display', serif; font-size: 28px; font-weight: 400; margin: 0 0 28px; color: #000; }
.related-articles__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; }
.related-card { display: flex; flex-direction: column; background: #fff; border-radius: 10px; overflow: hidden; text-decoration: none; color: inherit; box-shadow: 0 1px 6px rgba(0,0,0,.04); transition: box-shadow .25s, transform .25s; border: 1px solid #ececec; }
.related-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); transform: translateY(-3px); border-color: #e63329; }
.related-card__img { aspect-ratio: 16/10; background-size: cover; background-position: center; background-color: #ddd; }
.related-card__body { padding: 18px 18px 22px; display: flex; flex-direction: column; gap: 10px; flex: 1; }
.related-card__body h3 { font-family: 'DM Serif Display', serif; font-size: 17px; font-weight: 400; margin: 0; color: #111; line-height: 1.35; }
.related-card__cta { font-size: 13px; color: #e63329; font-weight: 600; letter-spacing: .3px; margin-top: auto; }
@media (max-width: 600px) {
  .related-articles { padding: 40px 20px; }
  .related-articles__grid { grid-template-columns: 1fr; }
}
</style>
