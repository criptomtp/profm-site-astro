  'fulfillment-cost-guide':                       { img: 'fulfillment-ukraine-services.webp', uk: 'Скільки коштує фулфілмент: тарифи та порівняння', ru: 'Сколько стоит фулфилмент: тарифы и сравнение', en: 'Fulfillment cost guide: pricing and comparisons' },
  'fulfillment-for-clothing-shoes':               { img: 'fulfillment-clothing-storage.webp', uk: 'Фулфілмент для магазину одягу та взуття', ru: 'Фулфилмент для магазина одежды и обуви', en: 'Fulfillment for clothing and shoe stores' },
