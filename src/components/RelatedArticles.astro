  seasonal: ['prepare-store-valentines-day', 'prepare-online-store-march-8', 'prepare-store-for-holidays', 'peak-season-logistics-mistakes'],
  mistakes: ['top-5-logistics-mistakes-ecommerce', 'peak-season-logistics-mistakes', 'where-online-store-loses-money', 'reduce-product-returns-ecommerce', 'why-audit-warehouse-in-summer'],
  wartime: ['business-in-ukraine-during-war', 'ecommerce-logistics-during-war', 'online-store-during-wartime', 'replace-russian-services-ukraine-checklist', 'expand-to-european-marketplaces'],
