// Per-language metadata (title + image). Image lives at /images/blog/{img}.
// UA/RU/EN titles taken from existing blog index pages.
const META = {
  '10-ways-increase-profit-ecommerce':            { img: 'fulfillment-warehouse-shipping.webp', uk: '10 робочих способів збільшити прибуток інтернет-магазину', ru: '10 рабочих способов увеличить прибыль интернет-магазина', en: '10 ways to increase ecommerce profit in Ukraine' },
