---
/**
 * Lightweight YouTube embed — loads iframe only on click.
 * Premium design: maxresdefault thumbnail + frosted glass play button.
 * CSS is in Base.astro (global .yt-facade styles).
 *
 * Usage: <YouTubeEmbed id="bHY3cFF9SlI" title="Екскурсія по складу" />
 */
interface Props {
  id: string;
  title: string;
}
const { id, title } = Astro.props;
---
<div class="yt-facade" data-id={id}>
  <img
    src={`https://i.ytimg.com/vi/${id}/maxresdefault.jpg`}
    onerror="this.src=this.src.replace('maxresdefault','hqdefault')"
    alt={title}
    width="1280"
    height="720"
    loading="lazy"
  />
  <button class="yt-play" aria-label={`Play: ${title}`}>
    <svg width="24" height="28" viewBox="0 0 24 28" fill="none"><polygon points="0,0 0,28 24,14" fill="#fff"/></svg>
  </button>
</div>
