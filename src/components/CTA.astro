---
interface Props { lang: 'uk' | 'ru' | 'en'; }
const { lang } = Astro.props;

const t = {
  uk: { title:'Готовий делегувати<br>логістику?', sub:'Залиш номер — передзвонимо протягом 15 хвилин і розрахуємо умови', btn:'Передзвоніть мені →', c1:'Безкоштовна консультація', c2:"Без зобов'язань", c3:'Договір за 1 день', thanks:'/ua/thanks/', placeholder:'+380XXXXXXXXX' },
  ru: { title:'Готовы передать<br>логистику?', sub:'Оставьте номер — перезвоним в течение 15 минут и подготовим расчёт', btn:'Перезвоните мне →', c1:'Бесплатная консультация', c2:'Без обязательств', c3:'Договор за 1 день', thanks:'/thanks/', placeholder:'+380XXXXXXXXX' },
  en: { title:'Ready to outsource<br>logistics?', sub:'Leave your number — we call back within 15 minutes with a custom quote', btn:'Call me back →', c1:'Free consultation', c2:'No obligations', c3:'Contract in 1 day', thanks:'/en/thanks/', placeholder:'Your phone number' },
}[lang];

const isEn = lang === 'en';
---
<section class="final-cta" id="ctaSection" data-thanks={t.thanks}>
<div class="ctr">
  <h2 set:html={t.title} />
  <p class="sub">{t.sub}</p>
  <form class="final-form" id="finalForm">
    <input type="tel" name="phone" placeholder={t.placeholder} required autocomplete="tel" aria-label="Phone" maxlength={isEn ? "25" : "19"}>
    <button type="submit">{t.btn}</button>
  </form>
  <div class="final-checks">
    <span>✓ {t.c1}</span><span>✓ {t.c2}</span><span>✓ {t.c3}</span>
  </div>
</div>
</section>

<style>
.final-cta{padding:100px 0;background:#e63329;color:#fff;text-align:center}
.final-cta h2{font-family:'DM Serif Display',serif;font-size:clamp(28px,4vw,48px);font-weight:400;margin-bottom:16px}
.final-cta .sub{font-size:17px;opacity:.85;max-width:480px;margin:0 auto 36px}
.final-form{display:flex;gap:12px;justify-content:center;max-width:460px;margin:0 auto}
.final-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.35);border-radius:8px;background:rgba(255,255,255,.1);color:#fff;font-size:16px;outline:none;font-family:'DM Sans',sans-serif;-webkit-appearance:none}
.final-form input::placeholder{color:rgba(255,255,255,.45)}
.final-form input:focus{border-color:#fff}
.final-form button{padding:16px 24px;background:#000;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:500;cursor:pointer;white-space:nowrap;transition:background .3s;font-family:'DM Sans',sans-serif}
.final-form button:hover{background:#222}
.final-checks{display:flex;gap:24px;justify-content:center;flex-wrap:wrap;margin-top:16px;font-size:13px;opacity:.7}
@media(max-width:768px){.final-form{flex-direction:column}.final-form input,.final-form button{width:100%}}
</style>

<script is:inline>
(function(){
  var form = document.getElementById('finalForm');
  if(!form) return;

  var input = form.querySelector('input[name="phone"]');
  var section = document.getElementById('ctaSection');
  var thanksUrl = section ? section.dataset.thanks : '/ua/thanks/';

  form.addEventListener('submit', function(e){
    e.preventDefault();
    var ph = input.value.trim();
    var clean = ph.replace(/\D/g, '');

    // Accept 10+ digits (works for any country)
    if(clean.length < 10){
      input.style.borderColor = '#fff';
      input.style.animation = 'shake .3s';
      setTimeout(function(){ input.style.animation = ''; }, 300);
      return;
    }

    // 1. Telegram notification (always works)
    fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});
    // 2. Save to CRM database
    fetch('/api/leads',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname,source:'site',comments:[{text:'Заявка з сайту: '+location.pathname,date:new Date().toLocaleString('uk-UA')}]})}).catch(function(){});

    var lang = document.documentElement.lang;
    var msg = lang === 'en' ? 'Thank you!' : lang === 'ru' ? 'Спасибо!' : 'Дякуємо!';
    form.innerHTML = '<p style="color:#fff;font-size:18px">\u2705 ' + msg + '</p>';
    setTimeout(function(){ window.location.href = thanksUrl; }, 1200);
  });
})();
</script>
