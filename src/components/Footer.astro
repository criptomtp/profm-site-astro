---
interface Props { lang: 'uk' | 'ru' | 'en'; }
const { lang } = Astro.props;

const p = lang === 'uk' ? '/ua' : lang === 'en' ? '/en' : '';
const privacyPath = lang === 'uk' ? '/ua/privacy/' : lang === 'en' ? '/en/privacy/' : '/ru/privacy/';

const t = {
  uk: { support:'Підтримка', pages:'Сторінки', social:'Соціальні мережі', services:'Послуги', about:'Про нас', reviews:'Відгуки', blog:'Блог', privacy:'Політика конфіденційності', copy:'© 2026 MTP Group Fulfillment. Всі права захищені.' },
  ru: { support:'Поддержка', pages:'Страницы', social:'Соц. сети', services:'Услуги', about:'О нас', reviews:'Отзывы', blog:'Блог', privacy:'Политика конфиденциальности', copy:'© 2026 MTP Group Fulfillment. Все права защищены.' },
  en: { support:'Support', pages:'Pages', social:'Social', services:'Services', about:'About', reviews:'Reviews', blog:'Blog', privacy:'Privacy Policy', copy:'© 2026 MTP Group Fulfillment. All rights reserved.' },
}[lang];
---
<footer class="footer"><div class="footer-grid">
<div><h3>{t.support}</h3><p><a href="mailto:mtpgrouppromo@gmail.com">mtpgrouppromo@gmail.com</a></p><p><a href="tel:+380501444645">+38(050) 144-46-45</a></p><p><a href="tel:+380938277767">+38(093) 827-77-67</a></p></div>
<div><h3>{t.pages}</h3><p><a href={`${p}/services/`}>{t.services}</a></p><p><a href={`${p}/about/`}>{t.about}</a></p><p><a href={`${p}/recalls/`}>{t.reviews}</a></p><p><a href={`${p}/blog/`}>{t.blog}</a></p></div>
<div><h3>{t.social}</h3><p><a href="https://www.facebook.com/fulfillmentmtp" target="_blank" rel="noopener">Facebook</a></p><p><a href="https://www.instagram.com/mtp_group/" target="_blank" rel="noopener">Instagram</a></p><p><a href="https://www.youtube.com/@mtpgroup" target="_blank" rel="noopener">YouTube</a></p><p><a href="https://t.me/nikolay_mtp" target="_blank" rel="noopener">Telegram</a></p></div>
</div><div class="footer-bottom"><a href={privacyPath}>{t.privacy}</a> &nbsp;|&nbsp; {t.copy}</div></footer>

<style>
.footer{background:#111;color:rgba(255,255,255,.7);padding:60px 24px 30px}
.footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:40px;max-width:1200px;margin:0 auto}
.footer h3{color:#fff;font-size:14px;font-weight:500;letter-spacing:1px;text-transform:uppercase;margin-bottom:16px}
.footer p,.footer a{font-size:14px;line-height:2;color:rgba(255,255,255,.5);transition:color .2s}
.footer a:hover{color:#fff}
.footer-bottom{text-align:center;margin-top:40px;padding-top:20px;border-top:1px solid rgba(255,255,255,.06);font-size:13px;color:rgba(255,255,255,.3);max-width:1200px;margin-left:auto;margin-right:auto}
</style>
