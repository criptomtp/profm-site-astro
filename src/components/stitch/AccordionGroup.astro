---
/*
 * AccordionGroup — Q&A accordion used in FAQ and long-form Editorial pages.
 * Pass `items` as an array of { q, a }. Inline JS toggles .open class per item.
 */
interface QA { q: string; a: string; }
interface Props {
  items: QA[];
  class?: string;
}
const { items, class: extraClass = '' } = Astro.props;
---
<div class={`s-acc ${extraClass}`.trim()} data-accordion>
  {items.map((item) => (
    <div class="s-acc__item">
      <button type="button" class="s-acc__btn" aria-expanded="false">
        <span>{item.q}</span>
        <svg class="s-acc__icon" viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
      </button>
      <div class="s-acc__panel">
        <div class="s-acc__content" set:html={item.a}></div>
      </div>
    </div>
  ))}
</div>

<script>
  document.querySelectorAll('[data-accordion]').forEach((group) => {
    group.querySelectorAll('.s-acc__btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.s-acc__item');
        const open = item?.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(!!open));
      });
    });
  });
</script>
