---
import Base from '../layouts/Base.astro';
import HeroCTA from '../components/HeroCTA.astro';

// JobPosting schema — Google Jobs requires datePosted + validThrough.
// Setting datePosted=today, validThrough=+60days to keep listings active.
const today = '2026-05-13';
const validThrough = '2026-07-13';

const orgSchema = {
  "@type": "Organization",
  "name": "MTP Group Fulfillment",
  "sameAs": "https://www.fulfillmentmtp.com.ua",
  "logo": "https://www.fulfillmentmtp.com.ua/images/logo.svg"
};

const locShchaslyve = {
  "@type": "Place",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Щасливе",
    "addressRegion": "Київська область",
    "addressCountry": "UA",
    "postalCode": "08322"
  }
};

const locBilohorodka = {
  "@type": "Place",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Білогородка",
    "addressRegion": "Київська область",
    "addressCountry": "UA",
    "postalCode": "08140"
  }
};

const jobs = [
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Комірник складу",
    "description": "Робота на сучасному фулфілмент-складі у Щасливому (Бориспільський район) або Білогородці. Приймання, розміщення товару, інвентаризація через WMS. Зарплата від 30 000 ₴ + бонуси за виробіток. Стабільний графік, навчання за рахунок компанії.",
    "datePosted": today,
    "validThrough": validThrough,
    "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema,
    "jobLocation": locShchaslyve,
    "baseSalary": {
      "@type": "MonetaryAmount",
      "currency": "UAH",
      "value": { "@type": "QuantitativeValue", "value": 30000, "unitText": "MONTH", "minValue": 30000 }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Комплектувальник замовлень",
    "description": "Збирання замовлень для інтернет-магазинів і B2B-клієнтів за маршрутом WMS. Сканування штрих-кодів, пакування, контроль якості. Зарплата від 30 000 ₴ + бонуси залежно від кількості зібраних замовлень за зміну.",
    "datePosted": today,
    "validThrough": validThrough,
    "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema,
    "jobLocation": locShchaslyve,
    "baseSalary": {
      "@type": "MonetaryAmount",
      "currency": "UAH",
      "value": { "@type": "QuantitativeValue", "value": 30000, "unitText": "MONTH", "minValue": 30000 }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Приймальник товару",
    "description": "Приймання вхідних поставок від клієнтів, перевірка комплектності за інвойсом, фотофіксація стану, оприбуткування у WMS. Зарплата від 30 000 ₴ + бонуси за обсяг приймання.",
    "datePosted": today,
    "validThrough": validThrough,
    "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema,
    "jobLocation": locShchaslyve,
    "baseSalary": {
      "@type": "MonetaryAmount",
      "currency": "UAH",
      "value": { "@type": "QuantitativeValue", "value": 30000, "unitText": "MONTH", "minValue": 30000 }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Водій навантажувача",
    "description": "Управління електронавантажувачем на складі. Переміщення палет до 2 тонн, завантаження-розвантаження транспорту, штабелювання у стелажах. Потрібне посвідчення категорії II. Зарплата від 30 000 ₴.",
    "datePosted": today,
    "validThrough": validThrough,
    "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema,
    "jobLocation": locShchaslyve,
    "baseSalary": {
      "@type": "MonetaryAmount",
      "currency": "UAH",
      "value": { "@type": "QuantitativeValue", "value": 30000, "unitText": "MONTH", "minValue": 30000 }
    }
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Головна", "item": "https://www.fulfillmentmtp.com.ua/" },
    { "@type": "ListItem", "position": 2, "name": "Вакансії", "item": "https://www.fulfillmentmtp.com.ua/vakansiyi/" }
  ]
};

const schemaJson = jobs.map(j => `<script type="application/ld+json">${JSON.stringify(j)}</script>`).join('') +
  `<script type="application/ld+json">${JSON.stringify(breadcrumbSchema)}</script>`;
---
<Base
  title="Вакансії MTP Group — робота на складі у Щасливому, від 30 000 ₴"
  description="Шукаємо комірника, комплектувальника, приймальника, водія навантажувача. Склад у Щасливому (Бориспільський район). Зарплата від 30 000 ₴ + бонуси за виробіток. Стабільний графік."
  canonical="https://www.fulfillmentmtp.com.ua/vakansiyi/"
  lang="uk"
  ogImage="https://www.fulfillmentmtp.com.ua/images/vakansiyi-hero.jpg"
  schema={schemaJson}
  showCTA={true}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/vakansiyi/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/vakansii/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/careers/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/vakansiyi/">
</Fragment>

<!-- HERO -->
<section class="vk-hero">
  <img class="vk-hero-bg" src="/images/vakansiyi-hero.jpg" alt="Команда фулфілмент-складу MTP Group у Щасливому — комплектувальники, водії навантажувача, приймальники товару за роботою" width="1200" height="630" loading="eager" fetchpriority="high" data-md-skip>
  <div class="vk-hero-overlay"></div>
  <div class="ctr">
    <div class="vk-hero-grid">
      <div class="vk-hero-left">
        <div class="vk-chip">MTP GROUP · ВАКАНСІЇ · ЩАСЛИВЕ + БІЛОГОРОДКА</div>
        <h1>Вакансії на складі MTP Group — від 30 000 ₴ + бонуси за виробіток</h1>
        <p class="vk-hero-sub">Шукаємо 4 позиції на основний склад у Щасливому (Бориспільський район) і додатковий у Білогородці. Стабільний графік 5/2 або 2/2, навчання за рахунок компанії, офіційне працевлаштування за вашим бажанням.</p>
      </div>
      <div class="vk-hero-right">
        <div class="vk-form-card">
          <div class="vk-form-title">Подати заявку на вакансію</div>
          <HeroCTA lang="uk" theme="light" button="Залишити заявку →" microCopy="✓ Передзвонимо за 1-2 години у робочий час · вкажіть бажану позицію після дзвінка" sourceTag="hero /vakansiyi/" />
        </div>
      </div>
    </div>
    <div class="vk-hero-stats">
      <div class="vk-stat"><div class="vk-stat-num">від 30 000 ₴</div><div class="vk-stat-lbl">МІНІМАЛЬНА З/П</div></div>
      <div class="vk-stat"><div class="vk-stat-num">БРОНЮВАННЯ</div><div class="vk-stat-lbl">ВІД МОБІЛІЗАЦІЇ</div></div>
      <div class="vk-stat"><div class="vk-stat-num">5/2 · 2/2</div><div class="vk-stat-lbl">ГРАФІКИ НА ВИБІР</div></div>
      <div class="vk-stat"><div class="vk-stat-num">ЖИТЛО</div><div class="vk-stat-lbl">ДЛЯ ІНОГОРОДНІХ</div></div>
    </div>
  </div>
</section>

<!-- BRONIUVANNYA banner — critical info for draft-age applicants -->
<section class="vk-reserve-banner">
  <div class="ctr">
    <div class="vk-reserve-grid">
      <div class="vk-reserve-icon">🛡️</div>
      <div class="vk-reserve-text">
        <h2>Офіційне бронювання працівників від мобілізації</h2>
        <p>MTP Group — підприємство критичної інфраструктури (логістика, постачання e-commerce). Маємо квоту на бронювання працівників призовного віку через Міноборони + Мінекономіки. Працівник на основних позиціях (комірник, комплектувальник, приймальник, водій навантажувача) отримує бронювання після випробувального терміну. Для іногородніх — надаємо житло поблизу складу. Деталі — на співбесіді.</p>
      </div>
    </div>
  </div>
</section>

<!-- WHY MTP — Employer brand -->
<section class="vk-sec">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">ЧОМУ MTP</div>
    <h2 class="vk-h2">Чому варто прийти працювати до нас — 6 практичних причин</h2>
    <div class="vk-why-grid">
      <div class="vk-why-card">
        <h3>Стабільна зарплата і бонуси</h3>
        <p>Мінімум 30 000 ₴ з першого місяця. Бонуси за виробіток — добре працюєш, заробляєш 35-45 К. Зарплата 2 рази на місяць без затримок. Бонус за рекомендацію друга — 3 000 ₴ якщо він пропрацював 1 місяць.</p>
      </div>
      <div class="vk-why-card">
        <h3>Сучасний склад з технологіями</h3>
        <p>WMS-система веде кожну операцію — менше ручної рутини. Сканери штрих-коду, RF-термінали, добре освітлені робочі зони. Не радянський склад а сучасна логістика рівня Європи.</p>
      </div>
      <div class="vk-why-card">
        <h3>Працюємо без простою з 2022</h3>
        <p>0 днів виробничого простою з лютого 2022 року. У нас 3 дизельних генератори + Starlink — працюємо в будь-який blackout. Зарплата гарантована незалежно від обстрілів і відключень.</p>
      </div>
      <div class="vk-why-card">
        <h3>Графіки на вибір</h3>
        <p>5/2 (понеділок-п'ятниця, 8:00-17:00) для тих хто любить вихідні з родиною. 2/2 (12-годинні зміни) для тих хто хоче більше вільних днів. Заняття змін відбувається у Щасливому або Білогородці — обираєте склад ближче до дому.</p>
      </div>
      <div class="vk-why-card">
        <h3>Навчання за рахунок компанії</h3>
        <p>Перший тиждень — оплачуване навчання роботі з WMS і сканерами. Якщо приходите без посвідчення на навантажувач — оплачуємо курси і допускаємо до роботи після сертифікації. Навчити навичкам — наша інвестиція у вас.</p>
      </div>
      <div class="vk-why-card">
        <h3>Можливість зростання</h3>
        <p>Перший рівень — комірник, picker або приймальник. Через 6-12 місяців — старший зміни (+5-10 К до зарплати). Через 1.5-2 роки — заступник керівника складу. Багато наших нинішніх керівників почали з лінійних позицій.</p>
      </div>
    </div>
  </div>
</section>

<!-- POSITIONS — 4 cards -->
<section class="vk-sec vk-sec-light" id="vakansii">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">ПОЗИЦІЇ</div>
    <h2 class="vk-h2">4 вакансії, які зараз шукаємо</h2>

    <article class="vk-job">
      <header class="vk-job-head">
        <div>
          <h3 id="komirnyk">Комірник складу</h3>
          <div class="vk-job-meta">Щасливе · Білогородка · 5/2 або 2/2 · повна зайнятість</div>
        </div>
        <div class="vk-job-salary">від 30 000 ₴</div>
      </header>
      <div class="vk-job-body">
        <p>Серце операцій MTP. Без точного складського обліку не працює нічого — ваша робота тримає всю систему у тонусі.</p>
        <div class="vk-job-cols">
          <div>
            <h4>Обов'язки</h4>
            <ul>
              <li>Приймання товару від клієнтів і постачальників</li>
              <li>Розміщення у стелажах за маршрутом WMS</li>
              <li>Ведення обліку через сканер штрих-кодів і RF-термінал</li>
              <li>Підтримка чистоти і порядку у робочій зоні</li>
            </ul>
          </div>
          <div>
            <h4>Вимоги</h4>
            <ul>
              <li>Уважність до деталей (це не формальність — у нас 99,98% точність)</li>
              <li>Базові навички роботи з ПК (WMS навчимо)</li>
              <li>Готовність до фізичної роботи — багато ходимо, носимо до 15 кг</li>
              <li>Відповідальність — підписуємо договір з матеріальною відповідальністю</li>
              <li>Досвід склад/логістика — плюс, але необов'язково</li>
            </ul>
          </div>
          <div>
            <h4>Ми пропонуємо</h4>
            <ul>
              <li><strong>Бронювання від мобілізації</strong> після випробувального</li>
              <li>Від 30 000 ₴ + бонус за виробіток</li>
              <li>Гарантована оплата кожні 2 тижні</li>
              <li><strong>Надаємо житло іногороднім</strong> поблизу складу</li>
              <li>Оплачуване навчання перший тиждень</li>
            </ul>
          </div>
        </div>
      </div>
    </article>

    <article class="vk-job">
      <header class="vk-job-head">
        <div>
          <h3 id="komplektuvalnyk">Комплектувальник замовлень</h3>
          <div class="vk-job-meta">Щасливе · 5/2 · повна зайнятість · бонус за швидкість</div>
        </div>
        <div class="vk-job-salary">від 30 000 ₴</div>
      </header>
      <div class="vk-job-body">
        <p>Збираєте замовлення для інтернет-магазинів і дистриб'юторів. Чим швидше і точніше — тим більше бонус. Наш топ-збирач заробляє 45+ К на місяць.</p>
        <div class="vk-job-cols">
          <div>
            <h4>Обов'язки</h4>
            <ul>
              <li>Збір замовлень за листами WMS</li>
              <li>Сканування штрих-кодів на 2 етапах (pick + pack)</li>
              <li>Контроль якості перед опломбуванням</li>
              <li>Пакування з захистом від пошкоджень</li>
              <li>Передача готових замовлень на відвантаження</li>
            </ul>
          </div>
          <div>
            <h4>Вимоги</h4>
            <ul>
              <li>Швидкість + уважність — два паралельні навики</li>
              <li>Базова робота зі сканером і ПК</li>
              <li>Фізична витривалість — багато pick-маршрутів за зміну</li>
              <li>Орієнтація на результат — у нас плата за виробіток</li>
              <li>Бажано: досвід комплектації / складу — велика перевага</li>
            </ul>
          </div>
          <div>
            <h4>Ми пропонуємо</h4>
            <ul>
              <li><strong>Бронювання від мобілізації</strong> після випробувального</li>
              <li>Від 30 000 ₴ + бонус за кожне зібране замовлення понад план</li>
              <li>Реальні приклади: топ-збирачі заробляють 40-50 К</li>
              <li><strong>Надаємо житло іногороднім</strong> поблизу складу</li>
              <li>Можливість стати тренером нових — +5 000 ₴ до основної</li>
            </ul>
          </div>
        </div>
      </div>
    </article>

    <article class="vk-job">
      <header class="vk-job-head">
        <div>
          <h3 id="pryymalnyk">Приймальник товару</h3>
          <div class="vk-job-meta">Щасливе · 5/2 · повна зайнятість · контроль якості</div>
        </div>
        <div class="vk-job-salary">від 30 000 ₴</div>
      </header>
      <div class="vk-job-body">
        <p>Перша лінія контролю — те що ви пропустите, дійде до клієнтських замовлень з помилкою. Тому ця позиція для уважних і відповідальних людей.</p>
        <div class="vk-job-cols">
          <div>
            <h4>Обов'язки</h4>
            <ul>
              <li>Приймання вхідних поставок від клієнтів</li>
              <li>Перевірка комплектності за інвойсом / накладною</li>
              <li>Фотофіксація стану товару і упаковки</li>
              <li>Оприбуткування у WMS з прив'язкою до партії і документа</li>
              <li>Складання акта розбіжностей якщо щось не сходиться</li>
            </ul>
          </div>
          <div>
            <h4>Вимоги</h4>
            <ul>
              <li>Висока уважність — критично важливо</li>
              <li>Базові навички ПК і роботи зі сканером</li>
              <li>Здатність працювати з документами (накладні, інвойси)</li>
              <li>Відповідальність — підписуємо договір матвідповідальності</li>
              <li>Спокій у роботі з конфліктними ситуаціями (розбіжності за товаром)</li>
            </ul>
          </div>
          <div>
            <h4>Ми пропонуємо</h4>
            <ul>
              <li><strong>Бронювання від мобілізації</strong> після випробувального</li>
              <li>Від 30 000 ₴ + бонус за обсяг приймання</li>
              <li>Гарантована оплата 2 рази на місяць</li>
              <li><strong>Надаємо житло іногороднім</strong> поблизу складу</li>
              <li>Можливість зростання до старшого приймальника (+8 000 ₴)</li>
            </ul>
          </div>
        </div>
      </div>
    </article>

    <article class="vk-job">
      <header class="vk-job-head">
        <div>
          <h3 id="vodiy-navantazhuvacha">Водій навантажувача</h3>
          <div class="vk-job-meta">Щасливе · 5/2 або 2/2 · повна зайнятість · є посвідчення</div>
        </div>
        <div class="vk-job-salary">від 30 000 ₴</div>
      </header>
      <div class="vk-job-body">
        <p>Управляєте електронавантажувачем на складі. Без вас палети самі не їздять, фури не розвантажуються, стелажі не наповнюються.</p>
        <div class="vk-job-cols">
          <div>
            <h4>Обов'язки</h4>
            <ul>
              <li>Управління електронавантажувачем</li>
              <li>Переміщення палет до 2 тонн між зонами складу</li>
              <li>Завантаження і розвантаження транспорту</li>
              <li>Штабелювання у стелажах висотою до 6 метрів</li>
              <li>Базове обслуговування навантажувача (зарядка, перевірка)</li>
            </ul>
          </div>
          <div>
            <h4>Вимоги</h4>
            <ul>
              <li>Посвідчення на навантажувач — категорія II (обов'язково!)</li>
              <li>Досвід роботи з електронавантажувачем — від 1 року</li>
