:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}body{font-family:var(--fb);font-weight:400;color:var(--black);background:var(--white);line-height:1.6;overflow-x:hidden}
a{text-decoration:none;color:inherit}img{max-width:100%;height:auto;display:block}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}


.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:32px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}.badge-dark::before{background:var(--red)}


.hero{position:relative;min-height:70vh;background:var(--black);color:var(--white);display:flex;flex-direction:column;justify-content:center;padding:120px 0 80px;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:url('/images/mtp-warehouse-team-work.webp') center/cover;opacity:.15}
.hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero h1{font-family:var(--fd);font-size:clamp(42px,6vw,80px);font-weight:400;line-height:.95;margin-bottom:28px}
.hero-sub{font-size:clamp(16px,1.8vw,20px);color:rgba(255,255,255,.6);line-height:1.7;max-width:520px}
.hero-form{display:flex;gap:12px;max-width:460px;margin-top:32px}
.hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;font-family:var(--fb);outline:none}
.hero-form input::placeholder{color:rgba(255,255,255,.25)}.hero-form input:focus{border-color:rgba(255,255,255,.5)}
.hero-form button{padding:16px 24px;background:transparent;color:#fff;border:2px solid #fff;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:all .3s}
.hero-form button:hover{background:var(--red);border-color:var(--red)}
.hero-note{font-size:13px;color:rgba(255,255,255,.35);margin-top:12px}
.sec-h2{font-family:var(--fd);font-size:clamp(32px,4.5vw,56px);font-weight:400;margin-bottom:48px}

.videos{padding:100px 0;background:var(--gray)}
.vid-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:48px}
.vid-card{border-radius:12px;overflow:hidden;background:var(--white);box-shadow:0 2px 20px rgba(0,0,0,.06)}
.vid-card .video-thumb{max-width:none;margin:0;border-radius:12px 12px 0 0}
.vid-card-info{padding:20px}
.vid-card-info h3{font-size:16px;font-weight:500;margin-bottom:4px}
.vid-card-info p{font-size:13px;color:var(--muted)}

.cases{padding:100px 0}
.case-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;margin-top:48px}
.case-card{border:1px solid #e0e0e0;border-radius:12px;padding:40px;transition:border-color .3s,box-shadow .3s}
.case-card:hover{border-color:var(--red);box-shadow:0 8px 32px rgba(230,51,41,.08)}
.case-brand{font-family:var(--fd);font-size:24px;font-weight:400;margin-bottom:16px}
.case-metrics{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:24px 0;padding:24px 0;border-top:1px solid #eee;border-bottom:1px solid #eee}
.case-metric-val{font-family:var(--fd);font-size:28px;color:var(--red);font-weight:400}
.case-metric-label{font-size:12px;color:var(--muted);margin-top:4px}
.case-card p{font-size:14px;color:var(--muted);line-height:1.7}
.case-tag{display:inline-block;background:var(--gray);font-size:11px;font-weight:500;letter-spacing:1px;padding:4px 12px;border-radius:100px;margin-bottom:16px;text-transform:uppercase;color:var(--muted)}

.reviews{padding:100px 0;background:#0a0a0a;color:var(--white)}
.rev-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:48px}
.rev-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:32px;transition:border-color .3s}
.rev-card:hover{border-color:rgba(255,255,255,.2)}
.rev-stars{color:var(--red);letter-spacing:4px;font-size:16px;margin-bottom:16px}
.rev-text{font-family:var(--fd);font-style:italic;font-size:17px;line-height:1.6;color:rgba(255,255,255,.85);margin-bottom:20px}
.rev-author{font-size:14px;color:rgba(255,255,255,.5)}
.rev-company{font-size:12px;color:rgba(255,255,255,.3);margin-top:4px}

.seo-article{padding:100px 0}
.seo-article h2{font-family:var(--fd);font-size:clamp(28px,3.5vw,40px);font-weight:400;margin-bottom:32px}
.seo-article h3{font-size:20px;font-weight:500;margin:32px 0 16px}
.seo-article p{font-size:16px;color:var(--muted);line-height:1.8;margin-bottom:16px;max-width:800px}

.final-cta{padding:120px 0;background:var(--red);color:var(--white);text-align:center}
.final-cta h2{font-family:var(--fd);font-size:clamp(32px,5vw,56px);font-weight:400;line-height:1.05;margin-bottom:20px}
.final-cta .sub{font-size:17px;opacity:.85;max-width:480px;margin:0 auto 40px;line-height:1.6}
.final-form{display:flex;gap:12px;justify-content:center;max-width:460px;margin:0 auto}
.final-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.35);border-radius:4px;background:rgba(255,255,255,.1);color:var(--white);font-size:15px;font-family:var(--fb);outline:none}
.final-form input::placeholder{color:rgba(255,255,255,.45)}.final-form input:focus{border-color:var(--white)}
.final-form button{padding:16px 24px;background:var(--black);color:var(--white);border:none;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:background .3s}.final-form button:hover{background:#222}
.final-checks{display:flex;gap:24px;justify-content:center;flex-wrap:wrap;margin-top:20px;font-size:13px;opacity:.7}







@media(max-width:768px){


.hero{padding:100px 0 60px}.hero-content{padding:0 24px}
.hero h1{font-size:clamp(36px,9vw,48px)}
.hero-form{flex-direction:column}.hero-form button{width:100%}
.vid-grid{grid-template-columns:1fr}
.case-grid{grid-template-columns:1fr}
.rev-grid{grid-template-columns:1fr}
.final-form{flex-direction:column}
}

</style>

