<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/paletne-zberigannya/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/paletnoe-khranenie/">
