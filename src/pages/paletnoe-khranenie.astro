<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
(function(){
var b=document.getElementById('navBurger'),l=document.getElementById('navLinks');
if(b&&l){b.addEventListener('click',function(){b.classList.toggle('open');l.classList.toggle('open');});l.addEventListener('click',function(e){if(e.target.tagName==='A'){b.classList.remove('open');l.classList.remove('open');}})
document.querySelectorAll('.nav-dropdown').forEach(function(dd){
var timer,menu=dd.querySelector('.nav-dropdown-menu');if(!menu)return;
dd.addEventListener('mouseenter',function(){clearTimeout(timer);menu.style.display='block';});
dd.addEventListener('mouseleave',function(){timer=setTimeout(function(){menu.style.display='';},300);});
});
document.querySelectorAll('.nav-dropdown-trigger').forEach(function(t){t.addEventListener('click',function(e){if(window.innerWidth<=900){e.preventDefault();this.closest('.nav-dropdown').classList.toggle('mobile-open');}});});
}
document.querySelectorAll('.faq-q').forEach(function(btn){btn.addEventListener('click',function(){var item=this.closest('.faq-item');item.classList.toggle('open');var a=item.querySelector('.faq-a');if(item.classList.contains('open')){a.style.maxHeight=a.scrollHeight+'px';}else{a.style.maxHeight='0';}});});
var form=document.getElementById('heroForm');
if(form){form.addEventListener('submit',function(e){e.preventDefault();var ph=form.querySelector('input[name="phone"]').value.replace(/\D/g,'');if(ph.length<10){alert('Введите корректный номер телефона');return;}
var leads=JSON.parse(localStorage.getItem('mtp_crm_leads')||'[]');leads.push({id:Date.now(),company:'Паллетное хранение',contact:'',phone:ph,email:'',shipments:0,type:'pallet',source:'SEO landing paletnoe-khranenie',status:'new',date:new Date().toISOString().split('T')[0],comments:[{text:'Форма: паллетное хранение Киев',date:new Date().toLocaleString('ru-RU')}],onboarding:[false,false,false,false,false,false,false]});localStorage.setItem('mtp_crm_leads',JSON.stringify(leads));fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});if(window.mtpSubmitLead)window.mtpSubmitLead(ph);form.innerHTML='<div style="text-align:center"><p style="color:#fff;font-size:18px;font-weight:500">\u2705 Спасибо!</p><p style="color:rgba(255,255,255,.5);font-size:14px;margin-top:8px">Перезвоним в ближайшее время</p></div>';setTimeout(function(){window.location.href='/thanks/';},1500);});}
})();
});
</script>
