<!-- TESTIMONIALS JS -->
<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
var testimonials=[
{text:"Від 100 до 800 відправок на день за 3 місяці. MTP — команда яка реально закриває питання логістики.",name:"Олексій Рябцев",company:"Власник інтернет-магазину"},
{text:"Зекономили 25 000 грн/місяць порівняно з власним складом. Рекомендую всім хто хоче масштабуватись.",name:"Павло Мокрієнко",company:"E-commerce підприємець"},
{text:"Передав логістику MTP — звільнив 40 годин на місяць для маркетингу. Рішення яке варто прийняти раніше.",name:"Антон Борисенко",company:"CEO BeautyBox"},
{text:"Працюємо з MTP вже 2 роки. Жодного збою навіть під час важких обстрілів. Стабільність на вищому рівні.",name:"Ірина Савченко",company:"OrnerUA"},
{text:"Особистий кабінет — це просто вогонь. Бачу залишки, відправки, повернення в реальному часі з телефону.",name:"Дмитро Коваль",company:"KRKR.com.ua"},
{text:"Спробував 3 фулфілменти до MTP. Тільки тут відчув що партнер реально зацікавлений в моєму зростанні.",name:"Михайло Гончар",company:"FashionUA"},
{text:"У нас важкі товари 30-60 кг. Думали не візьмуть — взяли і зробили спеціальні умови. Дуже задоволені.",name:"Олег Петренко",company:"EcoDrive"},
{text:"Автодзвінок після замовлення підняв наш викуп з 68% до 84% за місяць. Це просто космос.",name:"Вікторія Лисенко",company:"Косметичний бренд"},
{text:"Інтеграція з KeyCRM пройшла за 1 день. Тепер замовлення автоматично потрапляють на склад без ручної роботи.",name:"Сергій Бондаренко",company:"TechStore UA"},
{text:"MTP допоміг вийти на Rozetka. Без їхньої логістики це було б неможливо з нашими об\u2019ємами.",name:"Наталія Мороз",company:"Home & Decor"}
];
var track=document.getElementById('testiTrack');
if(!track)return;
track.innerHTML=testimonials.map(function(t){return '<div class="testi-slide"><div class="testi-stars">\u2605\u2605\u2605\u2605\u2605</div><div class="testi-quote">\u201C'+t.text+'\u201D</div><div class="testi-author">'+t.name+'</div><div class="testi-company">'+t.company+'</div></div>';}).join('');
var cs=0,total=testimonials.length,timer;
function slideTo(n){cs=((n%total)+total)%total;track.style.transform='translateX(-'+cs*100+'%)';document.querySelectorAll('.testi-dot').forEach(function(d,i){d.classList.toggle('active',i===cs);});}
var dots=document.getElementById('testiDots');for(var i=0;i<total;i++){var d=document.createElement('div');d.className='testi-dot'+(i===0?' active':'');d.onclick=(function(x){return function(){slideTo(x);resetT();};})(i);dots.appendChild(d);}
document.getElementById('tPrev').addEventListener('click',function(){slideTo(cs-1);resetT();});
document.getElementById('tNext').addEventListener('click',function(){slideTo(cs+1);resetT();});
function resetT(){clearInterval(timer);timer=setInterval(function(){slideTo(cs+1);},6000);}resetT();
});
</script>

<!-- FORM HANDLING JS -->
<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
function handleForm(form){form.addEventListener('submit',function(e){e.preventDefault();var ph=form.querySelector('input[name="phone"]').value;var clean=ph.replace(/\D/g,'');if(clean.length<12){form.querySelector('input[name="phone"]').style.borderColor='#e63329';return;}var leads=JSON.parse(localStorage.getItem('mtp_crm_leads')||'[]');leads.push({id:Date.now(),company:'Заявка з головної',contact:'',phone:ph,email:'',shipments:0,type:'other',source:'Головна',status:'new',date:new Date().toISOString().split('T')[0],comments:[{text:'Форма на головній',date:new Date().toLocaleString('uk-UA')}],onboarding:[false,false,false,false,false,false,false]});localStorage.setItem('mtp_crm_leads',JSON.stringify(leads));fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});form.innerHTML='<div style="text-align:center;padding:20px"><p style="color:#22c55e;font-size:18px;font-weight:500">\u2705 Дякуємо!</p><p style="color:rgba(255,255,255,0.5);font-size:14px;margin-top:8px">Передзвонимо найближчим часом</p></div>';setTimeout(function(){window.location.href='/ua/thanks/';},1500);});}
var hf=document.getElementById('heroForm');if(hf)handleForm(hf);

function applyPhoneMask(inp){
inp.addEventListener('input',function(){
var v=this.value.replace(/\D/g,'');
if(v.startsWith('380'))v=v.slice(2);else if(v.startsWith('38'))v=v.slice(2);else if(v.startsWith('80'))v='0'+v.slice(2);
var m='+38 (';
if(v.length>0)m+=v.substring(0,3);
if(v.length>=3)m+=') ';
