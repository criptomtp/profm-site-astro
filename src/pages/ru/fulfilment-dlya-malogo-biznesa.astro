<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
  /* YouTube facade */
  document.querySelectorAll('.yt-facade').forEach(function(el){
    el.addEventListener('click', function(){
      var id = el.getAttribute('data-id');
      var iframe = document.createElement('iframe');
      iframe.setAttribute('src','https://www.youtube.com/embed/' + id + '?autoplay=1&rel=0');
      iframe.setAttribute('frameborder','0');
      iframe.setAttribute('allow','accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture');
      iframe.setAttribute('allowfullscreen','');
      iframe.style.position = 'absolute';
      iframe.style.inset = '0';
      iframe.style.width = '100%';
      iframe.style.height = '100%';
      el.innerHTML = '';
      el.style.position = 'relative';
      el.appendChild(iframe);
    });
  });

  /* Hero form */
  var forms = document.querySelectorAll('#heroForm');
  forms.forEach(function(form){
    var inp = form.querySelector('input[name="phone"]');
    if(!inp) return;
    inp.addEventListener('input', function(){
      this.value = this.value.replace(/[^0-9+() -]/g, '');
    });
    inp.addEventListener('focus', function(){
      if(!this.value) this.value = '+38 (';
    });
    inp.addEventListener('blur', function(){
      if(this.value === '+38 (') this.value = '';
    });
    form.addEventListener('submit', function(e){
      e.preventDefault();
      var ph = inp.value.replace(/\D/g,'');
      if(ph.length < 10){
        inp.style.borderColor = 'var(--red)';
        return;
      }
      var leads = JSON.parse(localStorage.getItem('mtp_crm_leads') || '[]');
      leads.push({
        id: Date.now(),
        company: 'Фулфилмент для малого бизнеса (RU)',
        contact: '',
        phone: ph,
        email: '',
        shipments: 0,
        type: 'small-business',
        source: 'SEO landing fulfilment-dlya-malogo-biznesa RU',
        status: 'new',
        date: new Date().toISOString().split('T')[0],
        comments: [{text: 'Форма: фулфилмент для малого бизнеса (RU)', date: new Date().toLocaleString('ru-RU')}],
        onboarding: [false,false,false,false,false,false,false]
      });
      localStorage.setItem('mtp_crm_leads', JSON.stringify(leads));
      fetch('/api/telegram', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({phone: ph, page: location.pathname})
      }).catch(function(){});
      if(window.mtpSubmitLead) window.mtpSubmitLead(ph);
      form.innerHTML = '<div style="text-align:center"><p style="color:#fff;font-size:18px;font-weight:500">Спасибо!</p><p style="color:rgba(255,255,255,.5);font-size:14px;margin-top:8px">Перезвоним в ближайшее время</p></div>';
      setTimeout(function(){
        window.location.href = '/ru/thanks/';
      }, 1500);
    });
  });
});
</script>
