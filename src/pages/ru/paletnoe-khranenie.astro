  if(heroForm){heroForm.addEventListener('submit',function(e){e.preventDefault();var ph=heroForm.querySelector('input[name="phone"]').value.replace(/\D/g,'');if(ph.length<10){alert('Введите корректный номер телефона');return;}
  fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});if(window.mtpSubmitLead)window.mtpSubmitLead(ph);heroForm.innerHTML='<div style="text-align:center"><p style="color:#fff;font-size:18px;font-weight:500">Спасибо!</p><p style="color:rgba(255,255,255,.5);font-size:14px;margin-top:8px">Перезвоним в ближайшее время</p></div>';setTimeout(function(){window.location.href='/thanks/';},1500);});}
  var form = document.getElementById('pzBookingForm');
  if(!form) return;
  form.addEventListener('submit', function(e){
    e.preventDefault();
    var phoneInput = form.querySelector('input[name="phone"]');
    var ph = phoneInput.value.replace(/\D/g, '');
    if(ph.length < 10){
      phoneInput.style.borderColor = '#e63329';
      phoneInput.focus();
      return;
    }
    phoneInput.style.borderColor = '';
    var page = location.pathname;
    var nm = form.querySelector('input[name="name"]').value.trim();
    if(window.mtpSubmitLead){
      window.mtpSubmitLead(ph, page, nm);
    }
    fetch('/api/telegram', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        phone: ph,
        name: nm,
        email: form.querySelector('input[name="email"]').value.trim(),
        pallets: form.querySelector('select[name="pallets"]').value,
        page: page
      })
    }).catch(function(){});
    form.innerHTML = '<div style="text-align:center;padding:32px 0"><p style="font-size:20px;font-weight:600;color:#fff;margin-bottom:8px">Спасибо за заявку!</p><p style="font-size:15px;color:rgba(255,255,255,.55)">Перезвоним в течение 15 минут</p></div>';
    setTimeout(function(){ window.location.href = '/thanks/'; }, 2000);
  });
})();
