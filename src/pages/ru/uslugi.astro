<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
(function(){
var burger=document.getElementById('navBurger');
var links=document.getElementById('navLinks');
if(burger&&links){
burger.addEventListener('click',function(){burger.classList.toggle('open');links.classList.toggle('open');});
links.addEventListener('click',function(e){if(e.target.tagName==='A'){burger.classList.remove('open');links.classList.remove('open');}});
}

var els=document.querySelectorAll('.fade-in');
if('IntersectionObserver' in window){
var obs=new IntersectionObserver(function(entries){
entries.forEach(function(entry){
if(entry.isIntersecting){entry.target.classList.add('visible');obs.unobserve(entry.target);}
});
},{threshold:0.15});
els.forEach(function(el){obs.observe(el);});
}else{
els.forEach(function(el){el.classList.add('visible');});
}

document.querySelectorAll('.faq-q').forEach(function(btn){
btn.addEventListener('click',function(){
var item=this.parentElement;
var a=item.querySelector('.faq-a');
if(item.classList.contains('open')){
a.style.maxHeight='0';item.classList.remove('open');
}else{
document.querySelectorAll('.faq-item.open').forEach(function(o){o.querySelector('.faq-a').style.maxHeight='0';o.classList.remove('open');});
item.classList.add('open');a.style.maxHeight=a.scrollHeight+'px';
}
});
});

document.querySelectorAll('form').forEach(function(form){
form.addEventListener('submit',function(e){
e.preventDefault();
var ph=form.querySelector('input[name="phone"]');
if(!ph)return;
var phone=ph.value.replace(/[^+\d]/g,'');
if(phone.length<10)return;
if(typeof gtag==='function'){gtag('event','conversion',{'send_to':'AW-614588275/eh2qCJenw5kcEPO-h6UC','value':1.0,'currency':'UAH'});}
var page=window.location.pathname;
var leads=JSON.parse(localStorage.getItem('mtp_crm_leads')||'[]');
leads.push({id:Date.now(),phone:phone,source:'Сайт — '+page,status:'new',date:new Date().toISOString().split('T')[0]});
localStorage.setItem('mtp_crm_leads',JSON.stringify(leads));
fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:phone,page:page})}).catch(function(){});
if(window.mtpSubmitLead)window.mtpSubmitLead(phone);
form.innerHTML='<p style="color:#fff;font-weight:bold;text-align:center;font-size:18px">Спасибо! Перезвоним в ближайшее время.</p>';
setTimeout(function(){window.location.href='/thanks/';},1500);
});
});

// Mobile overlay
var nc=document.querySelector('.nav-center,#navLinks');
var nav=document.querySelector('nav.nav,.nav');
if(nc&&nav){
var ov=document.createElement('div');
ov.className='nav-overlay-bg';
ov.style.cssText='display:none;position:fixed;top:0;left:0;width:100%;height:100vh;background:rgba(0,0,0,.6);z-index:1;cursor:pointer';
nav.appendChild(ov);
function sync(){var open=nc.classList.contains('open');ov.style.display=open?'block':'none';document.body.style.overflow=open?'hidden':'';}
new MutationObserver(sync).observe(nc,{attributes:true,attributeFilter:['class']});
ov.addEventListener('click',function(){nc.classList.remove('open');var b=document.querySelector('.nav-burger,#navBurger');if(b)b.classList.remove('open');sync();});
}
})();
});
