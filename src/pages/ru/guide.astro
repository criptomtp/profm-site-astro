<script is:inline>
/* Hero form — CIS brand playbook */
(function(){
  var form=document.getElementById('heroFormGuide');
  if(!form)return;
  var inp=form.querySelector('input[name="phone"]');
  inp.addEventListener('input',function(){this.value=this.value.replace(/[^0-9+() -]/g,'');});
  inp.addEventListener('focus',function(){if(!this.value)this.value='+38 (';});
  inp.addEventListener('blur',function(){if(this.value==='+38 (')this.value='';});
  form.addEventListener('submit',function(e){
    e.preventDefault();
    var ph=inp.value.replace(/\D/g,'');
    if(ph.length<10){inp.style.borderColor='#e63329';return;}
    fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:inp.value,page:location.pathname,source:'hero /ru/guide/ CIS playbook'})}).catch(function(){});
    if(window.mtpSubmitLead)window.mtpSubmitLead(inp.value,location.pathname);
    form.innerHTML='<div style="text-align:center;padding:14px 20px"><p style="color:#fff;font-size:17px;font-weight:600;margin:0">✅ Спасибо!</p><p style="color:rgba(255,255,255,.7);font-size:13px;margin:6px 0 0">Перезвоним в течение 15 минут с расчётом</p></div>';
    setTimeout(function(){window.location.href='/ru/thanks/';},1500);
  });
})();
