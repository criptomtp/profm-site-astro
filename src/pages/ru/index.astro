var fn=document.getElementById('floatNotif'),ft=document.getElementById('fnText'),ni=0;
if(!fn||!ft)return;
function showFN(){var n=notifs[ni%notifs.length];ft.textContent='\uD83D\uDCE6 '+n.c+' \u00b7 '+n.t;fn.classList.add('show');setTimeout(function(){fn.classList.remove('show');},4000);ni++;}
setTimeout(showFN,2500);setInterval(showFN,7000);
});
</script>

