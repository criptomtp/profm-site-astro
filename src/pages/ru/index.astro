<!-- TESTIMONIALS JS -->
<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
var testimonials=[
{text:"От 100 до 800 отправок в день за 3 месяца. MTP \u2014 команда, которая реально закрывает вопрос логистики.",name:"Алексей Рябцев",company:"Владелец интернет-магазина"},
{text:"Сэкономили 25 000 грн/мес по сравнению с собственным складом. Рекомендую всем, кто хочет масштабироваться.",name:"Павел Мокриенко",company:"E-commerce предприниматель"},
{text:"Передал логистику MTP \u2014 высвободил 40 часов в месяц на маркетинг. Решение, которое стоило принять раньше.",name:"Антон Борисенко",company:"CEO BeautyBox"},
{text:"Работаем с MTP уже 2 года. Ни одного сбоя даже во время тяжёлых обстрелов. Стабильность на высшем уровне.",name:"Ирина Савченко",company:"OrnerUA"},
{text:"Личный кабинет \u2014 это просто невероятно удобно. Вижу остатки, отправки, возвраты в реальном времени с телефона.",name:"Дмитрий Коваль",company:"KRKR.com.ua"},
{text:"Попробовал 3 фулфилмента до MTP. Только здесь почувствовал, что партнёр реально заинтересован в моём росте.",name:"Михаил Гончар",company:"FashionUA"},
{text:"У нас тяжёлые товары 30-60 кг. Думали откажут \u2014 взяли и создали специальные условия. Очень довольны.",name:"Олег Петренко",company:"EcoDrive"},
{text:"Автозвонок после заказа поднял наш выкуп с 68% до 84% за месяц. Это колоссальная разница для бизнеса.",name:"Виктория Лысенко",company:"Косметический бренд"},
{text:"Интеграция с KeyCRM прошла за 1 день. Теперь заказы автоматически попадают на склад без ручной работы.",name:"Сергей Бондаренко",company:"TechStore UA"},
{text:"MTP помог выйти на Rozetka. Без их логистики это было бы невозможно с нашими объёмами.",name:"Наталия Мороз",company:"Home & Decor"}
];
var track=document.getElementById('testiTrack');
if(!track)return;
track.innerHTML=testimonials.map(function(t){return '<div class="testi-slide"><div class="testi-stars">\u2605\u2605\u2605\u2605\u2605</div><div class="testi-quote">\u201C'+t.text+'\u201D</div><div class="testi-author">'+t.name+'</div><div class="testi-company">'+t.company+'</div></div>';}).join('');
var cs=0,total=testimonials.length,timer;
function slideTo(n){cs=((n%total)+total)%total;track.style.transform='translateX(-'+cs*100+'%)';document.querySelectorAll('.testi-dot').forEach(function(d,i){d.classList.toggle('active',i===cs);});}
var dots=document.getElementById('testiDots');for(var i=0;i<total;i++){var d=document.createElement('div');d.className='testi-dot'+(i===0?' active':'');d.onclick=(function(x){return function(){slideTo(x);resetT();};})(i);dots.appendChild(d);}
document.getElementById('tPrev').addEventListener('click',function(){slideTo(cs-1);resetT();});
document.getElementById('tNext').addEventListener('click',function(){slideTo(cs+1);resetT();});
function resetT(){clearInterval(timer);timer=setInterval(function(){slideTo(cs+1);},6000);}resetT();
});
</script>

