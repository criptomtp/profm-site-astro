<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
/* Animated counters — slow, no jitter */
var counted=false;
function animateCounters(){
if(counted)return;
var els=document.querySelectorAll('.counter-val[data-target]');
if(!els.length)return;
var rect=els[0].getBoundingClientRect();
if(rect.top>window.innerHeight*1.2)return;
counted=true;
els.forEach(function(el){
var target=parseInt(el.dataset.target);
var duration=target>10000?3000:target>100?2500:1500;
var startTime=null;
function step(ts){
if(!startTime)startTime=ts;
var progress=Math.min((ts-startTime)/duration,1);
var eased=1-Math.pow(1-progress,4);
var val=Math.floor(eased*target);
el.textContent=val.toLocaleString('ru-RU').replace(/,/g,' ');
if(progress<1)requestAnimationFrame(step);
}
requestAnimationFrame(step);
});
}
window.addEventListener('scroll',animateCounters,{passive:true});
animateCounters();

/* Marketplace scroller arrows */
var scroller=document.getElementById('mpScroller');
var prevBtn=document.querySelector('.mp-prev');
var nextBtn=document.querySelector('.mp-next');
if(scroller&&prevBtn&&nextBtn){
var scrollAmt=300;
prevBtn.addEventListener('click',function(){scroller.scrollBy({left:-scrollAmt,behavior:'smooth'});});
nextBtn.addEventListener('click',function(){scroller.scrollBy({left:scrollAmt,behavior:'smooth'});});
}
});
</script>
