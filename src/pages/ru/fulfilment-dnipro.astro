const schemaJson = `<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","dateModified":"2026-05-05","name":"Фулфилмент в Днепр для брендов СНГ — выход на украинский рынок через киевский хаб","description":"Бренды Казахстана, Молдовы, Грузии, Узбекистана, Польши и Латвии выходят на украинский e-commerce рынок через наш киевский хаб. Днепропетровская область — 3.2 млн человек, 4-й по объёму e-commerce рынок Украины. Без своего склада в Украине, без CAPEX, без юр.лица в Днепре. Мы оформляем накладные от вашего юр.лица и отправляем украинским покупателям через Новую Почту. От 18 грн ($0.41) за заказ.","provider":{"@type":"Organization","name":"MTP Group Fulfillment","legalName":"ООО \\"МТП Груп Фулфилмент\\"","taxID":"45315740","foundingDate":"2023-10-02","url":"https://www.fulfillmentmtp.com.ua","telephone":"+380501444645"},"areaServed":[{"@type":"Country","name":"UA"},{"@type":"Country","name":"KZ"},{"@type":"Country","name":"MD"},{"@type":"Country","name":"GE"},{"@type":"Country","name":"UZ"},{"@type":"Country","name":"PL"},{"@type":"City","name":"Днепр"},{"@type":"AdministrativeArea","name":"Днепропетровская область"}],"serviceType":"Fulfillment Ukraine for CIS brands — market entry via Kyiv hub serving Dnipro region","audience":{"@type":"BusinessAudience","name":"Бренды из Казахстана (косметика, fashion, food), Молдовы (вино, агро, beauty), Грузии (вино, fashion), Узбекистана (текстиль, сухофрукты), Польши (beauty, fashion), Латвии (niche), выходящие на украинский e-commerce рынок без локальной юридической присутствия"},"offers":{"@type":"Offer","priceCurrency":"USD","price":"0.41","description":"$0.41 за заказ (18 грн локально). Минимальный месячный платёж $120 (5 000 грн) первые 3 месяца. CIS-бренд платит в USD/EUR с конверсией по курсу НБУ."}}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Может ли бренд из Казахстана продавать в Украину без юр.лица в Украине?","acceptedAnswer":{"@type":"Answer","text":"Да. Бренд из Казахстана (или другой страны СНГ) отправляет товар на наш киевский склад через стандартного логистического оператора (Meest Express, Nova Poshta International, DHL Cargo) — мы принимаем как cross-border поставку, оформляем украинскую таможенную декларацию по поручению вашего юр.лица. Дальше товар хранится у нас, продаётся через украинский интернет-магазин (ваш сайт или Rozetka/Prom) от имени вашего юр.лица. Украинский покупатель видит чек на ваш бренд. Расчёты с покупателями через украинскую платёжную систему — выводим вам в USD/EUR на счёт в Казахстане ежемесячно."}},{"@type":"Question","name":"Зачем CIS-бренду экспансия именно в Днепр, а не Киев или Львов?","acceptedAnswer":{"@type":"Answer","text":"Не вместо — а вдобавок. Днепропетровская область — 4-й по GMV украинский e-commerce рынок (после Киева, Львова, Одессы). 3.2 млн человек, медианный доход выше украинского национального среднего ($720/мес). Ключевые сектора: автозапчасти, промышленное оборудование, косметика, мода. Для CIS-бренда Днепр часто более подходящ чем Киев — киевские конкуренты сильнее, днепровские потребители менее brand-loaded. Наш киевский хаб обслуживает Днепр через Новую Почту 1-2 дня — экспансия в Днепр не требует отдельного склада."}},{"@type":"Question","name":"Какие документы нужны казахстанскому бренду чтобы стартовать в Украине?","acceptedAnswer":{"@type":"Answer","text":"Минимальный набор: устав вашего KZ-юр.лица + банковские реквизиты для выплаты + коммерческий инвойс на партию товара + сертификат происхождения (Form CT-1 для EAEU стран). Для отправки товара в Украину — стандартная экспортная декларация со стороны Казахстана + украинская импортная декларация (мы оформляем у наших таможенных партнёров). Регистрация украинского юр.лица для CIS-бренда НЕ обязательна — продаёте через cross-border B2C модель. Если объём растёт >$50K/мес — рассматривайте украинское представительство для оптимизации налогов."}},{"@type":"Question","name":"Как работает онбординг для молдавского винного бренда?","acceptedAnswer":{"@type":"Answer","text":"Шаг 1: подписание договора с MTP (CIS-бренд + украинский операционный партнёр модель). Шаг 2: подготовка товара для cross-border отправки — экспортные декларации со стороны MD, акцизные марки для алкоголя. Шаг 3: отправка тестовой партии 100-500 бутылок Meest Express MD→UA (transit 5-7 дней). Шаг 4: украинская таможня + акцизная маркировка на нашем складе (специальная зона для алкоголя у нас лицензированная). Шаг 5: подключение к Rozetka Marketplace или собственному сайту молдавского бренда. Шаг 6: первые продажи украинским покупателям. Цикл от подписания до первой продажи — 14-21 день."}},{"@type":"Question","name":"Как украинский покупатель платит казахстанскому бренду?","acceptedAnswer":{"@type":"Answer","text":"Покупатель в Украине платит на украинский расчётный счёт нашего операционного партнёра (или ваш украинский счёт если открывали юр.лицо). Мы работаем по агентской схеме — украинский Эквайринг (Visa/Mastercard, Apple/Google Pay, наложенный платёж Новой Почты) принимает гривну от покупателя. Раз в месяц мы переводим вам остаток в USD или EUR на ваш банковский счёт в Казахстане по курсу НБУ день перевода. Комиссия конверсии 0.5-1%. SLA выплат — 5 рабочих дней от запроса."}},{"@type":"Question","name":"Сколько времени идёт доставка в Днепр для CIS-бренда?","acceptedAnswer":{"@type":"Answer","text":"Cross-border фаза (например MD→UA через Meest): 5-7 дней транзит товара на наш киевский склад. Внутри Украины: с момента оформления заказа украинским покупателем до получения в днепровском отделении НП — 24-48 часов (наш стандартный pick → next-day НП до Днепра). Итого казахстанский/молдавский бренд от продажи к украинскому покупателю до получения товара в Днепре — те же 1-2 дня что для украинского бренда с украинским складом. Cross-border фаза один раз при пополнении запаса, а не при каждом заказе."}},{"@type":"Question","name":"Что с возвратами от украинских покупателей для бренда из Грузии?","acceptedAnswer":{"@type":"Answer","text":"Покупатель в Украине возвращает товар через любое отделение НП — посылка идёт на наш киевский склад (1-2 дня). Принимаем, фотофиксируем состояние, проверяем комплектность. Грузинскому бренду две опции: (а) товар возвращается на полку для повторной продажи (если состояние OK), (б) товар отправляется обратно в Грузию накопительной партией раз в квартал — это дешевле чем индивидуальная reverse-cross-border на каждый возврат. Тариф обработки возврата — 1/2 от тарифа отправки. Отчёт в кабинете в день приёмки."}},{"@type":"Question","name":"Какие e-commerce платформы Украины подключаем для CIS-бренда?","acceptedAnswer":{"@type":"Answer","text":"Rozetka Marketplace — самая большая UA-площадка, для CIS-бренда требует регистрации продавца (мы помогаем с пакетом документов). Prom.ua — открытая платформа, легче зайти. Kasta — fashion-маркетплейс, требует ваших сертификатов качества. Allo — электроника. Собственный сайт через Хорошоп (украинский SaaS, мы имеем коннектор). Все эти платформы работают независимо от страны регистрации продавца — важна украинская локализация контента (русский OK для большинства, украинский предпочтителен для pos top-3)."}},{"@type":"Question","name":"Сколько стоит вся модель для бренда из Узбекистана?","acceptedAnswer":{"@type":"Answer","text":"Базовый тариф фулфилмента $0.41 ($0.50-0.59 для объёма 30-200 заказов в день) + хранение $1.50 за м³ в месяц + украинская доставка через НП $1.50-2.50 за заказ (платит покупатель). Минимальный месячный платёж $120 (5 000 грн) первые 3 месяца — потом покрывается объёмом. Cross-border транспортировка из UZ в UA: ~$2-3 за кг через Meest, ~$1.50 за кг через специализированных EAEU-перевозчиков. Юридические + бухгалтерские услуги по cross-border схеме — отдельный тариф нашего партнёра, ~$200/месяц паушально."}}]}</script>
