.dn-cov-cell strong{display:block;font-family:Unbounded,sans-serif;font-weight:700;font-size:15px;color:#000;margin-bottom:6px}
.dn-cov-cell span{display:block;color:#666;font-size:12px}
.dn-int-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.dn-int-cell{background:#fff;padding:20px;border-left:3px solid #e63329;font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.45;color:#333}
.dn-int-cell strong{display:block;color:#000;font-family:Unbounded,sans-serif;font-weight:700;font-size:15px;margin-bottom:6px}
.dn-int-cell span{display:block;color:#666;font-size:13px}
.dn-uc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.dn-uc-card{background:#fff;border:1px solid #ddd;padding:28px 24px}
.dn-uc-card h3{font-family:Unbounded,sans-serif;font-weight:700;font-size:17px;margin:0 0 12px;color:#000}
.dn-uc-card p{font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.55;color:#333;margin:0}
.dn-uc-card a{color:#e63329;text-decoration:underline}
.dn-faq{display:flex;flex-direction:column;gap:8px}
.dn-faq details{background:#fff;border:1px solid #ddd;padding:0}
.dn-faq summary{padding:18px 24px;cursor:pointer;font-family:Unbounded,sans-serif;font-weight:700;font-size:16px;color:#000;list-style:none;position:relative}
.dn-faq summary::after{content:"+";position:absolute;right:24px;top:18px;color:#e63329;font-size:24px;line-height:1}
.dn-faq details[open] summary::after{content:"−"}
.dn-faq summary::-webkit-details-marker{display:none}
.dn-faq details p{padding:0 24px 18px;margin:0;font-family:'DM Sans',sans-serif;font-size:15px;line-height:1.6;color:#333}
.dn-flow{list-style:none;padding:0;margin:0;counter-reset:flow}
.dn-flow li{padding:20px 0 20px 60px;border-bottom:1px solid #ddd;position:relative;font-family:'DM Sans',sans-serif;font-size:16px;line-height:1.55;color:#333;counter-increment:flow}
.dn-flow li:before{content:counter(flow);position:absolute;left:0;top:18px;width:40px;height:40px;background:#e63329;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Unbounded,sans-serif;font-weight:800;font-size:16px}
.dn-flow li strong{color:#000;font-weight:700}
.dn-sec a{color:#e63329}

@media (max-width:900px){
  .dn-vs{grid-template-columns:1fr}
  .dn-prob-grid,.dn-int-grid,.dn-uc-grid,.dn-cov-grid{grid-template-columns:1fr;gap:16px}
}
</style>
