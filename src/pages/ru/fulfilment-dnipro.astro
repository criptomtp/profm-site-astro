    <div class="dn-sb-grid">
      <div class="dn-sb-cell"><div class="dn-sb-num">3.2 млн</div><div class="dn-sb-lbl">ЖИТЕЛЕЙ ДНЕПРОПЕТРОВСКОЙ ОБЛАСТИ</div></div>
