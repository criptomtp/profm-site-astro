<script is:inline>
(function(){
  var slider = document.getElementById('promCalcSlider');
  if(!slider) return;
  var volEl = document.getElementById('promCalcVolume');
  var ownEl = document.getElementById('promCalcOwn');
  var mtpEl = document.getElementById('promCalcMtp');
  var pctEl = document.getElementById('promCalcPercent');
  var metaEl = document.getElementById('promCalcMtpMeta');

  function fmt(n){
    return '\u20B4' + Math.round(n).toLocaleString('ru-RU').replace(/,/g, '\u00A0');
  }
  function fmtVolume(n){
    return Number(n).toLocaleString('ru-RU').replace(/,/g, '\u00A0');
  }

  function tariff(volume){
    if (volume < 200) return 27;
    if (volume < 1500) return 22;
    return 18;
  }
  function ownCostPerOrder(volume){
    var fixed = 100000;
    var variable = 50;
    var cost = fixed / Math.max(volume, 1) + variable;
    return Math.max(cost, 80);
  }

  function recalc(){
    var v = parseInt(slider.value, 10) || 1200;
    var rate = tariff(v);
    var mtpCost = v * rate + 6000;
    var ownPerOrder = ownCostPerOrder(v);
    var ownCost = v * ownPerOrder;
    var saving = ownCost > 0 ? (1 - mtpCost / ownCost) * 100 : 0;

    volEl.textContent = fmtVolume(v);
    ownEl.textContent = fmt(ownCost);
    mtpEl.textContent = fmt(mtpCost);
    pctEl.textContent = Math.round(saving) + '%';
    metaEl.textContent = rate + ' \u0433\u0440\u043D \u00D7 ' + fmtVolume(v) + ' \u0437\u0430\u043A\u0430\u0437\u043E\u0432';
  }

  slider.addEventListener('input', recalc);
  recalc();
})();
</script>

