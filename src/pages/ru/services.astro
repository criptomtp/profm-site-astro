---
import Base from '../../layouts/Base.astro';
import AuthorByline from '../../components/AuthorByline.astro';
import HeroCTA from '../../components/HeroCTA.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service","dateModified":"2026-04-25",
  "name": "Украинский фулфилмент для брендов из СНГ — MTP Group",
  "description": "3PL-сервис для продавцов из Казахстана, Молдовы, Грузии, Армении, Узбекистана и Азербайджана, выходящих на рынок Украины. Таможенное оформление, УкрСЕПРО, склад под Киевом, Rozetka + Prom.ua + OLX + Epicentr, UAH/USD расчёты.",
  "provider": {
    "@type": "Organization",
    "name": "MTP Group Fulfillment",
    "url": "https://www.fulfillmentmtp.com.ua",
    "telephone": "+380501444645",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Счастливое, Бориспольский район",
      "addressRegion": "Киевская область",
      "addressCountry": "UA"
    }
  },
  "areaServed": [
    {"@type":"Country","name":"Kazakhstan"},
    {"@type":"Country","name":"Moldova"},
    {"@type":"Country","name":"Georgia"},
    {"@type":"Country","name":"Armenia"},
    {"@type":"Country","name":"Uzbekistan"},
    {"@type":"Country","name":"Azerbaijan"},
    {"@type":"Country","name":"Ukraine"}
  ],
  "serviceType": "Cross-border fulfillment",
  "offers": {"@type":"AggregateOffer","lowPrice":"18","highPrice":"650","priceCurrency":"UAH","offerCount":"4","offers":[{"@type":"Offer","name":"Базовый тариф (200+ отправлений/день)","price":"18","priceCurrency":"UAH"},{"@type":"Offer","name":"Хранение","price":"650","priceCurrency":"UAH"}]}
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Главная","item":"https://www.fulfillmentmtp.com.ua/"},
    {"@type":"ListItem","position":2,"name":"Услуги для брендов из СНГ","item":"https://www.fulfillmentmtp.com.ua/ru/services/"}
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"Как быстро бренд из Казахстана или Молдовы может начать отгружать заказы украинским покупателям через MTP?","acceptedAnswer":{"@type":"Answer","text":"Полный цикл онбординга — 21 рабочий день. Неделя 1 — договор, учётные документы, открытие аккаунтов Rozetka/Prom. Неделя 2 — таможенное оформление первой партии, приёмка на склад в Бориспольском районе. Неделя 3 — интеграция с вашей CRM, тестовые заказы, запуск продаж. Если часть документов у вас уже готова, сроки сокращаются."}},
    {"@type":"Question","name":"Нужно ли открывать юрлицо в Украине для работы с MTP?","acceptedAnswer":{"@type":"Answer","text":"Нет. Мы работаем с иностранными компаниями по контракту резидент-нерезидент. Для Rozetka и Prom.ua мы можем выступать как ваш агент по продажам через свою учётную запись, либо помочь с регистрацией ФОП для вашего представителя. Решение выбирается под вашу налоговую стратегию в домашней юрисдикции."}},
    {"@type":"Question","name":"Какие товарные категории требуют сертификации УкрСЕПРО или ДСТУ перед ввозом?","acceptedAnswer":{"@type":"Answer","text":"Электроника с питанием от 50В, детские игрушки для детей до 14 лет, косметика, биологически активные добавки, текстиль с электроподогревом, медицинские изделия и средства защиты. Одежда, сумки, аксессуары, большинство товаров для дома — ввозятся без УкрСЕПРО. Мы даём бесплатный предварительный аудит вашего ассортимента за 48 часов."}},
    {"@type":"Question","name":"В какой валюте я получаю расчёт за проданные товары?","acceptedAnswer":{"@type":"Answer","text":"По вашему выбору: USD, EUR или UAH. Стандартная схема — еженедельный swift в USD на корпоративный счёт в банке вашей страны. Для Казахстана и Молдовы доступен прямой SEPA-перевод в EUR. Удержанный НДФЛ/налог на репатриацию подтверждается справкой формы 11-ЕСВ (или аналогом) для зачёта в домашней юрисдикции."}},
    {"@type":"Question","name":"Что с возвратами — кто платит за обратную логистику из Украины в мою страну?",
      "acceptedAnswer":{"@type":"Answer","text":"Возвраты украинских покупателей обрабатываются локально на нашем складе: приёмка, проверка, фотофиксация, возврат на полку или списание — 3 грн за единицу. В вашу страну возвращается только агрегированный остаток раз в квартал либо по вашему запросу (мы формируем consolidated shipment). Это экономит до 70% на обратной таможне и транспорте."}},
    {"@type":"Question","name":"Можно ли одновременно продавать на Rozetka в Украине и на Kaspi в Казахстане с одного склада?",
      "acceptedAnswer":{"@type":"Answer","text":"Нет, физически с украинского склада Kaspi обслуживаться не может — доставка из Украины в Казахстан занимает 7–12 дней, что нарушает SLA Kaspi. Но мы помогаем синхронизировать остатки: ваш казахстанский склад продаёт на Kaspi, украинский склад MTP — на Rozetka и Prom.ua, а общая ERP видит единый остаток. Это называется cross-listing без cross-shipping."}},
    {"@type":"Question","name":"Есть ли минимальная партия для первого завоза?",
      "acceptedAnswer":{"@type":"Answer","text":"Экономически оправданный минимум — одна палета (примерно 0,8 м³ или до 600 кг). Меньшие партии тоже принимаем, но таможенное оформление для группажных грузов занимает на 3–5 дней дольше и стоит дороже в расчёте на единицу. Если вы тестируете рынок — рекомендуем стартовать с партии на 2–4 недели продаж."}},
    {"@type":"Question","name":"Как устроен контроль качества при приёмке товара из-за границы?",
      "acceptedAnswer":{"@type":"Answer","text":"Каждая партия проходит трёхступенчатую приёмку: сверка количества по инвойсу, проверка внешнего вида упаковки (повреждения при транспортировке), выборочная проверка функциональности (10% для электроники, 5% для остальных категорий). Любые несоответствия — фотоакт в течение 24 часов, который можно использовать для претензии к транспортной компании или страховщику."}},
    {"@type":"Question","name":"Предоставляете ли вы услугу маркетплейс-менеджмента — ведение аккаунта, ответы на вопросы, работа с отзывами?",
      "acceptedAnswer":{"@type":"Answer","text":"Базовый маркетплейс-менеджмент включён: загрузка карточек, синхронизация остатков, печать ТТН, обработка статусов. Расширенное ведение (ответы на вопросы покупателей, работа с отзывами, участие в акциях, seo-оптимизация карточек) — отдельная услуга, 8 000 грн/мес за одну площадку."}},
    {"@type":"Question","name":"Что будет с моим товаром при длительных отключениях электричества в Украине?",
      "acceptedAnswer":{"@type":"Answer","text":"Ничего. Оба склада укомплектованы тремя генераторами с запасом дизтоплива на 5 суток непрерывной работы, двумя оптоволоконными провайдерами и двумя терминалами Starlink. За 2022–2026 годы — 0 дней простоя. WMS работает локально, заказы отгружаются даже при полном blackout региона."}},
    {"@type":"Question","name":"Можно ли получать товары напрямую с AliExpress / 1688 / китайских фабрик на ваш склад, минуя мою страну?",
      "acceptedAnswer":{"@type":"Answer","text":"Да. Это называется drop-fulfillment. Вы выступаете импортёром (мы помогаем оформить контракт с фабрикой), груз идёт морем или железной дорогой через Гданьск/Констанцу на украинскую таможню, оттуда — к нам на склад. Выгодно для партий от 3 м³: себестоимость единицы снижается на 30–45% по сравнению с двойным завозом (Китай → ваша страна → Украина)."}}
  ]
};

const schemaJson = `<script type="application/ld+json">${JSON.stringify(serviceSchema)}</script><script type="application/ld+json">${JSON.stringify(breadcrumbSchema)}</script><script type="application/ld+json">${JSON.stringify(faqSchema)}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","priceRange":"\u20b418-\u20b426 / \u043e\u0442\u043f\u0440\u0430\u0432\u043a\u0430","geo":{"@type":"GeoCoordinates","latitude":"50.3408","longitude":"30.8595"},"address":[{"@type":"PostalAddress","streetAddress":"\u0443\u043b. \u041f\u0440\u043e\u043c\u044b\u0448\u043b\u0435\u043d\u043d\u0430\u044f","addressLocality":"\u0421\u0447\u0430\u0441\u0442\u043b\u0438\u0432\u043e\u0435, \u0411\u043e\u0440\u0438\u0441\u043f\u043e\u043b\u044c\u0441\u043a\u0438\u0439 \u0440\u0430\u0439\u043e\u043d","addressRegion":"\u041a\u0438\u0435\u0432\u0441\u043a\u0430\u044f \u043e\u0431\u043b\u0430\u0441\u0442\u044c","postalCode":"08322","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"\u0411\u0435\u043b\u043e\u0433\u043e\u0440\u043e\u0434\u043a\u0430","addressRegion":"\u041a\u0438\u0435\u0432\u0441\u043a\u0430\u044f \u043e\u0431\u043b\u0430\u0441\u0442\u044c","postalCode":"08140","addressCountry":"UA"}],"location":[{"@type":"Place","name":"MTP Fulfillment \u2014 \u0421\u0447\u0430\u0441\u0442\u043b\u0438\u0432\u043e\u0435","geo":{"@type":"GeoCoordinates","latitude":"50.3408","longitude":"30.8595"}},{"@type":"Place","name":"MTP Fulfillment \u2014 \u0411\u0435\u043b\u043e\u0433\u043e\u0440\u043e\u0434\u043a\u0430","geo":{"@type":"GeoCoordinates","latitude":"50.4138","longitude":"30.1928"}}],"openingHours":"Mo-Su 08:00-20:00","areaServed":[{"@type":"Country","name":"UA"},{"@type":"Country","name":"KZ"},{"@type":"Country","name":"MD"},{"@type":"Country","name":"GE"}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BusinessAudience","audienceType":"E-commerce \u0431\u0440\u0435\u043d\u0434\u044b \u0438\u0437 \u0421\u041d\u0413","name":"CIS e-commerce brands entering Ukraine","geographicArea":[{"@type":"Country","name":"KZ"},{"@type":"Country","name":"MD"},{"@type":"Country","name":"GE"},{"@type":"Country","name":"AM"},{"@type":"Country","name":"UZ"},{"@type":"Country","name":"AZ"}]}</script>`;
---
<Base
  title="Услуги фулфилмента — 17 операций под SLA от 18 грн / отправка"
  description="3PL-вход на рынок Украины для продавцов из Казахстана, Молдовы, Грузии, Армении. Таможня, УкрСЕПРО, Rozetka, Prom, расчёт в USD. Запуск за 21 день."
  canonical="https://www.fulfillmentmtp.com.ua/ru/services/"
  lang="ru"
  ogImage="https://www.fulfillmentmtp.com.ua/images/fulfillment-shipping-process.webp"
  ogType="website"
  schema={schemaJson}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/poslugy/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/services/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/services/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/poslugy/">
</Fragment>

<!-- BREADCRUMBS -->
<nav class="ru-srv-bc" aria-label="Хлебные крошки">
  <div class="ru-srv-bc__inner">
    <a href="/">Главная</a>
    <span aria-hidden="true">›</span>
    <span class="ru-srv-bc__current">Услуги для брендов из СНГ</span>
  </div>
</nav>

<!-- HERO (Industrial split) -->
<section class="ru-srv-hero">
  <div class="ru-srv-hero__inner">
    <div class="ru-srv-hero__left">
      <span class="ru-srv-chip">3PL · CIS ВХОД · УКРАИНА</span>
      <h1 class="ru-srv-hero__title">Украинский фулфилмент для <span class="ru-srv-accent">брендов СНГ</span> &mdash; 3,700 м², 0 дней простоя с 2022</h1>
      <p class="ru-srv-hero__lead">MTP Group проводит продавцов из Казахстана, Молдовы, Грузии, Армении, Узбекистана и Азербайджана через все этапы выхода на украинский рынок: таможенное оформление, УкрСЕПРО, склад под Киевом, подключение к Rozetka и Prom.ua, расчёты в USD или EUR. Полный запуск — 21 рабочий день.</p>
      <HeroCTA lang="ru" theme="dark" button="Получить расчёт →" microCopy="Бесплатный аудит документов · Ответ в течение 15 минут · Договор с иностранной компанией" sourceTag="hero /ru/services/ CIS" />
    </div>
    <div class="ru-srv-hero__right">
      <div class="ru-srv-hero__card">
        <div class="ru-srv-hero__cardLabel">ПОКРЫТИЕ СЕРВИСА</div>
        <ul class="ru-srv-hero__countries">
          <li><strong>KZ</strong> Казахстан</li>
          <li><strong>MD</strong> Молдова</li>
          <li><strong>GE</strong> Грузия</li>
          <li><strong>AM</strong> Армения</li>
          <li><strong>UZ</strong> Узбекистан</li>
          <li><strong>AZ</strong> Азербайджан</li>
        </ul>
        <div class="ru-srv-hero__cardFoot">Вход через украинскую таможню ·<br>склад 3 000 м² · UAH / USD / EUR расчёт</div>
      </div>
    </div>
  </div>
</section>
<AuthorByline lang="ru" />


<!-- STATS BAR (Industrial required) -->
<section class="ru-srv-stats">
  <div class="ru-srv-stats__inner">
    <div class="ru-srv-stat"><strong>21</strong><span>день до первой продажи</span></div>
    <div class="ru-srv-stat"><strong>6</strong><span>стран СНГ в сервисе</span></div>
    <div class="ru-srv-stat"><strong>60k</strong><span>отправлений в месяц</span></div>
    <div class="ru-srv-stat"><strong>99,7%</strong><span>точность комплектации</span></div>
  </div>
</section>

<!-- PAIN POINTS -->
<section class="ru-srv-pain">
  <div class="ru-srv-pain__inner">
    <span class="ru-srv-section__label">БАРЬЕРЫ ВХОДА НА РЫНОК</span>
    <h2 class="ru-srv-section__title">Шесть вещей, которые убивают запуск иностранного бренда в Украине</h2>
    <p class="ru-srv-section__sub">И как MTP Group снимает каждую — ещё до вашего первого заказа.</p>
    <div class="ru-srv-pain__grid">
      <article class="ru-srv-pain__item">
        <div class="ru-srv-pain__num">01</div>
        <h3>Таможня и ВЭД-документы</h3>
        <p>Инвойс, упаковочный лист, сертификат происхождения, договор купли-продажи в валюте контракта, регистрация в «Единой таможенной базе» Украины. Неполный пакет — груз простаивает на СВХ по 150–400 грн/палета в день.</p>
        <div class="ru-srv-pain__fix">Наш брокер готовит весь пакет документов и подаёт ЭДО за 24 часа.</div>
      </article>
      <article class="ru-srv-pain__item">
        <div class="ru-srv-pain__num">02</div>
        <h3>УкрСЕПРО для регулируемых товаров</h3>
        <p>Электроника, детские товары, косметика, БАДы, медизделия — без сертификата Rozetka и Prom.ua не пропускают карточку к публикации. Самостоятельная сертификация — от 3 до 8 недель и 600–2 400 USD за позицию.</p>
        <div class="ru-srv-pain__fix">Даём список аккредитованных лабораторий и ведём процесс параллельно с приёмкой.</div>
      </article>
      <article class="ru-srv-pain__item">
        <div class="ru-srv-pain__num">03</div>
        <h3>Аккаунты Rozetka и Prom.ua</h3>
        <p>Площадки проверяют регистрационные документы продавца, требуют украинский расчётный счёт или договор с агентом-резидентом. Иностранный ИП-сертификат не принимается как единственный документ. Ожидание верификации — 5–15 дней.</p>
        <div class="ru-srv-pain__fix">Подключаем ваш товар через свой верифицированный аккаунт-агент за 1–3 дня.</div>
      </article>
      <article class="ru-srv-pain__item">
        <div class="ru-srv-pain__num">04</div>
        <h3>Оплата в валюте домашней юрисдикции</h3>
        <p>Украинские маркетплейсы рассчитываются только в гривне. Конвертация через обменный пункт даёт 2–4% потерь. SWIFT-комиссии банка-отправителя и банка-получателя съедают ещё 0,5–1,2%.</p>
        <div class="ru-srv-pain__fix">Агрегируем выручку, делаем SWIFT-пакетом раз в неделю, курс — межбанковский НБУ.</div>
      </article>
      <article class="ru-srv-pain__item">
        <div class="ru-srv-pain__num">05</div>
        <h3>Язык клиентского сервиса</h3>
        <p>Украинский покупатель ожидает поддержки на украинском или русском языке и в украинских часовых поясах. Английский чат-бот и польский колл-центр конвертируются в 4–6% отказов от уже оформленных заказов.</p>
        <div class="ru-srv-pain__fix">Колл-центр MTP говорит на укр/рус, работает с 08:00 до 20:00 по Киеву, звонит каждому покупателю в день заказа.</div>
      </article>
      <article class="ru-srv-pain__item">
        <div class="ru-srv-pain__num">06</div>
        <h3>Возвраты и послепродажный сервис</h3>
        <p>По украинскому законодательству покупатель возвращает товар в течение 14 дней. Если у вас нет локального склада — каждый возврат нужно либо репатриировать (обратная таможня + 15–30 USD), либо утилизировать.</p>
        <div class="ru-srv-pain__fix">Обрабатываем возвраты на украинском складе: 3 грн/шт, фотоотчёт, возврат на полку или списание.</div>
      </article>
    </div>
  </div>
</section>

<!-- 21-DAY TIMELINE (WOW) -->
<section class="ru-srv-tl">
  <div class="ru-srv-tl__inner">
    <span class="ru-srv-section__label ru-srv-section__label--light">ОНБОРДИНГ · 21 РАБОЧИЙ ДЕНЬ</span>
    <h2 class="ru-srv-section__title ru-srv-section__title--light">От подписания контракта до первой продажи — за три недели</h2>
    <p class="ru-srv-section__sub ru-srv-section__sub--light">Каждый этап зафиксирован в договоре. Просрочка по вине MTP — бесплатный месяц хранения.</p>
    <ol class="ru-srv-tl__list">
      <li class="ru-srv-tl__step">
        <div class="ru-srv-tl__day">ДНИ 1–3</div>
        <div class="ru-srv-tl__phase">Юридический контур</div>
        <p>Подписание внешнеэкономического контракта между вашим юрлицом и MTP Group. Открытие валютного счёта-транзита (если нужен). Предоставление уставных документов, выписки из реестра, документов директора. Вы — у себя дома, мы — в Киеве.</p>
      </li>
      <li class="ru-srv-tl__step">
        <div class="ru-srv-tl__day">ДНИ 4–7</div>
        <div class="ru-srv-tl__phase">Товарный аудит и сертификация</div>
        <p>Присылаете перечень SKU с HS-кодами. За 48 часов возвращаем: какие товары требуют УкрСЕПРО, ДСТУ или декларации соответствия; какие лаборатории подходят; сколько это будет стоить; реальные сроки. Параллельно запускаем процесс.</p>
