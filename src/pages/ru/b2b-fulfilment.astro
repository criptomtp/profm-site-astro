      </div>
      <div class="b2b-flow-arrows">→</div>
      <div class="b2b-flow-dest">
        <div class="b2b-flow-flag b2b-flow-dest-flag"><span class="b2b-flow-icon">🇺🇦</span><span class="b2b-flow-name">УКРАИНА</span><span class="b2b-flow-cat">30+ розничных сетей</span></div>
      </div>
