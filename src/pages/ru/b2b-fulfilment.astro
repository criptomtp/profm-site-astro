<!-- HERO — Photo + dark overlay + CTA card (komplektatsiya pattern) -->
<section class="b2b-hero">
  <img class="b2b-hero-bg" src="/images/b2b-fulfilment-hero.jpg" alt="Киевский B2B-склад MTP Group — палетное хранение и комплектация для CIS-брендов выходящих на украинский рынок" width="1200" height="630" loading="eager" fetchpriority="high" data-md-skip>
  <div class="b2b-hero-overlay"></div>
  <div class="ctr">
    <div class="b2b-hero-grid">
      <div class="b2b-hero-left">
        <div class="b2b-chip">B2B · CIS → УКРАИНА · ОПТОВАЯ ДИСТРИБУЦИЯ</div>
        <h1>Из Казахстана, Молдовы, Грузии в украинскую B2B-розницу через наш киевский склад</h1>
        <p class="b2b-hero-sub">Бренды Казахстана, Молдовы, Грузии, Узбекистана, Азербайджана и Польши выходят в Сильпо, АТБ, Watsons, Eva, Modnakasta без открытия украинской юр.лица. Палетное хранение от $10/мес, расчёты в USD/EUR на CIS-счёт ежемесячно. Cross-border B2B через нашего украинского оператора.</p>
      </div>
      <div class="b2b-hero-right">
        <div class="b2b-form-card">
          <div class="b2b-form-title">Расчёт для вашего CIS-бренда</div>
          <HeroCTA lang="ru" theme="light" button="Получить расчёт →" microCopy="✓ Ответ за 15 минут · KZ/MD/GE/UZ/AZ/PL → UA сети" sourceTag="hero /ru/b2b-fulfilment/" />
        </div>
      </div>
    </div>
    <div class="b2b-hero-stats">
      <div class="b2b-stat"><div class="b2b-stat-num">$10</div><div class="b2b-stat-lbl">ПАЛЕТНОЕ ХРАНЕНИЕ / МЕС</div></div>
      <div class="b2b-stat"><div class="b2b-stat-num">24 ч</div><div class="b2b-stat-lbl">SLA ОТГРУЗКИ</div></div>
      <div class="b2b-stat"><div class="b2b-stat-num">30+</div><div class="b2b-stat-lbl">UA РОЗНИЧНЫХ СЕТЕЙ</div></div>
      <div class="b2b-stat"><div class="b2b-stat-num">21-30 дней</div><div class="b2b-stat-lbl">ОНБОРДИНГ</div></div>
    </div>
  </div>
</section>

<!-- FLAG FLOW DIAGRAM — moved below hero as visual hook -->
<section class="b2b-flow-section">
  <div class="ctr">
    <div class="b2b-chip b2b-chip-dark">КАК РАБОТАЕТ ПОТОК</div>
    <h2 class="b2b-h2">Откуда CIS-бренды заходят в украинскую розницу через наш киевский хаб</h2>
    <div class="b2b-flow-diagram">
      <div class="b2b-flow-sources">
        <div class="b2b-flow-flag"><span class="b2b-flow-icon">🇰🇿</span><span class="b2b-flow-name">КАЗАХСТАН</span><span class="b2b-flow-cat">косметика, food, fashion</span></div>
        <div class="b2b-flow-flag"><span class="b2b-flow-icon">🇲🇩</span><span class="b2b-flow-name">МОЛДОВА</span><span class="b2b-flow-cat">вино, агро, beauty</span></div>
        <div class="b2b-flow-flag"><span class="b2b-flow-icon">🇬🇪</span><span class="b2b-flow-name">ГРУЗИЯ</span><span class="b2b-flow-cat">вино, fashion, food</span></div>
        <div class="b2b-flow-flag"><span class="b2b-flow-icon">🇺🇿</span><span class="b2b-flow-name">УЗБЕКИСТАН</span><span class="b2b-flow-cat">текстиль, сухофрукты</span></div>
        <div class="b2b-flow-flag"><span class="b2b-flow-icon">🇦🇿</span><span class="b2b-flow-name">АЗЕРБАЙДЖАН</span><span class="b2b-flow-cat">food, beauty</span></div>
        <div class="b2b-flow-flag"><span class="b2b-flow-icon">🇵🇱</span><span class="b2b-flow-name">ПОЛЬША</span><span class="b2b-flow-cat">beauty, fashion, FMCG</span></div>
