import Base from '../../layouts/Base.astro';
import HeroCTA from '../../components/HeroCTA.astro';

const schemaJson = `<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","dateModified":"2026-05-11","name":"B2B фулфилмент в Украине для CIS-брендов","description":"Бренды Казахстана, Молдовы, Грузии, Узбекистана, Азербайджана, Польши и Латвии выходят на украинский B2B-рынок через наш киевский склад. Поставка напрямую в украинскую розницу (Сильпо, АТБ, Watsons, Eva, Метро, Modnakasta, INTERTOP) от имени вашего CIS-юр.лица. Палетное хранение от $10/палет/мес, multi-SKU комплектация, 1С интеграция, ЕДО Вчасно/Edin, SLA 24 часа. Без украинского юр.лица, без CAPEX, без локального персонала.","provider":{"@type":"Organization","name":"MTP Group Fulfillment","legalName":"ООО \\"МТП Груп Фулфилмент\\"","taxID":"45315740","foundingDate":"2023-10-02","url":"https://www.fulfillmentmtp.com.ua","telephone":"+380501444645"},"areaServed":[{"@type":"Country","name":"UA"},{"@type":"Country","name":"KZ"},{"@type":"Country","name":"MD"},{"@type":"Country","name":"GE"},{"@type":"Country","name":"UZ"},{"@type":"Country","name":"AZ"},{"@type":"Country","name":"PL"},{"@type":"Country","name":"LV"}],"serviceType":"B2B Fulfillment Ukraine for CIS brands — wholesale entry to Ukrainian retail networks via Kyiv hub","audience":{"@type":"BusinessAudience","name":"Бренды из Казахстана (косметика, food, fashion), Молдовы (вино, агро, beauty), Грузии (вино, fashion), Узбекистана (текстиль, сухофрукты), Азербайджана (food, beauty), Польши (beauty, fashion, FMCG), Латвии (niche) — выходящие на украинский B2B-рынок без локальной юр.лица"},"offers":{"@type":"Offer","priceCurrency":"USD","price":"10","description":"Палетное хранение от $10/палет/мес (500 грн). Multi-SKU комплектация от $0.41 за заказ. 1С интеграция, ЕДО, накладные — включено. Минимальный месячный платёж $500 первые 3 месяца."}}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Может ли бренд из Казахстана поставлять напрямую в украинскую розницу без юр.лица в Украине?","acceptedAnswer":{"@type":"Answer","text":"Да. Cross-border B2B-модель через нашего украинского операционного партнёра. Бренд из Казахстана отправляет товар на наш киевский склад через стандартного логистического оператора, мы оформляем украинскую импортную декларацию, акцизные/качественные сертификаты при необходимости. Дальше товар продаётся в украинскую розницу (Сильпо, АТБ, Watsons, Eva) от имени нашего оператора по агентскому договору с вашим казахстанским юр.лицом. ЭДО Вчасно/Edin/Comarch — мы у вас в кабинете. Расчёты в USD/EUR на казахстанский счёт ежемесячно."}},{"@type":"Question","name":"Зачем CIS-бренду украинский B2B-рынок а не Россия?","acceptedAnswer":{"@type":"Answer","text":"Украина — 36 млн человек, четвёртая по размеру e-commerce и FMCG-розница в Восточной Европе. Российский рынок недоступен из-за санкций, морального давления, сложностей с расчётами. Украинская розница активно ищет альтернативы российским и белорусским поставщикам — после 2022 многие категории остались без поставщиков. CIS-бренды (Казахстан косметика, Молдова вино, Грузия fashion, Узбекистан текстиль, Азербайджан food) занимают эти ниши с минимальной конкуренцией. Маржа в украинской рознице 30-50% выше чем в локальном рынке CIS-бренда."}},{"@type":"Question","name":"Какие украинские розничные сети мы обслуживаем для CIS-брендов?","acceptedAnswer":{"@type":"Answer","text":"30+ крупнейших украинских сетей с готовыми SLA-протоколами: Сильпо (food, Comarch EDI), АТБ (food, жёсткие сроки), Watsons (beauty, фарма-сертификаты), Eva (beauty), Prostor (косметика+быт), Cosmo (премиум beauty), Brocard (селективная парфюмерия), Метро (B2B-канал, SAP Ariba), Novus (food+premium), Modnakasta (fashion), INTERTOP (обувь), Allo (электроника), Foxtrot (техника), Эпицентр (DIY). Для CIS-бренда регистрация поставщика на этих сетях идёт через нашего оператора с пакетом документов."}},{"@type":"Question","name":"Сколько стоит вся модель для бренда из Молдовы?","acceptedAnswer":{"@type":"Answer","text":"Палетное хранение $10/палет/мес ($1.50 за м³) + комплектация $0.41 за собранный B2B-заказ + украинская доставка через НП Грузовое отделение $80-150 за палет (платит клиент-сеть). Cross-border транспортировка из Молдовы в Украину — $50-80 за палет через Meest International (5-7 дней transit). Юр./бух. услуги по cross-border схеме (украинская таможня, ЭДО, расчёты, КЕП) — $200-400/мес паушально через нашего партнёра. Минимальный месячный платёж $500 первые 3 месяца, потом покрывается объёмом."}},{"@type":"Question","name":"Как организован cross-border поток для грузинского fashion-бренда?","acceptedAnswer":{"@type":"Answer","text":"Тбилисский бренд отправляет сезонную коллекцию на наш киевский склад. Транспортировка GE→UA: контейнер 20ft через DHL/Meest 8-14 дней transit или Black Sea sea freight через Одессу 12-20 дней (дешевле). На границе Украины — украинская импортная декларация, сертификаты соответствия для одежды, маркировка УКТ ЗЕД. На нашем складе принимаем, проверяем комплектность по инвойсу, размещаем в стеллажах для одежды (плечики или коробки). Сеть Modnakasta/Argo/INTERTOP делает заказ через свой портал — мы собираем box-pick розфасован за магазинами сети, ЭДО Вчасно, отправка НП Грузовое или собственный транспорт MTP. Грузинский бренд получает выручку в EUR на тбилисский счёт каждый месяц."}},{"@type":"Question","name":"Какой украинский ЭДО используется для CIS-брендов?","acceptedAnswer":{"@type":"Answer","text":"ЭДО Вчасно — самый популярный в UA, поддерживается всеми крупными сетями. Edin — популярен в фарма-сегменте (для нутрицевтиков, БАДов из CIS). Medoc — универсальный. Для специфичных сетей: АТБ — Comarch EDI, Метро — SAP Ariba. Мы работаем в вашем Вчасно-кабинете как операционный партнёр. Накладная, рахунок-фактура, акт приёмки-передачи генерируются в нашем WMS автоматически, подписываются КЕП (электронной квалифицированной подписью) через нашего ЭДО-провайдера. CIS-бренду не нужен украинский КЕП — у нашего оператора уже есть."}},{"@type":"Question","name":"Что с украинским НДС 20% на импорт из CIS?","acceptedAnswer":{"@type":"Answer","text":"При импорте товара на украинский склад уплачивается 20% НДС от таможенной стоимости. CIS-бренд платит этот НДС (мы помогаем оформить через таможенного партнёра). При продаже украинской рознице НДС включён в цену продажи — сеть не доплачивает отдельно, для неё это входной НДС. Для бренда CIS это операционный кеш-флоу момент: НДС уплачен при импорте, возвращается через продажи в течение 1-3 месяцев. Для стран в EAEU (Казахстан, Беларусь, Армения, Кыргызстан) — облегчённый таможенный режим по форме CT-1. Для Молдовы, Грузии — через DCFTA с Украиной (зона свободной торговли) с пониженными или отменёнными ввозными пошлинами для отдельных категорий."}},{"@type":"Question","name":"Как быстро бренд из Узбекистана может начать поставки в украинскую розницу?","acceptedAnswer":{"@type":"Answer","text":"21-30 рабочих дней от подписания договора до первой поставки в сеть. Цикл: дни 1-3 договор с нашим украинским оператором, дни 3-7 подготовка пакета документов CIS-стороны (устав, банковские реквизиты, инвойс, сертификат происхождения, УКТ ЗЕД-классификация), дни 7-14 cross-border транспортировка из Узбекистана (~10-14 дней transit), дни 14-16 приёмка и адресное хранение в WMS, дни 16-21 регистрация поставщика в украинской сети (Modnakasta, Сильпо) с пакетом документов, дни 21-25 настройка ЭДО-протоколов, дни 25-30 первая тестовая поставка end-to-end. Для крупных партий или специфичных сертификатов (food, фарма) — до 45 дней."}},{"@type":"Question","name":"Можем ли работать с молдавским винодельческим брендом для поставки в Сильпо/Novus?","acceptedAnswer":{"@type":"Answer","text":"Да, это один из ключевых сценариев. Молдавское вино — растущий сегмент украинской HoReCa и розницы. Сложность — алкоголь требует лицензии на хранение и продажу, акцизных марок, специфической температурной зоны. У нас есть отдельная лицензированная зона для алкоголя в Белогородке. Cross-border поставка MD→UA через Meest International — 5-7 дней transit, отдельный таможенный режим для алкоголя с акцизом. На складе оклейка акцизными марками, хранение при контролируемой температуре. Поставка в Сильпо/Novus/Wine.ua/специализированные wine-магазины через нашего операционного партнёра с лицензией на торговлю алкоголем."}}]}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://www.fulfillmentmtp.com.ua/ru/"},{"@type":"ListItem","position":2,"name":"Услуги","item":"https://www.fulfillmentmtp.com.ua/ru/services/"},{"@type":"ListItem","position":3,"name":"B2B фулфилмент для CIS-брендов","item":"https://www.fulfillmentmtp.com.ua/ru/b2b-fulfilment/"}]}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment — Kyiv hub for CIS brands","url":"https://www.fulfillmentmtp.com.ua/ru/b2b-fulfilment/","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","priceRange":"$10/палет/мес + $0.41/заказ","geo":{"@type":"GeoCoordinates","latitude":"50.3408","longitude":"30.8595"},"address":[{"@type":"PostalAddress","streetAddress":"ул. Промышленная","addressLocality":"Счастливое, Бориспольский район","addressRegion":"Киевская область","postalCode":"08322","addressCountry":"UA","description":"Склад 2 700 м² — основная локация B2B"},{"@type":"PostalAddress","addressLocality":"Белогородка","addressRegion":"Киевская область","postalCode":"08140","addressCountry":"UA","description":"Склад 1 000 м² — алкоголь, FEFO-зона"}],"openingHours":"Mo-Su 08:00-20:00","areaServed":[{"@type":"Country","name":"UA"},{"@type":"Country","name":"KZ"},{"@type":"Country","name":"MD"},{"@type":"Country","name":"GE"},{"@type":"Country","name":"UZ"},{"@type":"Country","name":"AZ"},{"@type":"Country","name":"PL"}]}</script>`;
---
<Base
