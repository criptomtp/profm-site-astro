---
import Base from '../../layouts/Base.astro';
import HeroCTA from '../../components/HeroCTA.astro';

const today = '2026-05-13';
const validThrough = '2026-07-13';

const orgSchema = {
  "@type": "Organization",
  "name": "MTP Group Fulfillment",
  "sameAs": "https://www.fulfillmentmtp.com.ua",
  "logo": "https://www.fulfillmentmtp.com.ua/images/logo.svg"
};

const locShchaslyve = {
  "@type": "Place",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Счастливое",
    "addressRegion": "Киевская область",
    "addressCountry": "UA",
    "postalCode": "08322"
  }
};

const jobs = [
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Кладовщик склада",
    "description": "Работа на современном фулфилмент-складе в Счастливом (Бориспольский район). Приёмка, размещение товара, инвентаризация через WMS. Зарплата от 30 000 ₴ + бонусы за выработку.",
    "datePosted": today, "validThrough": validThrough, "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema, "jobLocation": locShchaslyve,
    "baseSalary": {"@type":"MonetaryAmount","currency":"UAH","value":{"@type":"QuantitativeValue","value":30000,"unitText":"MONTH","minValue":30000}}
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Комплектовщик заказов",
    "description": "Сборка заказов для интернет-магазинов и B2B-клиентов по маршруту WMS. Сканирование штрих-кодов, упаковка, контроль качества. Зарплата от 30 000 ₴ + бонусы за количество.",
    "datePosted": today, "validThrough": validThrough, "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema, "jobLocation": locShchaslyve,
    "baseSalary": {"@type":"MonetaryAmount","currency":"UAH","value":{"@type":"QuantitativeValue","value":30000,"unitText":"MONTH","minValue":30000}}
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Приёмщик товара",
    "description": "Приёмка входящих поставок от клиентов, проверка комплектности по инвойсу, фотофиксация состояния, оприходование в WMS. Зарплата от 30 000 ₴ + бонусы за объём.",
    "datePosted": today, "validThrough": validThrough, "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema, "jobLocation": locShchaslyve,
    "baseSalary": {"@type":"MonetaryAmount","currency":"UAH","value":{"@type":"QuantitativeValue","value":30000,"unitText":"MONTH","minValue":30000}}
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Водитель погрузчика",
    "description": "Управление электропогрузчиком на складе. Перемещение паллет до 2 тонн, погрузка-разгрузка транспорта, штабелирование. Требуется удостоверение категории II. Зарплата от 30 000 ₴.",
    "datePosted": today, "validThrough": validThrough, "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema, "jobLocation": locShchaslyve,
    "baseSalary": {"@type":"MonetaryAmount","currency":"UAH","value":{"@type":"QuantitativeValue","value":30000,"unitText":"MONTH","minValue":30000}}
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Главная", "item": "https://www.fulfillmentmtp.com.ua/ru/" },
    { "@type": "ListItem", "position": 2, "name": "Вакансии", "item": "https://www.fulfillmentmtp.com.ua/ru/vakansii/" }
  ]
};

const schemaJson = jobs.map(j => `<script type="application/ld+json">${JSON.stringify(j)}</script>`).join('') +
  `<script type="application/ld+json">${JSON.stringify(breadcrumbSchema)}</script>`;
---
<Base
  title="Вакансии MTP Group — работа на складе в Счастливом, от 30 000 ₴"
  description="Ищем кладовщика, комплектовщика, приёмщика, водителя погрузчика. Склад в Счастливом (Бориспольский район). Зарплата от 30 000 ₴ + бонусы за выработку. Релокация из east-Ukraine — помогаем."
  canonical="https://www.fulfillmentmtp.com.ua/ru/vakansii/"
  lang="ru"
  ogImage="https://www.fulfillmentmtp.com.ua/images/vakansiyi-hero.jpg"
  schema={schemaJson}
  showCTA={true}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/vakansiyi/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/vakansii/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/careers/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/vakansiyi/">
</Fragment>

<section class="vk-hero">
  <img class="vk-hero-bg" src="/images/vakansiyi-hero.jpg" alt="Команда фулфилмент-склада MTP Group в Счастливом — комплектовщики, водители погрузчика, приёмщики товара за работой" width="1200" height="630" loading="eager" fetchpriority="high" data-md-skip>
  <div class="vk-hero-overlay"></div>
  <div class="ctr">
    <div class="vk-hero-grid">
      <div class="vk-hero-left">
        <div class="vk-chip">MTP GROUP · ВАКАНСИИ · СЧАСТЛИВОЕ + БЕЛОГОРОДКА</div>
        <h1>Работа на складе MTP Group — от 30 000 ₴ + бонусы за выработку</h1>
        <p class="vk-hero-sub">Ищем 4 позиции на основной склад в Счастливом (Бориспольский район) и дополнительный в Белогородке. Стабильный график 5/2 или 2/2, обучение за счёт компании, помощь с релокацией для переселенцев с востока.</p>
      </div>
      <div class="vk-hero-right">
        <div class="vk-form-card">
          <div class="vk-form-title">Подать заявку на вакансию</div>
          <HeroCTA lang="ru" theme="light" button="Оставить заявку →" microCopy="✓ Перезвоним за 1-2 часа в рабочее время · укажите позицию после звонка" sourceTag="hero /ru/vakansii/" />
        </div>
      </div>
    </div>
    <div class="vk-hero-stats">
      <div class="vk-stat"><div class="vk-stat-num">от 30 000 ₴</div><div class="vk-stat-lbl">МИНИМАЛЬНАЯ З/П</div></div>
      <div class="vk-stat"><div class="vk-stat-num">5/2 · 2/2</div><div class="vk-stat-lbl">ГРАФИКИ НА ВЫБОР</div></div>
      <div class="vk-stat"><div class="vk-stat-num">3 700 м²</div><div class="vk-stat-lbl">2 СКЛАДА</div></div>
      <div class="vk-stat"><div class="vk-stat-num">0 дней</div><div class="vk-stat-lbl">ПРОСТОЯ С 2022</div></div>
    </div>
  </div>
</section>

<section class="vk-sec">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">ПОЧЕМУ MTP</div>
    <h2 class="vk-h2">6 причин выбрать MTP — особенно для переселенцев</h2>
    <div class="vk-why-grid">
      <div class="vk-why-card">
        <h3>Стабильная зарплата + бонусы</h3>
        <p>От 30 000 ₴ с первого месяца. Бонусы за выработку — реальные топ-работники зарабатывают 40-50 К. Оплата 2 раза в месяц без задержек. Бонус за рекомендацию друга — 3 000 ₴ если он отработал месяц.</p>
      </div>
      <div class="vk-why-card">
        <h3>Помощь с релокацией</h3>
        <p>Для переселенцев из east-Ukraine помогаем найти жильё рядом со складом. Первый месяц — 50% покрытия арендной платы. Документы по переселению можем содействовать оформить через HR.</p>
      </div>
      <div class="vk-why-card">
        <h3>0 дней простоя с 2022</h3>
        <p>3 дизельных генератора + Starlink — работаем в любой blackout. Оба склада за 35-45 км от центра Киева, вне зон ракетных угроз. Зарплата гарантирована независимо от обстрелов и отключений.</p>
      </div>
      <div class="vk-why-card">
        <h3>Современный склад</h3>
        <p>WMS-система, RF-терминалы, сканеры. Не советский склад, а современная логистика европейского уровня. Меньше ручной рутины, больше технологий.</p>
      </div>
      <div class="vk-why-card">
        <h3>Обучение за наш счёт</h3>
        <p>Первая неделя — оплачиваемое обучение работе с WMS. Без удостоверения погрузчика? Оплачиваем курсы и допускаем к работе после сертификации.</p>
      </div>
      <div class="vk-why-card">
        <h3>Возможность роста</h3>
        <p>Через 6-12 месяцев — старший смены (+5-10 К к ЗП). Через 1.5-2 года — заместитель руководителя склада. Многие наши руководители начали с линейных позиций.</p>
      </div>
    </div>
  </div>
</section>

<section class="vk-sec vk-sec-light" id="vakansii">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">ПОЗИЦИИ</div>
    <h2 class="vk-h2">4 вакансии, которые сейчас открыты</h2>

    <article class="vk-job">
      <header class="vk-job-head">
        <div><h3 id="kladovshik">Кладовщик склада</h3><div class="vk-job-meta">Счастливое · Белогородка · 5/2 или 2/2 · полная занятость</div></div>
        <div class="vk-job-salary">от 30 000 ₴</div>
      </header>
      <div class="vk-job-body">
        <p>Сердце операций MTP. Без точного складского учёта не работает ничего — ваша работа держит всю систему в тонусе.</p>
        <div class="vk-job-cols">
          <div><h4>Обязанности</h4><ul><li>Приёмка товара от клиентов и поставщиков</li><li>Размещение в стеллажах по маршруту WMS</li><li>Ведение учёта через сканер штрих-кодов и RF-терминал</li><li>Циклическая инвентаризация 1-2 раза в неделю</li><li>Поддержание чистоты и порядка</li></ul></div>
          <div><h4>Требования</h4><ul><li>Внимательность к деталям (это критично — у нас 99,98% точность)</li><li>Базовые навыки ПК (WMS обучим)</li><li>Готовность к физической работе, ношение до 15 кг</li><li>Ответственность — договор материальной ответственности</li><li>Опыт склад/логистика — плюс, но не обязателен</li></ul></div>
          <div><h4>Предлагаем</h4><ul><li>От 30 000 ₴ + бонус за выработку</li><li>Гарантированная оплата 2 раза в месяц</li><li>Бесплатные обеды на складе</li><li>Транспорт от метро (для Счастливого)</li><li>Оплачиваемое обучение первая неделя</li></ul></div>
        </div>
      </div>
    </article>

    <article class="vk-job">
      <header class="vk-job-head">
        <div><h3 id="komplektovshik">Комплектовщик заказов</h3><div class="vk-job-meta">Счастливое · 5/2 · полная занятость · бонус за скорость</div></div>
        <div class="vk-job-salary">от 30 000 ₴</div>
      </header>
      <div class="vk-job-body">
        <p>Собираете заказы для интернет-магазинов и дистрибьюторов. Чем быстрее и точнее — тем больше бонус. Наш топ-сборщик зарабатывает 45+ К в месяц.</p>
        <div class="vk-job-cols">
          <div><h4>Обязанности</h4><ul><li>Сборка заказов по листам WMS</li><li>Сканирование штрих-кодов на 2 этапах</li><li>Контроль качества перед опломбированием</li><li>Упаковка с защитой от повреждений</li><li>Передача готовых заказов на отгрузку</li></ul></div>
          <div><h4>Требования</h4><ul><li>Скорость + внимательность — два параллельных навыка</li><li>Базовая работа со сканером и ПК</li><li>Физическая выносливость — много pick-маршрутов за смену</li><li>Ориентация на результат — оплата за выработку</li><li>Опыт комплектации — большое преимущество</li></ul></div>
          <div><h4>Предлагаем</h4><ul><li>От 30 000 ₴ + бонус за каждый заказ свыше плана</li><li>Топ-сборщики зарабатывают 40-50 К</li><li>Бесплатные обеды + кофе</li><li>График 5/2, подработка в пик</li><li>Возможность стать тренером новых (+5 000 ₴)</li></ul></div>
        </div>
      </div>
    </article>

    <article class="vk-job">
      <header class="vk-job-head">
        <div><h3 id="priyomshik">Приёмщик товара</h3><div class="vk-job-meta">Счастливое · 5/2 · полная занятость · контроль качества</div></div>
        <div class="vk-job-salary">от 30 000 ₴</div>
      </header>
      <div class="vk-job-body">
        <p>Первая линия контроля — что вы пропустите, дойдёт до клиентских заказов с ошибкой. Поэтому позиция для внимательных и ответственных людей.</p>
        <div class="vk-job-cols">
          <div><h4>Обязанности</h4><ul><li>Приёмка входящих поставок от клиентов</li><li>Проверка комплектности по инвойсу/накладной</li><li>Фотофиксация состояния товара и упаковки</li><li>Оприходование в WMS с привязкой к партии</li><li>Составление акта расхождений если нужно</li></ul></div>
          <div><h4>Требования</h4><ul><li>Высокая внимательность — критично</li><li>Базовые навыки ПК и сканера</li><li>Работа с документами (накладные, инвойсы)</li><li>Ответственность — договор матответственности</li><li>Спокойствие в конфликтных ситуациях с клиентами</li></ul></div>
          <div><h4>Предлагаем</h4><ul><li>От 30 000 ₴ + бонус за объём приёмки</li><li>Гарантированная оплата 2 раза в месяц</li><li>Бесплатные обеды</li><li>Работа за тёплым компьютером (не на ногах целый день)</li><li>Рост до старшего приёмщика (+8 000 ₴)</li></ul></div>
        </div>
      </div>
    </article>

    <article class="vk-job">
      <header class="vk-job-head">
        <div><h3 id="voditel-pogruzchika">Водитель погрузчика</h3><div class="vk-job-meta">Счастливое · 5/2 или 2/2 · полная занятость · нужно удостоверение</div></div>
        <div class="vk-job-salary">от 30 000 ₴</div>
      </header>
      <div class="vk-job-body">
        <p>Управляете электропогрузчиком на складе. Без вас паллеты сами не ездят, фуры не разгружаются, стеллажи не наполняются.</p>
        <div class="vk-job-cols">
          <div><h4>Обязанности</h4><ul><li>Управление электропогрузчиком</li><li>Перемещение паллет до 2 тонн между зонами</li><li>Погрузка-разгрузка транспорта</li><li>Штабелирование в стеллажах до 6 метров</li><li>Базовое обслуживание погрузчика</li></ul></div>
          <div><h4>Требования</h4><ul><li>Удостоверение на погрузчик категории II (обязательно!)</li><li>Опыт работы от 1 года</li><li>Внимательность — у нас ценный товар в стеллажах</li><li>Готовность к 12-часовым сменам если график 2/2</li><li>Без удостоверения? Оплачиваем курсы после испытательного</li></ul></div>
          <div><h4>Предлагаем</h4><ul><li>От 30 000 ₴ + бонус за объём смены</li><li>Гарантированная оплата 2 раза в месяц</li><li>Бесплатные обеды</li><li>График 5/2 или 2/2 — выбираете</li><li>Регулярное ТО погрузчиков</li></ul></div>
        </div>
      </div>
    </article>
  </div>
</section>

<section class="vk-sec">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">КАК ПОДАТЬ ЗАЯВКУ</div>
    <h2 class="vk-h2">3 простых шага до собеседования</h2>
    <ol class="vk-flow">
      <li><strong>1. Оставляете заявку.</strong> Заполняете форму вверху страницы — нужен только телефон. В комментарии укажите желаемую позицию.</li>
      <li><strong>2. Перезваниваем за 1-2 часа в рабочее время.</strong> HR задаёт несколько вопросов, отвечает на ваши, согласовываем удобное время собеседования.</li>
      <li><strong>3. Собеседование + тест-смена.</strong> Встреча на складе (Счастливое или Белогородка). Показываем склад. Если всё хорошо — на следующий день оплачиваемая тест-смена.</li>
    </ol>
  </div>
</section>

<section class="vk-sec vk-sec-light">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">ВОПРОСЫ И ОТВЕТЫ</div>
    <h2 class="vk-h2">Что обычно спрашивают кандидаты</h2>
    <div class="vk-faq">
      <details><summary>Как считается бонус за выработку?</summary><p>Для каждой позиции есть план продуктивности. Всё свыше плана — бонус 5-30 ₴ за единицу в зависимости от позиции. У месяц топ-работники добавляют 10-15 К к базовой. Детали обсуждаем на собеседовании.</p></details>
      <details><summary>Есть ли официальное трудоустройство?</summary><p>Да — по вашему желанию. Можем работать через ФОП-договор. Или оформить в трудовую через ТОВ. Дискриминации нет, но официальное даёт соцпакет.</p></details>
      <details><summary>Помощь с релокацией для переселенцев?</summary><p>Помогаем найти жильё рядом со складом — в Счастливом, Борисполе, Киеве-Левобережном. Первый месяц — 50% покрытия аренды компанией для переселенцев. Содействуем оформлению документов переселенца.</p></details>
      <details><summary>Как добраться до склада в Счастливом?</summary><p>Из Киева — маршрутка от м. "Бориспольская" или электричка до ст. "Счастливое". 40-60 мин из центра. Корпоративный автобус от метро (утро + вечер). До Белогородки — маршрутка с м. "Академгородок" или личным транспортом по Житомирской трассе.</p></details>
      <details><summary>Что с обедами?</summary><p>Бесплатные обеды на складе — наша кухня готовит. Кофе, чай, вода — неограниченно. Холодильник для своих обедов. Комната отдыха с микроволновкой.</p></details>
      <details><summary>Безопасность в военное время?</summary><p>Оба склада за 35-45 км от центра Киева — вне основных зон ракетных угроз. 3 дизельных генератора, Starlink, fire suppression, усиленный периметр. 0 дней простоя с февраля 2022. Зарплата гарантирована независимо от ситуации.</p></details>
      <details><summary>Если испытательный не пройду?</summary><p>Испытательный 14 дней. Оплачиваем полностью (не как ученика). Если не подходим — расходимся без претензий. Честно говорим на день 7.</p></details>
    </div>
  </div>
</section>

</Base>

<style is:global>
.vk-hero{position:relative;color:#fff;padding:64px 0 48px;overflow:hidden;background:#0a0a0a;border-bottom:6px solid #e63329}
.vk-hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;z-index:0}
.vk-hero-overlay{position:absolute;inset:0;background:linear-gradient(90deg,rgba(10,10,10,.95) 0%,rgba(10,10,10,.78) 50%,rgba(230,51,41,.45) 100%);z-index:1}
.vk-hero .ctr{position:relative;z-index:2;max-width:1280px}
.vk-hero-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:48px;align-items:center;margin-bottom:36px}
.vk-hero-left{min-width:0}
.vk-chip{display:inline-block;background:#e63329;color:#fff;font-family:'DM Sans',sans-serif;font-weight:700;font-size:11px;letter-spacing:.18em;padding:8px 14px;text-transform:uppercase;margin-bottom:20px}
.vk-chip-dark{background:#000}
.vk-hero h1{font-family:Unbounded,sans-serif;font-weight:900;font-size:clamp(26px,3.4vw,46px);line-height:1.06;letter-spacing:-0.025em;margin:0 0 20px;color:#fff}
.vk-hero-sub{font-family:'DM Sans',sans-serif;font-size:17px;line-height:1.55;color:rgba(255,255,255,.92);max-width:680px;margin:0}
.vk-form-card{background:#fff;color:#000;padding:24px;border:3px solid #e63329;box-shadow:8px 8px 0 rgba(0,0,0,.4)}
.vk-form-title{font-family:Unbounded,sans-serif;font-weight:800;font-size:18px;margin-bottom:16px;color:#000;text-transform:uppercase;letter-spacing:.02em;line-height:1.2}
.vk-hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:0;background:rgba(0,0,0,.85);border:2px solid #000}
.vk-stat{padding:18px 16px;border-right:1px solid rgba(255,255,255,.12);text-align:center}
.vk-stat:last-child{border-right:0}
.vk-stat-num{font-family:Unbounded,sans-serif;font-weight:900;font-size:clamp(16px,1.6vw,22px);color:#fff;letter-spacing:-0.02em;line-height:1.1}
.vk-stat-lbl{font-family:'DM Sans',sans-serif;font-weight:700;font-size:10px;letter-spacing:.14em;color:rgba(255,255,255,.7);margin-top:6px;text-transform:uppercase}
.vk-sec{padding:80px 0;background:#fff}
.vk-sec-light{background:#f3f3f3}
.vk-h2{font-family:Unbounded,sans-serif;font-weight:800;font-size:clamp(24px,3vw,38px);line-height:1.15;letter-spacing:-0.02em;margin:16px 0 32px;color:#000}
.vk-why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.vk-why-card{background:#fff;border:1px solid #ddd;border-left:4px solid #e63329;padding:28px 24px}
.vk-why-card h3{font-family:Unbounded,sans-serif;font-weight:800;font-size:17px;color:#000;margin:0 0 12px;line-height:1.25}
.vk-why-card p{font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.55;color:#333;margin:0}
.vk-job{background:#fff;border:2px solid #000;margin-bottom:24px;overflow:hidden}
.vk-job-head{display:flex;justify-content:space-between;align-items:center;background:#0a0a0a;color:#fff;padding:24px 28px;gap:24px;flex-wrap:wrap}
.vk-job-head h3{font-family:Unbounded,sans-serif;font-weight:900;font-size:22px;color:#fff;margin:0 0 6px;letter-spacing:-0.02em}
.vk-job-meta{font-family:'DM Sans',sans-serif;font-size:12px;color:rgba(255,255,255,.75);letter-spacing:.05em}
.vk-job-salary{font-family:Unbounded,sans-serif;font-weight:900;font-size:24px;color:#e63329;letter-spacing:-0.02em;background:#fff;padding:8px 16px;border:2px solid #e63329;flex-shrink:0}
.vk-job-body{padding:28px}
.vk-job-body > p{font-family:'DM Sans',sans-serif;font-size:16px;line-height:1.5;color:#333;margin:0 0 24px}
.vk-job-cols{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.vk-job-cols h4{font-family:'DM Sans',sans-serif;font-weight:700;font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#e63329;margin:0 0 12px;padding-bottom:8px;border-bottom:2px solid #e63329}
.vk-job-cols ul{list-style:none;padding:0;margin:0;font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.5;color:#333}
.vk-job-cols li{padding:6px 0 6px 20px;position:relative}
.vk-job-cols li:before{content:"▸";color:#e63329;font-weight:700;position:absolute;left:0;top:6px}
.vk-flow{list-style:none;padding:0;margin:0;counter-reset:f}
.vk-flow li{padding:24px 0 24px 64px;border-bottom:1px solid #eee;position:relative;font-family:'DM Sans',sans-serif;font-size:16px;line-height:1.55;color:#333;counter-increment:f}
.vk-flow li:before{content:counter(f);position:absolute;left:0;top:22px;width:44px;height:44px;background:#e63329;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Unbounded,sans-serif;font-weight:800;font-size:18px}
.vk-flow li strong{color:#000;font-weight:700;display:block;margin-bottom:4px}
.vk-faq{display:flex;flex-direction:column;gap:8px}
.vk-faq details{background:#fff;border:1px solid #ddd;padding:0}
.vk-faq summary{padding:18px 24px;cursor:pointer;font-family:Unbounded,sans-serif;font-weight:700;font-size:16px;color:#000;list-style:none;position:relative}
.vk-faq summary::after{content:"+";position:absolute;right:24px;top:18px;color:#e63329;font-size:24px;line-height:1}
.vk-faq details[open] summary::after{content:"−"}
.vk-faq summary::-webkit-details-marker{display:none}
.vk-faq details p{padding:0 24px 18px;margin:0;font-family:'DM Sans',sans-serif;font-size:15px;line-height:1.6;color:#333}
@media (max-width:980px){.vk-hero-grid{grid-template-columns:1fr;gap:28px}.vk-form-card{max-width:none}}
@media (max-width:900px){.vk-hero{padding:40px 0 32px}.vk-hero-stats{grid-template-columns:repeat(2,1fr)}.vk-stat:nth-child(2){border-right:0}.vk-stat:nth-child(1),.vk-stat:nth-child(2){border-bottom:1px solid rgba(255,255,255,.12)}.vk-why-grid{grid-template-columns:1fr;gap:16px}.vk-job-cols{grid-template-columns:1fr;gap:24px}.vk-job-head{flex-direction:column;align-items:flex-start}}
</style>
