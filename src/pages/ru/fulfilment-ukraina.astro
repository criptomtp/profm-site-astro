.step{text-align:center;padding:20px 12px}
.step-num{font-size:48px;font-weight:800;color:#e63329;opacity:.25;margin-bottom:8px}
.step h3{font-size:15px;margin:0 0 6px;font-weight:700}
.step p{font-size:13px;color:#777;line-height:1.5}
/* Price table */
.price-wrap{overflow-x:auto}
.price-table{width:100%;border-collapse:collapse;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 1px 8px rgba(0,0,0,.04)}
.price-table th{background:#000;color:#fff;padding:12px 18px;text-align:left;font-size:12px;text-transform:uppercase;letter-spacing:.06em}
.price-table td{padding:12px 18px;border-bottom:1px solid #f0f0f0;font-size:14px}
.price-table tr:last-child td{border:0}
.price-table strong{color:#000}
/* Mid CTA */
.mid-cta{text-align:center;padding:40px 24px;background:rgba(230,51,41,.06);border-top:1px solid rgba(230,51,41,.1);border-bottom:1px solid rgba(230,51,41,.1)}
.mid-cta-btn{display:inline-block;padding:16px 32px;background:#e63329;color:#fff;font-size:16px;font-weight:600;border-radius:4px;text-decoration:none;transition:background .3s}
.mid-cta-btn:hover{background:#c42b22}
.mid-cta-tg{display:block;margin-top:10px;font-size:13px;color:#666;text-decoration:none;transition:color .2s}
.mid-cta-tg:hover{color:#e63329}
/* FAQ */
.faq-list{max-width:760px;margin:0 auto}
.faq-item{border-bottom:1px solid #e0e0e0}
.faq-item summary{padding:18px 0;font-size:16px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary .fi{font-size:22px;color:#e63329;transition:transform .3s;flex-shrink:0;margin-left:12px}
.faq-item[open] summary .fi{transform:rotate(45deg)}
.faq-body{padding:0 0 18px;font-size:15px;line-height:1.7;color:#666}
/* SEO text */
.seo-text{max-width:760px;margin:0 auto}
.seo-text h2{font-size:26px;font-weight:800;margin:0 0 16px}
.seo-text h3{font-size:19px;font-weight:700;margin:28px 0 10px}
.seo-text p{font-size:15px;line-height:1.8;color:#555;margin:0 0 14px}
/* Sections visibility fix */
.sec,.sec-gray{display:block;visibility:visible;clip-path:none;opacity:1}
/* Mobile */
@media(max-width:900px){
.kpi-row{gap:16px}
.calc-grid{grid-template-columns:1fr}
.steps-grid{grid-template-columns:1fr 1fr}.steps-grid .step:last-child{grid-column:1/-1}
.photos{grid-template-columns:1fr}
}
</style>

<script is:inline>
// Calculator
(function(){
var o=document.getElementById('calcOrders'),s=document.getElementById('calcStorage'),i=document.getElementById('calcItems');
if(!o)return;
function r(n){if(n>200)return 18;if(n>150)return 19;if(n>100)return 20;if(n>50)return 22;if(n>20)return 23;if(n>5)return 25;return 26;}
function calc(){
var orders=parseInt(o.value),storage=parseFloat(s.value),items=parseFloat(i.value);
document.getElementById('calcOrdersVal').textContent=orders;
document.getElementById('calcStorageVal').textContent=storage;
document.getElementById('calcItemsVal').textContent=items;
var rate=r(orders),days=22,total=orders*days;
var mtp=Math.max(storage*650+total*rate+total*Math.max(0,items-1)*2.5,5000);
var own=55000;var save=own-mtp;
document.getElementById('resOwn').textContent=own.toLocaleString('uk');
document.getElementById('resMtp').textContent=Math.round(mtp).toLocaleString('uk');
document.getElementById('resSave').textContent=Math.max(0,save).toLocaleString('uk');
document.getElementById('resPct').textContent=Math.max(0,Math.round(save/own*100));
document.getElementById('resPer').textContent=Math.round(mtp/total);
}
o.addEventListener('input',calc);s.addEventListener('input',calc);i.addEventListener('input',calc);calc();
})();
</script>
