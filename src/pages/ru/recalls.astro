.ed-video-thumb:hover img,.ed-video-thumb:focus-visible img{filter:grayscale(0);opacity:1}
.ed-play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;pointer-events:none}
.ed-play span{display:flex;align-items:center;justify-content:center;width:88px;height:88px;background:var(--red);color:#fff;font-size:32px;padding-left:6px;transition:transform .3s}
