<style is:global>
.ed{color:var(--black);background:var(--white);font-family:var(--fb)}
.ed-ctr{max-width:1280px;margin:0 auto;padding:0 40px}
.ed-kicker{font-size:11px;font-weight:800;letter-spacing:.22em;text-transform:uppercase;color:var(--black)}
