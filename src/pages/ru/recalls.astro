.ed-tags span{border:1px solid rgba(0,0,0,.15);padding:6px 14px;font-size:10px;font-weight:800;letter-spacing:.18em;text-transform:uppercase;color:var(--black)}

.ed-case{padding:80px 0;border-top:1px solid #e5e5e5}
.ed-grid-12{display:grid;grid-template-columns:repeat(12,1fr);gap:64px;align-items:center}
