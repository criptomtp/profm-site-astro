---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент для ФОП: Автоматизація Бізнесу від 18 грн';
const description = 'Повний цикл фулфілменту для ФОП та малих підприємств. Комплектація, складування, доставка. Масштабуйте бізнес без найму персоналу.';
const ogImage = 'https://profm.ua/images/fulfillment-fop-hero.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  },
  priceRange: '₴18-₴150'
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент для ФОП:
        <br />Автоматизація Бізнесу
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Масштабуйте продажі без найму складу, водіїв та менеджерів. Від 18 грн за замовлення.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <div class="flex items-center justify-center gap-2">
          <span class="text-yellow-300">✓</span>
          <span>99.8% точність комплектації</span>
        </div>
        <div class="flex items-center justify-center gap-2">
          <span class="text-yellow-300">✓</span>
          <span>За 24 часи на шляху</span>
        </div>
      </div>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Розрахувати вартість
      </a>
    </div>
  </section>

  <!-- Benefits Grid -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Чому ФОП вибирають MTP</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Масштабуйте без персоналу</h3>
          <p class="text-gray-700">Збільшуйте обсяги 10x без найму водіїв, комплектувальників, менеджерів. Ми беремо на себе логістику.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Розширення до нових регіонів</h3>
          <p class="text-gray-700">Отримайте доступ до всієї України без створення складів у кожному місті. Ми доставимо за 24 часи.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Витрати гарантовано нижче</h3>
          <p class="text-gray-700">Синергія з 1000+ партнерами = оптимальні ставки. На 30-40% дешевше за власну логістику.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">API до вашого сайту</h3>
          <p class="text-gray-700">Синхронізація замовлень в реальному часі. WMS наша, контроль ваш. Один клік = замовлення готово.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Швидка сертифікація Rozetka</h3>
          <p class="text-gray-700">Щоб почати продавати на Rozetka FBO, потрібна сертифікована логістика. Ми це забезпечуємо за 3 дні.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Гарантія якості + відповідальність</h3>
          <p class="text-gray-700">Якщо ми помилимося — платимо штраф. У вас швидка логістика, ми несемо ризик збитків.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Flow -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Як це працює: 5 кроків</h2>
      <div class="space-y-6">
        <div class="flex gap-6 items-start">
          <div class="bg-red-600 text-white rounded-full w-12 h-12 flex items-center justify-center flex-shrink-0 font-bold text-lg">1</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Підключення через API</h3>
            <p class="text-gray-700">Синхронізуємо ваш магазин з нашою WMS системою. Замовлення автоматично потрапляють до нас у реальному часі.</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="bg-red-600 text-white rounded-full w-12 h-12 flex items-center justify-center flex-shrink-0 font-bold text-lg">2</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Передача товару на склад</h3>
            <p class="text-gray-700">Ви відправляєте партію товару на наш склад (місце дислокації: Київ, Харків, Львів). Ми приймаємо, сортуємо, розміщуємо.</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="bg-red-600 text-white rounded-full w-12 h-12 flex items-center justify-center flex-shrink-0 font-bold text-lg">3</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Комплектація за &lt;30 хв</h3>
            <p class="text-gray-700">Нове замовлення надходить, беремо товар зі складу, кладемо в коробку, друкуємо етикету, сканимо — все до 30 хвилин.</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="bg-red-600 text-white rounded-full w-12 h-12 flex items-center justify-center flex-shrink-0 font-bold text-lg">4</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Збір на доставку 4 рази на день</h3>
            <p class="text-gray-700">Укупуємо комплектоване у піддони, передаємо перевізнику. Рейси в Київ, Харків, Львів за розписанням 4x до дня.</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="bg-red-600 text-white rounded-full w-12 h-12 flex items-center justify-center flex-shrink-0 font-bold text-lg">5</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Доставка за 24 часи</h3>
            <p class="text-gray-700">Замовлення виходить у шлях, клієнту приходить відповідне повідомлення, доставляємо за 24 часи.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Прозорі ціни для ФОП</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        <div class="bg-white p-8 rounded border border-gray-200">
          <h3 class="text-2xl font-bold mb-6">Комплектація (за замовлення)</h3>
          <ul class="space-y-4">
            <li class="flex justify-between">
              <span>Базова комплектація (1 товар)</span>
              <span class="font-bold">18 грн</span>
            </li>
            <li class="flex justify-between">
              <span>До 3 товарів у замовленні</span>
              <span class="font-bold">24 грн</span>
            </li>
            <li class="flex justify-between">
              <span>4-7 товарів</span>
              <span class="font-bold">32 грн</span>
            </li>
            <li class="flex justify-between">
              <span>Друк TTN етикети</span>
              <span class="font-bold">0.5 грн</span>
            </li>
            <li class="flex justify-between">
              <span>Маркування + скотч</span>
              <span class="font-bold">1 грн</span>
            </li>
          </ul>
        </div>
        <div class="bg-white p-8 rounded border border-gray-200">
          <h3 class="text-2xl font-bold mb-6">Складування (за пал./місяць)</h3>
          <ul class="space-y-4">
            <li class="flex justify-between">
              <span>Стандартна паль (3900 м² склад)</span>
              <span class="font-bold">400 грн/місяць</span>
            </li>
            <li class="flex justify-between">
              <span>Клімат-контроль 18-22°C</span>
              <span class="font-bold">+100 грн/місяць</span>
            </li>
            <li class="flex justify-between">
              <span>VIP місце (рядом входу, видалення)</span>
              <span class="font-bold">+50 грн/місяць</span>
            </li>
            <li class="flex justify-between">
              <span>Моніторинг запасів (API)</span>
              <span class="font-bold">Безкоштовно</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="bg-white p-8 rounded border-l-4 border-red-600 mb-8">
        <h3 class="text-xl font-bold mb-4">Приклад для ФОП з 200 замовленнями/місяць</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <p class="text-gray-600 text-sm mb-2">Комплектація</p>
            <p class="text-2xl font-bold">200 × 24 = 4,800 грн</p>
          </div>
          <div>
            <p class="text-gray-600 text-sm mb-2">Складування (2 палі)</p>
            <p class="text-2xl font-bold">2 × 400 = 800 грн</p>
          </div>
          <div>
            <p class="text-gray-600 text-sm mb-2">Усього в місяц</p>
            <p class="text-3xl font-bold text-red-600">5,600 грн</p>
            <p class="text-sm text-gray-600 mt-2">~28 грн на замовлення</p>
          </div>
        </div>
      </div>

      <div class="bg-blue-50 p-6 rounded border border-blue-200">
        <p class="text-sm text-gray-700"><strong>Без мінімум заказів.</strong> Платите лише за те, що комплектуєте. В першому місяці комплектація 50 замовлень? = 1200 грн, без прихованих комісій.</p>
      </div>
    </div>
  </section>

  <!-- ROI Section -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Рентабельність: Економія на персоналі</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="border p-4 text-left">Статья витрат</th>
              <th class="border p-4 text-center">Власна логістика</th>
              <th class="border p-4 text-center">MTP (наш сервіс)</th>
              <th class="border p-4 text-center">Економія на місяць</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border p-4">Комплектувальник + бонус</td>
              <td class="border p-4 text-center">12,000 грн</td>
              <td class="border p-4 text-center">0 грн</td>
              <td class="border p-4 text-center font-bold text-red-600">+12,000 грн</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4">Водій + ТО авто</td>
              <td class="border p-4 text-center">15,000 грн</td>
              <td class="border p-4 text-center">0 грн</td>
              <td class="border p-4 text-center font-bold text-red-600">+15,000 грн</td>
            </tr>
            <tr>
              <td class="border p-4">Оренда складу</td>
              <td class="border p-4 text-center">3,000 грн</td>
              <td class="border p-4 text-center">0 грн</td>
              <td class="border p-4 text-center font-bold text-red-600">+3,000 грн</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4">Комплектація + складування в MTP</td>
              <td class="border p-4 text-center">—</td>
              <td class="border p-4 text-center">5,600 грн</td>
              <td class="border p-4 text-center font-bold text-red-600">—</td>
            </tr>
            <tr class="bg-red-50">
              <td class="border p-4 font-bold">Сумарна економія (200 замовлень)</td>
              <td class="border p-4 text-center">30,000 грн</td>
              <td class="border p-4 text-center">5,600 грн</td>
              <td class="border p-4 text-center font-bold text-red-600 text-lg">+24,400 грн/місяць</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-6 text-center text-gray-700">За рік економія: <strong class="text-red-600 text-lg">292,800 грн</strong> — достатньо для розширення у нові категорії товарів.</p>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Для яких ФОП це найбільш корисно</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold mb-3">ФОП з 100-500 замовлень/місяць</h3>
          <p class="text-gray-700 mb-4">Ще не рентабельно наймати свого комплектувальника? MTP це робить автоматично за тебе. Начеб складу на дому вже немає місця.</p>
          <p class="text-sm text-gray-600">Результат: масштабування без капітальних вложень</p>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold mb-3">ФОП мультиканальні (Rozetka + власний сайт)</h3>
          <p class="text-gray-700 mb-4">Один склад, один API, все синхронізується. Сложнее управління із Rozetka FBO вимагає сертифікованої логістики — ми тебе сертифікуємо за 3 дні.</p>
          <p class="text-sm text-gray-600">Результат: дозвіл на розширення на нові площадки</p>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold mb-3">ФОП з нестандартним розписанням</h3>
          <p class="text-gray-700 mb-4">Якщо ти займаєшся своїм розробленням або постійно подорожуєш, твоя логістика не повинна залежати від графіку. MTP працює 24/7.</p>
          <p class="text-sm text-gray-600">Результат: свобода від логістики, сфокус на producto</p>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold mb-3">ФОП з сезонними піками</h3>
          <p class="text-gray-700 mb-4">В сезон 500 замовлень, взимку 50. Наймати не рентабельно, робити все самому втомлює. MTP масштабується за кілька днів.</p>
          <p class="text-sm text-gray-600">Результат: гнучкість без додаткових витрат</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">FAQ для ФОП</h2>
      <div class="space-y-6">
        <details class="bg-gray-50 p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Чи потрібна мені особлива реєстрація як ФОП?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Ні. Ти просто підключаєшся до MTP через API або кабінет, і ми беремо на себе логістику. Реєстрація займає 10 хвилин онлайн. Жодних документів, жодних комісій.</p>
        </details>
        <details class="bg-gray-50 p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Скільки часу потрібно на інтеграцію з моєю платформою?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Залежить від твоєї платформи. Для Rozetka, Prom.ua, Shopify — стандартна інтеграція 2-3 дні. Для власного сайту на WooCommerce — 1 день. Якщо потрібен custom API — до 1 тижня. Ми допомагаємо на всіх етапах.</p>
        </details>
        <details class="bg-gray-50 p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Що у випадку, якщо я захочу піти від MTP?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Без проблем. Ми не укупуємо. У будь-який день ти можеш забрати свій товар із складу або передати його іншому логісту. Штрафів немає, контракт тримісячний з можливістю відмови.</p>
        </details>
        <details class="bg-gray-50 p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Як це працює в першому місяці, якщо я передаю перший замовлення?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">У першому місяці ти платиш за фактичні операції: скільки замовлень комплектував, скільки палів складував. Якщо 50 замовлень — платиш за 50. Мінімумів нема. Коли обсяги стабілізуються, можеш обговорити фіксовану ставку.</p>
        </details>
        <details class="bg-gray-50 p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Чи безпечна мула товара у вас на складі?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Так. У нас цехова система видеоспостереження, контроль доступу, страхування товару. Інвентарізація щомісяця. Якщо товар втрачено через нашу провину — компенсуємо вартість на 100%.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section id="contact" class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Готов розпочати?</h2>
      <p class="text-xl mb-8 opacity-90">
        Розрахуємо персональну пропозицію за 30 хвилин.
      </p>
      <div class="bg-white bg-opacity-10 p-8 rounded backdrop-blur-sm">
        <form class="space-y-4">
          <input type="text" placeholder="Ваше ім'я" class="w-full px-4 py-3 rounded bg-white text-gray-800 placeholder-gray-500" required />
          <input type="email" placeholder="Email або телефон" class="w-full px-4 py-3 rounded bg-white text-gray-800 placeholder-gray-500" required />
          <textarea placeholder="Коротко про ваш бізнес (кількість замовлень, дка товарів, очікування)" class="w-full px-4 py-3 rounded bg-white text-gray-800 placeholder-gray-500 h-24" required></textarea>
          <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 rounded transition">
            Замовити розрахунок
          </button>
        </form>
      </div>
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div>
          <p class="text-sm opacity-75 mb-1">ТЕЛЕФОН</p>
          <a href="tel:+380931234567" class="text-xl font-bold hover:opacity-80 transition">+38 (093) 123-45-67</a>
        </div>
        <div>
          <p class="text-sm opacity-75 mb-1">EMAIL</p>
          <a href="mailto:info@profm.ua" class="text-xl font-bold hover:opacity-80 transition">info@profm.ua</a>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
