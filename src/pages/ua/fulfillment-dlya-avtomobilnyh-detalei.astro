---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент для Автомобільних Запчастин: Точність, Якість, Доставка';
const description = 'Спеціалізований фулфілмент для запчастин до автомобілів, деталей, аксесуарів. Точна інвентаризація, контроль якості, 100% страховка, безпечна доставка за 24-48 годин.';
const ogImage = 'https://profm.ua/images/fulfillment-auto.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  }
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент для Автомобільних Запчастин<br />Точність & Якість
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Двигуни, коробки передач, генератори, гальма, аксесуари. Точна інвентаризація, контроль якості, 100% страховка, безпечна доставка за 24-48 годин.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент автозапчастин
      </a>
    </div>
  </section>

  <!-- Why Auto Parts Need Special Care -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Специфіка автомобільних запчастин у логістиці</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🔧 Висока вартість & складність</h3>
          <p class="text-gray-700">Двигун за 50,000 грн, коробка передач за 30,000 грн. Неправильна запчастина = автомобіль не роботе. Потребується 100% точність.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">📊 Складна інвентаризація</h3>
          <p class="text-gray-700">1000+ артикулів, различні версії для різних модельних років. FIFO система, каталог номерів, VIN код. Потребується точна база даних.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🛡️ Захист від пошкоджень</h3>
          <p class="text-gray-700">Двигун дорогий, крихкий. При падінні може розбитися. Потребується максимальна амортизація і контроль при складуванні.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🌡️ Контроль умів</h3>
          <p class="text-gray-700">Деякі запчастини (олива, масло) потребують температурного контролю. Потребується складування без коливань температури.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MTP Auto Parts Services -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Послуги MTP для автозапчастин</h2>
      <div class="space-y-4">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Точна інвентаризація & каталог</h3>
          <p class="text-gray-700">Кожна запчастина має каталог номер, VIN код, артикул. RFID теги для великих запчастин. База даних у реальному часі. Нулева втрата товарів.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ 100% контроль якості</h3>
          <p class="text-gray-700">Кожна запчастина перевіряється перед відправкою: цілісність, наявність всіх деталей, відповідність артикулу. Не відправляємо неправильну запчастину.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Безпечна упаковка & доставка</h3>
          <p class="text-gray-700">Дорогу запчастину упаковуємо максимально безпечно. Спеціальний транспорт для великих деталей. GPS моніторинг. Фото до/після доставки.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Контроль температури & умів</h3>
          <p class="text-gray-700">Для температурно-чутливих запчастин (олива, масло) — контроль 10-25°C. Для всіх — контроль вологості. Документація всіх показників.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Ціни для автозапчастин</h2>
      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-4">Комплектація & Доставка</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Комплектація (за замовлення)</span>
            <span class="font-bold">30-50 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Інвентаризація & каталог</span>
            <span class="font-bold">Включено</span>
          </li>
          <li class="flex justify-between">
            <span>100% контроль якості</span>
            <span class="font-bold">Включено</span>
          </li>
          <li class="flex justify-between">
            <span>Безпечна упаковка</span>
            <span class="font-bold">20-50 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Доставка спеціалізована (до 50 км)</span>
            <span class="font-bold">100-300 грн</span>
          </li>
          <li class="flex justify-between">
            <span>100% страховка</span>
            <span class="font-bold">Включено</span>
          </li>
        </ul>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Приклад: Магазин автозапчастин (200 замовлень/місяц)</h3>
        <p class="text-gray-700">
          Комплектація: 200 × 40 = 8,000 грн<br/>
          Упаковка: 200 × 35 = 7,000 грн<br/>
          Доставка: 200 × 200 = 40,000 грн<br/>
          Складування: 3 палі × 500 = 1,500 грн<br/>
          <strong class="text-lg">ВСЬОГО: 56,500 грн/месяц = 282 грн/замовлення</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Quality Guarantee -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Гарантія якості для автозапчастин</h2>
      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">99.95% точність артикулу</p>
            <p class="text-gray-700">Неправильна запчастина — не буде відправлено. Каталог номер, VIN код перевіряються перед відправкою. 99.95% точність.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Контроль якості 100%</p>
            <p class="text-gray-700">Кожна запчастина перевіряється на цілісність, наявність всіх деталей. Не відправляємо пошкоджені або неповні запчастини.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% страховка від пошкоджень</p>
            <p class="text-gray-700">Запчастина розбилася при доставці — платимо 100%. Миттєва компенсація. Клієнт отримує нову запчастину.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Безпечна доставка спеціалізована</p>
            <p class="text-gray-700">Дорогу запчастину доставляємо спеціальним транспортом. GPS моніторинг. Фото до/після. &lt;0.5% браку при доставці.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Логістика для магазинів автозапчастин</h2>
      <p class="text-xl mb-8 opacity-90">
        Точна інвентаризація, 100% контроль якості, 100% страховка, спеціалізована доставка.
      </p>
      <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент автозапчастин
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
