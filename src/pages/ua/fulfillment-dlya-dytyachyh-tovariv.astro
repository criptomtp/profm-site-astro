---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент для Дитячих Товарів: Безпека, Якість, Гігієна';
const description = 'Спеціалізований фулфілмент для дитячих товарів, одягу, іграшок, аксесуарів. Безпечна обробка, гігієнічні стандарти, 100% страховка, доставка за 24 години.';
const ogImage = 'https://profm.ua/images/fulfillment-baby.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  }
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент для Дитячих Товарів<br />Безпека & Гігієна для Малюків
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Пелюшки, одяг, іграшки, косметика для малюків. Максимальна гігієна, безпечна обробка, сертифікація, 100% страховка, доставка за 24 години.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент дитячих товарів
      </a>
    </div>
  </section>

  <!-- Why Baby Products Need Special Care -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Специфіка дитячих товарів у логістиці</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">👶 Безпека малюків</h3>
          <p class="text-gray-700">Малюки мають найніжнішу шкіру. Забруднення, хімічні залишки, пилу = дерматит, алергія. Потребується максимальна чистота & гігієна.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">📋 Сертифікація & Дозволи</h3>
          <p class="text-gray-700">Кожен дитячий товар повинен мати сертифікат від МОЗ, батьківське схвалення. Потребується документація, перевірка партій.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🧼 Гігієнічні стандарти</h3>
          <p class="text-gray-700">Для дитячих товарів — найвищі гігієнічні стандарти. Без пилу, плісені, запахів. Персонал має спеціальне навчання. Щодня дезінфекція.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">📦 Екологічна упаковка</h3>
          <p class="text-gray-700">Батьки переймаються екологією. Потребується упаковка без хімічних залишків, екологічна & безпечна.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MTP Baby Products Services -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Послуги MTP для дитячих товарів</h2>
      <div class="space-y-4">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Максимальна гігієна & чистота</h3>
          <p class="text-gray-700">Дедикована, чиста зона для дитячих товарів. Персонал у стерильному одязі, перчатках. Щодня санітарна дезінфекція. Без пилу, плісені, запахів.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Контроль сертифікації</h3>
          <p class="text-gray-700">Перш ніж приймемо товар, перевіряємо наявність сертифіката від МОЗ, батьківське схвалення. Якщо документ немає — не приймаємо товар.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Екологічна упаковка</h3>
          <p class="text-gray-700">Екологічні матеріали упаковки. Без хімічних залишків. Безпечна для дитини упаковка. Товар доставляється чистим.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ 100% Контроль якості</h3>
          <p class="text-gray-700">Кожна позиція перевіряється на цілісність, чистоту, відповідність описові. Нулева допуск на браки для дитячих товарів.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Ціни для дитячих товарів</h2>
      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-4">Комплектація & Доставка</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Комплектація (за замовлення)</span>
            <span class="font-bold">20-30 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Максимальна гігієна & дезінфекція</span>
            <span class="font-bold">Включено</span>
          </li>
          <li class="flex justify-between">
            <span>Екологічна упаковка</span>
            <span class="font-bold">10-20 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Контроль сертифікації</span>
            <span class="font-bold">Включено</span>
          </li>
          <li class="flex justify-between">
            <span>Доставка (стандарт)</span>
            <span class="font-bold">50-100 грн</span>
          </li>
          <li class="flex justify-between">
            <span>100% страховка</span>
            <span class="font-bold">Включено</span>
          </li>
        </ul>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Приклад: Дитячий магазин (350 замовлень/місяц)</h3>
        <p class="text-gray-700">
          Комплектація: 350 × 25 = 8,750 грн<br/>
          Упаковка екологічна: 350 × 15 = 5,250 грн<br/>
          Доставка: 350 × 75 = 26,250 грн<br/>
          Складування: 2 палі × 400 = 800 грн<br/>
          <strong class="text-lg">ВСЬОГО: 41,050 грн/месяц = 117 грн/замовлення</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Quality Guarantee -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Гарантія якості для дитячих товарів</h2>
      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% гігієнічна обробка</p>
            <p class="text-gray-700">Максимальна чистота від приймання до доставки. Персонал у стерильному одязі. Щодня дезінфекція. Товар готовий для малюка.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Контроль сертифікації 100%</p>
            <p class="text-gray-700">Кожна позиція має сертифікат від МОЗ, батьківське схвалення. Без сертифіката товар не буде приймати на склад.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Екологічна безпечність</p>
            <p class="text-gray-700">Упаковка без хімічних залишків. Матеріали безпечні для дитини. Товар не має запахів хімічних речовин.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% страховка від пошкоджень</p>
            <p class="text-gray-700">Дитячий товар повернувся брудним, пошкодженим — платимо 100%. Миттєва компенсація. Батьки в безпеці.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Логістика для дитячих магазинів</h2>
      <p class="text-xl mb-8 opacity-90">
        Максимальна гігієна, екологічна упаковка, 100% сертифікація, 100% страховка, доставка за 24 години.
      </p>
      <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент дитячих товарів
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
