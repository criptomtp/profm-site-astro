.res-label{font-size:14px;color:rgba(255,255,255,.6)}
.res-value{font-size:16px;font-weight:500;color:var(--white)}
.res-sub{font-size:12px;color:rgba(255,255,255,.35);margin-left:8px;font-weight:300}
.res-total{margin-top:24px;padding:24px;background:var(--red);border-radius:8px}
.res-total .res-row{border-bottom:none;padding:8px 0}
.res-total .res-label{color:rgba(255,255,255,.85);font-size:16px;font-weight:500}
.res-total .res-value{font-family:var(--fd);font-size:28px}
.res-cost-per{margin-top:16px;padding:16px;background:rgba(255,255,255,.06);border-radius:8px;text-align:center}
.res-cost-per .val{font-family:var(--fd);font-size:32px;color:var(--red)}
.res-cost-per .lbl{font-size:13px;color:rgba(255,255,255,.5);margin-top:4px}
.res-compare{margin-top:16px;padding:20px;border:1px solid rgba(255,255,255,.1);border-radius:8px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.6}
.res-compare strong{color:#fff;font-weight:500}
.res-compare .compare-title{font-size:13px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;font-weight:500}
.res-compare .compare-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.06)}
.res-compare .compare-row:last-child{border-bottom:none}
.res-compare .compare-total{margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.15);font-weight:500;color:rgba(255,255,255,.8)}
.res-time{margin-top:16px;padding:20px;background:rgba(230,51,41,.08);border:1px solid rgba(230,51,41,.2);border-radius:8px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.6}
.res-time strong{color:#fff;font-weight:500}

.tariff-section{padding:100px 0}
.table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-top:48px}
.tariff-table{width:100%;border-collapse:collapse;min-width:320px}
.tariff-table th,.tariff-table td{padding:16px 24px;text-align:left;border-bottom:1px solid #e0e0e0}
.tariff-table th{font-size:12px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:1px;background:var(--gray)}
.tariff-table td{font-size:15px}
.tariff-table tr:hover td{background:rgba(230,51,41,.03)}
.tariff-table .highlight{background:rgba(230,51,41,.06);font-weight:500}
.tariff-table .rate{font-family:var(--fd);font-size:20px;color:var(--red)}

.addons{padding:100px 0;background:#0a0a0a;color:var(--white)}
.addon-table{width:100%;border-collapse:collapse;min-width:560px}
.addon-table th,.addon-table td{padding:16px 24px;text-align:left;border-bottom:1px solid rgba(255,255,255,.08)}
.addon-table th{font-size:12px;font-weight:500;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:1px}
.addon-table td{font-size:15px;color:rgba(255,255,255,.7)}
.addon-table .price{font-family:var(--fd);font-size:20px;color:var(--red)}

.seo-article{padding:100px 0;background:var(--gray)}
.seo-article h2{font-family:var(--fd);font-size:clamp(28px,3.5vw,40px);font-weight:400;margin-bottom:32px}
.seo-article h3{font-size:20px;font-weight:500;margin:32px 0 16px}
.seo-article p{font-size:16px;color:var(--muted);line-height:1.8;margin-bottom:16px;max-width:800px}

@media(max-width:768px){
.hero{padding:100px 0 60px}.hero-content{padding:0 24px}
.hero h1{font-size:clamp(36px,9vw,48px)}
.hero-stats{gap:24px}.hero-stats>div{min-width:calc(50% - 12px)}
.calc-wrap{grid-template-columns:1fr}
.tariff-table,.addon-table{font-size:13px}
.tariff-table th,.tariff-table td,.addon-table th,.addon-table td{padding:12px 16px}
}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
  var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.15});
  document.querySelectorAll('.reveal').forEach(function(el,i){el.style.transitionDelay=(i%3)*.1+'s';obs.observe(el);});

  function getRate(n){
    if(n>200)return 18;if(n>150)return 19;if(n>100)return 20;
    if(n>75)return 21;if(n>50)return 22;if(n>20)return 23;
    if(n>10)return 24;if(n>5)return 25;return 26;
  }
  function fmt(n){return Math.round(n).toLocaleString('uk-UA');}
  function calculate(){
    var ordersPerDay=parseFloat(document.getElementById('calcOrders').value)||0;
    var weight=parseFloat(document.getElementById('calcWeight').value)||2;
    var volumeM3=parseFloat(document.getElementById('calcVolume').value)||0;
    var avgItems=parseFloat(document.getElementById('calcItems').value)||1;
    var rate=getRate(ordersPerDay);
    var totalOrders=ordersPerDay*22;
    var shipping=totalOrders*rate;
    var storage=volumeM3*650;
    var receiveCost=3;
    if(weight>2)receiveCost+=((weight-2)*0.5);
    var receiving=totalOrders*receiveCost;
    var copacking=0;
    if(avgItems>1){copacking=totalOrders*(avgItems-1)*2.5;}
    var total=shipping+storage+receiving+copacking;
    if(total<5000)total=5000;
    var ownRent=Math.max(Math.ceil(ordersPerDay/50),1)*15000;
    var ownStaff=Math.max(Math.ceil(ordersPerDay/30),2)*15000;
    var ownWms=5000;
    var ownUtils=2000;
    var ownMaterials=Math.round(ordersPerDay*22*1.5);
    var ownTotal=ownRent+ownStaff+ownWms+ownUtils+ownMaterials;
    var timeOwnHours=Math.round(ordersPerDay*0.15*22);
    var timeFreed=Math.min(timeOwnHours,160);
    var timeMarketing=Math.round(timeFreed*0.6);
    var timePersonal=Math.round(timeFreed*0.3);
    var costPerOrder=totalOrders>0?(total/totalOrders):0;
    document.getElementById('resShipping').textContent=fmt(shipping);
    document.getElementById('resShippingRate').textContent='('+rate+' грн/замовлення)';
    document.getElementById('resStorage').textContent=fmt(storage);
    document.getElementById('resReceiving').textContent=fmt(receiving);
    document.getElementById('resCopacking').textContent=fmt(copacking);
    document.getElementById('resTotal').textContent=fmt(total);
    document.getElementById('resCostPer').textContent=costPerOrder.toFixed(1);
    document.getElementById('ownRent').textContent=fmt(ownRent);
    document.getElementById('ownStaff').textContent=fmt(ownStaff);
    document.getElementById('ownWms').textContent=fmt(ownWms);
    document.getElementById('ownUtils').textContent=fmt(ownUtils);
    document.getElementById('ownMaterials').textContent=fmt(ownMaterials);
    document.getElementById('ownTotal').textContent=fmt(ownTotal);
    var saving=ownTotal>0?Math.max(0,Math.round((1-total/ownTotal)*100)):0;
    document.getElementById('resSaving').textContent=saving+'%';
    document.getElementById('timeFreed').textContent=timeFreed;
    document.getElementById('timeMarketing').textContent=timeMarketing;
    document.getElementById('timePersonal').textContent=timePersonal;
  }
  ['calcOrders','calcWeight','calcVolume','calcItems'].forEach(function(id){
    document.getElementById(id).addEventListener('input',calculate);
    document.getElementById(id).addEventListener('change',calculate);
  });
  calculate();
});
</script>
</Base>

<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
  var form=document.getElementById('heroForm');
  if(!form)return;
  form.addEventListener('submit',function(e){
    e.preventDefault();
    var ph=form.querySelector('input[name="phone"]').value.trim();
    if(ph.replace(/\D/g,'').length<10){form.querySelector('input').style.borderColor='#e63329';return;}
    fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});if(window.mtpSubmitLead)window.mtpSubmitLead(ph);
    form.innerHTML='<p style="color:#fff;font-size:18px">\u2705 Дякуємо!</p>';
  });
});
</script>
