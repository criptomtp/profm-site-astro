.hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero h1{font-family:var(--fd);font-size:clamp(42px,6vw,72px);font-weight:400;line-height:.95;margin-bottom:28px}
.hero-sub{font-size:clamp(16px,1.8vw,20px);color:rgba(255,255,255,.6);line-height:1.7;max-width:520px;margin-bottom:48px}
.hero-stats{display:flex;gap:48px;flex-wrap:wrap}
.hero-stat-val{font-family:var(--fb);font-size:clamp(28px,4vw,48px);font-weight:300;color:var(--white)}
.hero-stat-label{font-size:11px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:2px;margin-top:8px}

.calc-section{padding:80px 0 100px;background:var(--gray)}
.calc-wrap{display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:48px}
.calc-form{background:var(--white);border-radius:12px;padding:40px;box-shadow:0 2px 24px rgba(0,0,0,.06)}
.calc-form h3{font-family:var(--fd);font-size:24px;font-weight:400;margin-bottom:32px}
.calc-field{margin-bottom:24px}
.calc-field label{display:block;font-size:13px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.calc-field input,.calc-field select{width:100%;padding:14px 16px;border:1px solid #e0e0e0;border-radius:6px;font-size:16px;font-family:var(--fb);outline:none;transition:border-color .3s;background:var(--white);color:var(--black)}
.calc-field input:focus,.calc-field select:focus{border-color:var(--red)}
.calc-field .field-hint{font-size:12px;color:var(--muted);margin-top:4px}

.calc-results{background:var(--black);border-radius:12px;padding:40px;color:var(--white)}
