import Base from '../../layouts/Base.astro';

const schemaJson = `<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Фулфілмент для косметики","description":"Спеціалізований фулфілмент для beauty та косметичних товарів з FEFO-контролем, температурним зберіганням та збором за 30 секунд","provider":{"@type":"Organization","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":"+380501444645"},"areaServed":{"@type":"Country","name":"UA"},"serviceType":"Cosmetics Fulfillment","offers":{"@type":"Offer","priceCurrency":"UAH","price":"18","description":"Від 18 грн за відправлення (200+ замовлень/день)"}}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Яка температура зберігання косметики на складі MTP?","acceptedAnswer":{"@type":"Answer","text":"Склад MTP підтримує температуру 18-22°С цілодобово. Це оптимальний діапазон для більшості косметичних засобів: кремів, сироваток, тоніків, декоративної косметики."}},{"@type":"Question","name":"Як працює FEFO-контроль термінів придатності?","acceptedAnswer":{"@type":"Answer","text":"FEFO (First Expired First Out) — товари з найближчим терміном придатності відправляються першими. Дата сканується при прийманні, WMS автоматично вибирає партію для відправки. Тариф: 0,50 грн/одиниця."}},{"@type":"Question","name":"Скільки коштує фулфілмент для косметики?","acceptedAnswer":{"@type":"Answer","text":"Відправка від 18 грн/замовлення (при 200+/день), зберігання 650 грн/м³/міс, FEFO-контроль 0,50 грн/од, доукомплектація пробниками 2,50 грн/од. Мінімальний платіж 5 000 грн/міс."}},{"@type":"Question","name":"Чи потрібна нотифікація для зберігання косметики?","acceptedAnswer":{"@type":"Answer","text":"З серпня 2026 року нотифікація стає обов'язковою для продажу косметики в Україні. MTP зберігає товар на сертифікованому складі, але документи на продукцію залишаються відповідальністю продавця."}},{"@type":"Question","name":"Як швидко збирається замовлення косметики?","acceptedAnswer":{"@type":"Answer","text":"Середній час збору — 30 секунд. Замовлення відправляються 4 рази на день. Для beauty-товарів додатково перевіряється цілісність упаковки перед відправкою."}},{"@type":"Question","name":"Чи можна вкладати пробники або листівки?","acceptedAnswer":{"@type":"Answer","text":"Так. Доукомплектація коштує 2,50 грн за одиницю. Можна вкладати пробники, листівки з промокодами, подарунки. Все пакується вручну під час збирання замовлення."}},{"@type":"Question","name":"Як обробляються повернення косметики?","acceptedAnswer":{"@type":"Answer","text":"Повернення приймається на склад, розпаковується, перевіряється стан та цілісність упаковки. Якісний товар повертається на полицю, пошкоджений відкладається для списання за рішенням клієнта."}}]}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Головна","item":"https://www.fulfillmentmtp.com.ua/"},{"@type":"ListItem","position":2,"name":"Послуги","item":"https://www.fulfillmentmtp.com.ua/ua/3pl-logistyka/"},{"@type":"ListItem","position":3,"name":"Фулфілмент для косметики","item":"https://www.fulfillmentmtp.com.ua/ua/fulfilment-dlya-kosmetyky/"}]}</script>`;
