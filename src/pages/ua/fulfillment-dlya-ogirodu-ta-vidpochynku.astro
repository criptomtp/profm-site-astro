---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент для Саду & Відпочинку: Вага, Об\'єм, Захист';
const description = 'Спеціалізований фулфілмент для садових інструментів, меблів, кемпінгу. Спеціальна упаковка, контроль вологості, 100% страховка, доставка за 48 годин.';
const ogImage = 'https://profm.ua/images/fulfillment-garden.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  }
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент для Саду & Відпочинку<br />Вага, Об\'єм, Захист
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Дачні меблі, газонокосарки, мангали, намети, вудки. Спеціальна упаковка для великих товарів, контроль вологості, 100% страховка, доставка за 48 годин.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент товарів для саду
      </a>
    </div>
  </section>

  <!-- Why Garden & Outdoor Need Special Care -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Специфіка товарів для саду у логістиці</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">📦 Вага & Об\'єм</h3>
          <p class="text-gray-700">Газонокосарка за 50 кг, мангал за 100 кг, намет за 15 кг. Дуже об\'ємні товари. Потребується спеціальний транспорт & спеціальна обробка при складуванні.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">💧 Вологість & Іржа</h3>
          <p class="text-gray-700">Металеві частини іржавіють при вологості &gt;70%. Деревина деформується. Потребується контроль вологості & захист від вологи при доставці.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🌞 Сезонність</h3>
          <p class="text-gray-700">Товари для саду мають сезонні піки (весна, літо). Потребується гнучка система для обробки великих піків замовлень. 1000 намітів за місяць.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🔍 Контроль комплектності</h3>
          <p class="text-gray-700">Мангал має гриль, ніжки, покришку, прибори. Намет має стійки, тканину, колишки. Одна деталь — повна неповнота товару при отриманні.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MTP Garden Services -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Послуги MTP для товарів саду</h2>
      <div class="space-y-4">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Спеціалізована упаковка для великих товарів</h3>
          <p class="text-gray-700">Газонокосарка в дерев'яному ящику з піною. Мангал в картонній коробці з розпірками. Намет в спеціальній торбі. Максимальна захист.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Контроль вологості & захист від іржі</h3>
          <p class="text-gray-700">Вологість &lt;70% для металевих виробів. Упаковка з осушувачем вологи. При доставці товар захищений від дощу & вологи. Контроль всіх показників.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Контроль комплектності 100%</h3>
          <p class="text-gray-700">Перед відправкою кожна позиція перевіряється на комплектність: всі деталі в наявності, ніщо не забуте. Контрольний лист за кожним товаром.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Сезонна гнучкість & доставка</h3>
          <p class="text-gray-700">При піках замовлень розширюємо персонал. Можемо обробляти 2-3 рази більше замовлень. Доставляємо за 48 годин без затримок.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Ціни для товарів саду</h2>
      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-4">Комплектація & Доставка</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Комплектація (за замовлення)</span>
            <span class="font-bold">50-100 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Спеціальна упаковка (за позицію)</span>
            <span class="font-bold">30-80 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Контроль комплектності</span>
            <span class="font-bold">Включено</span>
          </li>
          <li class="flex justify-between">
            <span>Контроль вологості & захист від іржі</span>
            <span class="font-bold">+30 грн/паль/месяц</span>
          </li>
          <li class="flex justify-between">
            <span>Доставка (до 50 км)</span>
            <span class="font-bold">150-300 грн</span>
          </li>
          <li class="flex justify-between">
            <span>100% страховка</span>
            <span class="font-bold">Включено</span>
          </li>
        </ul>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Приклад: Магазин садових товарів (60 замовлень/місяц)</h3>
        <p class="text-gray-700">
          Комплектація: 60 × 75 = 4,500 грн<br/>
          Упаковка: 60 × 55 = 3,300 грн<br/>
          Доставка спеціалізована: 60 × 225 = 13,500 грн<br/>
          Складування: 2 палі × 30 = 60 грн/месяц = 60 грн<br/>
          <strong class="text-lg">ВСЬОГО: 21,360 грн/месяц = 356 грн/замовлення</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Quality Guarantee -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Гарантія якості для товарів саду</h2>
      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% контроль комплектності</p>
            <p class="text-gray-700">Кожна позиція перевіряється на наявність всіх деталей. Контрольний лист за кожним товаром. Нічого не буде забуто.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Захист від іржі & вологи</p>
            <p class="text-gray-700">Вологість &lt;70%, упаковка з осушувачем. Товар доставляється в ідеальному стані без бура і коросії. Максимальна захист.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Спеціалізована доставка 48 годин</p>
            <p class="text-gray-700">Великі товари доставляємо спеціальним транспортом. Без затримок, без зайвих манипуляцій. &lt;0.5% браку при доставці.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% страховка від пошкоджень</p>
            <p class="text-gray-700">Газонокосарка розбилася при доставці — платимо 100%. Миттєва компенсація. Клієнт отримує новий товар.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Логістика для магазинів садових товарів</h2>
      <p class="text-xl mb-8 opacity-90">
        Спеціалізована упаковка, контроль комплектності, захист від іржі, 100% страховка, доставка за 48 годин.
      </p>
      <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент товарів саду
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
