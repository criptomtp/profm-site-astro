<script type="module" is:inline>
  // Swagger UI via CDN — loaded only on this page, deferred.
  const link = document.createElement('link');
  link.rel = 'stylesheet';
  link.href = 'https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui.css';
  document.head.appendChild(link);

  const s = document.createElement('script');
  s.src = 'https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui-bundle.js';
  s.onload = () => {
    window.SwaggerUIBundle({
      url: '/openapi.json',
      dom_id: '#swagger-ui',
      deepLinking: true,
      docExpansion: 'list',
      defaultModelsExpandDepth: -1,
      tryItOutEnabled: true,
      persistAuthorization: true,
    });
  };
  document.body.appendChild(s);

  // Copy buttons
  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const pre = btn.closest('.apidoc-code').querySelector('pre');
      try {
        await navigator.clipboard.writeText(pre.textContent);
        const o = btn.textContent; btn.textContent = 'Copied ✓';
        setTimeout(() => btn.textContent = o, 1500);
      } catch {}
    });
  });
</script>

<style is:global>
  .apidoc-hero{background:#000;color:#fff;padding:clamp(60px,10vw,120px) 20px 80px;position:relative;overflow:hidden}
  .apidoc-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at top right, rgba(230,51,41,.18), transparent 60%);pointer-events:none}
  .apidoc-hero__inner{max-width:1200px;margin:0 auto;position:relative}
  .apidoc-hero__label{display:inline-block;font:600 12px/1 'Inter',system-ui,sans-serif;letter-spacing:.18em;text-transform:uppercase;color:#e63329;border:1px solid rgba(230,51,41,.4);padding:8px 14px;border-radius:4px;margin-bottom:28px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace}
  .apidoc-hero__title{font:800 clamp(40px,7vw,76px)/1.02 'Inter',system-ui,sans-serif;letter-spacing:-.025em;margin:0 0 22px;color:#fff}
  .apidoc-hero__accent{color:#e63329}
  .apidoc-hero__sub{font:400 clamp(17px,2vw,21px)/1.55 'Inter',system-ui,sans-serif;color:rgba(255,255,255,.78);max-width:720px;margin:0 0 36px}
  .apidoc-hero__actions{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:40px}
  .apidoc-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 22px;font:600 15px/1 'Inter',system-ui,sans-serif;text-decoration:none;border-radius:6px;transition:all .15s;border:1px solid transparent}
  .apidoc-btn--primary{background:#e63329;color:#fff}
  .apidoc-btn--primary:hover{background:#c82a23}
  .apidoc-btn--outline{background:transparent;color:#fff;border-color:rgba(255,255,255,.28)}
