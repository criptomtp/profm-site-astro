---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент для Прикраси Дому & Предметів Інтер\'єру: Хрупкість, Якість, Безпека';
const description = 'Спеціалізований фулфілмент для предметів інтер\'єру, картин, зеркал, ленам. Захист від пошкоджень, бережна упаковка, 100% страховка, безпечна доставка за 24-48 годин.';
const ogImage = 'https://profm.ua/images/fulfillment-decor.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  }
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент для Прикраси Дому & Інтер\'єру<br />Захист Від Пошкоджень
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Картини, дзеркала, ставки, світильники, керамічні чаші. Максимальна упаковка, бережна обробка, 100% страховка, доставка за 24-48 годин.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент предметів інтер\'єру
      </a>
    </div>
  </section>

  <!-- Why Home Decor Needs Special Care -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Специфіка предметів інтер\'єру у логістиці</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🎨 Крихкість матеріалів</h3>
          <p class="text-gray-700">Дзеркало, скло, керамічна чаша, картина з скляною рамкою легко розбиваються. Одна удар при упаковці — повна втрата товару. Потребується максимальна амортизація.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🌈 Естетичне значення</h3>
          <p class="text-gray-700">Картина за 2000 грн, дзеркало за 1500 грн. Клієнт платить за красоту. Навіть дрібна помилка (подряпина на скле) = рецензія 1 зірка, повернення.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">📏 Великі розміри</h3>
          <p class="text-gray-700">Велике дзеркало 150×100 см, картина 2×3 м. Потребується спеціальна упаковка, спеціальний транспорт, спеціальна обробка при розвантаженні.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🔍 Контроль видимих дефектів</h3>
          <p class="text-gray-700">Потребується контроль для видимих дефектів: царапин на скле, сколів на рамці, забруднення. 100% контроль перед відправкою.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MTP Home Decor Services -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Послуги MTP для предметів інтер\'єру</h2>
      <div class="space-y-4">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Максимальна амортизація</h3>
          <p class="text-gray-700">Для дзеркал & скла — спеціальні скельниці з піною. Для картин — картонні розпірки. Для кераміки — повітряна пелена + піна. Захист з усіх сторін.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Контроль видимих дефектів</h3>
          <p class="text-gray-700">Перед упаковкою кожна позиція перевіряється: нема царапин, сколів, забруднення. Якщо дефект — повідомляємо клієнтові перш за все, перш за відправку.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Спеціалізована доставка</h3>
          <p class="text-gray-700">Для великих, крихких предметів — спеціальний транспорт. Два працівники при розвантаженні. GPS моніторинг. Фото перед & після доставки.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ 100% Страховка & Компенсація</h3>
          <p class="text-gray-700">Дзеркало розбилося при доставці — платимо 100%. Миттєва компенсація. Клієнт отримує новий товар без чекання.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Ціни для предметів інтер\'єру</h2>
      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-4">Комплектація & Доставка</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Комплектація (за замовлення)</span>
            <span class="font-bold">40-60 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Спеціальна крихка упаковка</span>
            <span class="font-bold">30-80 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Контроль видимих дефектів</span>
            <span class="font-bold">Включено</span>
          </li>
          <li class="flex justify-between">
            <span>Спеціалізована доставка (до 50 км)</span>
            <span class="font-bold">150-300 грн</span>
          </li>
          <li class="flex justify-between">
            <span>100% страховка</span>
            <span class="font-bold">Включено</span>
          </li>
        </ul>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Приклад: Магазин прикрас дому (80 замовлень/місяц)</h3>
        <p class="text-gray-700">
          Комплектація: 80 × 50 = 4,000 грн<br/>
          Упаковка спеціальна: 80 × 55 = 4,400 грн<br/>
          Доставка спеціалізована: 80 × 225 = 18,000 грн<br/>
          Складування: 2 палі × 400 = 800 грн<br/>
          <strong class="text-lg">ВСЬОГО: 27,200 грн/месяц = 340 грн/замовлення</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Quality Guarantee -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Гарантія якості для предметів інтер\'єру</h2>
      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% контроль видимих дефектів</p>
            <p class="text-gray-700">Кожна позиція перевіряється на царапини, skolи, забруднення. Якщо дефект — повідомляємо клієнтові перш ніж відправити товар.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Максимальна амортизація при доставці</p>
            <p class="text-gray-700">&lt;0.5% браку при доставці. Дзеркала, дзеркала, картини доставляються розпрямленими, без пошкоджень. Максимальний захист.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Спеціалізована доставка крихких товарів</p>
            <p class="text-gray-700">Два працівники при розвантаженні. GPS моніторинг. Фото перед & після доставки. Максимальна бережність.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% страховка від пошкоджень</p>
            <p class="text-gray-700">Дзеркало розбилося при доставці — платимо 100%. Миттєва компенсація. Клієнт отримує новий товар без суму.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Логістика для магазинів прикрас дому</h2>
      <p class="text-xl mb-8 opacity-90">
        Максимальна амортизація, 100% контроль видимих дефектів, 100% страховка, спеціалізована доставка.
      </p>
      <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент предметів інтер\'єру
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
