---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент для Гуртових Закупівель: Об\'єм, Масштаб, Контроль';
const description = 'Спеціалізований фулфілмент для гуртових закупівель, оптовиків, розповсюджувачів. Масштабна логістика, автоматизація, контроль інвентаризації, 100% страховка.';
const ogImage = 'https://profm.ua/images/fulfillment-wholesale.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  }
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент для Гуртових Закупівель<br />Масштаб & Ефективність
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Для оптовиків, розповсюджувачів, B2B компаній. Масштабна логістика, автоматизація, контроль інвентаризації, 100% страховка, швидка обробка.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент гуртових закупівель
      </a>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Специфіка гуртових закупівель</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">📦 Великі об\'єми</h3>
          <p class="text-gray-700">10,000+ одиниць на місяць. Потребується масштабна логістика, автоматизація, контроль інвентаризації. Звичайна система не підходить.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🔍 Точна інвентаризація</h3>
          <p class="text-gray-700">Кожна одиниця мусить бути облікована. RFID, баркода, каталог номерів. База даних у реальному часі. Нулева втрата товарів.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">⚡ Швидка обробка</h3>
          <p class="text-gray-700">Гурт замовлення мусять бути обробленими швидко. Потребується автоматизація для комплектації & упаковки. 2-4 години на замовлення.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">💰 Висока вартість</h3>
          <p class="text-gray-700">Гурт замовлення часто вартості 100,000+ грн. Потребується 100% страховка і безпека. Контроль якості на кожному етапі.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Послуги MTP для гуртових закупівель</h2>
      <div class="space-y-4">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Масштабна логістика</h3>
          <p class="text-gray-700">Можемо обробляти 10,000+ одиниць на місяць. Автоматизована система комплектації. Швидка обробка без затримок.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Точна інвентаризація</h3>
          <p class="text-gray-700">RFID теги, баркода, каталог номери. База даних у реальному часі. WMS система для контролю всіх товарів. Нулева втрата.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Швидка комплектація</h3>
          <p class="text-gray-700">Середня комплектація гурт замовлення — 2-4 години. Автоматизована система. Персонал навчений на швидкість & точність.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ 100% контроль якості</h3>
          <p class="text-gray-700">Кожна партія перевіряється. Контроль відповідності, цілісності, якості. 99.9% точність на гурт замовлення.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Ціни для гуртових закупівель</h2>
      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-4">Комплектація & Доставка</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Комплектація гурт замовлення</span>
            <span class="font-bold">2-4 грн/одиниця</span>
          </li>
          <li class="flex justify-between">
            <span>Інвентаризація & контроль</span>
            <span class="font-bold">Включено</span>
          </li>
          <li class="flex justify-between">
            <span>Складування (за палю/месяц)</span>
            <span class="font-bold">300-500 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Доставка (регіони)</span>
            <span class="font-bold">0.5-1 грн/км</span>
          </li>
          <li class="flex justify-between">
            <span>100% страховка</span>
            <span class="font-bold">Включено</span>
          </li>
        </ul>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Приклад: Оптовик (50,000 одиниць/місяц)</h3>
        <p class="text-gray-700">
          Комплектація: 50,000 × 3 = 150,000 грн<br/>
          Складування: 10 палів × 400 = 4,000 грн<br/>
          Доставка регіони: 50,000 × 0.75 км × 1 грн = 37,500 грн<br/>
          <strong class="text-lg">ВСЬОГО: 191,500 грн/месяц = 3.83 грн/одиниця</strong>
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Гарантія якості</h2>
      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">99.9% точність комплектації</p>
            <p class="text-gray-700">Для гурт замовлень 50,000+ одиниць — 99.9% точність. Максимальна точність при масштабних операціях.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% інвентаризація</p>
            <p class="text-gray-700">Кожна одиниця облікована у системі. Нулева втрата. Контроль у реальному часі через WMS & RFID.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lang">100% страховка від пошкоджень</p>
            <p class="text-gray-700">Гурт замовлення вартості 100,000+ грн — 100% страховка. Миттєва компенсація при пошкодженні при доставці.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Логістика для оптовиків & розповсюджувачів</h2>
      <p class="text-xl mb-8 opacity-90">
        Масштабна логістика, точна інвентаризація, швидка комплектація, 100% страховка.
      </p>
      <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент гуртових закупівель
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
