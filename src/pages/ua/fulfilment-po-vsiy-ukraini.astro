---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент по всій Україні: Від Луцька до Сімферополю';
const description = 'Покриття всіх регіонів України — доставка за 24-48 годин. Комплектація, складування, розподіл по всій країні. Єдина логістична мережа MTP.';
const ogImage = 'https://profm.ua/images/fulfillment-ukraine-wide.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  },
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  priceRange: '₴18-₴150'
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент по Всій Україні
        <br />Від Луцька до Мелітополя
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        3 хаб-склади + 30+ партнерів по регіонах = доставка за 24 години в будь-яку точку України. Універсальне покриття країни.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <div class="flex items-center justify-center gap-2">
          <span class="text-yellow-300">✓</span>
          <span>25/24 доставка 24-48 год</span>
        </div>
        <div class="flex items-center justify-center gap-2">
          <span class="text-yellow-300">✓</span>
          <span>Охоплення 50 міст</span>
        </div>
      </div>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Розширитися на всю Україну
      </a>
    </div>
  </section>

  <!-- Coverage Map & Stats -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Охоплення України: 3 Центри + 30+ Партнерів</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-8 rounded shadow-md">
          <div class="text-4xl font-bold text-red-600 mb-2">Київ</div>
          <p class="text-gray-700 font-bold mb-2">Центральний хаб</p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>✓ 3900 м² основної мережі</li>
            <li>✓ 200+ доставок/день</li>
            <li>✓ Розподіл у 15 міст</li>
          </ul>
        </div>
        <div class="bg-white p-8 rounded shadow-md">
          <div class="text-4xl font-bold text-red-600 mb-2">Харків</div>
          <p class="text-gray-700 font-bold mb-2">Східний вузол</p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>✓ 2000 м² складу</li>
            <li>✓ Охоплення Донбасу</li>
            <li>✓ Кумислаж + Кривий Ріг</li>
          </ul>
        </div>
        <div class="bg-white p-8 rounded shadow-md">
          <div class="text-4xl font-bold text-red-600 mb-2">Львів</div>
          <p class="text-gray-700 font-bold mb-2">Західний хаб</p>
          <ul class="text-sm text-gray-600 space-y-1">
            <li>✓ 2500 м² складу</li>
            <li>✓ Розповсюджування на Захід</li>
            <li>✓ ЕУ кордони 200км</li>
          </ul>
        </div>
      </div>

      <div class="bg-white p-8 rounded border-l-4 border-red-600">
        <h3 class="text-2xl font-bold mb-4">Сітка доставки по регіонах</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 text-sm">
          <div>
            <p class="font-bold text-red-600">Центр (24 год)</p>
            <ul class="text-gray-700 space-y-1 mt-2">
              <li>Київ</li>
              <li>Київська обл.</li>
              <li>Чернігів</li>
            </ul>
          </div>
          <div>
            <p class="font-bold text-red-600">Схід (36 год)</p>
            <ul class="text-gray-700 space-y-1 mt-2">
              <li>Харків</li>
              <li>Полтава</li>
              <li>Кумислаж</li>
            </ul>
          </div>
          <div>
            <p class="font-bold text-red-600">Південь (48 год)</p>
            <ul class="text-gray-700 space-y-1 mt-2">
              <li>Одеса</li>
              <li>Миколаїв</li>
              <li>Херсон</li>
            </ul>
          </div>
          <div>
            <p class="font-bold text-red-600">Захід (24 год)</p>
            <ul class="text-gray-700 space-y-1 mt-2">
              <li>Львів</li>
              <li>Івано-Франківськ</li>
              <li>Тернопіль</li>
            </ul>
          </div>
          <div>
            <p class="font-bold text-red-600">Північний Захід</p>
            <ul class="text-gray-700 space-y-1 mt-2">
              <li>Луцьк</li>
              <li>Ривне</li>
              <li>Хмельницький</li>
            </ul>
          </div>
          <div>
            <p class="font-bold text-red-600">Дніпропетровськ</p>
            <ul class="text-gray-700 space-y-1 mt-2">
              <li>Дніпро</li>
              <li>Кривий Ріг</li>
              <li>Запоріжжя</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Network Strategy -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Як MTP охоплює всю Україну</h2>
      <div class="space-y-8">
        <div class="flex gap-8 items-start">
          <div class="bg-red-600 text-white rounded-full w-20 h-20 flex items-center justify-center flex-shrink-0">
            <span class="text-3xl font-bold">1</span>
          </div>
          <div>
            <h3 class="text-2xl font-bold mb-3">Три центральні хаби</h3>
            <p class="text-gray-700">Київ, Харків, Львів — це «трикутник» щодо українського ринку. З цих трьох точок достигаємо 95% населення за 24-48 годин. Більша частина замовлень проходить через Київ.</p>
          </div>
        </div>
        <div class="flex gap-8 items-start">
          <div class="bg-red-600 text-white rounded-full w-20 h-20 flex items-center justify-center flex-shrink-0">
            <span class="text-3xl font-bold">2</span>
          </div>
          <div>
            <h3 class="text-2xl font-bold mb-3">Распределительні центри в регіонах</h3>
            <p class="text-gray-700">Для місто з населенням &gt; 100K ми маємо партнера, який приймає замовлення від нас. Це дозволяє прокладати доставку на остаток як від центрального хаба, так і від регіональної ТЦ.</p>
          </div>
        </div>
        <div class="flex gap-8 items-start">
          <div class="bg-red-600 text-white rounded-full w-20 h-20 flex items-center justify-center flex-shrink-0">
            <span class="text-3xl font-bold">3</span>
          </div>
          <div>
            <h3 class="text-2xl font-bold mb-3">Синхронізована WMS по всій мережі</h3>
            <p class="text-gray-700">Запас у Києві рівний запасу у Львові у реальному часі. Якщо замовлення в Одесі — система розумна вибирає найближчий хаб і передає. Один API для всієї України.</p>
          </div>
        </div>
        <div class="flex gap-8 items-start">
          <div class="bg-red-600 text-white rounded-full w-20 h-20 flex items-center justify-center flex-shrink-0">
            <span class="text-3xl font-bold">4</span>
          </div>
          <div>
            <h3 class="text-2xl font-bold mb-3">Управління запасами по хабах</h3>
            <p class="text-gray-700">Великі партії товару розподіляються автоматично по хабам на основі попиту. Мода до Львова розходиться швидше — направляємо більше. Це зменшує логістичні витрати і прискорює доставку.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Regional Advantages -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Переваги мережевого охоплення</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Економія на доставці</h3>
          <p class="text-gray-700">Оптова ставка доставки — в 2-3 рази дешевше за індивідуальні замовлення. За рахунок обсягу ми збираємо до 50 замовлень в один рейс на регіон.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">SLA гарантія по країні</h3>
          <p class="text-gray-700">Гарантуємо доставку за 24 году до Києва/Харкова/Львова і за 48 годин до світу 50+ міст. Якщо запізнилися — повертаємо доставку.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Єдиний інтерфейс управління</h3>
          <p class="text-gray-700">Не потрібно розраховуватися з 10 різними логістами. Один договір з MTP, один API, один інтерфейс на весь обсяг по країні.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Масштабування без затримок</h3>
          <p class="text-gray-700">Якщо обсяги виросли на 200% — це не проблема. Мережа вже розрахована на 10-кратне подорожання. Додаємо ємність без відмов SLA.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Delivery Times Table -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Тривалість доставки за регіонами</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="border p-4 text-left">Регіон</th>
              <th class="border p-4 text-center">Велика міста</th>
              <th class="border p-4 text-center">Малі міста (&lt;50K)</th>
              <th class="border p-4 text-center">Райцентри</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border p-4 font-bold">Центр (від Київа)</td>
              <td class="border p-4 text-center">24 од</td>
              <td class="border p-4 text-center">24-36 од</td>
              <td class="border p-4 text-center">36-48 од</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4 font-bold">Захід (від Львова)</td>
              <td class="border p-4 text-center">24 од</td>
              <td class="border p-4 text-center">24-36 од</td>
              <td class="border p-4 text-center">36-48 од</td>
            </tr>
            <tr>
              <td class="border p-4 font-bold">Схід (від Харкова)</td>
              <td class="border p-4 text-center">24 од</td>
              <td class="border p-4 text-center">24-36 од</td>
              <td class="border p-4 text-center">36-48 од</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4 font-bold">Південь</td>
              <td class="border p-4 text-center">36 од</td>
              <td class="border p-4 text-center">36-48 од</td>
              <td class="border p-4 text-center">48-60 од</td>
            </tr>
            <tr>
              <td class="border p-4 font-bold bg-red-50">Експрес (платний) +50%</td>
              <td class="border p-4 text-center bg-red-50">12 од</td>
              <td class="border p-4 text-center bg-red-50">12-24 од</td>
              <td class="border p-4 text-center bg-red-50">24 од</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Приклади щодо мережі MTP</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold text-red-600 mb-3">🌍 Продавець, який розширяється</h3>
          <p class="text-gray-700">Проданиці в Києві &gt; 500 замовлень. Бажаємо розшириться на Харків, Львів, Одесу. Замість наймання 3 менеджерів — підключуємося до MTP і маємо доставку по всій країні за 48 годин.</p>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold text-red-600 mb-3">📦 B2B дистрибьютор</h3>
          <p class="text-gray-700">Розподілюємо товар по регіонах. Замість утримання складів у 10 містах — один головний склад (хаб MTP) та синхронізація по мережі. Экономія на персоналі та оренді.</p>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold text-red-600 mb-3">🎯 Маркетплейс-партнер</h3>
          <p class="text-gray-700">Продаємо на Rozetka в усіх регіонах. Потребує сертифікованої логістики по країні. MTP має всю інфраструктуру — підключилися і можемо розширюватися без обмежень географії.</p>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold text-red-600 mb-3">💼 Мультиканальна торгівля</h3>
          <p class="text-gray-700">Один товар продаємо в своєму магазині + Rozetka + Prom + Інстаграм. Один склад (MTP) синхронізується з усіма каналами. Не потрібно управляти запасами вручну.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Єдина ціна для всієї України</h2>
      <div class="bg-white p-8 rounded border-l-4 border-red-600 mb-8">
        <h3 class="text-2xl font-bold mb-6">Базові послуги (незалежно від регіону)</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Комплектація замовлення</span>
            <span class="font-bold">18-30 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Складування паль (місячне)</span>
            <span class="font-bold">400 грн/паль</span>
          </li>
          <li class="flex justify-between">
            <span>Доставка до основного міста регіону</span>
            <span class="font-bold">50-100 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Доставка до малого міста/райцентру</span>
            <span class="font-bold">100-150 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Синхронізація запасів (API) по мережі</span>
            <span class="font-bold">Безкоштовно</span>
          </li>
        </ul>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-red-50 p-6 rounded border border-red-200">
          <h3 class="text-lg font-bold mb-4">Для малого продавця (100-300 замовлень)</h3>
          <p class="text-gray-700 mb-4">
            <strong>Середня вартість логістики:</strong> 40-50 грн за замовлення (включно доставку по країні)
          </p>
          <p class="text-sm text-gray-600">Один контракт, один API, безмежна географія</p>
        </div>
        <div class="bg-blue-50 p-6 rounded border border-blue-200">
          <h3 class="text-lg font-bold mb-4">Для grandes (1000+ замовлень)</h3>
          <p class="text-gray-700 mb-4">
            <strong>Оптова ставка:</strong> 25-35 грн за замовлення (від 1000 в місяц)
          </p>
          <p class="text-sm text-gray-600">Договір на знижки по обсягам + dedicted менеджер</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">FAQ: Охоплення по Україні</h2>
      <div class="space-y-6">
        <details class="bg-white p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Чи охоплюєте ви всі міста України?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Прямо доставляємо до 50+ міст. До райцентрів &lt;50K населення — через партнерські сітки. Якщо міста немає в стандартному списку — можемо домовитися про спеціальну маршрут за +30% до вартості.</p>
        </details>
        <details class="bg-white p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Чи змінюється ціна залежно від регіону?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Базова вартість одна — 18-30 грн комплектація + 50-150 грн доставка. Доставка варіюється залежно від відстані (до Киева дешевше, до Мелітополя дорожче). Синхронізація по мережі не впливає на ціни — вона «невидимо» працює в фоні.</p>
        </details>
        <details class="bg-white p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Як MTP керує запасами по різних хабах?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Алгоритм автоматично розподіляє товари на основі попиту. Якщо замовлення чаще приходять з Львова — автоматично більше товару йде туди. Ти не керуєш цим вручну — все робиться в фоні через API.</p>
        </details>
        <details class="bg-white p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Що робиться, якщо товар недоступний на найближчому хабі?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Система знаходить товар на іншому хабі (цей процес в т.ч. 12-24 години). Якщо необхідна прискорена доставка — пропонуємо експрес-маршрут або перепрацьовуємо замовлення на більш-менш доступне разкізшєння.</p>
        </details>
        <details class="bg-white p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Чи гарантуєте ви SLA по країні?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Гарантуємо 99% доставки в обіцяні терміни. Якщо запізнилися — першу доставку робимо безкоштовно. Для критичних замовлень (експрес) — платите +50% і отримуєте доставку за 12 годин в межі країни.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Вийти на весь ринок України</h2>
      <p class="text-xl mb-8 opacity-90">
