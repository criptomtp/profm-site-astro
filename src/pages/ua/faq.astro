  ogImage="https://www.fulfillmentmtp.com.ua/images/faq-hero.webp"
  schema={`<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Що таке фулфілмент?","acceptedAnswer":{"@type":"Answer","text":"Фулфілмент — це комплекс послуг на складі: приймання товару, його зберігання, збір замовлень і відправка покупцям. Замість того щоб займатися логістикою самому, ви передаєте це нам, а самі займаєтесь маркетингом і продажами."}},{"@type":"Question","name":"Чи можу я скористатися фулфілментом MTP, якщо я apenas почав бізнес?","acceptedAnswer":{"@type":"Answer","text":"Так. Мінімальний щомісячний платіж становить 5 000 грн. Якщо вартість послуг менше, ви все одно платите мінімум. Це дозволяє стартапам почати з MTP без великих витрат на налаштування власного складу."}},{"@type":"Question","name":"Як розраховується вартість фулфілменту?","acceptedAnswer":{"@type":"Answer","text":"Вартість складається з трьох компонентів: (1) зберігання товару — 650 грн за м³ на місяць, (2) відправка замовлення — від 18 до 26 грн (залежить від кількості замовлень на день), (3) додаткові послуги (доукомплектація, стікерування та інше). Усього порівнюється з мінімальним платежем 5 000 грн/місяц, і беремо більше значення."}},{"@type":"Question","name":"Яка мінімальна кількість замовлень на добу для роботи з MTP?","acceptedAnswer":{"@type":"Answer","text":"Немає мінімальної кількості замовлень. Навіть якщо ви маєте 1-2 замовлення на день, ми вас обслуговуватимемо по динамічному тарифу: 26 грн за замовлення (при 0-5 замовлень на день). Однак на більші обсяги ви отримаєте знижку: від 200+ замовлень на день тариф падає до 18 грн."}},{"@type":"Question","name":"Яка ціна палетного зберігання?","acceptedAnswer":{"@type":"Answer","text":"Палетне зберігання розраховується як звичайне зберігання: 650 грн за м³ на місяць. Крім того, за формування палети (стрейчування) ми беремо 350 грн (включено вартість палети). Це залежить від того, хочете ви зберігання окремих одиниць чи цілі палети."}},{"@type":"Question","name":"Яка вартість доукомплектації?","acceptedAnswer":{"@type":"Answer","text":"Доукомплектація (додавання додаткового товару при збір замовлення) коштує 2,50 грн за одиницю. Це дозволяє чітко контролювати витрати при вкладанні листівок, пробників, подарунків та інших матеріалів до посилки."}},{"@type":"Question","name":"Скільки часу вам потрібно, щоб зібрати і відправити замовлення?","acceptedAnswer":{"@type":"Answer","text":"Усереднений час збору одного замовлення становить 30 секунд. Замовлення обробляються 4 рази на день, тому ваш товар може бути відправлений в день отримання замовлення від клієнта."}},{"@type":"Question","name":"Чи скажете ви від себе товар перевізнику чи клієнти дають трек на вас?","acceptedAnswer":{"@type":"Answer","text":"Ми передаємо товар від вас. Клієнти натискають кнопку 'Замовити' в вашому магазині, платять вам, і замовлення потрапляє прямо до нас на склад через API. Ми збираємо його і відправляємо в Нову Пошту, а потім той доставляє до клієнта."}},{"@type":"Question","name":"Яка ваша доступність для інтеграції з моїм магазином?","acceptedAnswer":{"@type":"Answer","text":"Ми інтегруємося за 2 години з будь-яким популярним CRM/магазином: Rozetka, Prom.ua, Shopify, WooCommerce, OpenCart, Bitrix1C та іншими. API дозволяє автоматично синхронізувати залишки, замовлення та статуси."}},{"@type":"Question","name":"Чи сумісна ваша система з Zapier?","acceptedAnswer":{"@type":"Answer","text":"Так. Наш API сумісний з Zapier, тому ви можете автоматизувати багато процесів через популярні інтеграції без прямого кодування."}},{"@type":"Question","name":"Як я переглядаю залишки товару в реальному часі?","acceptedAnswer":{"@type":"Answer","text":"Маєте два способи: (1) офіційний кабінет MTP — в реальному часі бачите залишки, замовлення, розрахунки; (2) Telegram-бот (@MTPGroupFulfillment_bot) — вам приходять сповіщення про нові замовлення, платежі від перевізників та статуси обробки."}},{"@type":"Question","name":"Чи є відділення у інших містах, крім Бориспіля?","acceptedAnswer":{"@type":"Answer","text":"Основні склади розташовані у Бориспілі (біля аеропорту) та Білогородці (Київська область). Географічна диверсифікація гарантує, що при форс-мажорі на одній локації інша продовжує роботу. Ми також готуємо третій склад у Щасливому."}},{"@type":"Question","name":"Чи надаєте ви послуги лікування FEFO для фармації та косметики?","acceptedAnswer":{"@type":"Answer","text":"Так. Для товарів з обмеженим терміном дії (косметика, БАДи, лікарські засоби) ми застосовуємо FEFO контроль (First Expiry First Out). Тариф — 0,50 грн за одиницю. Це гарантує, що товар відпускається у порядку наближення терміну дійсності."}},{"@type":"Question","name":"Чи включена обробка повернень у фулфілмент?","acceptedAnswer":{"@type":"Answer","text":"Так. Розпаковка та обробка повернених товарів включена у послугу. Вартість розпаковки становить 50% від вартості (відправка + доукомплектація). Чи потрібно утилізувати товар чи повернути його вам на склад — обговорюється в договорі."}},{"@type":"Question","name":"Чи можна відправляти товари на адрес замовника, різні від адреси чергової доставки?","acceptedAnswer":{"@type":"Answer","text":"Так. Ви можете вказати різні адреси доставки для кожного замовлення. Ми обробимо таке замовлення правильно через API."}},{"@type":"Question","name":"Чи обробляєте ви замовлення, що надходять вночі?","acceptedAnswer":{"@type":"Answer","text":"Так. Ми працюємо 24/7, включаючи вихідні та святки. Замовлення обробляються 4 рази на день, тому навіть якщо замовлення прийшло вночі, воно буде зібрано й відправлено виконавцю наступного ранку."}},{"@type":"Question","name":"Як ви контролюєте точність комплектації?","acceptedAnswer":{"@type":"Answer","text":"WMS-система мінімізує людський фактор на 99%: кожна позиція сканується штрихкодом, система підказує де взяти товар, і кінцевий контроль перед відправкою гарантує, що все правильно. У разі помилки ми компенсуємо витрати."}},{"@type":"Question","name":"Чи видається гарантійний талон при відправці?","acceptedAnswer":{"@type":"Answer","text":"Так. Якщо у вас є гарантійні талони, ми їх заповнюємо (5 грн за талон) і вкладаємо в посилку. Це критично для техніки, гаджетів та інших гарантованих товарів."}},{"@type":"Question","name":"Чи включена фіскалізація чеків РРО?","acceptedAnswer":{"@type":"Answer","text":"Так. Ми проводимо фіскалізацію кожного замовлення через РРО (реєстратор розрахункових операцій). Покупець отримує чек з номером — ви працюєте в рамках закону без власного касового апарату."}},{"@type":"Question","name":"Як набирається статистика, якщо у вас нескільки каналів продажу?","acceptedAnswer":{"@type":"Answer","text":"Залишки синхронізуються централізовано: якщо товар є у вас на складі у MTP, то і на Rozetka, і на Prom.ua, і у вашому магазині бачитимуть правильні залишки. Це запобігає перепродажам і скаргам клієнтів."}},{"@type":"Question","name":"Чи можна здійснити тестування перед підписанням договору?","acceptedAnswer":{"@type":"Answer","text":"Так. Пропонуємо безкоштовний тестовий період: прихистіть 5-10 замовлень для перевірки якості роботи. Це допоможе вам переконатися у нашій надійності до офіційного запуску."}},{"@type":"Question","name":"Як щось не так з замовленням — яким чином ми вирішуємо конфлікти?","acceptedAnswer":{"@type":"Answer","text":"Офіційний договір SLA чітко описує процес. Якщо при комплектації допущена помилка, ми компенсуємо вартість товару. Матеріальна відповідальність зафіксована в договорі, все відбувається прозоро."}},{"@type":"Question","name":"Який мінімальний розмір замовлення палет?","acceptedAnswer":{"@type":"Answer","text":"Немає мінімального розміру палети. Ви можете складувати половину палети, чверть палети та інше. Розраховується все по обсягу (м³), тому гнучко підходить навіть малим партіям."}},{"@type":"Question","name":"Чи можете ви обробляти замовлення з кількома адресами доставки?","acceptedAnswer":{"@type":"Answer","text":"Так. B2B або корпоративні замовлення з кількома точками доставки обробляються як окремі замовлення з різними адресами. Система автоматично розділяє посилки."}},{"@type":"Question","name":"Які способи оплати у вас за послуги?","acceptedAnswer":{"@type":"Answer","text":"Ми приймаємо банківські переводи, карти, поточні рахунки. На кінець місяця ми надаємо рахунок на ваше найменування (якщо вам потрібна ФОП чи ЮЛ). Реквізити обговорюються в договорі."}},{"@type":"Question","name":"Можу я у будь-якої миттю розійтися з MTP?","acceptedAnswer":{"@type":"Answer","text":"Так. Договір дозволяє розірвати у будь-який момент за письмовим зверненням. Товар, що залишився на складі, ми можемо видати вам назад або упакувати для доставки адресатові."}},{"@type":"Question","name":"Чи є у вас готові шаблони для інтеграції через Webhooks?","acceptedAnswer":{"@type":"Answer","text":"Так. Для розробників у нас є REST API з повною документацією та примерами коду для Python, PHP та JavaScript. Webhooks дозволяють отримувати сповіщення про статусі замовлення в реальному часі."}},{"@type":"Question","name":"Як часто я отримую звіти про роботу?","acceptedAnswer":{"@type":"Answer","text":"Звіти доступні в кабінеті в реальному часі: кількість зібраних замовлень, вартість послуг, залишки товару. Також щомісяця ми надаємо детальний звіт за запитом (у форматі Excel або CSV)."}},{"@type":"Question","name":"Як взяти участь у програмі партнерства чи рефералу?","acceptedAnswer":{"@type":"Answer","text":"Ми надаємо комісійну схему для партнерів, які приносять нових клієнтів. Обговоріть деталі з нашим sales-відділом: +38 (050) 144-46-45."}},{"@type":"Question","name":"Як часто оновляються ціни?","acceptedAnswer":{"@type":"Answer","text":"Тарифи встановлені на весь 2026 рік (із ступня 01.01.2026). Якщо буде необхідність змінити, ми повідомимо за 30 днів до вступу в силу нових умов."}},{"@type":"Question","name":"Чи можемо ми обговорити спеціальні умови для великих партій?","acceptedAnswer":{"@type":"Answer","text":"Так. Для клієнтів з обсягом 500+ замовлень на місяць ми готові обговорити персональну цінову пропозицію та спеціальні умови. Зв'яжіться з менеджером: mtpgrouppromo@gmail.com."}}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","logo":"https://www.fulfillmentmtp.com.ua/images/mtp-logo.webp","sameAs":["https://www.instagram.com/mtp_group/","https://www.facebook.com/fulfillmentmtp"],"address":{"@type":"PostalAddress","addressLocality":"Бориспіль","addressRegion":"Київська область","addressCountry":"UA"},"telephone":"+380501444645"}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Головна","item":"https://www.fulfillmentmtp.com.ua/"},{"@type":"ListItem","position":2,"name":"FAQ","item":"https://www.fulfillmentmtp.com.ua/ua/faq/"}]}</script>`}
