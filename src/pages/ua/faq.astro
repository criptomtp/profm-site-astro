  schema={`<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Що таке фулфілмент?","acceptedAnswer":{"@type":"Answer","text":"Фулфілмент — це комплекс послуг на складі: приймання товару, його зберігання, збір замовлень і відправка покупцям. Замість того щоб займатися логістикою самому, ви передаєте це нам, а самі займаєтесь маркетингом і продажами."}},{"@type":"Question","name":"Скільки коштує фулфілмент у MTP?","acceptedAnswer":{"@type":"Answer","text":"Відправка від 18 до 26 грн/замовлення (динамічний тариф). Зберігання 650 грн/м³/міс. Мінімальний платіж 5 000 грн/міс."}},{"@type":"Question","name":"Чи є мінімальна кількість замовлень?","acceptedAnswer":{"@type":"Answer","text":"Немає мінімуму. Працюємо від 1 до 6 000 замовлень/день. Мінімальний платіж — 5 000 грн/міс."}},{"@type":"Question","name":"Як швидко збирається замовлення?","acceptedAnswer":{"@type":"Answer","text":"Середній час збору — 30 секунд. Замовлення обробляються 4 рази на день."}},{"@type":"Question","name":"З якими маркетплейсами працюєте?","acceptedAnswer":{"@type":"Answer","text":"Rozetka, Prom.ua, Kasta, OLX, Shopify, WooCommerce, OpenCart. CRM: KeyCRM, SalesDrive, LP-CRM. Інтеграція за 2 години."}}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Головна","item":"https://www.fulfillmentmtp.com.ua/"},{"@type":"ListItem","position":2,"name":"FAQ","item":"https://www.fulfillmentmtp.com.ua/ua/faq/"}]}</script>`}
