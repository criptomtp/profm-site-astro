<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.faq-card__q').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var card = this.closest('.faq-card');
      var wasActive = card.classList.contains('active');
      var block = card.closest('.faq-block');
      block.querySelectorAll('.faq-card.active').forEach(function(c) { c.classList.remove('active'); });
      if (!wasActive) card.classList.add('active');
    });
  });

  var links = document.querySelectorAll('.faq-nav__link');
  var blocks = document.querySelectorAll('.faq-block');
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) {
        links.forEach(function(l) { l.classList.remove('faq-nav__link--active'); });
        var target = document.querySelector('.faq-nav__link[href="#' + e.target.id + '"]');
        if (target) target.classList.add('faq-nav__link--active');
      }
    });
  }, { rootMargin: '-40% 0px -60% 0px' });
  blocks.forEach(function(b) { obs.observe(b); });
});
</script>

