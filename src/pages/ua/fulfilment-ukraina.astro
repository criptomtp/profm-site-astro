@media(max-width:768px){
.nav-links{display:none}
.counters{gap:24px}
.proof-grid,.tariff-grid{grid-template-columns:1fr}
.case-grid{grid-template-columns:1fr;text-align:center}
.case-arrow{transform:rotate(90deg)}
}
