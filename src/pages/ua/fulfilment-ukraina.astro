.case-arrow{font-size:48px;color:#e63329;text-align:center}
.case-quote{text-align:center;font-family:'DM Serif Display',Georgia,serif;font-size:clamp(18px,2.5vw,26px);font-style:italic;margin-top:48px;color:rgba(255,255,255,.75);max-width:580px;margin-left:auto;margin-right:auto}
