.faq-list{max-width:760px;margin:0 auto}
.faq-item{border-bottom:1px solid #e0e0e0}
.faq-item summary{padding:18px 0;font-size:16px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none}
