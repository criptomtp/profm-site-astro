.fu-label{font-size:13px;text-transform:uppercase;letter-spacing:.1em;opacity:.7}
.hero-note{margin-top:12px;font-size:13px;opacity:.6}

/* PROOF */
.fu-proof{padding:80px 0;background:#fafafa}
.fu-proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;margin:40px 0}
.fu-proof-card{background:#fff;border-radius:16px;padding:40px 32px;text-align:center;box-shadow:0 2px 20px rgba(0,0,0,.06)}
.fu-proof-icon{font-size:48px;margin-bottom:16px}
.fu-proof-card h3{font-size:20px;margin:0 0 12px}
.fu-proof-card p{font-size:15px;color:#555;line-height:1.7}
.fu-proof-result{text-align:center;margin-top:48px;padding:32px;background:#000;border-radius:16px;color:#fff}
.fu-result-num{font-family:'DM Serif Display','Georgia',serif;font-size:96px;color:#e63329;line-height:1}
.fu-result-text{font-size:18px;margin-top:8px;opacity:.8}

/* PRICING */
.fu-pricing{padding:80px 0}
.fu-tariff-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:40px}
.fu-tariff-card{background:#fafafa;border-radius:16px;padding:40px 28px;border:2px solid transparent}
.fu-tariff-main{border-color:#e63329;background:#fff;box-shadow:0 4px 24px rgba(230,51,41,.12)}
.fu-tariff-name{font-size:13px;text-transform:uppercase;letter-spacing:.1em;color:#888;margin-bottom:8px}
.fu-tariff-price{font-family:'DM Serif Display','Georgia',serif;font-size:42px;margin-bottom:20px}
.fu-tariff-price span{font-size:16px;font-family:'DM Sans',sans-serif;color:#888}
.fu-tariff-card ul{list-style:none;padding:0;margin:0}
.fu-tariff-card li{padding:8px 0;border-bottom:1px solid #eee;font-size:15px;color:#444}
.fu-tariff-card li::before{content:'✓ ';color:#e63329;font-weight:700}
.fu-tariff-scale{margin-top:20px;padding-top:16px;border-top:2px solid #eee}
.fu-scale-row{display:flex;justify-content:space-between;padding:6px 0;font-size:14px;color:#666}
.fu-scale-row strong{color:#000}

/* CASE */
.fu-case{padding:80px 0;background:#000;color:#fff}
.fu-case-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:32px;align-items:center;margin:40px 0}
.fu-case-before,.fu-case-after{padding:32px;border-radius:16px}
.fu-case-before{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1)}
.fu-case-after{background:rgba(230,51,41,.1);border:1px solid rgba(230,51,41,.3)}
.fu-case-before h3,.fu-case-after h3{font-size:14px;text-transform:uppercase;letter-spacing:.1em;margin:0 0 20px;opacity:.6}
.fu-case-stat{margin-bottom:12px;font-size:15px;color:rgba(255,255,255,.7)}
.fu-case-stat span{font-family:'DM Serif Display','Georgia',serif;font-size:36px;display:block;color:#fff;line-height:1.1}
.fu-stat-green span{color:#e63329}
.fu-case-arrow{font-size:48px;color:#e63329;text-align:center}
.fu-case-before p,.fu-case-after p{font-size:14px;color:rgba(255,255,255,.5);line-height:1.6;margin:16px 0 0}
.fu-case-quote{text-align:center;font-family:'DM Serif Display','Georgia',serif;font-size:clamp(20px,3vw,28px);font-style:italic;margin-top:48px;color:rgba(255,255,255,.8);max-width:600px;margin-left:auto;margin-right:auto}

/* COMPARE */
.fu-compare{padding:80px 0;background:#fafafa}
.fu-compare-wrap{overflow-x:auto;margin-top:40px}
.fu-table{width:100%;border-collapse:collapse;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.fu-table th{background:#000;color:#fff;padding:16px 24px;text-align:left;font-size:14px;text-transform:uppercase;letter-spacing:.05em}
.fu-table td{padding:14px 24px;border-bottom:1px solid #eee;font-size:15px}
.fu-table tr:last-child td{border-bottom:0}
.fu-total td{background:#f0f0f0;font-weight:700}
.fu-save-badge{text-align:center;margin-top:24px;display:inline-block;background:#e63329;color:#fff;padding:12px 32px;border-radius:100px;font-weight:700;font-size:18px;width:100%;max-width:400px;margin-left:auto;margin-right:auto;display:block;margin-left:auto;margin-right:auto}

/* FAQ */
.fu-faq{padding:80px 0}
.faq-list{max-width:760px;margin:40px auto 0}
.faq-item{border-bottom:1px solid #e0e0e0}
.faq-item summary{padding:20px 0;font-size:17px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary span{font-size:24px;color:#e63329;transition:transform .3s}
.faq-item[open] summary span{transform:rotate(45deg)}
.faq-body{padding:0 0 20px;font-size:15px;line-height:1.7;color:#555}

/* SEO ARTICLE */
.fu-article{padding:80px 0;background:#fafafa}
.fu-seo-text{max-width:760px;margin:0 auto}
.fu-seo-text h2{font-family:'DM Serif Display','Georgia',serif;font-size:32px;margin:0 0 20px}
.fu-seo-text h3{font-size:22px;margin:32px 0 12px}
.fu-seo-text p{font-size:16px;line-height:1.8;color:#444;margin:0 0 16px}

/* CTA */
.fu-cta{padding:80px 0;background:#000;color:#fff;text-align:center}
.fu-cta h2{font-family:'DM Serif Display','Georgia',serif;font-size:clamp(28px,4vw,42px);margin:0 0 12px}
.fu-cta p{opacity:.7;margin-bottom:32px;font-size:18px}
.fu-cta-phones{margin-top:24px;display:flex;gap:24px;justify-content:center;flex-wrap:wrap}
.fu-cta-phones a{color:#e63329;font-size:18px;font-weight:600;text-decoration:none}

/* SHARED */
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.sec-h2{font-family:'DM Serif Display','Georgia',serif;font-size:clamp(28px,4vw,42px);text-align:center;margin:0 0 12px}
.sec-sub{text-align:center;color:#888;font-size:17px;margin:0 0 12px;max-width:600px;margin-left:auto;margin-right:auto}
.badge{display:inline-block;font-size:12px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;padding:6px 16px;border:1.5px solid #e63329;border-radius:100px;color:#e63329;margin-bottom:16px}

/* HERO FORM */
.hero-form{display:flex;max-width:440px;margin:0 auto;gap:0;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.2)}
.hero-form input{flex:1;padding:16px 20px;border:0;font-size:16px;font-family:inherit;outline:none;min-width:0}
.hero-form button{padding:16px 28px;background:#e63329;color:#fff;border:0;font-size:15px;font-weight:700;cursor:pointer;white-space:nowrap;transition:background .2s}
.hero-form button:hover{background:#c62b22}

/* MOBILE */
@media(max-width:768px){
.fu-counters{gap:24px}
.fu-proof-grid,.fu-tariff-grid{grid-template-columns:1fr}
.fu-case-grid{grid-template-columns:1fr;text-align:center}
.fu-case-arrow{transform:rotate(90deg)}
.fu-table{font-size:14px}
.fu-table th,.fu-table td{padding:10px 14px}
}
</style>

<script is:inline>
// Counter animation
function animateCounters(){
document.querySelectorAll('.fu-num[data-target]').forEach(function(el){
var target=parseInt(el.dataset.target);var duration=2500;var start=0;var startTime=null;
var suffix=target>=1000?'+':'';
if(target>=1000){var display=Math.round(target/1000);var isK=true;}
function step(ts){
if(!startTime)startTime=ts;
var progress=Math.min((ts-startTime)/duration,1);
var eased=1-Math.pow(1-progress,4);
var current=Math.round(eased*target);
if(isK){el.textContent=Math.round(eased*display)+' 000+';}
else{el.textContent=current+'+';}
if(progress<1)requestAnimationFrame(step);
}
requestAnimationFrame(step);
});
}
var observer=new IntersectionObserver(function(entries){
entries.forEach(function(e){if(e.isIntersecting){animateCounters();observer.disconnect();}});
},{threshold:0.3});
var counters=document.querySelector('.fu-counters');
if(counters)observer.observe(counters);

// Form handler
document.querySelectorAll('.hero-form').forEach(function(form){
form.addEventListener('submit',function(e){
e.preventDefault();
var phone=form.querySelector('input[name="phone"]').value.trim();
if(!phone)return;
fetch('/api/mtp-crm-leads',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:phone,source:'fulfilment-ukraina-ua'})}).catch(function(){});
window.location.href='/ua/thanks/';
});
});
</script>
