function animate(){if(done)return;done=true;
document.querySelectorAll('.counter-num').forEach(function(el){
var t=parseInt(el.dataset.target),d=2500,s=null,k=t>=1000,v=k?Math.round(t/1000):t;
function step(ts){if(!s)s=ts;var p=Math.min((ts-s)/d,1),e=1-Math.pow(1-p,4);
el.textContent=k?Math.round(e*v)+' 000+':Math.round(e*t)+'+';if(p<1)requestAnimationFrame(step);}
requestAnimationFrame(step);});}
var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting)animate();});},{threshold:.3});
var c=document.querySelector('.counters');if(c)obs.observe(c);
})();
