*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{overflow-x:hidden;overflow-y:auto;height:auto;min-height:100vh}
body{font-family:'DM Sans',sans-serif;color:#1a1a1a;line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
img{max-width:100%;height:auto;display:block}
.hdr-spacer{display:none}
.hdr{position:fixed;top:0;left:0;right:0;height:64px;background:#000;z-index:10000;display:flex;align-items:center;padding:0 24px;border-bottom:1px solid rgba(255,255,255,.06)}
.hdr-inner{display:flex;align-items:center;justify-content:space-between;max-width:1400px;width:100%;margin:0 auto}
.hdr-logo{font-family:'DM Serif Display',serif;font-size:20px;color:#fff;text-decoration:none;white-space:nowrap;letter-spacing:1px}
.hdr-logo-mtp{color:#e63329;font-weight:700}
.hdr-nav{display:flex;align-items:center;gap:28px}
.hdr-nav>a{color:rgba(255,255,255,.85);font-size:14px;text-decoration:none;transition:color .2s;font-family:'DM Sans',sans-serif;letter-spacing:.3px}
.hdr-nav>a:hover{color:#fff}
.hdr-dd{position:relative}
.hdr-dd-trigger{background:none;border:none;color:rgba(255,255,255,.85);font-size:14px;cursor:pointer;font-family:'DM Sans',sans-serif;display:flex;align-items:center;gap:4px;padding:0;letter-spacing:.3px}
.hdr-dd-trigger:hover{color:#fff}
.hdr-arrow{font-size:10px;transition:transform .2s}
.hdr-dd.open .hdr-arrow{transform:rotate(180deg)}
.hdr-mega{display:none;position:absolute;top:calc(100% + 14px);left:50%;transform:translateX(-50%);background:#0a0a0a;border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:24px 28px;min-width:460px;box-shadow:0 12px 48px rgba(0,0,0,.6);z-index:10001}
.hdr-mega::before{content:'';position:absolute;top:-6px;left:50%;transform:translateX(-50%);border:6px solid transparent;border-bottom-color:rgba(255,255,255,.08);border-top:none}
.hdr-dd.open .hdr-mega{display:grid;grid-template-columns:1fr 1fr auto;gap:0}
.hdr-mega-col{padding:0 20px;border-right:1px solid rgba(255,255,255,.06)}
.hdr-mega-col:first-child{padding-left:0}
.hdr-mega-col:last-child{padding-right:0;border-right:none}
.hdr-mega-col--cta{display:flex;align-items:flex-end}
.hdr-mega-title{display:block;font-size:10px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:2.5px;margin:0 0 10px;font-weight:600}
.hdr-mega-col a{display:block;padding:6px 0;font-size:14px;color:rgba(255,255,255,.85);white-space:nowrap;text-decoration:none;transition:color .2s,padding-left .2s}
.hdr-mega-col a:hover{color:#fff;padding-left:4px}
.hdr-mega-cta{font-weight:600;color:#fff !important;font-size:13px !important;padding:10px 20px !important;background:rgba(255,255,255,.08);border-radius:8px;text-align:center;transition:background .2s !important}
.hdr-mega-cta:hover{background:rgba(255,255,255,.15) !important;padding-left:20px !important}
.hdr-dd::after{content:'';position:absolute;top:100%;left:0;right:0;height:18px}
.hdr-right{display:flex;align-items:center;gap:16px}
.hdr-right a{color:rgba(255,255,255,.6);font-size:13px;text-decoration:none;transition:color .2s;font-family:'DM Sans',sans-serif;padding:4px 2px}
.hdr-right a:hover,.hdr-right a.active{color:#fff}
.hdr-phone{white-space:nowrap;font-variant-numeric:tabular-nums;color:rgba(255,255,255,.5) !important;font-size:12px !important}
.hdr-burger{display:none;background:none;border:none;cursor:pointer;padding:12px;flex-direction:column;gap:5px;z-index:10001}
.hdr-burger span{display:block;width:24px;height:2px;background:#fff;transition:transform .3s,opacity .3s;border-radius:2px}
.hdr-burger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.hdr-burger.open span:nth-child(2){opacity:0}
.hdr-burger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}
.hdr-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;backdrop-filter:blur(4px)}
.hdr-overlay.open{display:block}
.hdr-mobile-bottom{display:none}
.hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;background:#000}
.hero-bg{position:absolute;inset:0;overflow:hidden;z-index:0}
.hero-bg img{width:100%;height:100%;object-fit:cover;opacity:.35;display:block}
.hero-inner{position:relative;z-index:1;max-width:860px;margin:0 auto;padding:100px 24px 80px;text-align:center;color:#fff}
.badge{display:inline-block;font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;padding:6px 18px;border:1.5px solid #e63329;border-radius:100px;color:#e63329;margin-bottom:20px}
.hero h1{font-family:'DM Serif Display',Georgia,serif;font-size:clamp(32px,6vw,64px);line-height:1.08;margin:0 0 20px;font-weight:400;letter-spacing:-.02em}
.hero-sub{font-size:clamp(16px,2.2vw,19px);color:rgba(255,255,255,.8);max-width:620px;margin:0 auto 40px;line-height:1.65}
.counters{display:flex;justify-content:center;gap:48px;margin-bottom:40px;flex-wrap:wrap}
.counter{text-align:center}
.counter-num{display:block;font-family:'DM Serif Display',Georgia,serif;font-size:clamp(36px,5vw,56px);color:#e63329}
.counter-label{font-size:12px;text-transform:uppercase;letter-spacing:.12em;color:rgba(255,255,255,.5)}
.form-wrap{max-width:440px;margin:0 auto}
.form-row{display:flex;border-radius:12px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.3)}
.form-row input{flex:1;padding:16px 20px;border:0;font-size:16px;font-family:inherit;outline:none;min-width:0}
.form-row button{padding:16px 28px;background:#e63329;color:#fff;border:0;font-size:15px;font-weight:700;cursor:pointer;white-space:nowrap;transition:background .2s}
.form-row button:hover{background:#c62b22}
.form-note{text-align:center;margin-top:10px;font-size:12px;color:rgba(255,255,255,.4)}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.sec{padding:80px 20px;color:#1a1a1a;background:#fff}
.sec-alt{background:#fafafa;color:#1a1a1a}
.sec-dark{background:#000;color:#fff}
.sec h2,.sec-alt h2{color:#000}
.sec p,.sec-alt p{color:#444}
.sec-dark h2{color:#fff}
.sec-dark p{color:rgba(255,255,255,.85)}
.sec-title{font-family:'DM Serif Display',Georgia,serif;font-size:clamp(28px,4vw,42px);text-align:center;margin:0 0 12px;color:#000}
.sec-dark .sec-title{color:#fff}
.sec-sub{text-align:center;color:#888;font-size:16px;max-width:560px;margin:0 auto 40px}
.proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px}
.proof-card{background:#fff;border-radius:16px;overflow:visible;box-shadow:0 2px 16px rgba(0,0,0,.06);transition:transform .3s;min-height:350px}
.proof-card:hover{transform:translateY(-4px)}
.proof-card img{width:100%;height:280px;object-fit:cover;border-radius:16px 16px 0 0;display:block}
.proof-card-body{padding:24px}
.proof-card h3{font-size:18px;margin:0 0 8px;font-weight:700}
.proof-card p{font-size:14px;color:#666;line-height:1.65}
.proof-zero{text-align:center;margin-top:48px;padding:36px;background:#000;border-radius:16px;color:#fff}
.proof-zero-num{font-family:'DM Serif Display',Georgia,serif;font-size:96px;color:#e63329;line-height:1}
.proof-zero-text{font-size:17px;margin-top:4px;color:rgba(255,255,255,.7)}
.tariff-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.tariff-card{background:#fafafa;border-radius:16px;padding:36px 24px;border:2px solid transparent}
.tariff-featured{border-color:#e63329;background:#fff;box-shadow:0 4px 24px rgba(230,51,41,.1)}
.tariff-label{font-size:12px;text-transform:uppercase;letter-spacing:.12em;color:#999;margin-bottom:6px}
.tariff-price{font-family:'DM Serif Display',Georgia,serif;font-size:42px;margin-bottom:20px;line-height:1}
.tariff-price span{font-size:15px;font-family:'DM Sans',sans-serif;color:#999}
.tariff-card ul{list-style:none;padding:0}
.tariff-card li{padding:8px 0;border-bottom:1px solid #eee;font-size:14px;color:#555}
.tariff-card li::before{content:'\2713 ';color:#e63329;font-weight:700}
.tariff-scale{margin-top:16px;padding-top:12px;border-top:2px solid #eee}
.tariff-scale-row{display:flex;justify-content:space-between;padding:5px 0;font-size:13px;color:#777}
.tariff-scale-row strong{color:#1a1a1a}
.case-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:32px;align-items:center}
.case-box{padding:28px;border-radius:16px}
.case-before{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08)}
.case-after{background:rgba(230,51,41,.08);border:1px solid rgba(230,51,41,.2)}
.case-box h3{font-size:12px;text-transform:uppercase;letter-spacing:.12em;margin:0 0 16px;color:rgba(255,255,255,.5)}
.case-metric{margin-bottom:10px;font-size:14px;color:rgba(255,255,255,.6)}
.case-metric span{display:block;font-family:'DM Serif Display',Georgia,serif;font-size:36px;color:#fff;line-height:1.1}
.case-after .case-metric span{color:#e63329}
.case-box p{font-size:13px;color:rgba(255,255,255,.4);line-height:1.6;margin-top:12px}
.case-arrow{font-size:48px;color:#e63329;text-align:center}
.case-quote{text-align:center;font-family:'DM Serif Display',Georgia,serif;font-size:clamp(18px,2.5vw,26px);font-style:italic;margin-top:48px;color:rgba(255,255,255,.75);max-width:580px;margin-left:auto;margin-right:auto}
.compare-wrap{overflow-x:auto}
.compare-table{width:100%;border-collapse:collapse;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 1px 10px rgba(0,0,0,.05)}
.compare-table th{background:#000;color:#fff;padding:14px 20px;text-align:left;font-size:13px;text-transform:uppercase;letter-spacing:.06em}
.compare-table td{padding:13px 20px;border-bottom:1px solid #eee;font-size:14px}
.compare-table tr:last-child td{border:0}
.compare-total td{background:#f0f0f0;font-weight:700}
.compare-badge{display:block;margin:20px auto 0;background:#e63329;color:#fff;padding:12px 32px;border-radius:100px;font-weight:700;font-size:17px;text-align:center;max-width:380px}
.faq-list{max-width:760px;margin:0 auto}
.faq-item{border-bottom:1px solid #e0e0e0}
.faq-item summary{padding:18px 0;font-size:16px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary .faq-icon{font-size:22px;color:#e63329;transition:transform .3s;flex-shrink:0;margin-left:12px}
.faq-item[open] summary .faq-icon{transform:rotate(45deg)}
.faq-body{padding:0 0 18px;font-size:15px;line-height:1.7;color:#666}
.seo-text{max-width:760px;margin:0 auto}
.seo-text h2{font-family:'DM Serif Display',Georgia,serif;font-size:30px;margin:0 0 16px}
.seo-text h3{font-size:20px;margin:28px 0 10px;font-weight:700}
.seo-text p{font-size:15px;line-height:1.8;color:#555;margin:0 0 14px}
.ft{background:#111;color:rgba(255,255,255,.7);padding:60px 24px 30px}
.ft-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:40px;max-width:1200px;margin:0 auto}
.ft h4{color:#fff;font-size:13px;font-weight:500;letter-spacing:1px;text-transform:uppercase;margin-bottom:14px}
.ft p,.ft a{font-size:13px;line-height:2;color:rgba(255,255,255,.5);transition:color .2s}
.ft a:hover{color:#fff}
.ft-bottom{text-align:center;margin-top:36px;padding-top:18px;border-top:1px solid rgba(255,255,255,.06);font-size:12px;color:rgba(255,255,255,.25);max-width:1200px;margin-left:auto;margin-right:auto}
@media(max-width:900px){
.hdr{padding:0 16px}
.hdr-burger{display:flex}
.hdr-right{display:none}
.hdr-nav{position:fixed;top:0;right:-300px;width:300px;max-width:85vw;height:100%;background:#111;flex-direction:column;align-items:stretch;padding:80px 24px 120px;gap:0;z-index:10000;transition:right .3s ease;overflow-y:auto;box-shadow:-4px 0 24px rgba(0,0,0,.6)}
.hdr-nav.open{right:0}
.hdr-nav>a{font-size:17px;padding:16px 0;width:100%;border-bottom:1px solid rgba(255,255,255,.08);color:#fff}
.hdr-dd{width:100%}
.hdr-dd-trigger{font-size:17px;padding:16px 0;width:100%;border-bottom:1px solid rgba(255,255,255,.08);justify-content:space-between;color:#fff}
.hdr-mega{position:static;transform:none;min-width:auto;display:none;border:none;box-shadow:none;background:rgba(255,255,255,.04);border-radius:8px;padding:12px 16px;margin:8px 0}
.hdr-mega::before{display:none}
.hdr-dd.open .hdr-mega{display:block}
.hdr-mega-col{padding:8px 0;border-right:none;border-bottom:1px solid rgba(255,255,255,.04)}
.hdr-mega-col:last-child{border-bottom:none}
.hdr-mega-col a{font-size:15px;padding:10px 0;color:rgba(255,255,255,.8)}
.hdr-mega-cta{background:rgba(230,51,41,.15);margin-top:8px;text-align:center;border-radius:6px;padding:12px 16px !important}
.hdr-mega-col--cta{display:block}
.hdr-mobile-bottom{display:flex;flex-direction:column;gap:12px;margin-top:auto;padding:24px 0;border-top:1px solid rgba(255,255,255,.08)}
.hdr-mobile-langs{display:flex;gap:12px}
.hdr-lang-btn{display:inline-flex;align-items:center;justify-content:center;width:44px;height:44px;border-radius:8px;background:rgba(255,255,255,.06);color:rgba(255,255,255,.7);font-size:14px;font-weight:500;text-decoration:none;transition:background .2s}
.hdr-lang-btn.active{background:#e63329;color:#fff}
.hdr-mobile-phone{display:block;text-align:center;padding:14px;background:rgba(255,255,255,.06);border-radius:8px;color:#fff;text-decoration:none;font-size:16px}
.counters{gap:24px}
.proof-grid,.tariff-grid{grid-template-columns:1fr}
.case-grid{grid-template-columns:1fr;text-align:center}
.case-arrow{transform:rotate(90deg)}
}
.sec,.sec-alt,.sec-dark{display:block;visibility:visible;clip-path:none;opacity:1}
</style>
</head>
