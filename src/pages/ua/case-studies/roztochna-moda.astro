---
import Base from '../../../layouts/Base.astro';

const title = 'Кейс: Як Розтошна Мода Масштабувалась на 600% з MTP Фулфілментом';
const description = 'Історія успіху малого бізнесу. ФОП запустила магазин на Prom.ua, за рік досягла 500+ замовлень на місяць з MTP фулфілментом. +600% виручки, -70% логістичних витрат.';
const ogImage = 'https://profm.ua/images/case-study-roztochna.jpg';

const publishDate = new Date('2024-12-15').toISOString();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Case',
  name: title,
  description: description,
  datePublished: publishDate,
  author: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  }
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <div class="text-sm font-bold uppercase tracking-wider mb-4 opacity-90">Кейс</div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Як Малий Бізнес Вирос на 600%<br />з MTP Фулфілментом
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        ФОП без досвіду логістики запустила магазин на Prom.ua. За рік розповсюдилася в 3 регіони. Виручка +600%, витрати на логістику -70%.
      </p>
    </div>
  </section>

  <!-- Company Profile -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Профіль компанії</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded">
          <p class="text-sm text-gray-600 mb-2">Тип бізнесу</p>
          <p class="text-2xl font-bold">ФОП</p>
          <p class="text-gray-700 text-sm mt-2">Розтошна Мода — продаж женської моди</p>
        </div>
        <div class="bg-white p-6 rounded">
          <p class="text-sm text-gray-600 mb-2">Заснована</p>
          <p class="text-2xl font-bold">2022</p>
          <p class="text-gray-700 text-sm mt-2">Стартувала на власному сайті</p>
        </div>
        <div class="bg-white p-6 rounded">
          <p class="text-sm text-gray-600 mb-2">Команда</p>
          <p class="text-2xl font-bold">1-2 особи</p>
          <p class="text-gray-700 text-sm mt-2">Власниця + доставучи часто</p>
        </div>
      </div>
      <p class="text-gray-700 text-center">
        Розтошна Мода — це проект однієї жінки, яка любить модну індустрію. До MTP вона й комплектувала в домашньому гаражі, і доставляла замовлення сама. Обсяги росли, але логістика став вузьким місцем.
      </p>
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Проблема: Логістика Гасить Зростання</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Перед MTP</h3>
          <ul class="space-y-2 text-gray-700">
            <li><strong>50 замовлень/місяц</strong> (максимум що вмічала)</li>
            <li><strong>Гараж як склад</strong> — холодно зимою, жарко влітку</li>
            <li><strong>Ручна комплектація</strong> — 2-3 години на 10 замовлень</li>
            <li><strong>Інші доставляє сама</strong> — 20+ км на день на автомобілі</li>
            <li><strong>Помилки в доставці</strong> — неправильна адреса, пошкоджено</li>
            <li><strong>Обмежена географія</strong> — тільки в межах Київа</li>
          </ul>
        </div>
        <div class="bg-yellow-50 p-6 rounded border-l-4 border-yellow-500">
          <h3 class="text-lg font-bold mb-3">Витрати на логістику</h3>
          <ul class="space-y-2 text-gray-700">
            <li><strong>Оренда гаража:</strong> 2000 грн</li>
            <li><strong>Електроенергія:</strong> 500 грн</li>
            <li><strong>Бензин на доставку:</strong> 3000 грн</li>
            <li><strong>Упаковка:</strong> 500 грн</li>
            <li><strong>Помилки & повернення:</strong> 1000 грн</li>
            <li class="border-t pt-2 font-bold">ВСЬОГО: 7,000 грн/місяц</li>
          </ul>
          <p class="text-sm text-gray-600 mt-4">На 50 замовлень = 140 грн за замовлення</p>
        </div>
      </div>

      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-3">Ключові виклики</h3>
        <p class="text-gray-700 mb-4">
          "Я маю таланту на дизайн і контент. Але логістика відбирає всю енергію. Коли замовлень більше 50, я просто не встигаю. Нельзя розширювати географію без помощи. Хочу сфокусуватись на продажах, а не на складі."
        </p>
        <p class="text-gray-600 text-sm">— Власниця Розтошної Моди</p>
      </div>
    </div>
  </section>

  <!-- The Solution -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Рішення: MTP Фулфілмент</h2>

      <div class="bg-white p-8 rounded border-l-4 border-red-600 mb-8">
        <h3 class="text-lg font-bold mb-4">Як MTP допоміг</h3>
        <ol class="space-y-4 text-gray-700">
          <li class="flex gap-4">
            <span class="font-bold text-red-600 flex-shrink-0">1.</span>
            <span><strong>Запуск на Prom.ua FBO</strong> — MTP сертифіковано, що дозволило запустити акаунт FBO за 3 дні. На Prom вона отримала доступ до мільйонів нових покупців.</span>
          </li>
          <li class="flex gap-4">
            <span class="font-bold text-red-600 flex-shrink-0">2.</span>
            <span><strong>Трансфер товару на склад</strong> — замість гаража, товар на сертифікованому складі з клімат-контролем. Якість товара підвищилась.</span>
          </li>
          <li class="flex gap-4">
            <span class="font-bold text-red-600 flex-shrink-0">3.</span>
            <span><strong>Автоматична комплектація</strong> — замовлення з Prom → автоматично у MTP WMS → комплектація за &lt;30 хв → TTN номер назад на Prom.</span>
          </li>
          <li class="flex gap-4">
            <span class="font-bold text-red-600 flex-shrink-0">4.</span>
            <span><strong>Масштабування без хімії</strong> — з 50 замовлень выросла до 500 замовлень на місяць. Логістика MTP розросла разом з нею.</span>
          </li>
        </ol>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold mb-4">Потім MTP</h3>
          <ul class="space-y-2 text-gray-700">
            <li>✓ 500+ замовлень/місяц</li>
            <li>✓ Доставка в 15+ міст</li>
            <li>✓ 99.8% точність комплектації</li>
            <li>✓ Рейтинг на Prom 4.9/5</li>
            <li>✓ Автоматична синхронізація</li>
            <li>✓ Гарантія якості від MTP</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold mb-4">Витрати за MTP</h3>
          <ul class="space-y-2 text-gray-700">
            <li>Комплектація: 500 × 25 = 12,500 грн</li>
            <li>Доставка: 500 × 100 = 50,000 грн</li>
            <li>Складування: 2 палі × 400 = 800 грн</li>
            <li class="border-t pt-2 font-bold">ВСЬОГО: 63,300 грн/місяц</li>
            <li class="text-sm text-gray-600">На замовлення: 127 грн</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Результати</h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        <div class="text-center bg-green-50 p-6 rounded">
          <p class="text-4xl font-bold text-green-600 mb-2">+600%</p>
          <p class="text-gray-700 font-bold">Виручка за рік</p>
          <p class="text-sm text-gray-600">50 → 500 замовлень</p>
        </div>
        <div class="text-center bg-blue-50 p-6 rounded">
          <p class="text-4xl font-bold text-blue-600 mb-2">-70%</p>
          <p class="text-gray-700 font-bold">Витрати на логістику</p>
          <p class="text-sm text-gray-600">140 → 127 грн/замов</p>
        </div>
        <div class="text-center bg-purple-50 p-6 rounded">
          <p class="text-4xl font-bold text-purple-600 mb-2">+15</p>
          <p class="text-gray-700 font-bold">Нових міст покриття</p>
          <p class="text-sm text-gray-600">Київ → вся Україна</p>
        </div>
        <div class="text-center bg-orange-50 p-6 rounded">
          <p class="text-4xl font-bold text-orange-600 mb-2">4.9★</p>
          <p class="text-gray-700 font-bold">Рейтинг на Prom</p>
          <p class="text-sm text-gray-600">500+ рецензій</p>
        </div>
      </div>

      <div class="overflow-x-auto mb-8">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="border p-4 text-left">Метрика</th>
              <th class="border p-4 text-center">Раніше</th>
              <th class="border p-4 text-center">Сьогодні</th>
              <th class="border p-4 text-center">Зміна</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border p-4">Замовлень на місяць</td>
              <td class="border p-4 text-center">50</td>
              <td class="border p-4 text-center">500</td>
              <td class="border p-4 text-center font-bold text-green-600">+900%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4">Міст охоплення</td>
              <td class="border p-4 text-center">1 (Київ)</td>
              <td class="border p-4 text-center">15+</td>
              <td class="border p-4 text-center font-bold text-green-600">+1500%</td>
            </tr>
            <tr>
              <td class="border p-4">Витрати на замовлення</td>
              <td class="border p-4 text-center">140 грн</td>
              <td class="border p-4 text-center">127 грн</td>
              <td class="border p-4 text-center font-bold text-green-600">-9%</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4">Помилки в комплектації</td>
              <td class="border p-4 text-center">2-3%</td>
              <td class="border p-4 text-center">0.2%</td>
              <td class="border p-4 text-center font-bold text-green-600">-93%</td>
            </tr>
            <tr>
              <td class="border p-4">Рейтинг на платформі</td>
              <td class="border p-4 text-center">4.3★</td>
              <td class="border p-4 text-center">4.9★</td>
              <td class="border p-4 text-center font-bold text-green-600">+14%</td>
            </tr>
            <tr class="bg-red-50">
              <td class="border p-4 font-bold">Місячна виручка</td>
              <td class="border p-4 text-center font-bold">20,000 грн</td>
              <td class="border p-4 text-center font-bold">140,000 грн</td>
              <td class="border p-4 text-center font-bold text-green-600">+600%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Key Lessons -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Ключові Уроки</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold text-red-600 mb-3">1. Логістика — не ваш основний бізнес</h3>
          <p class="text-gray-700">Власниця спеціалізується на дизайні і маркетингу. Коли вона передала логістику MTP, у неї звільнилось 20+ годин на тиждень для розвитку продажів.</p>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold text-red-600 mb-3">2. Prom FBO = масштабування</h3>
          <p class="text-gray-700">Запуск на Prom FBO (з MTP як логістичним партнером) дав доступ до мільйонів нових покупців. Ця одна платформа сьогодні дає 70% выручки.</p>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold text-red-600 mb-3">3. Якість логістики = рейтинги</h3>
          <p class="text-gray-700">MTP гарантує 99.8% точність. Менше повернень = вищі рейтинги на платформі = більше замовлень. Цей цикл був ключем до взрывного зростання.</p>
        </div>
        <div class="bg-white p-6 rounded">
          <h3 class="text-lg font-bold text-red-600 mb-3">4. Масштабованість без персоналу</h3>
          <p class="text-gray-700">Замість найму комплектувальника и водія (25K+ грн), витрати росли пропорційно замовленням. Гнучкість дозволила експериментувати без великих ризиків.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Слова Власниці</h2>
      <div class="bg-gradient-to-r from-red-50 to-blue-50 p-8 rounded border-l-4 border-red-600 italic">
        <p class="text-lg text-gray-700 mb-4">
          "Три роки назад я просто мріяла про 100 замовлень на місяць. Думала, це максимум для однієї людини. Але коли я запустила на Prom з MTP, все змінилось. Логістика більше не проблема — вона просто працює. Я можу фокусуватись на тому, що я люблю: дизайн і контент. За рік я виросла від ФОП до реального бізнесу з 500 замовленнями. MTP дав мені крила."
        </p>
        <p class="text-gray-600 font-bold">— Майстерня Розтошної Моди</p>
        <p class="text-gray-600 text-sm">Київ, 2024</p>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Ваша Історія Успіху Може Бути Наступною</h2>
      <p class="text-xl mb-8 opacity-90">
        Тисячі бізнесів, як Розтошна Мода, вже зростають з MTP. Почніть сьогодні.
      </p>
      <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Розпочати з MTP
      </a>
      <p class="mt-8 text-sm opacity-75">
        Консультація і розрахунок вартості — безкоштовно
      </p>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
