import Base from '../../layouts/Base.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
---
<Base
  title="Складські послуги Київ від 650 грн/м³ — 2 склади | MTP"
  description="Складські послуги для інтернет-магазинів: адресне зберігання, збір за 30 сек, 6 000 відправок/добу. 2 склади під Києвом (Бориспіль + Білогородка). Від 650 грн/м³."
  canonical="https://www.fulfillmentmtp.com.ua/ua/skladski-poslugy/"
  lang="uk"
  ogImage="https://www.fulfillmentmtp.com.ua/images/mtp-fulfillment-warehouse-hero.webp"
  showCTA={false}
  schema={`<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Складські послуги для інтернет-магазинів","description":"Адресний склад у Бориспілі та Білогородці. Зберігання від 650 грн/м³. Збір замовлення за 30 секунд, 4 відправки на день.","provider":{"@type":"Organization","name":"MTP Group Fulfillment","legalName":"ТОВ \\"МТП Груп Фулфілмент\\"","taxID":"45315740","foundingDate":"2023-10-02","url":"https://www.fulfillmentmtp.com.ua","telephone":"+380501444645"},"areaServed":{"@type":"Country","name":"UA"},"offers":{"@type":"Offer","priceCurrency":"UAH","price":"650","description":"Зберігання від 650 грн/м³/міс"}}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"ItemList","name":"Що входить у складські послуги MTP Group","itemListOrder":"ItemListOrderAscending","itemListElement":[{"@type":"ListItem","position":1,"name":"Приймання і розвантаження товару"},{"@type":"ListItem","position":2,"name":"Вхідний контроль якості (QC)"},{"@type":"ListItem","position":3,"name":"Адресне розміщення у WMS"},{"@type":"ListItem","position":4,"name":"Зберігання при t 15-25°C з відеоспостереженням 24/7"},{"@type":"ListItem","position":5,"name":"Комплектація замовлень (picking) за 30 секунд"},{"@type":"ListItem","position":6,"name":"Пакування і брендоване пакування"},{"@type":"ListItem","position":7,"name":"Відправка у Нова Пошта, Укрпошта, Meest, Justin"},{"@type":"ListItem","position":8,"name":"Обробка повернень і рекламацій"}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Головна","item":"https://www.fulfillmentmtp.com.ua/"},{"@type":"ListItem","position":2,"name":"Послуги","item":"https://www.fulfillmentmtp.com.ua/ua/3pl-logistyka/"},{"@type":"ListItem","position":3,"name":"Складські послуги","item":"https://www.fulfillmentmtp.com.ua/ua/skladski-poslugy/"}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Який мінімальний об'єм товару?","acceptedAnswer":{"@type":"Answer","text":"Мінімального немає — оплата за фактичне місце. Мінімальний місячний платіж 5 000 грн (перші 3 місяці)."}},{"@type":"Question","name":"Яка температура на складі?","acceptedAnswer":{"@type":"Answer","text":"15-25°C цілий рік, опалення взимку, контроль вологості. Підходить для косметики, електроніки, одягу, побутової хімії."}},{"@type":"Question","name":"Як працює WMS-облік?","acceptedAnswer":{"@type":"Answer","text":"Штрих-код для кожного товару, адреса для кожної ячейки. WMS формує оптимальний маршрут збору. Залишки онлайн 24/7 через кабінет і Telegram-бот."}},{"@type":"Question","name":"Чи є палетне зберігання?","acceptedAnswer":{"@type":"Answer","text":"Так, від 450 грн/палет/міс. Стелажі до 2 тонн/ярус, навантажувачі і гідравлічні рокли."}},{"@type":"Question","name":"Як проводиться інвентаризація?","acceptedAnswer":{"@type":"Answer","text":"Планова інвентаризація щомісячно. Позапланова — за запитом протягом 24 годин. Результати з розбіжностями по кожному SKU у WMS-кабінеті."}},{"@type":"Question","name":"Чи є страхування?","acceptedAnswer":{"@type":"Answer","text":"Офіційний договір з матеріальною відповідальністю за товар. Всі операції фіксуються в WMS. Склад обладнаний цілодобовою відеофіксацією та охороною."}},{"@type":"Question","name":"З якими CRM і платформами ви інтегруєтесь?","acceptedAnswer":{"@type":"Answer","text":"Horoshop, Prom.ua, Rozetka Marketplace, OpenCart, WooCommerce, Shopify, 1C, BAS, KeyCRM, SalesDrive. Для нестандартних систем — REST API. Інтеграція 1-2 дні."}},{"@type":"Question","name":"Скільки часу займає підключення до фулфілменту?","acceptedAnswer":{"@type":"Answer","text":"3-5 робочих днів від підписання договору до першої відправки. Для великих обсягів (1 000+ SKU) — 7-10 днів."}},{"@type":"Question","name":"Як розраховується вартість складських послуг?","acceptedAnswer":{"@type":"Answer","text":"Оплата за 3 компоненти: зберігання від 650 грн/м³/міс або 450 грн/палет/міс; комплектація від 18 грн/замовлення; додаткові послуги (приймання, маркування, повернення). Абонплати за місце немає."}},{"@type":"Question","name":"Свій склад чи фулфілмент — що вигідніше?","acceptedAnswer":{"@type":"Answer","text":"До 30 замовлень/день — своїми силами. Від 30 до 200 — фулфілмент економить 30-50% витрат і 80+ годин роботи власника на місяць. Від 200 — комбіновано або повністю фулфілмент."}}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","legalName":"ТОВ \\"МТП Груп Фулфілмент\\"","taxID":"45315740","foundingDate":"2023-10-02","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","address":[{"@type":"PostalAddress","addressLocality":"Щасливе, Бориспільський район","addressRegion":"Київська область","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"Білогородка","addressRegion":"Київська область","addressCountry":"UA","description":"Склад 1 100 м²"}],"openingHours":"Mo-Su 08:00-20:00"}</script>`}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/skladski-poslugy/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/skladskie-uslugi/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/warehouse-services/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/ua/skladski-poslugy/">
</Fragment>

<!-- SECTION 1 — HERO: SPLIT-SCREEN -->
<section class="sp-hero">
  <div class="sp-hero-video">
    <video autoplay muted loop playsinline poster="/images/mtp-fulfillment-warehouse-hero.webp">
      <source src="/videos/warehouse-tour.mp4" type="video/mp4">
    </video>
  </div>
  <div class="sp-hero-form-side">
    <div class="sp-hero-inner">
      <div class="badge">СКЛАДСЬКІ ПОСЛУГИ</div>
      <h1>Складські послуги для інтернет-магазинів у Києві та області</h1>
      <p class="sp-hero-sub">Передайте зберігання, збір і відправку замовлень нам&nbsp;&mdash; ви займаєтесь продажами. Два склади. Адресна система. Збір за 30&nbsp;секунд.</p>
      <form class="sp-hero-form" id="heroFormSplit">
        <input type="text" name="name" placeholder="Ваше ім'я" autocomplete="given-name" aria-label="Ім'я">
        <input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="19" required autocomplete="tel" aria-label="Телефон">
        <button type="submit">Розрахувати вартість &rarr;</button>
      </form>
      <p class="sp-hero-note">Безкоштовна консультація &middot; Передзвонимо за 15 хвилин</p>
      <a href="tel:+380501444645" class="sp-hero-phone">+380 50 144 46 45</a>
    </div>
  </div>
</section>

<!-- SECTION 2 — TIMELINE: 5 STAGES -->
<section class="tl-section">
  <div class="ctr">
    <div class="badge badge-dark">ЯК ЦЕ ПРАЦЮЄ</div>
    <h2 class="sec-h2">Від привезення товару до контролю з телефона</h2>
    <div class="tl-track">
      <div class="tl-line" aria-hidden="true"></div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Привозите товар</h3>
          <p>Розвантажимо коробки (20&nbsp;грн/шт.) або палети (80&nbsp;грн/шт.), перевіримо і зафіксуємо в WMS.</p>
        </div>
      </div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Розміщуємо</h3>
          <p>Кожна одиниця отримує адресу: полиця, ряд, ячейка. FEFO для косметики та БАДів.</p>
        </div>
      </div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Збираємо</h3>
          <p>Замовлення з CRM &rarr; WMS автоматично. Збір за 30&nbsp;секунд, 4&nbsp;відправки/день.</p>
        </div>
      </div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Зберігаємо</h3>
          <p>t&deg; 15-25&deg;C, вологість, відеоспостереження 24/7.</p>
        </div>
      </div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Контролюєте</h3>
          <p>Залишки, статуси через Telegram-Bot та кабінет. 15&nbsp;хв/день замість 4&nbsp;годин.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 3 — INLINE CALCULATOR (ALPINE.JS) -->
<section class="calc-section" id="calculator">
  <div class="ctr">
    <div class="badge badge-dark">КАЛЬКУЛЯТОР</div>
    <h2 class="sec-h2">Скільки коштує складське обслуговування для вашого магазину</h2>
    <p class="calc-sub">Введіть параметри&nbsp;&mdash; ми порахуємо вартість за місяць.</p>

    <div class="calc-wrap" id="calcWrap">
      <div class="calc-inputs">
        <div class="calc-field">
          <label>Кількість SKU (найменувань): <strong id="r-sku">500</strong></label>
          <input type="range" min="50" max="5000" step="50" id="c-sku" value="500">
          <div class="calc-range-labels"><span>50</span><span>5 000</span></div>
        </div>
        <div class="calc-field">
          <label>Замовлень на день: <strong id="r-orders">50</strong></label>
          <input type="range" min="5" max="200" step="5" id="c-orders" value="50">
          <div class="calc-range-labels"><span>5</span><span>200</span></div>
        </div>
        <div class="calc-field">
          <label>Середній розмір товару:</label>
          <div class="calc-radio-group">
            <label class="calc-radio"><input type="radio" name="size" value="small"> Дрібний</label>
            <label class="calc-radio active"><input type="radio" name="size" value="medium" checked> Середній</label>
            <label class="calc-radio"><input type="radio" name="size" value="large"> Великий</label>
          </div>
        </div>
      </div>

      <div class="calc-results">
        <div class="calc-result-row">
          <span>Зберігання</span>
          <span class="calc-val" id="r-storage">1 300 грн</span>
        </div>
        <div class="calc-result-row">
          <span>Комплектація</span>
          <span class="calc-val" id="r-picking">57 500 грн</span>
        </div>
        <div class="calc-result-row calc-total">
          <span>РАЗОМ на місяць</span>
          <span class="calc-val" id="r-total">58 800 грн</span>
        </div>
        <p class="calc-disclaimer">* Орієнтовний розрахунок. Точну вартість порахуємо за 15 хвилин після дзвінка.</p>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 4 — YOUTUBE EMBED + STATS -->
<section class="vid-section">
  <div class="ctr">
    <div class="badge badge-dark">СКЛАД ЗСЕРЕДИНИ</div>
    <h2 class="sec-h2">Подивіться як працює наш склад</h2>
    <div class="vid-player">
      <YouTubeEmbed id="bHY3cFF9SlI" title="Екскурсія по складу MTP Group" />
    </div>
    <div class="vid-stats">
      <div class="vid-stat">
        <div class="vid-stat-val">3 900 м&sup2;</div>
        <div class="vid-stat-label">складських площ на двох об'єктах</div>
      </div>
      <div class="vid-stat">
        <div class="vid-stat-val">60 000+</div>
        <div class="vid-stat-label">відправлень щомісяця</div>
      </div>
      <div class="vid-stat">
        <div class="vid-stat-val">10+ років</div>
        <div class="vid-stat-label">досвіду у фулфілменті</div>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 5 — TESTIMONIALS CAROUSEL -->
<section class="rev-section">
  <div class="ctr">
    <div class="badge badge-dark">ВІДГУКИ КЛІЄНТІВ</div>
    <h2 class="sec-h2">Що кажуть наші клієнти</h2>
    <div class="rev-carousel">
      <div class="rev-card">
        <div class="rev-stars" aria-label="5 з 5 зірок">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote class="rev-quote">&laquo;Відправки зросли з 12 до 72/день, собівартість впала з 30 до 14&nbsp;грн.&raquo;</blockquote>
        <div class="rev-author">
          <div class="rev-name">Власник Carter's Ukraine</div>
          <div class="rev-biz">Дитячий одяг &middot; 3 000+ SKU</div>
        </div>
      </div>
      <div class="rev-card">
        <div class="rev-stars" aria-label="5 з 5 зірок">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote class="rev-quote">&laquo;За 7 років роботи з MTP&nbsp;&mdash; жодної рекламації.&raquo;</blockquote>
        <div class="rev-author">
          <div class="rev-name">Представник Elemis Ukraine</div>
          <div class="rev-biz">Luxury-косметика &middot; FEFO-зберігання</div>
        </div>
      </div>
      <div class="rev-card">
        <div class="rev-stars" aria-label="5 з 5 зірок">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote class="rev-quote">&laquo;Собівартість впала з 33 до 14&nbsp;грн. 90&nbsp;годин/міс вивільнено.&raquo;</blockquote>
        <div class="rev-author">
          <div class="rev-name">Засновниця I.Love.My.Cycle</div>
          <div class="rev-biz">Wellness &middot; 200+ замовлень/день</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 6 — CTA -->
<section class="sp-cta" id="ctaSection">
  <div class="ctr">
    <h2>Ваш товар заслуговує на професійний склад</h2>
    <p class="sp-cta-sub">Підключення за 3-5 днів. Без довгих контрактів.</p>
    <form class="sp-cta-form" id="ctaFormBottom">
      <input type="text" name="name" placeholder="Ваше ім'я" autocomplete="given-name" aria-label="Ім'я">
      <input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="19" required autocomplete="tel" aria-label="Телефон">
      <button type="submit">Отримати розрахунок &rarr;</button>
    </form>
    <div class="sp-cta-checks">
      <span>&#10003; Без довгострокового контракту</span>
      <span>&#10003; Тестовий період</span>
      <span>&#10003; Вихід за 1 день</span>
    </div>
  </div>
</section>

<!-- SECTION 7 — FAQ -->
<section class="faq" id="faq">
  <div class="ctr">
    <div class="badge badge-dark">FAQ</div>
    <h2 class="sec-h2">Часті запитання</h2>
    <div class="faq-list">
      <div class="faq-item">
        <button class="faq-q" data-faq>Який мінімальний об'єм товару?</button>
        <div class="faq-a"><p>Мінімального немає&nbsp;&mdash; оплата за фактичне місце. Мінімальний місячний платіж&nbsp;&mdash; 5&nbsp;000&nbsp;грн.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" data-faq>Яка температура на складі?</button>
        <div class="faq-a"><p>15-25&deg;C цілий рік. Опалення взимку, контроль вологості. Підходить для косметики, електроніки, одягу, побутової хімії.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" data-faq>Як працює WMS-облік?</button>
        <div class="faq-a"><p>Штрих-код для кожного товару, адреса для кожної ячейки. WMS контролює точність збору і формує оптимальний маршрут. Залишки онлайн 24/7.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" data-faq>Чи є палетне зберігання?</button>
        <div class="faq-a"><p>Так, від 450&nbsp;грн/палет/міс. Стелажі витримують до 2&nbsp;тонн на ярус. Навантажувачі та гідравлічні рокли для переміщення.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" data-faq>Як проводиться інвентаризація?</button>
        <div class="faq-a"><p>Планова інвентаризація&nbsp;&mdash; щомісячно. Позапланова&nbsp;&mdash; за запитом протягом 24&nbsp;годин. Результати з розбіжностями по кожному SKU доступні в WMS-кабінеті.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" data-faq>Чи є страхування?</button>
        <div class="faq-a"><p>Офіційний договір з матеріальною відповідальністю за товар. Всі операції фіксуються в WMS. Склад обладнаний цілодобовою відеофіксацією та охороною.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" data-faq>З якими CRM і платформами ви інтегруєтесь?</button>
        <div class="faq-a"><p>Нативні інтеграції: Horoshop, Prom.ua, Rozetka Marketplace, OpenCart, WooCommerce, Shopify, 1C, BAS, Dilovod, KeyCRM, CRM SalesDrive. Для нестандартних систем&nbsp;&mdash; REST API і webhooks. Типове підключення&nbsp;&mdash; 1-2 робочі дні. Замовлення падають у WMS автоматично, статуси повертаються у ваш кабінет у реальному часі.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" data-faq>Скільки часу займає підключення до фулфілменту?</button>
        <div class="faq-a"><p>3-5 робочих днів від підписання договору до першої відправки. Перші 2 дні&nbsp;&mdash; приймання товару, маркування, розміщення по адресах у WMS. День 3-4&nbsp;&mdash; налаштування інтеграції з CRM, тестовий збір замовлення. День 5&nbsp;&mdash; виходимо у повноцінну роботу. Для великих обсягів (1 000+ SKU) термін може бути 7-10 днів.</p></div>
      </div>
      <div class="faq-item">
        <button class="faq-q" data-faq>Як розраховується вартість складських послуг?</button>
