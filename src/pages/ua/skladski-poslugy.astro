function sync(){
var open=nc.classList.contains('open');
ov.style.display=open?'block':'none';
document.body.style.overflow=open?'hidden':'';
}
new MutationObserver(sync).observe(nc,{attributes:true,attributeFilter:['class']});
ov.addEventListener('click',function(){
nc.classList.remove('open');
var b=document.querySelector('.nav-burger,#navBurger');
if(b)b.classList.remove('open');
sync();
});
var dd=nav.querySelector('.nav-dropdown');
if(dd){
var ddLink=dd.querySelector('a');
var ddMenu=dd.querySelector('.nav-dropdown-menu');
if(ddLink&&ddMenu){
ddLink.addEventListener('click',function(e){
if(window.innerWidth<=900){
e.preventDefault();
dd.classList.toggle('mobile-open');
ddMenu.classList.toggle('mobile-open');
}
});
}}
})();
});
</script>
