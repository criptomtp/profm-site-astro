---
import Base from '../../layouts/Base.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
---
<Base
  title="Складські послуги Київ — зберігання товарів для інтернет-магазинів | MTP Fulfillment"
  description="Адресний склад у Бориспілі та Білогородці. Зберігання від 650 грн/м³. Збір замовлення за 30 секунд, 4 відправки на день. 10+ років досвіду, до 6 000 замовлень/добу."
  canonical="https://www.fulfillmentmtp.com.ua/ua/skladski-poslugy/"
  lang="uk"
  ogImage="https://www.fulfillmentmtp.com.ua/images/mtp-fulfillment-warehouse-hero.webp"
  showCTA={false}
  schema={`<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Складські послуги для інтернет-магазинів","description":"Адресний склад у Бориспілі та Білогородці. Зберігання від 650 грн/м³. Збір замовлення за 30 секунд, 4 відправки на день.","provider":{"@type":"Organization","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":"+380501444645"},"areaServed":{"@type":"Country","name":"UA"},"offers":{"@type":"Offer","priceCurrency":"UAH","price":"650","description":"Зберігання від 650 грн/м³/міс"}}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Головна","item":"https://www.fulfillmentmtp.com.ua/"},{"@type":"ListItem","position":2,"name":"Послуги","item":"https://www.fulfillmentmtp.com.ua/ua/services/"},{"@type":"ListItem","position":3,"name":"Складські послуги","item":"https://www.fulfillmentmtp.com.ua/ua/skladski-poslugy/"}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Який мінімальний об'єм товару?","acceptedAnswer":{"@type":"Answer","text":"Мінімального немає — оплата за фактичне місце. Мін. платіж 5 000 грн."}},{"@type":"Question","name":"Яка температура на складі?","acceptedAnswer":{"@type":"Answer","text":"15-25°C цілий рік."}},{"@type":"Question","name":"Як працює WMS-облік?","acceptedAnswer":{"@type":"Answer","text":"Штрих-код для кожного товару, адреса для кожної ячейки. Залишки онлайн 24/7."}},{"@type":"Question","name":"Чи є палетне зберігання?","acceptedAnswer":{"@type":"Answer","text":"Так, від 450 грн/палет/міс. До 2 тонн/ярус."}},{"@type":"Question","name":"Як проводиться інвентаризація?","acceptedAnswer":{"@type":"Answer","text":"Планова щомісячно. Позапланова за 24 год."}},{"@type":"Question","name":"Чи є страхування?","acceptedAnswer":{"@type":"Answer","text":"Договір з матеріальною відповідальністю. Відеофіксація 24/7."}}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","address":[{"@type":"PostalAddress","addressLocality":"Щасливе, Бориспільський район","addressRegion":"Київська область","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"Білогородка","addressRegion":"Київська область","addressCountry":"UA","description":"Склад 1 100 м²"}],"openingHours":"Mo-Su 08:00-20:00"}</script>`}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/skladski-poslugy/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/skladski-poslugy/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/warehouse-services/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/ua/skladski-poslugy/">
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
</Fragment>

<!-- SECTION 1 — HERO: SPLIT-SCREEN -->
<section class="sp-hero">
  <div class="sp-hero-video">
    <video autoplay muted loop playsinline poster="/images/mtp-fulfillment-warehouse-hero.webp">
      <source src="/videos/warehouse-tour.mp4" type="video/mp4">
    </video>
  </div>
  <div class="sp-hero-form-side">
    <div class="sp-hero-inner">
      <div class="badge">СКЛАДСЬКІ ПОСЛУГИ</div>
      <h1>Складські послуги для інтернет-магазинів у Києві та області</h1>
      <p class="sp-hero-sub">Передайте зберігання, збір і відправку замовлень нам&nbsp;&mdash; ви займаєтесь продажами. Два склади. Адресна система. Збір за 30&nbsp;секунд.</p>
      <form class="sp-hero-form" id="heroFormSplit">
        <input type="text" name="name" placeholder="Ваше ім'я" autocomplete="given-name" aria-label="Ім'я">
        <input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="19" required autocomplete="tel" aria-label="Телефон">
        <input type="email" name="email" placeholder="Email" autocomplete="email" aria-label="Email">
        <button type="submit">Розрахувати вартість &rarr;</button>
      </form>
      <p class="sp-hero-note">Безкоштовна консультація &middot; Передзвонимо за 15 хвилин</p>
      <a href="tel:+380501444645" class="sp-hero-phone">+380 50 144 46 45</a>
    </div>
  </div>
</section>

<!-- SECTION 2 — TIMELINE: 5 STAGES -->
<section class="tl-section">
  <div class="ctr">
    <div class="badge badge-dark">ЯК ЦЕ ПРАЦЮЄ</div>
    <h2 class="sec-h2">Від привезення товару до контролю з телефона</h2>
    <div class="tl-track">
      <div class="tl-line" aria-hidden="true"></div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Привозите товар</h3>
          <p>Розвантажимо коробки (20&nbsp;грн/шт.) або палети (80&nbsp;грн/шт.), перевіримо і зафіксуємо в WMS.</p>
        </div>
      </div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Розміщуємо</h3>
          <p>Кожна одиниця отримує адресу: полиця, ряд, ячейка. FEFO для косметики та БАДів.</p>
        </div>
      </div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Збираємо</h3>
          <p>Замовлення з CRM &rarr; WMS автоматично. Збір за 30&nbsp;секунд, 4&nbsp;відправки/день.</p>
        </div>
      </div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Зберігаємо</h3>
          <p>t&deg; 15-25&deg;C, вологість, відеоспостереження 24/7.</p>
        </div>
      </div>
      <div class="tl-step">
        <div class="tl-dot"></div>
        <div class="tl-content">
          <h3>Контролюєте</h3>
          <p>Залишки, статуси через Telegram-Bot та кабінет. 15&nbsp;хв/день замість 4&nbsp;годин.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 3 — INLINE CALCULATOR (ALPINE.JS) -->
<section class="calc-section" id="calculator">
  <div class="ctr">
    <div class="badge badge-dark">КАЛЬКУЛЯТОР</div>
    <h2 class="sec-h2">Скільки коштує складське обслуговування для вашого магазину</h2>
    <p class="calc-sub">Введіть параметри&nbsp;&mdash; ми порахуємо вартість за місяць.</p>

    <div class="calc-wrap" x-data="{
      sku: 500,
      orders: 50,
      size: 'medium',
      get sizeFactor() {
        return this.size === 'small' ? 0.003 : this.size === 'medium' ? 0.008 : 0.02;
      },
      get pricePerOrder() {
        if (this.orders <= 10) return 26;
        if (this.orders <= 50) return 23;
        if (this.orders <= 100) return 21;
        return 18;
      },
      get storageCost() {
        return Math.round(this.sku * this.sizeFactor * 650);
      },
      get pickingCost() {
        return Math.round(this.orders * 22 * this.pricePerOrder);
      },
      get totalCost() {
        return this.storageCost + this.pickingCost;
      },
      fmt(n) {
        return n.toLocaleString('uk-UA');
      }
    }">
      <div class="calc-inputs">
        <div class="calc-field">
          <label>Кількість SKU (найменувань): <strong x-text="fmt(sku)"></strong></label>
          <input type="range" min="50" max="5000" step="50" x-model.number="sku">
          <div class="calc-range-labels"><span>50</span><span>5 000</span></div>
        </div>
        <div class="calc-field">
          <label>Замовлень на день: <strong x-text="fmt(orders)"></strong></label>
          <input type="range" min="5" max="200" step="5" x-model.number="orders">
          <div class="calc-range-labels"><span>5</span><span>200</span></div>
        </div>
        <div class="calc-field">
          <label>Середній розмір товару:</label>
          <div class="calc-radio-group">
            <label class="calc-radio" :class="{ active: size === 'small' }">
              <input type="radio" name="size" value="small" x-model="size"> Дрібний
            </label>
            <label class="calc-radio" :class="{ active: size === 'medium' }">
              <input type="radio" name="size" value="medium" x-model="size"> Середній
            </label>
            <label class="calc-radio" :class="{ active: size === 'large' }">
              <input type="radio" name="size" value="large" x-model="size"> Великий
            </label>
          </div>
        </div>
      </div>

      <div class="calc-results">
        <div class="calc-result-row">
          <span>Зберігання</span>
          <span class="calc-val" x-text="fmt(storageCost) + ' грн'"></span>
        </div>
        <div class="calc-result-row">
          <span>Комплектація</span>
          <span class="calc-val" x-text="fmt(pickingCost) + ' грн'"></span>
        </div>
        <div class="calc-result-row calc-total">
          <span>РАЗОМ на місяць</span>
          <span class="calc-val" x-text="fmt(totalCost) + ' грн'"></span>
        </div>
        <p class="calc-disclaimer">* Орієнтовний розрахунок. Точну вартість порахуємо за 15 хвилин після дзвінка.</p>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 4 — YOUTUBE EMBED + STATS -->
<section class="vid-section">
  <div class="ctr">
    <div class="badge badge-dark">СКЛАД ЗСЕРЕДИНИ</div>
    <h2 class="sec-h2">Подивіться як працює наш склад</h2>
    <div class="vid-player">
      <YouTubeEmbed id="bHY3cFF9SlI" title="Екскурсія по складу MTP Group" />
    </div>
    <div class="vid-stats">
      <div class="vid-stat">
        <div class="vid-stat-val">3 900 м&sup2;</div>
        <div class="vid-stat-label">складських площ на двох об'єктах</div>
      </div>
      <div class="vid-stat">
        <div class="vid-stat-val">60 000+</div>
        <div class="vid-stat-label">відправлень щомісяця</div>
      </div>
      <div class="vid-stat">
        <div class="vid-stat-val">10+ років</div>
        <div class="vid-stat-label">досвіду у фулфілменті</div>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 5 — TESTIMONIALS CAROUSEL -->
<section class="rev-section">
  <div class="ctr">
    <div class="badge badge-dark">ВІДГУКИ КЛІЄНТІВ</div>
    <h2 class="sec-h2">Що кажуть наші клієнти</h2>
    <div class="rev-carousel">
      <div class="rev-card">
        <div class="rev-stars" aria-label="5 з 5 зірок">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote class="rev-quote">&laquo;Відправки зросли з 12 до 72/день, собівартість впала з 30 до 14&nbsp;грн.&raquo;</blockquote>
        <div class="rev-author">
          <div class="rev-name">Власник Carter's Ukraine</div>
          <div class="rev-biz">Дитячий одяг &middot; 3 000+ SKU</div>
        </div>
      </div>
      <div class="rev-card">
        <div class="rev-stars" aria-label="5 з 5 зірок">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote class="rev-quote">&laquo;За 7 років роботи з MTP&nbsp;&mdash; жодної рекламації.&raquo;</blockquote>
        <div class="rev-author">
          <div class="rev-name">Представник Elemis Ukraine</div>
          <div class="rev-biz">Luxury-косметика &middot; FEFO-зберігання</div>
        </div>
      </div>
      <div class="rev-card">
        <div class="rev-stars" aria-label="5 з 5 зірок">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <blockquote class="rev-quote">&laquo;Собівартість впала з 33 до 14&nbsp;грн. 90&nbsp;годин/міс вивільнено.&raquo;</blockquote>
        <div class="rev-author">
          <div class="rev-name">Засновниця I.Love.My.Cycle</div>
          <div class="rev-biz">Wellness &middot; 200+ замовлень/день</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 6 — CTA -->
<section class="sp-cta" id="ctaSection">
  <div class="ctr">
    <h2>Ваш товар заслуговує на професійний склад</h2>
    <p class="sp-cta-sub">Підключення за 3-5 днів. Без довгих контрактів.</p>
    <form class="sp-cta-form" id="ctaFormBottom">
      <input type="text" name="name" placeholder="Ваше ім'я" autocomplete="given-name" aria-label="Ім'я">
      <input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="19" required autocomplete="tel" aria-label="Телефон">
      <input type="email" name="email" placeholder="Email" autocomplete="email" aria-label="Email">
      <button type="submit">Отримати розрахунок &rarr;</button>
    </form>
    <div class="sp-cta-checks">
      <span>&#10003; Без довгострокового контракту</span>
      <span>&#10003; Тестовий період</span>
      <span>&#10003; Вихід за 1 день</span>
    </div>
  </div>
</section>

<!-- SECTION 7 — FAQ -->
<section class="faq" id="faq">
  <div class="ctr">
    <div class="badge badge-dark">FAQ</div>
    <h2 class="sec-h2">Часті запитання</h2>
    <div class="faq-q" data-faq>Який мінімальний об'єм товару?</div>
    <div class="faq-a"><p>Мінімального немає&nbsp;&mdash; оплата за фактичне місце. Мінімальний місячний платіж&nbsp;&mdash; 5&nbsp;000&nbsp;грн.</p></div>
    <div class="faq-q" data-faq>Яка температура на складі?</div>
    <div class="faq-a"><p>15-25&deg;C цілий рік. Опалення взимку, контроль вологості. Підходить для косметики, електроніки, одягу, побутової хімії.</p></div>
    <div class="faq-q" data-faq>Як працює WMS-облік?</div>
    <div class="faq-a"><p>Штрих-код для кожного товару, адреса для кожної ячейки. WMS контролює точність збору і формує оптимальний маршрут. Залишки онлайн 24/7.</p></div>
    <div class="faq-q" data-faq>Чи є палетне зберігання?</div>
    <div class="faq-a"><p>Так, від 450&nbsp;грн/палет/міс. Стелажі витримують до 2&nbsp;тонн на ярус. Навантажувачі та гідравлічні рокли для переміщення.</p></div>
    <div class="faq-q" data-faq>Як проводиться інвентаризація?</div>
    <div class="faq-a"><p>Планова інвентаризація&nbsp;&mdash; щомісячно. Позапланова&nbsp;&mdash; за запитом протягом 24&nbsp;годин. Результати з розбіжностями по кожному SKU доступні в WMS-кабінеті.</p></div>
    <div class="faq-q" data-faq>Чи є страхування?</div>
    <div class="faq-a"><p>Офіційний договір з матеріальною відповідальністю за товар. Всі операції фіксуються в WMS. Склад обладнаний цілодобовою відеофіксацією та охороною.</p></div>
  </div>
</section>

<script is:inline>
(function(){
  // Form handler for both hero and CTA forms
  function handleForm(formId) {
    var form = document.getElementById(formId);
    if (!form || form.dataset.handled) return;
    form.dataset.handled = '1';
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var phoneInput = form.querySelector('input[name="phone"]');
      var ph = phoneInput.value.trim();
      var clean = ph.replace(/\D/g, '');
      if (clean.length < 10) {
        phoneInput.style.borderColor = '#e63329';
        phoneInput.focus();
        return;
      }
      if (typeof window.mtpSubmitLead === 'function') {
        window.mtpSubmitLead(ph, location.pathname);
      }
      form.innerHTML = '<p style="color:#fff;font-size:18px;font-weight:500;padding:16px 0">&#10004; Дякуємо! Передзвонимо за 15 хвилин.</p>';
      setTimeout(function() {
        window.location.href = '/ua/thanks/';
      }, 1500);
    });
  }
  handleForm('heroFormSplit');
  handleForm('ctaFormBottom');
})();
</script>

</Base>

<style>
/* ==========================================
   SECTION 1 — HERO SPLIT-SCREEN
   ========================================== */
.sp-hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 100vh;
  background: var(--black);
  color: var(--white);
}
.sp-hero-video {
  position: relative;
  overflow: hidden;
}
.sp-hero-video video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.sp-hero-form-side {
  display: flex;
  align-items: center;
  padding: 80px 48px 60px;
}
.sp-hero-inner {
  max-width: 520px;
  width: 100%;
}
.sp-hero-inner h1 {
  font-family: var(--fd);
  font-size: clamp(28px, 3vw, 48px);
  font-weight: 400;
  line-height: 1.05;
  margin-bottom: 20px;
}
.sp-hero-sub {
  font-size: 16px;
  color: rgba(255,255,255,.65);
  line-height: 1.7;
  margin-bottom: 32px;
}
.sp-hero-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.sp-hero-form input {
  padding: 14px 18px;
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 6px;
  background: rgba(255,255,255,.06);
  color: #fff;
  font-size: 15px;
  font-family: var(--fb);
  outline: none;
  transition: border-color .2s;
}
.sp-hero-form input::placeholder {
  color: rgba(255,255,255,.3);
}
.sp-hero-form input:focus {
  border-color: rgba(255,255,255,.5);
}
.sp-hero-form button {
  padding: 16px 24px;
  background: var(--red);
  color: #fff;
  border: none;
  border-radius: 6px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  font-family: var(--fb);
  transition: background .3s;
}
.sp-hero-form button:hover {
  background: #c42b22;
}
.sp-hero-note {
  font-size: 13px;
  color: rgba(255,255,255,.35);
  margin-top: 14px;
}
.sp-hero-phone {
  display: inline-block;
  margin-top: 10px;
  font-size: 15px;
  font-weight: 500;
  color: rgba(255,255,255,.7);
  transition: color .2s;
}
.sp-hero-phone:hover {
  color: #fff;
}

/* Mobile hero: video becomes background, form overlays */
@media (max-width: 768px) {
  .sp-hero {
    grid-template-columns: 1fr;
    min-height: auto;
    position: relative;
  }
  .sp-hero-video {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .sp-hero-video video {
    opacity: .2;
  }
  .sp-hero-form-side {
    position: relative;
    z-index: 1;
    padding: 120px 24px 60px;
  }
  .sp-hero-inner h1 {
    font-size: clamp(26px, 7vw, 36px);
  }
}

/* ==========================================
   SECTION 2 — TIMELINE
   ========================================== */
.tl-section {
  padding: 100px 0;
  background: var(--white);
}
.tl-track {
  position: relative;
  display: flex;
  justify-content: space-between;
  gap: 16px;
  margin-top: 48px;
}
.tl-line {
  position: absolute;
  top: 14px;
  left: 14px;
  right: 14px;
  height: 3px;
  background: #e0e0e0;
}
.tl-line::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--red);
  transform-origin: left;
}
