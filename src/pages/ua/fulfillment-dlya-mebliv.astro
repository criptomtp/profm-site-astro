---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент для Меблів: Великогабаритне, Монтаж, Захист від пошкоджень';
const description = 'Спеціалізований фулфілмент для меблів. Великі упаковки, спеціальні піддони, страховка 100%, монтаж на місці, доставка у 48 годин. Для маркетплейсів і магазинів.';
const ogImage = 'https://profm.ua/images/fulfillment-furniture.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  }
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент для Меблів<br />Велико-Габаритна Доставка & Монтаж
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Дивани, ліжка, шафи, столи. Спеціальна упаковка, спеціалізована доставка, монтаж, 100% страховка, гарантія за 48 годин.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент меблів
      </a>
    </div>
  </section>

  <!-- Why Furniture is Complex -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Чому меблі потребують спеціального підходу</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">📦 Великі розміри & вага</h3>
          <p class="text-gray-700">Диван на 150 кг не поміститься в звичайну коробку. Потребується спеціальна упаковка, спеціальний транспорт, спеціалізовані перевізники.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">💰 Висока вартість</h3>
          <p class="text-gray-700">Крісло за 8000 грн повернулося пошкоджено = 8000 грн збитків + рецензія. Потребується максимальна захист і страховка 100%.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🚚 Складна логістика</h3>
          <p class="text-gray-700">Диван потребує спеціального транспорту, спеціалізованого перевізника, специалиста для розвантаження. Потребується підписання документів про ушкодження.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🔧 Монтаж & Сервіс</h3>
          <p class="text-gray-700">Деякі меблі потребують монтажу. Потребується команда спеціалістів. Клієнт очікує не лише доставку, але й монтаж на місце.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MTP Furniture Services -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Послуги MTP для меблів</h2>
      <div class="space-y-4">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Спеціальна упаковка</h3>
          <p class="text-gray-700">Піддони, дерево́вяні каркаси, поліетилен, повітряна пелена. Захист від подряпин, пошкоджень, вологи. Крупногабаритна упаковка — максимальна захист.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Спеціалізована доставка</h3>
          <p class="text-gray-700">Машини 5-20 тон. Спеціалісти для розвантаження. GPS моніторинг. Фото перед доставкою, після доставки, при розвантаженні. Документи про стан.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Монтаж & Сервіс</h3>
          <p class="text-gray-700">Для крісел, столів, ліжок — монтаж включений. Команда спеціалістів приймає меблі, монтує, перевіряє, показує як користуватися. Інструменти & матеріали включені.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ 100% Страховка & Компенсація</h3>
          <p class="text-gray-700">Якщо діван приходить пошкодженим — платимо 100% вартість. Не потрібно чекати розпорядження. Миттєва компенсація на місці.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Ціни для меблів</h2>
      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-4">Комплектація & Доставка</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Комплектація (за замовлення)</span>
            <span class="font-bold">50-100 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Спеціальна упаковка (за позицію)</span>
            <span class="font-bold">20-50 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Доставка (до 50 км)</span>
            <span class="font-bold">200-500 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Монтаж (за предмет)</span>
            <span class="font-bold">100-300 грн</span>
          </li>
          <li class="flex justify-between">
            <span>100% страховка</span>
            <span class="font-bold">Включено</span>
          </li>
        </ul>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Приклад: Магазин меблів (50 замовлень/місяц)</h3>
        <p class="text-gray-700">
          Комплектація: 50 × 75 = 3,750 грн<br/>
          Упаковка: 50 × 30 = 1,500 грн<br/>
          Доставка спеціалізована: 50 × 350 = 17,500 грн<br/>
          Монтаж: 50 × 200 = 10,000 грн<br/>
          Складування: 5 палів × 400 = 2,000 грн<br/>
          <strong class="text-lg">ВСЬОГО: 34,750 грн/місяц = 695 грн/замовлення</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Безпечна логістика для меблів</h2>
      <p class="text-xl mb-8 opacity-90">
        Спеціальна упаковка, монтаж, 100% страховка, доставка за 48 годин.
      </p>
      <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент меблів
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
