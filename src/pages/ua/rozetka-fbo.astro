---
import Base from '../../layouts/Base.astro';

const title = 'Rozetka FBO з MTP: Запустіть за 3 Дні, Займіть ТОП Місця';
const description = 'Стати Rozetka FBO продавцем з MTP. Ми — офіційний партнер логістики. Сертифікація за 3 дні, комплектація за 24 години, доставка по Україні, гарантія якості 99.8%.';
const ogImage = 'https://profm.ua/images/rozetka-fbo-mtp.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  },
  priceRange: '₴18-₴150'
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Rozetka FBO з MTP<br />За 3 Дні до ТОП Місць
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        MTP — офіційний партнер логістики Rozetka. Сертифіковуємо продавців, комплектуємо замовлення, доставляємо по Україні. Запуск за 72 години.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <div class="flex items-center justify-center gap-2">
          <span class="text-yellow-300">✓</span>
          <span>3 дні до запуску</span>
        </div>
        <div class="flex items-center justify-center gap-2">
          <span class="text-yellow-300">✓</span>
          <span>99.8% якість гарантія</span>
        </div>
      </div>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити на Rozetka FBO
      </a>
    </div>
  </section>

  <!-- Why Rozetka FBO -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Чому Rozetka FBO — найкращий канал продажів</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">20 млн покупців мішяці</h3>
          <p class="text-gray-700">Rozetka — це 50% всіх онлайн покупок в Україні. Один товар на FBO отримує доступ до 20+ млн людей.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Безумовна Rozetka доставка</h3>
          <p class="text-gray-700">Покупцям від Rozetka це выглядає як покупка у Rozetka. Доставляємо за 24 години = вищі рейтинги = більше замовлень.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Рейтинг впливає на видимість</h3>
          <p class="text-gray-700">FBO продавці з рейтингом 4.8+ отримують буст в алгоритмі. Швидка доставка (24 год) — це 4.8+ гарантія.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">Конкурентна перевага</h3>
          <p class="text-gray-700">FBO продавці займають ТОП місця перед звичайними. Той же товар, але вислер виголос на платформі = більше продажів.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FBO vs Marketplace -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">FBO vs Стандартний продавець</h2>
      <div class="overflow-x-auto mb-8">
        <table class="w-full border-collapse">
          <thead>
            <tr class="bg-gray-100">
              <th class="border p-4 text-left">Параметр</th>
              <th class="border p-4 text-center">FBO (з MTP)</th>
              <th class="border p-4 text-center">Звичайний Rozetka</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="border p-4"><strong>Доставка</strong></td>
              <td class="border p-4 text-center">24 години</td>
              <td class="border p-4 text-center">3-5 днів</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4"><strong>Комісія Rozetka</strong></td>
              <td class="border p-4 text-center">5-10%</td>
              <td class="border p-4 text-center">10-20%</td>
            </tr>
            <tr>
              <td class="border p-4"><strong>Видимість в пошуку</strong></td>
              <td class="border p-4 text-center">ТОП 5</td>
              <td class="border p-4 text-center">Далі вниз</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4"><strong>Середній рейтинг</strong></td>
              <td class="border p-4 text-center">4.8-5.0 ⭐</td>
              <td class="border p-4 text-center">4.2-4.5 ⭐</td>
            </tr>
            <tr>
              <td class="border p-4"><strong>Управління складом</strong></td>
              <td class="border p-4 text-center">Ми robimo</td>
              <td class="border p-4 text-center">Ви сами</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="border p-4"><strong>Риск повернень</strong></td>
              <td class="border p-4 text-center">MTP несе</td>
              <td class="border p-4 text-center">Ви несете</td>
            </tr>
            <tr class="bg-green-50">
              <td class="border p-4 font-bold"><strong>Конверсія (звичайна)</strong></td>
              <td class="border p-4 text-center font-bold">+40-60%</td>
              <td class="border p-4 text-center">100% базис</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="bg-green-50 p-6 rounded border-l-4 border-green-600">
        <p class="text-gray-700">
          <strong>Висновок:</strong> FBO продавець з 1000 замовлень в місяц отримує +40-60% більше продажів, платить -30-40% комісії, має 99.8% якість гарантію. На практиці це означає +30-40% доходу у місяц.
        </p>
      </div>
    </div>
  </section>

  <!-- How to Launch FBO -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Запуск Rozetka FBO за 3 дні</h2>
      <div class="space-y-6">
        <div class="flex gap-6 items-start">
          <div class="bg-red-600 text-white rounded-full w-12 h-12 flex items-center justify-center flex-shrink-0 font-bold text-lg">День 1</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Підготовка документів</h3>
            <p class="text-gray-700">Надаєте нам: ІД номери товарів, цены, категорії. Ми готуємо список для сертифікації Rozetka. На справку піде 30-60 хвилин.</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="bg-red-600 text-white rounded-full w-12 h-12 flex items-center justify-center flex-shrink-0 font-bold text-lg">День 2</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Передача товару і сертифікація</h3>
            <p class="text-gray-700">Відправляєте першу партію товару на наш склад. MTP отримує, розміщує, і подає документи Rozetka на сертифікацію. Rozetka перевіряє за кілька годин.</p>
          </div>
        </div>
        <div class="flex gap-6 items-start">
          <div class="bg-red-600 text-white rounded-full w-12 h-12 flex items-center justify-center flex-shrink-0 font-bold text-lg">День 3</div>
          <div>
            <h3 class="text-xl font-bold mb-2">Запуск на Rozetka FBO</h3>
            <p class="text-gray-700">Rozetka схвалює вас як FBO партнера. Товари з'являються на платформі. Перші замовлення автоматично комплектуються MTP. Ви отримуєте гроші.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rozetka Requirements -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Вимоги Rozetka FBO</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-lg font-bold mb-4">✓ Потрібно</h3>
          <ul class="space-y-2 text-gray-700">
            <li>Реальна компанія (ФОП або ТОВ)</li>
            <li>Товари в допущених категоріях</li>
            <li>Оригинальні або ліцензовані товари</li>
            <li>Упаковка відповідає стандартам</li>
            <li>Сертифікація (якщо потребується)</li>
          </ul>
        </div>
        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-lg font-bold mb-4">✗ Не приймаються</h3>
          <ul class="space-y-2 text-gray-700">
            <li>Контрафактна продукція</li>
            <li>Б/У товари (окрім окремих категорій)</li>
            <li>Товари без потрібної сертифікації</li>
            <li>Товари з закінченим терміном</li>
            <li>Заборонена категорія</li>
          </ul>
        </div>
      </div>

      <div class="mt-8 bg-blue-50 p-6 rounded border border-blue-200">
        <p class="font-bold mb-2">❓ Невпевнені чи ваш товар підходить?</p>
        <p class="text-gray-700">Напишіть нам деталі про товар. MTP перевірить вимоги Rozetka і скаже чи можливо запуститися за 3 дні або потребує додаткових документів.</p>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Як це коштує</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        <div class="bg-white p-8 rounded border border-gray-200">
          <h3 class="text-2xl font-bold mb-6">MTP сервіси</h3>
          <ul class="space-y-3">
            <li class="flex justify-between">
              <span>Комплектація (за замовлення)</span>
              <span class="font-bold">18-30 грн</span>
            </li>
            <li class="flex justify-between">
              <span>Доставка по Україні</span>
              <span class="font-bold">50-150 грн</span>
            </li>
            <li class="flex justify-between">
              <span>Складування</span>
              <span class="font-bold">400 грн/паль/місяц</span>
            </li>
          </ul>
        </div>
        <div class="bg-white p-8 rounded border border-gray-200">
          <h3 class="text-2xl font-bold mb-6">Rozetka FBO переваги</h3>
          <ul class="space-y-3 text-gray-700">
            <li>✓ Комісія Rozetka: 5-10% (замість 10-20%)</li>
            <li>✓ Тріплінг трафіку (у ТОП 5)</li>
            <li>✓ +40-60% конверсія</li>
            <li>✓ Чистий приріст: +30-40% доходу</li>
          </ul>
        </div>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Приклад розрахунку (1000 замовлень)</h3>
        <div class="grid grid-cols-2 gap-4 text-gray-700 mb-4">
          <div>
            <p class="text-sm text-gray-600">Комплектація</p>
            <p class="font-bold">1000 × 25 = 25,000 грн</p>
          </div>
          <div>
            <p class="text-sm text-gray-600">Доставка</p>
            <p class="font-bold">1000 × 100 = 100,000 грн</p>
          </div>
        </div>
        <p class="text-center border-t pt-4">
          <span class="text-gray-700">MTP витрати: </span>
          <span class="font-bold text-red-600">125,000 грн = 125 грн/замовлення</span>
        </p>
        <p class="text-center text-sm text-gray-600 mt-2">Економія комісії Rozetka: +150,000 грн</p>
        <p class="text-center font-bold text-lg mt-2">Сумарна вигода: +25,000 грн/місяц</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">FAQ: Rozetka FBO</h2>
      <div class="space-y-6">
        <details class="bg-gray-50 p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Як швидко можна запуститися?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">За 3 дні у більшості випадків. Якщо товар вже має всі сертифікати і документи — запустимо за 24 години. Якщо потребує додаткової сертифікації — 7-14 днів.</p>
        </details>
        <details class="bg-gray-50 p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Чи Rozetka платить комісію якому-небудь посередниці?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Ні. Rozetka платить комісію лише MTP як логісту. Ви платите MTP за комплектацію і доставку. Не має додаткових комісій за сертифікацію або запуск.</p>
        </details>
        <details class="bg-gray-50 p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Як довго товар повинен бути у MTP?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">Мінімум 1-2 тижні перш ніж почніть продавати. Це дозволяє системі стабілізуватися. Потім можете отримати товар назад у будь-який момент.</p>
        </details>
        <details class="bg-gray-50 p-6 rounded cursor-pointer group">
          <summary class="font-bold text-lg flex justify-between items-center">
            Який страховий покриття якщо товар загубиться?
            <span class="group-open:rotate-180 transition">↓</span>
          </summary>
          <p class="mt-4 text-gray-700">MTP застраховує весь товар на складі. Якщо втрачено через нашу провину — компенсуємо вартість 100%. Крім того, є комерційна страховка від перевізника.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Запустіте на Rozetka FBO за 3 дні</h2>
      <p class="text-xl mb-8 opacity-90">
        +40-60% більше замовлень, -30-40% менше комісій. Найкращий канал продажів в Україні.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
          Запустити на Rozetka FBO
        </a>
        <a href="tel:+380931234567" class="inline-block border-2 border-white text-white px-8 py-4 rounded font-bold text-lg hover:bg-white hover:text-red-600 transition">
          Зв'язатися з менеджером
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
