<div class="pricing-row"><span>0 &ndash; 5</span><span>26 грн</span></div>
<div class="pricing-row"><span>6 &ndash; 20</span><span>25 грн</span></div>
<div class="pricing-row"><span>21 &ndash; 50</span><span>23 грн</span></div>
<div class="pricing-row"><span>51 &ndash; 100</span><span>22 грн</span></div>
