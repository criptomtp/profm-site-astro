</section>

<!-- SERVICES GRID -->
<section class="services-section">
<div class="container">
<h2 class="section-heading">Що ми пропонуємо</h2>
<p class="section-subtitle">Повний цикл фулфілмент послуг для вашого інтернет-магазину</p>
<div class="services-grid">

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M20 7l-8-4-8 4v10l8 4 8-4V7zm-8 11L6 14.5V9.5l6 3v5.5zm1-7L7 8l5-2.5L17 8l-4 3zm5 3.5L14 18v-5.5l4-3v5.5z"/></svg></div>
<h3>Зберігання товару</h3>
