---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент для Мистецтва & Ремесла: Хрупкість, Упаковка, Контроль';
const description = 'Спеціалізований фулфілмент для матеріалів для творчості, ремесловості, ручної роботи. Захист від пошкоджень, вологості, 100% страховка, доставка за 24-48 годин.';
const ogImage = 'https://profm.ua/images/fulfillment-crafts.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  }
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент для Мистецтва & Ремесла<br />Захист Від Пошкоджень
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Краски, олівці, паперу, клеї, тканини. Максимальна упаковка, контроль вологості, 100% страховка, доставка за 24-48 годин.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент матеріалів для творчості
      </a>
    </div>
  </section>

  <!-- Why Art & Crafts Need Special Care -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Специфіка матеріалів для творчості у логістиці</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🎨 Різноманіття & Хрупкість</h3>
          <p class="text-gray-700">Від тонкого паперу до важких красок. Від дрібних намистин до великих полотен. Кожен товар потребує іншої упаковки. Потребується гнучка система.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">💧 Вологість & Деградація</h3>
          <p class="text-gray-700">Папір в'язнеме при вологості &gt;70%. Краска висихає або замерзає при неправильній температурі. Потребується контроль вологості & температури.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🎁 Подарункова упаковка</h3>
          <p class="text-gray-700">Матеріали для творчості часто дарують. Потребується красива упаковка. Деталь упаковки впливає на враження від подарунка.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">📦 Об'ємність & Логістика</h3>
          <p class="text-gray-700">Матеріали для творчості легкі, але об'ємні. Коробка за 0.5 кг може бути 30×30×15 см. Потребується оптимізація для економії міста.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MTP Art & Crafts Services -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Послуги MTP для матеріалів творчості</h2>
      <div class="space-y-4">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Контроль вологості & температури</h3>
          <p class="text-gray-700">Для паперу — контроль вологості 40-60%. Для красок — контроль температури 10-25°C. Для тканин — захист від світла. Все залежить від матеріалу.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Спеціалізована упаковка по типам</h3>
          <p class="text-gray-700">Для паперу — платформи для економії місця. Для красок — герметичні контейнери. Для намистин — подарункова упаковка. Для кожного матеріалу своя упаковка.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Контроль якості & стану</h3>
          <p class="text-gray-700">Кожна позиція перевіряється на цілісність, скінченість, відповідність описові. Контроль упаковки, термінів придатності. 99.8% точність.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Подарункова упаковка опція</h3>
          <p class="text-gray-700">При замовленні можна обрати подарункову упаковку. Красивий пакет, стрічка, оформлення. Матеріали доставляються готовими до дарування.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Ціни для матеріалів творчості</h2>
      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-4">Комплектація & Доставка</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Комплектація (за замовлення)</span>
            <span class="font-bold">15-25 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Упаковка по типах матеріалів</span>
            <span class="font-bold">5-15 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Подарункова упаковка (опція)</span>
            <span class="font-bold">20-50 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Контроль вологості & температури</span>
            <span class="font-bold">Включено</span>
          </li>
          <li class="flex justify-between">
            <span>Доставка (стандарт)</span>
            <span class="font-bold">40-100 грн</span>
          </li>
          <li class="flex justify-between">
            <span>100% страховка</span>
            <span class="font-bold">Включено</span>
          </li>
        </ul>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Приклад: Магазин матеріалів творчості (300 замовлень/місяц)</h3>
        <p class="text-gray-700">
          Комплектація: 300 × 20 = 6,000 грн<br/>
          Упаковка: 300 × 10 = 3,000 грн<br/>
          Доставка: 300 × 70 = 21,000 грн<br/>
          Складування: 2 палі × 300 = 600 грн<br/>
          <strong class="text-lg">ВСЬОГО: 30,600 грн/месяц = 102 грн/замовлення</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Quality Guarantee -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Гарантія якості для матеріалів творчості</h2>
      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">99.8% точність комплектації</p>
            <p class="text-gray-700">Кожна позиція перевіряється на цілісність, відповідність описові. Неправильний матеріал — не буде відправлено.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Контроль вологості & температури</p>
            <p class="text-gray-700">Папір 40-60% вологості, краски 10-25°C. Документація всіх показників. Якщо умови вийшли за межі — сповіщаємо клієнтові.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lang">Спеціалізована упаковка</p>
            <p class="text-gray-700">Кожен матеріал упаковується оптимально для його типу. Папір на платформах, краски в герметичних контейнерах, намистини в подарунковій упаковці.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% страховка від пошкоджень</p>
            <p class="text-gray-700">Матеріали приватилися пошкодженими — платимо 100%. Миттєва компенсація. Клієнт може без страху замовляти творчі матеріали.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Логістика для магазинів матеріалів творчості</h2>
      <p class="text-xl mb-8 opacity-90">
        Спеціалізована упаковка, контроль умов, подарункове оформлення, 100% страховка, доставка за 24-48 годин.
      </p>
      <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент матеріалів творчості
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
