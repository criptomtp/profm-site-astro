<!-- ====== SECTION 1 — HERO ====== -->
<section class="tpl-hero">
  <div class="tpl-hero-inner ctr">
    <div class="tpl-hero-text">
      <div class="badge">3PL ЛОГІСТИКА</div>
      <h1>3PL логістика для брендів&nbsp;&mdash; повний аутсорсинг складу та&nbsp;доставки</h1>
      <p class="tpl-hero-sub">Ви розвиваєте продукт і маркетинг. Ми&nbsp;беремо на себе склад, збір, пакування, відправку, повернення та&nbsp;контроль грошей.</p>

      <!-- Animated flow diagram -->
      <div class="flow-diagram" aria-label="Схема роботи: Ваша CRM передає замовлення на MTP Склад, далі Нова Пошта доставляє Клієнту">
        <div class="flow-box">Ваша CRM</div>
        <div class="flow-line" aria-hidden="true"><span class="flow-arrow">&rarr;</span></div>
        <div class="flow-box flow-box--accent">MTP Склад</div>
        <div class="flow-line" aria-hidden="true"><span class="flow-arrow">&rarr;</span></div>
        <div class="flow-box">Нова Пошта</div>
        <div class="flow-line" aria-hidden="true"><span class="flow-arrow">&rarr;</span></div>
        <div class="flow-box">Клієнт</div>
      </div>

      <div class="crm-badges">
        <span>KeyCRM</span>
        <span>Horoshop</span>
        <span>Prom</span>
        <span>WooCommerce</span>
        <span>Shopify</span>
      </div>

      <form class="tpl-hero-form" id="heroForm">
        <input type="text" name="name" placeholder="Ваше ім'я" autocomplete="given-name" aria-label="Ім'я">
        <input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="19" required autocomplete="tel" aria-label="Телефон">
        <select name="crm" aria-label="CRM система">
          <option value="" disabled selected>Ваша CRM</option>
          <option value="KeyCRM">KeyCRM</option>
          <option value="Horoshop">Horoshop</option>
          <option value="Prom.ua">Prom.ua</option>
          <option value="WooCommerce">WooCommerce</option>
          <option value="Shopify">Shopify</option>
          <option value="OpenCart">OpenCart</option>
          <option value="other">Інша</option>
        </select>
        <button type="submit">Підключитись за 2-3 дні &rarr;</button>
      </form>
      <div class="hero-note">Безкоштовна консультація &middot; Передзвонимо за 15 хвилин</div>
    </div>

    <div class="tpl-hero-stats">
      <div class="tpl-stat"><strong>150+</strong><span>клієнтів</span></div>
      <div class="tpl-stat"><strong>60 000+</strong><span>відправлень/міс</span></div>
    </div>
  </div>
</section>

<!-- ====== SECTION 2 — CASE STUDIES ====== -->
<section class="cases-sec"><div class="ctr">
  <div class="badge badge-dark">КЕЙСИ</div>
  <h2 class="sec-h2">Результати клієнтів</h2>

  <div class="cases-grid">
    <!-- Case 1 -->
    <div class="case-card">
      <h3 class="case-name">Carter's Ukraine</h3>
      <div class="case-split">
        <div class="case-before">
          <span class="case-label case-label--before">ДО</span>
          <ul>
            <li>10-12 відправок/день</li>
            <li>30 грн/відправка</li>
            <li>0 год на маркетинг</li>
          </ul>
        </div>
        <div class="case-after">
          <span class="case-label case-label--after">ПІСЛЯ</span>
          <ul>
            <li>60-72 відправки (&times;5)</li>
            <li>14 грн (-53%)</li>
            <li>90 год/міс вивільнено</li>
          </ul>
        </div>
      </div>
      <blockquote class="case-quote">&laquo;Ми думали аутсорс&nbsp;&mdash; це втрата контролю. Виявилось навпаки.&raquo;</blockquote>
    </div>

    <!-- Case 2 -->
    <div class="case-card">
      <h3 class="case-name">I.Love.My.Cycle</h3>
      <div class="case-split">
        <div class="case-before">
          <span class="case-label case-label--before">ДО</span>
          <ul>
            <li>20-25 відправок/день</li>
            <li>33 грн/відправка</li>
          </ul>
        </div>
        <div class="case-after">
          <span class="case-label case-label--after">ПІСЛЯ</span>
          <ul>
            <li>73 відправки/день (&times;3)</li>
            <li>14 грн (-58%)</li>
            <li>90 год/міс вивільнено</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Case 3 -->
    <div class="case-card">
      <h3 class="case-name">Біодобавки</h3>
      <div class="case-split">
        <div class="case-before">
          <span class="case-label case-label--before">ДО</span>
          <ul>
            <li>10-15 відправок/день</li>
            <li>60 грн/відправка</li>
            <li>Проблеми з FEFO</li>
          </ul>
        </div>
        <div class="case-after">
          <span class="case-label case-label--after">ПІСЛЯ</span>
          <ul>
            <li>25-30 відправок (&times;2)</li>
            <li>16 грн (-73%)</li>
            <li>FEFO автоматизовано</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div></section>

<!-- ====== SECTION 3 — ROI CALCULATOR ====== -->
<section class="calc-sec" x-data="{
  orders: 1500,
  salary: 45000,
  rent: 25000,
  other: 10000,
  get dailyOrders() { return Math.round(this.orders / 22) },
  get pricePerOrder() {
    const d = this.dailyOrders;
    if (d <= 7) return 26;
    if (d <= 34) return 23;
    if (d <= 68) return 21;
    return 18;
  },
  get storageEstimate() { return Math.round(this.orders * 0.005 * 650) },
  get yourCost() { return this.salary + this.rent + this.other },
  get mtpCost() { return this.orders * this.pricePerOrder + this.storageEstimate },
  get saving() { return this.yourCost - this.mtpCost },
  get savingPct() { return this.yourCost > 0 ? Math.round((this.saving / this.yourCost) * 100) : 0 },
  get annualSaving() { return this.saving * 12 },
  fmt(n) { return n.toLocaleString('uk-UA') }
}">
<div class="ctr">
  <div class="badge badge-dark">КАЛЬКУЛЯТОР</div>
  <h2 class="sec-h2">Порахуйте економію з MTP</h2>

  <div class="calc-grid">
    <div class="calc-sliders">
      <div class="calc-field">
        <label>Замовлень/місяць: <strong x-text="fmt(orders)"></strong></label>
        <input type="range" min="100" max="5000" step="50" x-model.number="orders">
      </div>
      <div class="calc-field">
        <label>Зарплати логістики: <strong x-text="fmt(salary) + ' грн'"></strong></label>
        <input type="range" min="0" max="100000" step="1000" x-model.number="salary">
      </div>
      <div class="calc-field">
        <label>Оренда складу: <strong x-text="fmt(rent) + ' грн'"></strong></label>
        <input type="range" min="0" max="50000" step="1000" x-model.number="rent">
      </div>
      <div class="calc-field">
        <label>Інші витрати: <strong x-text="fmt(other) + ' грн'"></strong></label>
        <input type="range" min="0" max="30000" step="500" x-model.number="other">
      </div>
    </div>

    <div class="calc-result">
      <div class="calc-row">
        <span>Ваші витрати</span>
        <strong x-text="fmt(yourCost) + ' грн/міс'"></strong>
      </div>
      <div class="calc-row calc-row--accent">
        <span>З MTP</span>
        <strong x-text="fmt(mtpCost) + ' грн/міс'"></strong>
      </div>
      <div class="calc-row" x-show="mtpCost > 0">
        <span>Ціна за відправку</span>
        <strong x-text="pricePerOrder + ' грн'"></strong>
      </div>
      <div class="calc-divider"></div>
      <div class="calc-row calc-row--big" x-show="saving > 0">
        <span>Економія</span>
        <strong x-text="fmt(saving) + ' грн/міс (' + savingPct + '%)'"></strong>
      </div>
      <div class="calc-row" x-show="saving > 0">
        <span>За рік</span>
        <strong x-text="fmt(annualSaving) + ' грн'"></strong>
      </div>
      <div class="calc-row calc-row--warn" x-show="saving <= 0">
        <span>Вартість MTP</span>
        <strong x-text="fmt(mtpCost) + ' грн/міс'"></strong>
      </div>
    </div>
  </div>
</div>
</section>

<!-- ====== SECTION 4 — INTEGRATIONS ====== -->
<section class="integ-sec"><div class="ctr">
  <div class="badge badge-dark">ІНТЕГРАЦІЇ</div>
  <h2 class="sec-h2">Підключаємо вашу CRM за&nbsp;2&nbsp;години</h2>

  <div class="integ-grid">
    <div class="integ-badge integ-badge--ok">KeyCRM <span>&#10003;</span></div>
    <div class="integ-badge integ-badge--ok">Horoshop <span>&#10003;</span></div>
    <div class="integ-badge integ-badge--ok">Prom.ua <span>&#10003;</span></div>
    <div class="integ-badge integ-badge--ok">WooCommerce <span>&#10003;</span></div>
    <div class="integ-badge integ-badge--ok">Shopify <span>&#10003;</span></div>
    <div class="integ-badge">Custom API</div>
  </div>

  <div class="integ-flow">
    <div class="integ-step"><span class="integ-num">1</span><p>Замовлення &rarr; CRM</p></div>
    <div class="integ-step"><span class="integ-num">2</span><p>Авто &rarr; MTP</p></div>
    <div class="integ-step"><span class="integ-num">3</span><p>Збираємо</p></div>
    <div class="integ-step"><span class="integ-num">4</span><p>Трекінг &rarr; CRM</p></div>
  </div>

  <p class="integ-note">Підключення за 2 години &middot; Ручна робота: 0</p>
</div></section>

<!-- ====== SECTION 5 — WHAT'S INCLUDED ====== -->
<section class="included-sec"><div class="ctr">
  <div class="badge badge-dark">СЕРВІС</div>
  <h2 class="sec-h2">Що входить у 3PL</h2>

  <div class="inc-item">
    <div class="inc-text">
      <h3>Прийом та зберігання</h3>
      <p>FEFO-контроль строків придатності. Два склади під Києвом&nbsp;&mdash; 3&nbsp;900 м&sup2;. Адресне зберігання кожної одиниці. Дивіться <a href="/ua/services/" style="color:#e63329;font-weight:500">повний перелік послуг</a>.</p>
    </div>
    <div class="inc-num">01</div>
  </div>

  <div class="inc-item inc-item--reverse">
    <div class="inc-num">02</div>
    <div class="inc-text">
      <h3>Збір та пакування</h3>
      <p>Середній час збору&nbsp;&mdash; 30 секунд. Брендоване пакування, вкладки, подарункова упаковка за вашими правилами. Порахуйте вартість через <a href="/ua/calculator/" style="color:#e63329;font-weight:500">калькулятор вартості</a>.</p>
    </div>
  </div>

  <div class="inc-item">
    <div class="inc-text">
      <h3>Відправка та ТТН</h3>
      <p>4 відправки/день. Нова Пошта, Укрпошта, Rozetka Delivery. Автоматичне створення ТТН та статусів.</p>
    </div>
    <div class="inc-num">03</div>
  </div>

  <div class="inc-item inc-item--reverse">
    <div class="inc-num">04</div>
    <div class="inc-text">
      <h3>Обробка повернень</h3>
      <p>Щоденний забір повернень. Перевірка, повернення на полицю або списання. Повний контроль через WMS.</p>
    </div>
  </div>

  <div class="inc-item">
    <div class="inc-text">
      <h3>Контроль грошей</h3>
      <p>Шериф Платежів&nbsp;&mdash; Telegram-сповіщення при кожному отриманні коштів від перевізника. Жодна гривня не загубиться. Читайте <a href="/ua/recalls/" style="color:#e63329;font-weight:500">відгуки клієнтів</a> про нашу прозорість.</p>
    </div>
    <div class="inc-num">05</div>
  </div>

  <div class="inc-item inc-item--reverse">
    <div class="inc-num">06</div>
    <div class="inc-text">
      <h3>Фіскалізація</h3>
      <p>CheckBox РРО&nbsp;&mdash; фіскальні чеки автоматично. Відповідність законодавству без додаткових дій з вашого боку.</p>
    </div>
  </div>

  <div class="inc-item">
    <div class="inc-text">
      <h3>SMS та автопродзвін</h3>
      <p>Автоматичні SMS та продзвін покупцям. Підвищення викупу на 10-15%. Менше повернень, більше прибутку.</p>
    </div>
    <div class="inc-num">07</div>
  </div>
</div></section>

<!-- ====== SECTION 6 — CARRIERS ====== -->
<section class="carriers-sec"><div class="ctr">
  <div class="badge badge-dark">ПЕРЕВІЗНИКИ</div>
