<tr><td><strong>Всього</strong></td><td></td><td>41 200 грн</td></tr>
<tr><td>Ціна за замовлення</td><td>41 200 ÷ 1 500</td><td><strong>27,5 грн</strong></td></tr>
</tbody>
</table>
</div>

