<script>
function calculateROI() {
  const ordersPerDay = parseInt(document.getElementById('ordersPerDay').value) || 0;
  const avgOrderValue = parseInt(document.getElementById('avgOrderValue').value) || 0;
  const staff = parseInt(document.getElementById('staff').value) || 0;

  // Own warehouse costs
  const baseSalary = staff * 15000;
  const orendalBase = ordersPerDay < 50 ? 5000 : ordersPerDay < 100 ? 10000 : 15000;
  const materials = (ordersPerDay * 250) / 20; // rough estimate
  const other = 3000;
  const ownWarehouseCost = baseSalary + orendalBase + materials + other;

  // Fulfillment costs
  let fulfillmentBase = 0;
  if (ordersPerDay < 50) fulfillmentBase = 15000;
  else if (ordersPerDay < 100) fulfillmentBase = 20000;
  else if (ordersPerDay < 150) fulfillmentBase = 25000;
  else fulfillmentBase = 30000;

  const fulfillmentCost = fulfillmentBase + (ordersPerDay * 22); // avg shipping cost

  // Time value
  const hoursPerMonth = ordersPerDay < 50 ? 30 : ordersPerDay < 100 ? 60 : 100;
  const hourlyRate = (avgOrderValue * ordersPerDay * 20) / 160; // rough calc
  const timeValue = hoursPerMonth * (hourlyRate / 160);

  // Results
  const savings = Math.max(ownWarehouseCost - fulfillmentCost, 0);
  const totalROI = savings + timeValue;

  document.getElementById('ownWarehouseCost').textContent = ownWarehouseCost.toLocaleString('uk-UA');
  document.getElementById('fulfillmentCost').textContent = fulfillmentCost.toLocaleString('uk-UA');
  document.getElementById('savings').textContent = savings.toLocaleString('uk-UA');
  document.getElementById('timeValue').textContent = Math.floor(timeValue).toLocaleString('uk-UA');
  document.getElementById('totalROI').textContent = Math.floor(totalROI).toLocaleString('uk-UA');
  document.getElementById('roiResult').style.display = 'block';
}

// Auto-calculate on load
calculateROI();
</script>

