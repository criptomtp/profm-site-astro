.operator-score{display:inline-block}
.score-badge{display:inline-block;padding:4px 14px;border-radius:100px;font-size:14px;font-weight:600;background:rgba(255,255,255,.15);color:#fff;letter-spacing:.5px}
.operator-top .score-badge{background:rgba(0,0,0,.2)}
.operator-body{padding:28px}
.operator-body p{margin-bottom:16px}

/* Operator details */
.operator-details{display:grid;grid-template-columns:1fr;gap:8px;padding:20px;background:#f9f9f9;border-radius:8px;margin:20px 0;font-size:15px}
.detail-row{display:flex;gap:8px;line-height:1.6}
.detail-label{font-weight:600;color:#000;min-width:150px;flex-shrink:0}
.operator-details a{color:#e63329;text-decoration:none}
.operator-details a:hover{text-decoration:underline}

/* Pros/cons */
.operator-pros-cons{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin:20px 0}
.pros,.cons{padding:16px 20px;border-radius:8px}
.pros{background:#f0faf0;border:1px solid #d4edda}
.cons{background:#fff5f5;border:1px solid #f5c6cb}
.pros strong{color:#28703c;display:block;margin-bottom:8px;font-size:14px;text-transform:uppercase;letter-spacing:1px}
.cons strong{color:#e63329;display:block;margin-bottom:8px;font-size:14px;text-transform:uppercase;letter-spacing:1px}
.pros ul,.cons ul{margin:0;padding-left:18px;font-size:14px;line-height:1.7}
.pros li,.cons li{margin-bottom:6px}
@media(max-width:640px){.operator-pros-cons{grid-template-columns:1fr}.detail-label{min-width:120px}}

/* Operator CTA */
.operator-cta{margin-top:20px;text-align:center}
.operator-cta a{display:inline-block;padding:16px 32px;background:#e63329;color:#fff;border-radius:6px;font-size:16px;font-weight:600;text-decoration:none;transition:background .3s}
.operator-cta a:hover{background:#c42b22}

/* Comparison table */
.comparison-table-wrap{margin:24px 0;overflow-x:auto;-webkit-overflow-scrolling:touch}
.comparison-table{width:100%;border-collapse:collapse;font-size:14px;min-width:700px}
.comparison-table th{background:#e63329;color:#fff;padding:14px 16px;text-align:left;font-weight:600;font-size:13px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap}
.comparison-table td{padding:12px 16px;border-bottom:1px solid #e8e8e8;vertical-align:middle}
.comparison-table tr:hover{background:#f9f9f9}
.table-highlight{background:#fff5f4!important}
.table-highlight:hover{background:#fff0ee!important}
.table-highlight td{font-weight:500}

/* Blog CTA */
.blog-cta{background:#e63329;color:#fff;padding:40px 32px;border-radius:12px;text-align:center;margin:48px 0}
.blog-cta h3{font-family:'DM Serif Display',serif;font-size:24px;font-weight:400;margin-bottom:8px;color:#fff}
.blog-cta p{opacity:.85;margin-bottom:20px;font-size:15px}
.blog-cta a{display:inline-block;padding:14px 28px;background:#000;color:#fff;border-radius:6px;text-decoration:none;font-weight:600;transition:background .3s}
.blog-cta a:hover{background:#333}

/* Blog table */
.blog-table{margin:24px 0;overflow-x:auto}
.blog-table table{width:100%;border-collapse:collapse;font-size:15px}
.blog-table th,.blog-table td{padding:12px 16px;border:1px solid #e0e0e0;text-align:left}
.blog-table th{background:#000;color:#fff;font-weight:600;font-size:13px;text-transform:uppercase}
.blog-table tr:hover{background:#f9f9f9}

/* Blackout comparison */
.blackout-comparison{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:24px 0}
.blackout-card{padding:20px;border-radius:10px;font-size:14px}
.blackout-card strong{display:block;margin-bottom:12px;font-size:15px}
.blackout-card ul{margin:0;padding-left:18px}
.blackout-card li{margin-bottom:6px;line-height:1.6}
.blackout-good{background:#f0faf0;border:1px solid #d4edda}
.blackout-good strong{color:#28703c}
.blackout-warn{background:#fff5f5;border:1px solid #f5c6cb}
.blackout-warn strong{color:#e63329}
@media(max-width:640px){.blackout-comparison{grid-template-columns:1fr}}

/* FAQ */
.blog-faq{margin:24px 0}
.blog-faq details{border:1px solid #e0e0e0;border-radius:8px;margin-bottom:8px;overflow:hidden}
.blog-faq summary{padding:16px 20px;font-weight:600;font-size:16px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center}
.blog-faq summary::after{content:'+';font-size:20px;color:#e63329;transition:transform .3s}
.blog-faq details[open] summary::after{transform:rotate(45deg)}
.blog-faq summary::-webkit-details-marker{display:none}
.blog-faq details p{padding:0 20px 16px;color:#666;font-size:15px;line-height:1.7;margin:0}
.blog-faq details a{color:#e63329;text-decoration:none}
.blog-faq details a:hover{text-decoration:underline}

/* Responsive */
@media(max-width:768px){
.blog-hero-img{margin:-80px -24px 24px}
.operator-header{flex-direction:column;align-items:flex-start;gap:8px;padding:20px}
.operator-rank{font-size:24px;min-width:auto}
.operator-body{padding:20px}
.detail-row{flex-direction:column;gap:2px}
.detail-label{min-width:auto}
}
</style>
