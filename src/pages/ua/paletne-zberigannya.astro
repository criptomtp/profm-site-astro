<script is:inline>
(function(){
  document.querySelectorAll('.faq-q').forEach(function(btn){btn.addEventListener('click',function(){var item=this.closest('.faq-item');item.classList.toggle('open');var a=item.querySelector('.faq-a');if(item.classList.contains('open')){a.style.maxHeight=a.scrollHeight+'px';}else{a.style.maxHeight='0';}});});
  var heroForm = document.getElementById('heroForm');
  if(heroForm){heroForm.addEventListener('submit',function(e){e.preventDefault();var ph=heroForm.querySelector('input[name="phone"]').value.replace(/\D/g,'');if(ph.length<10){alert('Введіть коректний номер телефону');return;}
  fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});if(window.mtpSubmitLead)window.mtpSubmitLead(ph);heroForm.innerHTML='<div style="text-align:center"><p style="color:#fff;font-size:18px;font-weight:500">Дякуємо!</p><p style="color:rgba(255,255,255,.5);font-size:14px;margin-top:8px">Передзвонимо найближчим часом</p></div>';setTimeout(function(){window.location.href='/ua/thanks/';},1500);});}
  var form = document.getElementById('pzBookingForm');
  if(!form) return;
  form.addEventListener('submit', function(e){
    e.preventDefault();
    var phoneInput = form.querySelector('input[name="phone"]');
    var ph = phoneInput.value.replace(/\D/g, '');
    if(ph.length < 10){
      phoneInput.style.borderColor = '#e63329';
      phoneInput.focus();
      return;
    }
    phoneInput.style.borderColor = '';
    var page = location.pathname;
    if(window.mtpSubmitLead){
      window.mtpSubmitLead(ph, page);
    }
    fetch('/api/telegram', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        phone: ph,
        name: form.querySelector('input[name="name"]').value.trim(),
        email: form.querySelector('input[name="email"]').value.trim(),
        pallets: form.querySelector('select[name="pallets"]').value,
        page: page
      })
    }).catch(function(){});
    form.innerHTML = '<div style="text-align:center;padding:32px 0"><p style="font-size:20px;font-weight:600;color:#fff;margin-bottom:8px">Дякуємо за заявку!</p><p style="font-size:15px;color:rgba(255,255,255,.55)">Передзвонимо протягом 15 хвилин</p></div>';
    setTimeout(function(){ window.location.href = '/ua/thanks/'; }, 2000);
  });
})();
</script>
