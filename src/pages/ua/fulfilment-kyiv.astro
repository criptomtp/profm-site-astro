:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-block;padding:6px 16px;border:1px solid var(--red);color:var(--red);font-size:11px;font-weight:600;letter-spacing:2px;border-radius:2px;text-transform:uppercase}
.badge-dark{border-color:#ccc;color:#666}
.sec-h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;text-align:center;margin:12px 0 48px}

.hero{position:relative;min-height:90vh;background:var(--black);color:var(--white);display:flex;flex-direction:column;justify-content:center;padding:140px 0 0;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:linear-gradient(105deg,rgba(0,0,0,.88) 0%,rgba(0,0,0,.65) 55%,rgba(0,0,0,.45) 100%),url('https://img.youtube.com/vi/bHY3cFF9SlI/maxresdefault.jpg') center/cover no-repeat}
.hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero-content::before{content:'';position:absolute;left:calc(8vw - 40px);top:0;height:100%;width:3px;background:var(--red)}
.hero h1{font-family:var(--fd);font-size:clamp(36px,5vw,72px);font-weight:400;line-height:.95;margin-bottom:28px}
.hero-sub{font-size:clamp(16px,1.8vw,19px);color:rgba(255,255,255,.6);line-height:1.7;max-width:580px;margin-bottom:40px}
.hero-form{display:flex;gap:12px;max-width:460px}
.hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;font-family:var(--fb);outline:none}
.hero-form input::placeholder{color:rgba(255,255,255,.25)}.hero-form input:focus{border-color:rgba(255,255,255,.5)}
.hero-form button{padding:16px 24px;background:transparent;color:#fff;border:2px solid #fff;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:all .3s}
.hero-form button:hover{background:var(--red);border-color:var(--red)}
.hero-note{font-size:13px;color:rgba(255,255,255,.3);margin-top:12px}
.hero-stats{display:flex;gap:32px;padding:48px 8vw 0;margin-top:auto;position:relative;z-index:2}
.hero-stat{border-top:3px solid var(--red);padding:20px 0;flex:1}
.hero-stat-val{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;color:#fff;white-space:nowrap}
.hero-stat-label{font-size:11px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:2px;margin-top:4px}

.why-kyiv{padding:100px 0}
.wk-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:32px}
.wk-card{padding:40px 32px;border:1px solid #e0e0e0;border-radius:12px}
.wk-icon{font-size:32px;margin-bottom:16px}
.wk-card h3{font-size:18px;font-weight:600;margin-bottom:8px}
.wk-card p{font-size:15px;color:var(--muted);line-height:1.7}

.warehouses{padding:100px 0;background:#0a0a0a;color:#fff}
.wh-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:32px;margin-bottom:32px}
.wh-card{padding:40px 36px;border:1px solid rgba(255,255,255,.1);border-radius:12px}
.wh-name{font-family:var(--fd);font-size:28px;margin-bottom:4px}
.wh-size{font-size:42px;font-family:var(--fd);color:var(--red);margin-bottom:20px}
.wh-features{list-style:none;padding:0}
.wh-features li{font-size:14px;color:rgba(255,255,255,.6);padding:8px 0;border-bottom:1px solid rgba(255,255,255,.06);padding-left:20px;position:relative}
.wh-features li::before{content:'✓';position:absolute;left:0;color:var(--red)}
.wh-note{text-align:center;font-size:15px;color:rgba(255,255,255,.5);max-width:600px;margin:0 auto}

.services-full{padding:100px 0;background:var(--gray)}
.sf-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.sf-card{padding:36px 28px;background:#fff;border-radius:12px;border:1px solid #e0e0e0}
.sf-num{font-family:var(--fd);font-size:48px;color:rgba(0,0,0,.06);line-height:1;margin-bottom:8px}
.sf-card h3{font-size:17px;font-weight:600;margin-bottom:8px}
.sf-card p{font-size:14px;color:var(--muted);line-height:1.6}

.case-study{padding:100px 0;background:#0a0a0a;color:#fff}
.case-content{max-width:800px;margin:0 auto}
.case-intro{font-size:18px;color:rgba(255,255,255,.7);line-height:1.7;margin-bottom:40px;text-align:center}
.case-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.case-metric{text-align:center;padding:28px 16px;border:1px solid rgba(255,255,255,.1);border-radius:8px}
.cm-val{display:block;font-family:var(--fd);font-size:clamp(24px,3vw,36px);color:var(--red);margin-bottom:4px}
.cm-label{font-size:12px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:1px}

.pricing{padding:100px 0}
.price-table{max-width:700px;margin:0 auto 32px;border-radius:12px;overflow:hidden;border:1px solid #e0e0e0}
.price-row{display:flex;border-bottom:1px solid #eee;font-size:15px}.price-row:last-child{border:none}
.price-row>span{flex:1;padding:14px 20px}
.price-header{background:var(--black);color:#fff;font-weight:600;font-size:13px;text-transform:uppercase;letter-spacing:.5px}
.price-row:not(.price-header):hover{background:var(--gray)}
.price-highlight{background:var(--red);color:#fff;font-weight:600}
.price-note{text-align:center;font-size:15px;color:var(--muted);max-width:600px;margin:0 auto;font-style:italic}

.vs-section{padding:100px 0;background:var(--gray)}
.vs-table{max-width:800px;margin:0 auto;border-radius:12px;overflow:hidden;border:1px solid #e0e0e0}
.vs-row{display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;border-bottom:1px solid #eee;font-size:14px}
.vs-row:last-child{border:none}
.vs-row>span{padding:14px 16px}
.vs-header{background:var(--black);color:#fff;font-weight:600;font-size:12px;text-transform:uppercase}
.vs-win{color:var(--red);font-weight:600}

.faq{padding:100px 0;background:#0a0a0a;color:#fff}
.faq-list{max-width:700px;margin:0 auto}
.faq-item{border-bottom:1px solid rgba(255,255,255,.08)}
.faq-q{width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:var(--fb);text-align:left}
.faq-q::after{content:'+';font-size:24px;color:var(--red);transition:transform .3s;flex-shrink:0;margin-left:16px}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.faq-a p{padding:0 0 20px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.7}

.article-section{background:#fff;padding:80px 8vw}
.article-section h2{font-family:var(--fd);font-size:clamp(28px,3.5vw,44px);font-weight:400;margin:20px 0 40px}
.article-content{max-width:800px}
.article-content h3{font-family:var(--fd);font-size:clamp(18px,2vw,26px);font-weight:400;margin:36px 0 12px;color:var(--black)}
.article-content h3:first-child{margin-top:0}
.article-content p{font-size:16px;line-height:1.85;color:#444;margin-bottom:8px}

@media(max-width:768px){
.hero-content::before{left:0;width:2px}.hero-form{flex-direction:column}.hero-form button{width:100%}
.hero-stats{flex-wrap:wrap;gap:24px;padding:32px 24px 0}
.wk-grid{grid-template-columns:1fr}
.wh-grid{grid-template-columns:1fr}
.sf-grid{grid-template-columns:1fr}
.case-metrics{grid-template-columns:1fr}
.vs-section .ctr{overflow-x:auto}.vs-table{min-width:600px}
}

.wk-card,.wh-card,.sf-card,.case-metric{opacity:1!important;transform:none!important}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
document.querySelectorAll('.faq-q').forEach(function(btn){btn.addEventListener('click',function(){var item=btn.parentElement;var a=item.querySelector('.faq-a');var open=item.classList.contains('open');document.querySelectorAll('.faq-item.open').forEach(function(el){el.classList.remove('open');el.querySelector('.faq-a').style.maxHeight=null;});if(!open){item.classList.add('open');a.style.maxHeight=a.scrollHeight+'px';}});});
});
</script>
