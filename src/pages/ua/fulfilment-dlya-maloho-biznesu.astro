.sb-hero-solution{padding:40px 24px;border-left:none;border-top:4px solid var(--red)}
.sb-hero-center .hero-form{flex-direction:column}
.sb-hero-center .hero-form button{width:100%}
.sb-scale-labels{grid-template-columns:1fr;gap:32px}
.sb-econ-table{font-size:13px}
.sb-econ-table th,.sb-econ-table td{padding:8px 12px}
.sb-pains-grid{grid-template-columns:1fr}
.sb-tl-grid{grid-template-columns:1fr;gap:32px}
.sb-tl-connector{display:none!important}
.sb-pr-cards{grid-template-columns:1fr}
}

@media(min-width:769px) and (max-width:1024px){
.sb-pains-grid{grid-template-columns:repeat(3,1fr)}
.sb-pains-grid .sb-pain-card:nth-child(4),.sb-pains-grid .sb-pain-card:nth-child(5){grid-column:span 1}
}

/* force visible (no FOUC) */
.sb-pain-card,.sb-tl-step,.sb-pr-card,.sb-scale-item{opacity:1!important;transform:none!important}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
/* FAQ accordion */
document.querySelectorAll('.sb-faq-q').forEach(function(btn){
btn.addEventListener('click',function(){
var item=btn.parentElement;
var a=item.querySelector('.sb-faq-a');
var open=item.classList.contains('open');
document.querySelectorAll('.sb-faq-item.open').forEach(function(el){el.classList.remove('open');el.querySelector('.sb-faq-a').style.maxHeight=null;});
if(!open){item.classList.add('open');a.style.maxHeight=a.scrollHeight+'px';}
});
});
/* YouTube facade */
document.querySelectorAll('.yt-facade').forEach(function(el){
el.addEventListener('click',function(){
var id=el.getAttribute('data-id');
var iframe=document.createElement('iframe');
iframe.setAttribute('src','https://www.youtube.com/embed/'+id+'?autoplay=1&rel=0');
iframe.setAttribute('frameborder','0');
iframe.setAttribute('allowfullscreen','');
iframe.setAttribute('allow','accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture');
iframe.style.cssText='position:absolute;top:0;left:0;width:100%;height:100%;border:none';
el.style.position='relative';
el.innerHTML='';
el.appendChild(iframe);
});
});
});
</script>
