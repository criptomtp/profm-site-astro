const schemaJson = `<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Фулфілмент для малого бізнесу","description":"Фулфілмент для малого бізнесу в Україні: пакування, зберігання, відправка від 18 грн/замовлення. WMS, інтеграція з CRM, генератори, Starlink.","provider":{"@type":"Organization","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":"+380501444645"},"areaServed":{"@type":"Country","name":"UA"},"offers":{"@type":"Offer","priceCurrency":"UAH","price":"18","description":"Від 18 грн за відправлення (100+ замовлень/день)"}}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Головна","item":"https://www.fulfillmentmtp.com.ua/"},{"@type":"ListItem","position":2,"name":"Послуги","item":"https://www.fulfillmentmtp.com.ua/ua/3pl-logistyka/"},{"@type":"ListItem","position":3,"name":"Фулфілмент для малого бізнесу","item":"https://www.fulfillmentmtp.com.ua/ua/fulfilment-dlya-maloho-biznesu/"}]}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Скільки реально коштує фулфілмент при 10 замовленнях на день?","acceptedAnswer":{"@type":"Answer","text":"При 10 замовленнях/день — від 26 грн за відправку. За місяць (200 замовлень) це 5 200 грн. Для порівняння: навіть мінімальний власний склад обійдеться у 25 000-30 000 грн. Різниця — 5 разів."}},{"@type":"Question","name":"Чи потрібен довгостроковий контракт для початку роботи?","acceptedAnswer":{"@type":"Answer","text":"Ні. Без прив'язки до довгострокових контрактів. Договір можна розірвати з попередженням за 14 днів. Ви не ризикуєте — спробуйте і оціните сервіс."}},{"@type":"Question","name":"Чи підходить фулфілмент для продажів через Instagram і Telegram?","acceptedAnswer":{"@type":"Answer","text":"Так. Навіть без CRM є рішення: ви надсилаєте замовлення через Telegram-бот або простий інтерфейс. Ми збираємо і відправляємо. Коли зростете — підключите CRM."}},{"@type":"Question","name":"Як працює брендоване пакування для малого бізнесу?","acceptedAnswer":{"@type":"Answer","text":"Привозите або замовляєте через нас: брендовані коробки, крафт-пакети, наклейки, листівки-подяки. Все зберігається на складі і вкладається в кожну посилку. Покупець бачить ваш бренд — без згадки MTP."}},{"@type":"Question","name":"Коли малому бізнесу стає вигідно переходити на фулфілмент?","acceptedAnswer":{"@type":"Answer","text":"Від 5 замовлень на день або коли пакування забирає більше 2 годин щодня. Мінімальний платіж 5 000 грн/міс — це менше ніж зарплата навіть одного пакувальника."}},{"@type":"Question","name":"Чи є пробний період без зобов'язань?","acceptedAnswer":{"@type":"Answer","text":"Формально пробного періоду немає, але договір без довгострокової прив'язки. Перші 2 тижні — це фактично тест: якщо не підходить — розірвання за 14 днів без штрафів."}},{"@type":"Question","name":"Як малий бізнес контролює товар на чужому складі?","acceptedAnswer":{"@type":"Answer","text":"Через WMS-кабінет онлайн 24/7: залишки по кожному SKU, статуси замовлень, фото-фіксація, звіти. Telegram-бот сповіщає про оплати. Повний контроль без фізичної присутності."}},{"@type":"Question","name":"Що якщо мій бізнес виросте з 10 до 200 замовлень на день?","acceptedAnswer":{"@type":"Answer","text":"Масштабування автоматичне. Тариф знижується зі зростанням обсягів: 200+ замовлень/день = 18 грн замість 26 грн. Жодних додаткових домовленостей — WMS і склад готові."}}]}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","address":[{"@type":"PostalAddress","addressLocality":"Щасливе, Бориспільський район","addressRegion":"Київська область","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"Білогородка","addressRegion":"Київська область","addressCountry":"UA","description":"Склад 1 100 м²"}],"openingHours":"Mo-Su 08:00-20:00"}</script>`;
---
<Base
  title="Фулфілмент для малого бізнесу від 18 грн | MTP Group"
  description="Фулфілмент для малого бізнесу в Україні: зберігання, пакування, відправка від 18 грн. WMS-кабінет 24/7, генератори, інтеграція з CRM за 2 години."
  canonical="https://www.fulfillmentmtp.com.ua/ua/fulfilment-dlya-maloho-biznesu/"
  lang="uk"
  ogImage="https://www.fulfillmentmtp.com.ua/images/mtp-fulfillment-warehouse-hero.webp"
  schema={schemaJson}
  preloadHero={false}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/fulfilment-dlya-maloho-biznesu/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/fulfilment-dlya-malogo-biznesa/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/ua/fulfilment-dlya-maloho-biznesu/">
</Fragment>

<!-- HERO — Split-screen comparison -->
<section class="sb-hero">
<div class="sb-hero-split">
<div class="sb-hero-pain">
<div class="sb-hero-pain-inner">
<div class="sb-pain-label">ЗАРАЗ</div>
<div class="sb-pain-line">Ваш гараж.</div>
<div class="sb-pain-line">3 години пакування.</div>
<div class="sb-pain-line">Excel-таблиця.</div>
<div class="sb-pain-line sb-pain-dim">Пропущений забір НП.</div>
<div class="sb-pain-line sb-pain-dim">Помилка в адресі.</div>
</div>
</div>
<div class="sb-hero-solution">
<div class="sb-hero-solution-inner">
<div class="sb-solution-label">З MTP GROUP</div>
<div class="sb-solution-line">Склади MTP Group.</div>
<div class="sb-solution-line">30 секунд на замовлення.</div>
<div class="sb-solution-line">WMS-система.</div>
<div class="sb-solution-line sb-solution-bright">4 забори НП на день.</div>
<div class="sb-solution-line sb-solution-bright">99.5% точність.</div>
</div>
</div>
</div>
<div class="sb-hero-center">
<div class="badge">МАЛИЙ БІЗНЕС</div>
<h1>Фулфілмент для<br>малого бізнесу</h1>
<div class="sb-hero-price">від 18 <small>грн/відправка</small></div>
<form class="hero-form" id="heroForm"><input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="19" required autocomplete="tel" aria-label="Телефон"><button type="submit">Розрахувати вартість &#8594;</button></form>
<div class="sb-hero-note">Безкоштовна консультація &middot; Без довгострокових контрактів</div>
</div>
</div>
</section>

<!-- THRESHOLD — Коли вже час? -->
<section class="sb-threshold"><div class="ctr">
<div class="badge badge-dark">МАСШТАБ</div>
<h2 class="sec-h2">Коли малому бізнесу час на фулфілмент?</h2>
<div class="sb-scale">
<div class="sb-scale-bar">
<div class="sb-scale-fill" style="width:100%"></div>
<div class="sb-scale-mark" style="left:5%"><span class="sb-mark-dot"></span></div>
<div class="sb-scale-mark" style="left:30%"><span class="sb-mark-dot sb-mark-warn"></span></div>
<div class="sb-scale-mark" style="left:65%"><span class="sb-mark-dot sb-mark-crit"></span></div>
</div>
<div class="sb-scale-labels">
<div class="sb-scale-item sb-scale-pos1">
<div class="sb-scale-num">5&ndash;10</div>
<div class="sb-scale-txt">замовлень/день</div>
<div class="sb-scale-desc">Починайте думати. Порахуйте, скільки годин витрачаєте на пакування щодня.</div>
</div>
<div class="sb-scale-item sb-scale-pos2">
<div class="sb-scale-num">30&ndash;50</div>
<div class="sb-scale-txt">замовлень/день</div>
<div class="sb-scale-desc">Критичний поріг. Ви вже пропускаєте забори, плутаєте адреси, не встигаєте.</div>
</div>
<div class="sb-scale-item sb-scale-pos3">
<div class="sb-scale-num">100+</div>
<div class="sb-scale-txt">замовлень/день</div>
<div class="sb-scale-desc">Без фулфілменту неможливо. Кожна хвилина затримки &mdash; втрачений клієнт.</div>
</div>
</div>
</section></div></section>

<!-- UNIT ECONOMICS BATTLE -->
<section class="sb-economics"><div class="ctr">
<div class="badge">ЕКОНОМІКА</div>
<h2 class="sec-h2">Скільки ви справді витрачаєте?</h2>
<p class="sb-econ-sub">Порівняння щомісячних витрат: власний склад проти MTP Group</p>
<div class="sb-econ-table-wrap">
<table class="sb-econ-table">
<thead>
<tr><th>Витрата</th><th>Свій склад</th><th>MTP Group</th></tr>
</thead>
<tbody>
<tr class="sb-econ-vol"><td colspan="3"><strong>10 замовлень/день (~200/міс)</strong></td></tr>
<tr><td>Оренда приміщення</td><td>8 000 грн</td><td>&mdash;</td></tr>
<tr><td>Зарплата пакувальника</td><td>12 000 грн</td><td>&mdash;</td></tr>
<tr><td>Пакувальні матеріали</td><td>2 000 грн</td><td>включено</td></tr>
<tr><td>Комунальні + генератор</td><td>4 000 грн</td><td>включено</td></tr>
<tr><td>WMS-система</td><td>1 500 грн</td><td>включено</td></tr>
<tr><td>Відправка (200 зам.)</td><td>&mdash;</td><td>5 200 грн</td></tr>
<tr class="sb-econ-total"><td>РАЗОМ</td><td>27 500 грн</td><td class="sb-econ-save">5 200 грн</td></tr>
<tr class="sb-econ-vol"><td colspan="3"><strong>50 замовлень/день (~1 000/міс)</strong></td></tr>
<tr><td>Оренда приміщення</td><td>15 000 грн</td><td>&mdash;</td></tr>
<tr><td>Зарплата (2 пакувальники)</td><td>28 000 грн</td><td>&mdash;</td></tr>
<tr><td>Пакувальні матеріали</td><td>5 000 грн</td><td>включено</td></tr>
<tr><td>Комунальні + генератор</td><td>6 000 грн</td><td>включено</td></tr>
<tr><td>WMS-система</td><td>2 500 грн</td><td>включено</td></tr>
<tr><td>Відправка (1 000 зам.)</td><td>&mdash;</td><td>22 000 грн</td></tr>
<tr class="sb-econ-total"><td>РАЗОМ</td><td>56 500 грн</td><td class="sb-econ-save">22 000 грн</td></tr>
<tr class="sb-econ-vol"><td colspan="3"><strong>100 замовлень/день (~2 000/міс)</strong></td></tr>
<tr><td>Оренда приміщення</td><td>20 000 грн</td><td>&mdash;</td></tr>
<tr><td>Зарплата (4 пакувальники)</td><td>56 000 грн</td><td>&mdash;</td></tr>
<tr><td>Пакувальні матеріали</td><td>10 000 грн</td><td>включено</td></tr>
<tr><td>Комунальні + генератор</td><td>8 000 грн</td><td>включено</td></tr>
<tr><td>WMS-система</td><td>3 500 грн</td><td>включено</td></tr>
<tr><td>Відправка (2 000 зам.)</td><td>&mdash;</td><td>40 000 грн</td></tr>
<tr class="sb-econ-total"><td>РАЗОМ</td><td>97 500 грн</td><td class="sb-econ-save">40 000 грн</td></tr>
<tr class="sb-econ-vol"><td colspan="3"><strong>200 замовлень/день (~4 000/міс)</strong></td></tr>
<tr><td>Оренда + утримання</td><td>35 000 грн</td><td>&mdash;</td></tr>
<tr><td>Зарплата (7 пакувальників)</td><td>98 000 грн</td><td>&mdash;</td></tr>
<tr><td>Пакувальні матеріали</td><td>18 000 грн</td><td>включено</td></tr>
<tr><td>Комунальні + генератор</td><td>12 000 грн</td><td>включено</td></tr>
<tr><td>WMS-система</td><td>5 000 грн</td><td>включено</td></tr>
<tr><td>Відправка (4 000 зам.)</td><td>&mdash;</td><td>72 000 грн</td></tr>
<tr class="sb-econ-total"><td>РАЗОМ</td><td>168 000 грн</td><td class="sb-econ-save">72 000 грн</td></tr>
</tbody>
</table>
</div>
<p class="sb-econ-note">* Ціни MTP Group включають: зберігання, збір, пакування, матеріали, WMS, ТТН. <a href="/ua/tsiny/" style="color:var(--red)">Детальні тарифи &rarr;</a></p>
</div></section>

<!-- 5 PAIN → 5 SOLUTIONS -->
<section class="sb-pains"><div class="ctr">
<div class="badge">РІШЕННЯ</div>
<h2 class="sec-h2">5 болей малого бізнесу &mdash; 5 рішень MTP</h2>
<div class="sb-pains-grid">
<div class="sb-pain-card">
<div class="sb-pc-pain"><span class="sb-pc-icon">&#9889;</span><div class="sb-pc-pain-text">Блекаути зупиняють відправки на 1-3 дні, клієнти скасовують замовлення</div></div>
<div class="sb-pc-arrow">&darr;</div>
<div class="sb-pc-fix"><strong>3 генератори + Starlink + 2 провайдери</strong> &mdash; з лютого 2022 року жодного дня простою. Ваші замовлення відправляються щодня.</div>
</div>
<div class="sb-pain-card">
<div class="sb-pc-pain"><span class="sb-pc-icon">&#128230;</span><div class="sb-pc-pain-text">Повернення товарів &mdash; хаос: де лежить, в якому стані, як повернути на полицю</div></div>
<div class="sb-pc-arrow">&darr;</div>
<div class="sb-pc-fix"><strong>Повернення під контролем</strong> &mdash; приймаємо, перевіряємо стан, фото-фіксуємо і повертаємо на полицю. Все через WMS автоматично.</div>
</div>
<div class="sb-pain-card">
<div class="sb-pc-pain"><span class="sb-pc-icon">&#128200;</span><div class="sb-pc-pain-text">Сезонні піки &mdash; Чорна п'ятниця, Новий рік: замовлень x5, а ви не встигаєте</div></div>
<div class="sb-pc-arrow">&darr;</div>
<div class="sb-pc-fix"><strong>Масштабування без болю</strong> &mdash; потужність MTP до 6 000 відправлень/день. Ваш пік &mdash; наш звичайний вівторок.</div>
</div>
<div class="sb-pain-card">
<div class="sb-pc-pain"><span class="sb-pc-icon">&#128221;</span><div class="sb-pc-pain-text">Облік залишків в Excel &mdash; пересортиця, товар &laquo;зник&raquo;, невідомо скільки на складі</div></div>
<div class="sb-pc-arrow">&darr;</div>
<div class="sb-pc-fix"><strong>WMS-кабінет 24/7</strong> &mdash; точні залишки в реальному часі, сканування кожної одиниці, звіти з телефону.</div>
</div>
<div class="sb-pain-card">
<div class="sb-pc-pain"><span class="sb-pc-icon">&#128268;</span><div class="sb-pc-pain-text">Інтеграція з CRM &mdash; ручне копіювання замовлень, помилки в адресах і ТТН</div></div>
<div class="sb-pc-arrow">&darr;</div>
<div class="sb-pc-fix"><strong>API-інтеграція за 2 години</strong> &mdash; KeyCRM, SalesDrive, Horoshop, Shopify, Prom, Rozetka. Замовлення потрапляють на склад автоматично.</div>
</div>
</section></div></section>

<section class="warehouse-tour">
<div class="tour-inner">
<div class="tour-text">
<div class="badge">СКЛАД</div>
<h2>Великий склад —<br>навіть для малих</h2>
<p>Малому бізнесу не потрібен власний склад. Зберігайте товар на 3 900 м² поряд із великими брендами — без мінімальних обсягів.</p>
<button class="tour-btn" onclick="openVideoModal('bHY3cFF9SlI')">&#9654; Оглянути склад</button>
</div>
<div class="tour-video">
<div class="video-thumb" onclick="openVideoModal('bHY3cFF9SlI')" style="cursor:pointer">
<img src="https://img.youtube.com/vi/bHY3cFF9SlI/maxresdefault.jpg" onerror="this.src='https://img.youtube.com/vi/bHY3cFF9SlI/hqdefault.jpg'" alt="Склад MTP Group для малого бізнесу — без мінімальних обсягів" width="640" height="360" loading="lazy">
<div class="play-overlay"><div class="play-btn-large">&#9654;</div><span>Тур по складу</span></div>
</div>
</div>
</div>
</section></div>
</section>

<!-- GROWTH TIMELINE — 3 steps -->
<section class="sb-timeline"><div class="ctr">
<div class="badge badge-dark">ПІДКЛЮЧЕННЯ</div>
<h2 class="sec-h2">Від заявки до першої відправки &mdash; 3 дні</h2>
<div class="sb-tl-grid">
<div class="sb-tl-step">
<div class="sb-tl-day">День 1</div>
<div class="sb-tl-connector"></div>
<h3>Консультація</h3>
<p>Обговорюємо обсяги, асортимент, вимоги до пакування. Підписуємо договір. Налаштовуємо інтеграцію з вашою CRM &mdash; за 2-4 години.</p>
</div>
<div class="sb-tl-step">
<div class="sb-tl-day">День 2</div>
<div class="sb-tl-connector"></div>
<h3>Товар на складі</h3>
<p>Привозите товар. Ми штрихкодуємо кожну одиницю, розміщуємо в адресному зберіганні WMS. Перевіряємо залишки разом.</p>
</div>
<div class="sb-tl-step sb-tl-step-last">
<div class="sb-tl-day">День 3</div>
<div class="sb-tl-connector"></div>
<h3>Перша відправка</h3>
<p>Перше замовлення приходить через API, збирається за 30 секунд, пакується і їде на Нову Пошту. Ви працюєте &mdash; ми відправляємо.</p>
</div>
</section></div></section>

<!-- DYNAMIC PRICING — 3 cards -->
