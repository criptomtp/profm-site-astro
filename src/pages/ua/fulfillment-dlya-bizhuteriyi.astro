---
import Base from '../../layouts/Base.astro';

const title = 'Фулфілмент для Біжутерії & Аксесуарів: Захист, Розлік, Якість';
const description = 'Спеціалізований фулфілмент для біжутерії, годинників, сумок. Захист від пошкоджень, точна інвентаризація, 100% страховка, безпечна доставка за 24 години.';
const ogImage = 'https://profm.ua/images/fulfillment-jewelry.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  }
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Фулфілмент для Біжутерії & Аксесуарів<br />Защита, Інвентар, Якість
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Золоті кільця, сережки, браслети, годинники, сумки. Захист від пошкоджень, точна інвентаризація, 100% страховка, безпечна доставка за 24 години.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент біжутерії
      </a>
    </div>
  </section>

  <!-- Why Jewelry Needs Special Care -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Специфіка біжутерії у логістиці</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">💎 Висока вартість</h3>
          <p class="text-gray-700">Золоте кільце за 5000 грн, брилант за 30 000 грн. Втрата 1 товару = велика збитків. Потребується максимальна безпека і контроль.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🔍 Точна інвентаризація</h3>
          <p class="text-gray-700">Кожна позиція мусить бути облікована: дорога біжутерія легко теряється. Потребується RFID, баркода, каталогізація. Система управління складом.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🔐 Безпека від крадіжки</h3>
          <p class="text-gray-700">Персонал мусить бути надійним. Склад мусить мати охорону 24/7, кінокамери, сигналізацію. Потребується максимальна безпека.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">✨ Захист від окислення</h3>
          <p class="text-gray-700">Срібні прикраси окислюються при вологості &gt;70%. Золото дарує. Потребується контроль вологості 30-50%.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MTP Jewelry Services -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Послуги MTP для біжутерії</h2>
      <div class="space-y-4">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Максимальна безпека 24/7</h3>
          <p class="text-gray-700">Дедикована, запертая зона для дорогої біжутерії. Охорона 24/7, кінокамери, сигналізація, сейфи. Персонал перевіряється. Максимальна безпека від крадіжки.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Точна інвентаризація & RFID</h3>
          <p class="text-gray-700">Кожна позиція має штрихкод, RFID тег або каталог номер. Інвентаризація 1-2 рази на місяць. Система управління — відслідкування кожного товару в реальному часі.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Контроль окислення 30-50%</h3>
          <p class="text-gray-700">Для срібних, золотих прикрас — контроль вологості 30-50%. Дезинсекція для запобігання окислення. Упаковка в анти-окислюючі пакети.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Спеціальна упаковка & Доставка</h3>
          <p class="text-gray-700">Дорога біжутерія доставляється у спеціальних коробках з усередненою розривалкою. Спеціалізований перевізник. GPS відслідкування. Фото до/після.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Ціни для біжутерії</h2>
      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-4">Комплектація & Доставка</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Комплектація (за замовлення)</span>
            <span class="font-bold">30-50 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Точна інвентаризація & каталогізація</span>
            <span class="font-bold">+100 грн/месяц</span>
          </li>
          <li class="flex justify-between">
            <span>Спеціальна упаковка (дорога біжутерія)</span>
            <span class="font-bold">20-50 грн</span>
          </li>
          <li class="flex justify-between">
            <span>Безпека 24/7 & сейфи</span>
            <span class="font-bold">+300 грн/месяц</span>
          </li>
          <li class="flex justify-between">
            <span>Спеціалізована доставка</span>
            <span class="font-bold">200-500 грн</span>
          </li>
          <li class="flex justify-between">
            <span>100% страховка</span>
            <span class="font-bold">Включено</span>
          </li>
        </ul>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Приклад: Магазин біжутерії (100 замовлень/місяц)</h3>
        <p class="text-gray-700">
          Комплектація: 100 × 40 = 4,000 грн<br/>
          Упаковка спеціальна: 100 × 35 = 3,500 грн<br/>
          Доставка спеціалізована: 100 × 350 = 35,000 грн<br/>
          Інвентаризація: 100 грн/месяц<br/>
          Безпека: 300 грн/месяц<br/>
          <strong class="text-lg">ВСЬОГО: 42,900 грн/месяц = 429 грн/замовлення</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Quality Guarantee -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Гарантія якості для біжутерії</h2>
      <div class="space-y-6">
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% безпека від крадіжки</p>
            <p class="text-gray-700">Охорона 24/7, кінокамери, сигналізація, сейфи. Персонал надійний. Системи доступу. Максимальна безпека для дорогої біжутерії.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Точна інвентаризація 100%</p>
            <p class="text-gray-700">Кожна позиція каталогізована, штрихкодована. Інвентаризація 1-2 рази на місяць. Система управління в реальному часі. Нульева втрата товарів.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">Захист від окислення</p>
            <p class="text-gray-700">Вологість 30-50% для золота & срібла. Упаковка в анти-окислюючі пакети. Дезинсекція. Дорога біжутерія надходить як нова.</p>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="text-3xl font-bold text-red-600">✓</span>
          <div>
            <p class="font-bold text-lg">100% страховка від крадіжки & пошкоджень</p>
            <p class="text-gray-700">При крадіжці або пошкодженні — платимо 100% вартість. Миттєва компенсація. Клієнт в безпеці.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Логістика для ювелірних магазинів</h2>
      <p class="text-xl mb-8 opacity-90">
        Максимальна безпека 24/7, точна інвентаризація, 100% страховка, спеціалізована доставка.
      </p>
      <a href="/#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Запустити фулфілмент біжутерії
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
