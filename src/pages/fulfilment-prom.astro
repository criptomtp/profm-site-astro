---
import Base from '../layouts/Base.astro';
import HeroCTA from '../components/HeroCTA.astro';

// FAQ — UA, Prom-specific (5 hottest topics)
const faq = [
  {
    q: 'Чому в Prom.ua немає власного FBO як у Rozetka?',
    a: '<p>Prom побудовано як маркетплейс відкритого типу — 700 000 продавців, 100 млн товарів, мінімальний поріг входу. Власний фулфілмент (FBO) для такої кількості SKU фізично неможливо побудувати — це сотні гектарів складів і десятки тисяч операторів. Тому Prom залишив логістику на стороні продавця. Це не баг — це бізнес-модель. Для тебе це означає одне: маркетплейс не контролює твій склад і твою якість відправки. Все це твоя зона. Або зона твого 3PL-партнера.</p>'
  },
  {
    q: 'Як ви інтегруєтеся з моїм Prom-кабінетом — потрібен розробник?',
    a: '<p>Ні. Ти у кабінеті Prom створюєш API-токен (Налаштування → Управління токенами → Створити токен), копіюєш його і передаєш нам. Все. Далі наш WMS опитує API Prom кожні 30 хвилин: тягне нові замовлення, оновлює статуси (Прийнято → Виконано / Скасовано), пушить актуальні залишки на Prom (раз на 3 години — це обмеження самого Prom, не наше). Підключення займає 1 робочий день. Інженерів з твого боку не треба.</p>'
  },
  {
    q: 'Що з 30-хвилинним polling — чи встигаємо same-day shipping?',
    a: '<p>Це чесне питання яке конкуренти оминають. У Prom немає webhook-ів — API працює тільки на пуллінг, і максимальна затримка від моменту замовлення до того як WMS його побачить — 30 хв. Що ми робимо: опитуємо API кожні 30 хв, у пік (10:00–22:00) — кожні 15 хв через додаткове polling-вікно. Замовлення яке прийшло до 14:00 — відправляється тим же днем. Замовлення після 14:00 — наступного робочого дня. SLA same-day shipping для Prom = 14:00 cut-off, не 17:00 як у Rozetka FBO.</p>'
  },
  {
    q: 'Чи можна одночасно продавати на Prom + Rozetka + власний сайт з одного складу?',
    a: '<p>Так — це і є наша основна модель. Один WMS, один залишок на SKU. Замовлення з Prom (polling 30 хв), Rozetka (real-time API), Kasta, Allo, Bigl, Horoshop, WooCommerce, Shopify надходять у єдину чергу. Система резервує штуку, друкує етикетку у форматі того маркетплейсу і передає Новій Пошті, Укрпошті або Meest. Жодного дублювання запасів, нуль ризику подвійного продажу. Більшість наших клієнтів живуть саме у моделі Prom + Rozetka + власний сайт.</p>'
  },
  {
    q: 'Скільки реально коштує — і коли вигідніше за власний склад?',
    a: '<p>Старт від 18 ₴ за відправлення (комплектація + пакування) + 22 ₴/міс за палетомісце. Власний склад економічно при 200+ замовленнях на день — оренда (300 ₴/м²/міс на околиці Києва), 2 пакувальники (35 000 ₴/міс кожен), генератор, страхування, амортизація обладнання. Точка беззбитковості домашнього складу — приблизно 4 500 замовлень на місяць. До цього обсягу 3PL вигідніший. Точний розрахунок під твої цифри — у <a href="/ua/calculator/">калькуляторі</a>.</p>'
  },
  {
    q: 'Чи можу я бачити в реальному часі що відбувається з моїм товаром?',
    a: '<p>Так, повний доступ до WMS-кабінету 24/7 з твого ноутбука або телефону. Бачиш: залишок по кожному SKU в обох локаціях (Щасливе, Білогородка), статус кожного замовлення (Прийнято з Prom → Зарезервовано → Зібрано → Відправлено), фото пакування при сумнівах, історію руху товарів за будь-який період. Telegram-бот пушить події в реальному часі: нове замовлення, відправлення в Нову Пошту, оплата накладеним платежем, повернення. Жодних дзвінків менеджеру щоб дізнатися де моя посилка — все видно одразу.'
  },
  {
    q: 'Що відбувається з товаром при поверненні з Prom — як швидко він знову на полиці?',
    a: '<p>Покупець відмовився або повернув посилку — Нова Пошта везе її назад на наш склад. Приймаємо за 24 години після прибуття: розпаковуємо, оцінюємо стан (фото в 4 ракурси), перевіряємо комплектацію. Якщо товар у первинному стані — оновлюємо залишок у WMS і ставимо назад у комірку, готовий до повторного продажу. Якщо пошкоджений — окрема зона рекламацій з можливістю списання, переоцінки або повернення постачальнику. У кабінеті бачиш повну історію: причина повернення, дата, фото стану, поточний статус (готовий до продажу / у зоні рекламацій / списано).'
  }
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a.replace(/<[^>]+>/g, '').trim() }
  }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Головна', item: 'https://www.fulfillmentmtp.com.ua/' },
    { '@type': 'ListItem', position: 2, name: 'Послуги', item: 'https://www.fulfillmentmtp.com.ua/ua/3pl-logistyka/' },
    { '@type': 'ListItem', position: 3, name: 'Фулфілмент для Prom.ua', item: 'https://www.fulfillmentmtp.com.ua/fulfilment-prom/' }
  ]
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Фулфілмент для продавців Prom.ua',
  description: 'У Prom немає власного FBO. MTP Group — твій склад, API-інтеграція з кабінетом Prom і відправка через Нову Пошту/Укрпошту/Meest за 24 години.',
  serviceType: 'Fulfillment',
  provider: {
    '@type': 'Organization',
    name: 'MTP Group Fulfillment',
    url: 'https://www.fulfillmentmtp.com.ua',
    telephone: '+380501444645'
  },
  areaServed: { '@type': 'Country', name: 'UA' },
  audience: { '@type': 'BusinessAudience', name: 'Продавці Prom.ua' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'UAH',
    price: '18',
    description: 'Від 18 ₴ за відправлення для продавців Prom.ua'
  },
  dateModified: '2026-04-28'
};

const schemaJson = `<script type="application/ld+json">${JSON.stringify(serviceSchema)}</script><script type="application/ld+json">${JSON.stringify(faqSchema)}</script><script type="application/ld+json">${JSON.stringify(breadcrumbSchema)}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","priceRange":"₴18-₴26 / відправка","geo":{"@type":"GeoCoordinates","latitude":"50.3408","longitude":"30.8595"},"address":[{"@type":"PostalAddress","streetAddress":"вул. Промислова","addressLocality":"Щасливе, Бориспільський район","addressRegion":"Київська область","postalCode":"08322","addressCountry":"UA","description":"Склад 2 700 м²"},{"@type":"PostalAddress","addressLocality":"Білогородка","addressRegion":"Київська область","postalCode":"08140","addressCountry":"UA","description":"Склад 1 000 м²"}],"location":[{"@type":"Place","name":"MTP Fulfillment — Щасливе","geo":{"@type":"GeoCoordinates","latitude":"50.3408","longitude":"30.8595"}},{"@type":"Place","name":"MTP Fulfillment — Білогородка","geo":{"@type":"GeoCoordinates","latitude":"50.4138","longitude":"30.1928"}}],"openingHours":"Mo-Su 08:00-20:00","areaServed":[{"@type":"Country","name":"UA"}]}</script>`;
---

<Base
  title="Фулфілмент для Prom.ua 2026 | FBO для продавця | MTP Group"
  description="У Prom.ua немає власного FBO. MTP — твій 3PL-склад, API-інтеграція кабінету Prom за 1 день, відправка НП/Укрпошта/Meest за 24 год. Від 18 ₴ за замовлення."
  canonical="https://www.fulfillmentmtp.com.ua/fulfilment-prom/"
  lang="uk"
  ogImage="https://www.fulfillmentmtp.com.ua/images/mtp-warehouse-interior.webp"
  ogType="article"
  autoArticle={false}
  schema={schemaJson}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/fulfilment-prom/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/fulfilment-prom/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/fulfilment-prom/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/fulfilment-prom/">
</Fragment>

<!-- BREADCRUMBS -->
<nav class="prom-base__bc" aria-label="Breadcrumbs">
  <div class="prom-base__bc-inner">
    <a href="/">Головна</a><span aria-hidden="true">›</span>
    <a href="/ua/3pl-logistyka/">Послуги</a><span aria-hidden="true">›</span>
    <span class="prom-base__bc-current">Фулфілмент для Prom.ua</span>
  </div>
</nav>

<!-- HERO: massive 0 + headline + calculator card -->
<section class="prom-base__hero">
  <div class="prom-base__hero-inner">
    <div class="prom-base__hero-left">
      <div class="prom-base__zero" aria-hidden="true">0</div>
      <div class="prom-base__hero-text">
        <span class="prom-base__chip">FBO ДЛЯ PROM.UA · 700K ПРОДАВЦІВ</span>
        <h1 class="prom-base__h1">FBO у <span class="prom-base__h1-strike">Prom.ua</span> <br><span class="prom-base__h1-red">не існує.</span> <br>До сьогодні.</h1>
        <p class="prom-base__lead">Маркетплейс віддає тобі склад, пакування, відправку і повернення. Ми це робимо за тебе. API-інтеграція з твоїм кабінетом Prom за 1 день. Відправка Новою Поштою, Укрпоштою і Meest за 24 години. Від 18 ₴ за замовлення.</p>
      </div>
    </div>

    <!-- Calculator card -->
    <aside class="prom-base__calc" aria-label="Калькулятор економії">
      <div class="prom-base__calc-head">
        <span class="prom-base__calc-label">КАЛЬКУЛЯТОР FBO</span>
        <span class="prom-base__calc-sub">Власний склад vs MTP</span>
      </div>
      <div class="prom-base__calc-slider">
        <label for="prom-orders" class="prom-base__calc-sublabel">Замовлень на місяць: <strong id="prom-orders-val">800</strong></label>
        <input type="range" id="prom-orders" min="100" max="5000" step="50" value="800" aria-label="Кількість замовлень на місяць">
        <div class="prom-base__calc-range"><span>100</span><span>5 000</span></div>
      </div>
      <div class="prom-base__calc-rows">
        <div class="prom-base__calc-row prom-base__calc-row--own">
          <span class="prom-base__calc-rname">Власний склад</span>
          <span class="prom-base__calc-rval"><span id="prom-own-val">61 000</span> ₴/міс</span>
        </div>
        <div class="prom-base__calc-row prom-base__calc-row--mtp">
          <span class="prom-base__calc-rname">MTP Fulfillment</span>
          <span class="prom-base__calc-rval"><span id="prom-mtp-val">22 600</span> ₴/міс</span>
        </div>
      </div>
      <div class="prom-base__calc-save">
        <span class="prom-base__calc-save-label">ЕКОНОМІЯ</span>
        <span class="prom-base__calc-save-val"><span id="prom-save-val">38 400</span> ₴/міс</span>
      </div>
      <p class="prom-base__calc-note">Розрахунок орієнтовний. Точну ціну для твоїх SKU — у <a href="/ua/calculator/">калькуляторі</a>.</p>
    </aside>
  </div>

  <!-- HeroCTA below the hero grid (sticks to left column on desktop, full-width on mobile) -->
  <div class="prom-base__hero-form">
    <HeroCTA
      lang="uk"
      theme="light"
      button="Отримати розрахунок →"
      microCopy="✓ Відповідь у Telegram протягом 15 хв"
      sourceTag="hero /fulfilment-prom/"
    />
  </div>
</section>

<!-- MARKETPLACE CONTEXT — 3 paragraphs editorial style -->
<section class="prom-base__why">
  <div class="prom-base__why-inner">
    <span class="prom-base__chip prom-base__chip--muted">01 · КОНТЕКСТ</span>
    <h2 class="prom-base__h2">Чому Prom не має власного FBO — і чому це твій шанс</h2>
    <p>Prom.ua — найбільший маркетплейс України за кількістю продавців. 700 000 акаунтів, 100 мільйонів товарних позицій, 30–50 млн відвідувань на місяць. Для порівняння: у Rozetka — 50 млн відвідувань і ~30 000 активних селерів, у Kasta — 3 000 мерчантів. Prom — це масштаб, якому байдуже до якості — туди впускають усіх. Якщо ти продаєш товари для дому, електроніку, авто-мото, одяг або косметику — ти на Prom. Це Топ-5 категорій маркетплейсу за кількістю замовлень у 2025 році.</p>
    <p>Зворотний бік цього масштабу: у Prom немає власного фулфілменту. Маркетплейс не приймає твій вантаж на власні склади, не пакує, не відправляє і не приймає повернень. Те, що Rozetka називає FBO (Fulfillment by Operator), у Prom не існує. Все, що пропонує Prom — це <strong>Prom Доставка</strong>, агрегатор перевізників за 30 ₴/міс. Тобто маркетплейс монетизує трафік і комісію (4,2–15% залежно від категорії), а вся операційна частина — склад, обладнання, персонал, страхування, паливо для генераторів, інтернет, повернення — на тобі. Або на твоєму 3PL.</p>
    <p>Для нового продавця у 2026 році це непросто. Безкоштовний план Prom закрито з 12 листопада 2024 року — тепер мінімум 5 900 ₴/рік за підписку Старт, до 11 500 ₴ за Максимум. Комісія на товари з субдоменів продавця — введено з травня 2025. Алгоритми ранжування у пошуку маркетплейсу почали віддавати перевагу тим хто має SLA «менше 30 хв» на обробку замовлення. Економіка стиснулась: середній чек на Prom — 1 000–1 500 ₴, маржа 25–35%, з якої треба віддати комісію + еквайринг + логістику + рекламу + повернення. Якщо ти ще тримаєш склад вдома або в гаражі і пакуєш ввечері після роботи — арифметика не сходиться. Тут і виникає 3PL: ми твій <em>зовнішній</em> FBO — те, що сам Prom не побудував. Не через відсутність бажання, а через масштаб маркетплейсу — побудувати власний склад на 700 000 продавців неможливо. Зробити це для тебе одного — реально.</p>
  </div>
</section>

<!-- HOW WE INTEGRATE WITH PROM API -->
<section class="prom-base__api">
  <div class="prom-base__api-inner">
    <span class="prom-base__chip prom-base__chip--muted">02 · ІНТЕГРАЦІЯ</span>
    <h2 class="prom-base__h2">Як працює інтеграція Prom + MTP — без розробників з твого боку</h2>
    <p class="prom-base__api-lead">Prom надає публічний REST API з токен-авторизацією. Жоден з конкурентів у видачі Google не пояснює як це працює — лише пишуть «є API-інтеграція». Ось що відбувається насправді коли ти підключаєшся до нас.</p>

    <div class="prom-base__api-steps">
      <article class="prom-base__api-step">
        <span class="prom-base__api-num">01</span>
        <h3>Створюєш токен у кабінеті Prom</h3>
        <p>Налаштування → Управління API токенами → Створити токен. Обираєш scope (читання замовлень, оновлення статусів, синхронізація залишків), копіюєш ключ. Це 4 кліки і 30 секунд.</p>
      </article>
      <article class="prom-base__api-step">
        <span class="prom-base__api-num">02</span>
        <h3>Передаєш токен нам</h3>
        <p>Через захищений канал (1Password / Bitwarden / зашифрований email). Інженер MTP підключає токен до твого WMS-кабінету за 1–2 години. NDA + договір про обробку персональних даних — в той же день.</p>
      </article>
      <article class="prom-base__api-step">
        <span class="prom-base__api-num">03</span>
        <h3>Налаштовуємо синхронізацію</h3>
        <p>Замовлення тягнемо кожні 30 хв (у пік — кожні 15). Залишки пушимо на Prom раз на 3 год — це обмеження самого API Prom, прискорити неможливо. Статуси (Прийнято / Виконано / Скасовано) мапимо на наш WMS автоматично.</p>
      </article>
      <article class="prom-base__api-step">
        <span class="prom-base__api-num">04</span>
        <h3>Тестове замовлення</h3>
        <p>Створюєш у Prom тестове замовлення на свою адресу. Перевіряємо: API підтягнув, WMS відкрив завдання, оператор зібрав, ТТН Нової Пошти роздрукована. Якщо все ОК — ти у бойовому режимі. Зазвичай це 3-й день онбордінгу.</p>
      </article>
    </div>

    <p class="prom-base__api-note"><strong>Чесно про обмеження.</strong> У Prom немає webhook-ів для нових замовлень — тільки polling. Це означає максимальну затримку 30 хв між моментом коли клієнт оформив замовлення і моментом коли ми його побачили. Для same-day shipping до 14:00 cut-off ця затримка несуттєва. Для інтернет-аптек з SLA 4 години — критична, у такому випадку обирай маркетплейси з webhooks (Rozetka, Horoshop). Друге обмеження — синхронізація залишків раз на 3 години. Якщо ти продаєш швидко-runner SKU (топ-5 позицій з 50+ замовлень/день), ми тримаємо віртуальний резерв 5–10% поверх реального залишку щоб уникнути overselling у вікні 3 годин.</p>

    <p class="prom-base__api-extra">Що ще нам передає API Prom: метод оплати (передоплата / накладений платіж / Prom-каса), коментарі клієнта, тип доставки (НП відділення / поштомат / адресна / Укрпошта), вибраний клієнтом перевізник, статуси повернень. Все це автоматично потрапляє в WMS і друкується на пакувальному листі — оператор бачить що клієнт обрав поштомат і пакує у максимальний розмір 1 (40×30×20 см), щоб посилка пройшла на «Поштомат до 30 кг». Жодного «передзвонимо клієнту бо щось не зрозуміли» — типова проблема селерів які працюють руками. Більше про різниці маркетплейсів — у статті <a href="/ua/blog/yak-pratsiuie-fulfilment/">Як працює фулфілмент</a>.</p>
  </div>
</section>

<!-- REAL NUMBERS — case study with cinematic warehouse photo -->
<section class="prom-base__case">
  <div class="prom-base__case-inner">
    <div class="prom-base__case-photo">
      <img
        src="/images/mtp-warehouse-interior.webp"
        alt="Склад MTP Group — операційна зона комплектації Prom-замовлень"
        width="1200"
        height="800"
        loading="lazy"
      >
    </div>
    <div class="prom-base__case-text">
      <span class="prom-base__chip prom-base__chip--red">03 · РЕАЛЬНІ ЦИФРИ</span>
      <h2 class="prom-base__h2 prom-base__h2--light">Магазин товарів для дому. Prom як основний канал. Що змінилось за 4 місяці.</h2>
      <p class="prom-base__case-lead">Клієнт прийшов у січні 2026 року з типовою картиною: 2 роки на Prom, 320 замовлень/міс на 4 SKU (текстиль, кухонне начиння), власний склад 80 м² на околиці Києва, 1 пакувальник, дружина як менеджер. Маржа стискалася через зростання комісії Prom і вартість оренди. Шукали або великий стрибок, або вихід.</p>

      <div class="prom-base__case-metrics">
        <div class="prom-base__case-metric">
          <span class="prom-base__case-mlabel">Замовлень / міс</span>
          <span class="prom-base__case-mval">320 <span class="prom-base__case-mar">→</span> <strong>740</strong></span>
        </div>
        <div class="prom-base__case-metric">
          <span class="prom-base__case-mlabel">CR (Prom-кабінет)</span>
          <span class="prom-base__case-mval">1.8% <span class="prom-base__case-mar">→</span> <strong>2.7%</strong></span>
        </div>
        <div class="prom-base__case-metric">
          <span class="prom-base__case-mlabel">Повернення</span>
          <span class="prom-base__case-mval">7.4% <span class="prom-base__case-mar">→</span> <strong>3.1%</strong></span>
        </div>
        <div class="prom-base__case-metric">
          <span class="prom-base__case-mlabel">Час упакування</span>
          <span class="prom-base__case-mval">12 хв <span class="prom-base__case-mar">→</span> <strong>4 хв</strong></span>
        </div>
      </div>

      <p class="prom-base__case-text-p">Що зробили: перевели весь склад до нас за 3 робочих дні (фура з його орендованого складу до нашого RC у Бориспільському районі). Підключили API Prom і додали Rozetka + власний сайт на Horoshop — той самий залишок, три канали. Замість дешевого скотчу — брендована коробка з логотипом і вкладишем-карткою лояльності. Замість «зробить дружина» — наш SLA 24 хв на упакування і фотофіксація перед запечатуванням. CR виросло, бо Prom-алгоритм підняв його у видачу за SLA «менше 30 хв». Повернення впали, бо упакування стало посиленим — посуд більше не приходить розбитим, текстиль не пом'ятим.</p>
      <p class="prom-base__case-text-p">Економіка: він платив 47 000 ₴/міс за склад + персонал, тепер платить 23 000 ₴/міс нам. Мінус 24 000 ₴/міс прямих витрат + плюс 130 000 ₴/міс додаткового обороту з Rozetka і власного сайту. Загальна маржа виросла на 2,2 раза за квартал. Час, який раніше йшов на пакування і упакування — пішов у підбір нових постачальників і запуск 2 нових SKU-категорій. Ім'я приховано на прохання клієнта — конкуренти у його ніші читають цю сторінку.</p>
    </div>
  </div>
</section>

<!-- PROCESS — single thin red line with 6 dots -->
<section class="prom-base__process">
  <div class="prom-base__process-inner">
    <span class="prom-base__chip prom-base__chip--muted">04 · ПРОЦЕС</span>
    <h2 class="prom-base__h2">Шість етапів від твого постачальника до клієнта Prom</h2>
    <p class="prom-base__process-lead">Без зайвих кроків. Без передач між підрядниками. Один склад, один WMS, одна команда — від моменту коли вантаж заїхав до нас, до моменту коли клієнт натиснув «отримано» у мобільному додатку Prom.</p>

    <div class="prom-base__line">
      <ol class="prom-base__line-steps">
        <li><span class="prom-base__line-dot" aria-hidden="true"></span><span class="prom-base__line-num">01</span><span class="prom-base__line-name">Приймання</span></li>
        <li><span class="prom-base__line-dot" aria-hidden="true"></span><span class="prom-base__line-num">02</span><span class="prom-base__line-name">Зберігання</span></li>
        <li><span class="prom-base__line-dot" aria-hidden="true"></span><span class="prom-base__line-num">03</span><span class="prom-base__line-name">Збір</span></li>
        <li><span class="prom-base__line-dot" aria-hidden="true"></span><span class="prom-base__line-num">04</span><span class="prom-base__line-name">Пакування</span></li>
        <li><span class="prom-base__line-dot" aria-hidden="true"></span><span class="prom-base__line-num">05</span><span class="prom-base__line-name">Відправка</span></li>
        <li><span class="prom-base__line-dot" aria-hidden="true"></span><span class="prom-base__line-num">06</span><span class="prom-base__line-name">Контроль повернень</span></li>
      </ol>
    </div>

    <p class="prom-base__process-extra"><strong>Приймання</strong> — приходить фура від твого постачальника або з імпорту, ми перевіряємо за товарною накладною, проводимо вибірковий QC (3–5% партії), наносимо EAN-13 штрихкоди (якщо їх немає — друкуємо за 1,20 ₴/од), розкладаємо по стелажах. <strong>Зберігання</strong> — палетомісце 1,2×0,8×1,8 м у температурному режимі +18…+24°C; для косметики і БАДів є окрема зона +2…+8°C з 24/7 моніторингом. <strong>Збір</strong> — оператор отримує picking-лист на термінал збору даних (ТЗД), збирає товари за маршрутом, верифікує штрихкоди, передає на пакувальний стіл. <strong>Пакування</strong> — твоя коробка, твій скотч, твої вкладиші, фотофіксація перед запечатуванням (фото у твоєму кабінеті 7 днів). <strong>Відправка</strong> — друк ТТН з API НП/Укрпошти, передача водію Нової Пошти о 14:00 і 18:00 щодня. <strong>Контроль повернень</strong> — клієнт відправляє назад, ми приймаємо, перевіряємо, фотографуємо, повертаємо на стелаж або в зону «брак». Без втрат, без «загубилось».</p>
  </div>
</section>

