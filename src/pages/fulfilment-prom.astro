<script is:inline>
  // Hero calculator: cost_own = orders * 45 + 25000; cost_mtp = orders * 22 + 5000
  (function () {
    var slider = document.getElementById('prom-orders');
    var ordersOut = document.getElementById('prom-orders-val');
    var ownOut = document.getElementById('prom-own-val');
    var mtpOut = document.getElementById('prom-mtp-val');
    var saveOut = document.getElementById('prom-save-val');
    if (!slider || !ordersOut || !ownOut || !mtpOut || !saveOut) return;

    var fmt = function (n) {
      return Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
    };

    var update = function () {
      var orders = parseInt(slider.value, 10) || 0;
      var costOwn = orders * 45 + 25000;
      var costMtp = orders * 22 + 5000;
      var save = costOwn - costMtp;
      ordersOut.textContent = fmt(orders);
      ownOut.textContent = fmt(costOwn);
      mtpOut.textContent = fmt(costMtp);
      saveOut.textContent = fmt(save);
    };

    slider.addEventListener('input', update);
    slider.addEventListener('change', update);
    update();
  })();
</script>
