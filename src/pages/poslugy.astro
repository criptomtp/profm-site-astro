---
import Base from '../layouts/Base.astro';
import HeroCTA from '../components/HeroCTA.astro';
import AuthorByline from '../components/AuthorByline.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Головна", "item": "https://www.fulfillmentmtp.com.ua/" },
    { "@type": "ListItem", "position": 2, "name": "Послуги", "item": "https://www.fulfillmentmtp.com.ua/poslugy/" }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Фулфілмент-послуги в Україні",
  "serviceType": "Fulfillment services hub",
  "description": "Повний spectrum фулфілмент-послуг для українського e-commerce: зберігання, комплектація, доставка, повернення, інтеграції з маркетплейсами та CRM, копакінг, маркування, кросдокінг.",
  "provider": {
    "@type": "Organization",
    "name": "MTP Group Fulfillment",
    "url": "https://www.fulfillmentmtp.com.ua",
    "telephone": "+380501444645",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Щасливе, Бориспільський район",
      "addressRegion": "Київська область",
      "addressCountry": "UA"
    }
  },
  "areaServed": { "@type": "Country", "name": "UA" },
  "dateModified": "2026-04-29",
  "offers": [
    { "@type": "Offer", "name": "Палетне зберігання", "priceCurrency": "UAH", "price": "450", "description": "від 450 грн/палета/міс" },
    { "@type": "Offer", "name": "Комплектація замовлень", "priceCurrency": "UAH", "price": "18", "description": "від 18 грн/відправлення" },
    { "@type": "Offer", "name": "Складські послуги", "priceCurrency": "UAH", "price": "650", "description": "від 650 грн/м³/міс" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Які послуги входять у фулфілмент MTP?",
      "acceptedAnswer": { "@type": "Answer", "text": "17 операцій повного циклу: приймання поставки, зберігання (палетне/поличне/холодне), комплектація замовлень, упаковка, маркування, доставка по Україні та міжнародна, обробка повернень, копакінг, кросдокінг, інвентаризація, фотофіксація браку, автодзвінок підтвердження замовлень, контроль грошей через Шериф Платежів, інтеграції з 12+ CRM, експорт у маркетплейси (Rozetka, Prom, Allo)." } },
    { "@type": "Question", "name": "Скільки коштують послуги фулфілменту?",
      "acceptedAnswer": { "@type": "Answer", "text": "Базова комплектація — від 18 грн за відправлення при обсязі 200+ замовлень/день. Зберігання — 450 грн/палета/міс або 650 грн/м³/міс. Мінімальний платіж — 5 000 грн/міс. Точну вартість для вашого SKU-набору рахуємо у калькуляторі." } },
    { "@type": "Question", "name": "Як швидко можна підключитися?",
      "acceptedAnswer": { "@type": "Answer", "text": "3-5 робочих днів від першого контакту до старту операцій: день 1 — заявка та воркшоп, день 2 — підпис договору, день 3 — приймання поставки, день 4 — налаштування інтеграції з CRM, день 5 — перші тестові відправлення." } },
    { "@type": "Question", "name": "З якими CRM та маркетплейсами інтегруєтесь?",
      "acceptedAnswer": { "@type": "Answer", "text": "KeyCRM, SalesDrive, LP-CRM, Sitniks, Horoshop, OpenCart, WooCommerce, Shopify, 1С, BAS. Маркетплейси: Rozetka, Prom.ua, Allo, Kasta, Епіцентр. Інтеграція з будь-якою системою через REST API за 2-4 години." } },
    { "@type": "Question", "name": "Чи приймаєте товари з браком та повернення?",
      "acceptedAnswer": { "@type": "Answer", "text": "Так. Обробка повернень — 24-48 годин від отримання посилки до повернення товару у продаж або фотофіксації браку. SLA точність: 99.5% правильно ідентифікованих повернень." } },
    { "@type": "Question", "name": "Скільки SKU можете обслуговувати?",
      "acceptedAnswer": { "@type": "Answer", "text": "Поточна потужність — 50 000+ активних SKU на наших 5 500 м². Працюємо з мікро-брендами (200 SKU) і з великими каталогами (15 000+ SKU). Мінімального обсягу немає." } },
    { "@type": "Question", "name": "Як контролюються гроші клієнтів?",
      "acceptedAnswer": { "@type": "Answer", "text": "Шериф Платежів — наша внутрішня система, що надсилає Telegram-сповіщення власнику бізнесу при кожному отриманні коштів від перевізника. Прозорість 100%, без затримок." } },
    { "@type": "Question", "name": "Працюєте з холодним ланцюгом і небезпечними товарами?",
      "acceptedAnswer": { "@type": "Answer", "text": "Холодне зберігання (+2…+8°C) — так, окрема зона на 200 палет. Небезпечні вантажі (ADR) — наразі не приймаємо. Великогабаритні (меблі, побутова техніка) — приймаємо до 500 кг/одиниця." } }
  ]
};
---
<Base
  title="Послуги фулфілменту в Україні — повний spectrum для e-commerce"
  description="17 фулфілмент-операцій під одним SLA: зберігання, комплектація, доставка, повернення, інтеграції. 5 500 м², 99.8% точність, 150+ клієнтів. Розрахунок ціни."
  canonical="https://www.fulfillmentmtp.com.ua/poslugy/"
  lang="uk"
  ogType="website"
  ogImage="https://www.fulfillmentmtp.com.ua/images/poslugy-hero.webp"
  schema={`<script type="application/ld+json">${JSON.stringify(serviceSchema)}</script><script type="application/ld+json">${JSON.stringify(breadcrumbSchema)}</script><script type="application/ld+json">${JSON.stringify(faqSchema)}</script>`}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/poslugy/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/services/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/services/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/poslugy/">
</Fragment>

<!-- ====== HERO ====== -->
<section class="poslugy__hero">
  <div class="poslugy__container">
    <nav class="poslugy__crumbs" aria-label="Хлібні крихти">
      <a href="/">Головна</a> <span>/</span> <span aria-current="page">Послуги</span>
    </nav>
    <div class="poslugy__label">Хаб послуг</div>
    <h1 class="poslugy__h1">Повний spectrum фулфілмент-послуг в&nbsp;Україні</h1>
    <p class="poslugy__sub">Від приймання поставки до доставки покупцю — 17 операцій під одним SLA. Зберігання, комплектація, доставка, повернення, інтеграції з маркетплейсами та CRM. Без сезонних провалів і без зайвих перепідписів.</p>
    <div class="poslugy__hero-bottom">
      <HeroCTA lang="uk" theme="light" button="Розрахувати вартість →" microCopy="✓ Відповідь протягом 15 хв · Безкоштовна консультація" sourceTag="hero /poslugy/" />
    </div>
  </div>
</section>
<AuthorByline lang="uk" />

<!-- ====== STATS BAR ====== -->
<section class="poslugy__stats">
  <div class="poslugy__container">
    <div class="poslugy__stats-grid">
      <div class="poslugy__stat"><strong>5&thinsp;500&nbsp;м²</strong><span>складська площа</span></div>
      <div class="poslugy__stat"><strong>17 операцій</strong><span>повний цикл</span></div>
      <div class="poslugy__stat"><strong>99,8%</strong><span>точність комплектації</span></div>
      <div class="poslugy__stat"><strong>24 години</strong><span>приймання поставки</span></div>
    </div>
  </div>
</section>

<!-- ====== TL;DR ====== -->
<section class="poslugy__tldr">
  <div class="poslugy__container poslugy__container--narrow">
    <div class="poslugy__label poslugy__label--inline">30 секунд</div>
    <h2>Що таке фулфілмент-хаб MTP коротко</h2>
    <p><strong>Фулфілмент</strong> — це аутсорсинг операційної логістики інтернет-магазину. Ми приймаємо вашу поставку на склад, зберігаємо товар, збираємо замовлення, упаковуємо, передаємо у Нову Пошту чи Укрпошту і обробляємо повернення. Ви займаєтесь продуктом, маркетингом і клієнтським досвідом — операційка на нас.</p>
    <p>На сторінці нижче — <strong>7 категорій послуг</strong>: зберігання, комплектація, доставка, повернення, інтеграції, маркетплейси, спецпослуги. Кожна категорія — окрема LP з цінами, SLA і кейсами. Якщо вам потрібен лише один блок (наприклад, тільки палетне зберігання) — ми робимо. Якщо потрібен повний цикл під ключ — теж робимо.</p>
    <p><strong>Ціни</strong> починаються від 18 грн за відправлення при 200+ замовлень/день і від 450 грн за палету на місяць. Мінімального обсягу немає, мінімальний платіж — 5 000 грн/міс. <a href="/ua/calculator/">Розрахуйте у калькуляторі</a> або <a href="/ua/tsiny/">подивіться повний прайс</a>.</p>
  </div>
</section>

<!-- ====== STICKY CHIPS ====== -->
<nav class="poslugy__chips" aria-label="Категорії послуг">
  <div class="poslugy__container">
    <div class="poslugy__chips-row" role="tablist">
      <a href="#zberihannya" class="poslugy__chip" data-chip="zberihannya">Зберігання</a>
      <a href="#komplektatsiya" class="poslugy__chip" data-chip="komplektatsiya">Комплектація</a>
      <a href="#dostavka" class="poslugy__chip" data-chip="dostavka">Доставка</a>
      <a href="#povernennya" class="poslugy__chip" data-chip="povernennya">Повернення</a>
      <a href="#intehratsii" class="poslugy__chip" data-chip="intehratsii">Інтеграції</a>
      <a href="#marketpleysy" class="poslugy__chip" data-chip="marketpleysy">Маркетплейси</a>
      <a href="#spetsposlugy" class="poslugy__chip" data-chip="spetsposlugy">Спецпослуги</a>
    </div>
  </div>
</nav>

<!-- ====== 1. ЗБЕРІГАННЯ ====== -->
<section class="poslugy__cat" id="zberihannya">
  <div class="poslugy__container">
    <div class="poslugy__cat-label">01 / Зберігання та інвентаризація</div>
    <h2 class="poslugy__cat-h">Палетне, поличне, холодне, великогабаритне</h2>
    <p>Склад MTP у Щасливому (Бориспільський район) — 5 500 м² зі стелажним зберіганням до 11 м висоти, окремою холодною зоною (+2…+8°C) на 200 палет, зоною для великогабаритних товарів і кліматичним контролем для косметики й бадів. Вас не цікавить те, що відбувається всередині складу — вас цікавить, що ваш товар у наявності, не пошкоджений і доступний для збору замовлень за 30 хвилин після оплати клієнтом. Саме це ми гарантуємо SLA.</p>
    <p>Кожна одиниця товару отримує внутрішній SKU-код у нашій WMS, фіксується фото при прийомі (для візуального контролю стану), розміщується у конкретну адресу комірки. При інвентаризації (раз на квартал) розбіжність між WMS і фактом не перевищує 0,2% — це виміряний показник за 12 місяців роботи з нашими ТОП-20 клієнтами.</p>
    <ul class="poslugy__tags">
      <li>Палетне зберігання — від 450 грн/палета/міс</li>
      <li>Поличне зберігання — від 35 грн/SKU/міс</li>
      <li>Холодне зберігання +2…+8°C — від 680 грн/палета/міс</li>
      <li>Великогабаритне (до 500 кг) — індивідуальний прайс</li>
      <li>Інвентаризація щоквартальна — входить у тариф</li>
      <li>Фотофіксація браку та невідповідностей</li>
    </ul>
    <p class="poslugy__cat-links">Деталі: <a href="/ua/skladski-poslugy/">Складські послуги</a> · <a href="/ua/paletne-zberigannya/">Палетне зберігання</a> · <a href="/ua/fulfilment-kyiv/">Склад у Київській області</a></p>
  </div>
</section>

<!-- ====== 2. КОМПЛЕКТАЦІЯ ====== -->
<section class="poslugy__cat poslugy__cat--alt" id="komplektatsiya">
  <div class="poslugy__container">
    <div class="poslugy__cat-label">02 / Комплектація замовлень</div>
    <h2 class="poslugy__cat-h">Pick &amp; Pack з точністю 99,8%</h2>
    <p>Збирання замовлення — те, що бачить ваш клієнт у посилці. Помилковий товар, забутий аксесуар, пом'ятий бренд-конверт — це не "невелика операційна неприємність". Це -1 покупець назавжди й мінус 12-15 нових покупців через відгук на Rozetka. Тому SLA на точність комплектації у нас 99,8% — це означає <strong>2 помилки на 1 000 зібраних замовлень</strong>, не більше. За попередній квартал фактичний показник — 99,87%.</p>
    <p>Як ми це робимо: подвійна верифікація сканером штрих-коду (на стадії пікінгу і на стадії пакування), фотофіксація запакованого замовлення перед закриттям коробки для замовлень понад 3 000 грн, окрема стрічка для замовлень з крихкими товарами (косметика, кераміка, скло). Скоро запускаємо AI-перевірку фото перед запечатанням — пілот на 4 клієнтах, точність у тестах 99,95%.</p>
    <ul class="poslugy__tags">
      <li>Pick &amp; Pack стандарт — від 18 грн/відправлення</li>
      <li>Брендоване пакування — +2,50 грн/коробка</li>
      <li>Кастомні вкладки (флаєр, подяка) — +1,50 грн</li>
      <li>Подарункова упаковка — +25 грн</li>
      <li>Cut-off передачі у перевізника — 18:00 щоденно</li>
      <li>Same-day відправка для замовлень до 15:00</li>
    </ul>
    <p class="poslugy__cat-links">Кейси: <a href="/ua/blog/case-ecodrive/">Case EcoDrive (12k SKU)</a> · <a href="/ua/3pl-logistyka/">3PL для брендів</a> · <a href="/ua/blog/chomu-fulfilment-deshevshyy/">Чому фулфілмент дешевший за свій склад</a></p>
  </div>
</section>

<!-- ====== 3. ДОСТАВКА ====== -->
<section class="poslugy__cat" id="dostavka">
  <div class="poslugy__container">
    <div class="poslugy__cat-label">03 / Доставка по Україні та міжнародна</div>
    <h2 class="poslugy__cat-h">Нова Пошта, Укрпошта, Justin, Meest, DHL</h2>
    <p>У нас немає власного автопарку — це свідома стратегія. Замість того щоб конкурувати з Новою Поштою на її ж полі, ми інтегруємось з усіма основними перевізниками і вибираємо найкращий маршрут для конкретного замовлення. Якщо клієнт вибрав Нову Пошту — посилка йде Новою Поштою. Якщо це переказ післяплатою у глибинку Закарпаття — оптимальніше може бути Укрпошта. Якщо це B2B-доставка пацієнтам у Польщу — DHL Express.</p>
    <p>Що ми контролюємо: cut-off (фінальна годинна передачі у відділення/кур'єру), статус посилки в реальному часі через API перевізника, грошові надходження від післяплати (через нашу систему Шериф Платежів — Telegram-сповіщення в момент отримання коштів від НП). Що не контролюємо: швидкість самої доставки після передачі — це публічна оферта перевізника. Але ми передаємо посилку в день оформлення замовлення (для замовлень до 15:00), тому статистика "замовлено сьогодні — у клієнта завтра або післязавтра" виконується у 94% випадків.</p>
    <ul class="poslugy__tags">
      <li>Нова Пошта — у відділення, поштомат, кур'єр</li>
      <li>Укрпошта — пакомат, відділення, на адресу</li>
      <li>Justin, Meest — повна підтримка</li>
      <li>Міжнародна: DHL Express, UPS, Meest International</li>
      <li>Шериф Платежів — Telegram-контроль грошей</li>
      <li>Same-day для Києва — кур'єром від 8:00 до 22:00</li>
    </ul>
    <p class="poslugy__cat-links">Деталі: <a href="/ua/fulfilment-ukraina/">Фулфілмент в Україні</a> · <a href="/ua/blog/peak-season-logistics-mistakes/">Помилки у пік-сезон</a></p>
  </div>
</section>

<!-- ====== 4. ПОВЕРНЕННЯ ====== -->
<section class="poslugy__cat poslugy__cat--alt" id="povernennya">
  <div class="poslugy__container">
    <div class="poslugy__cat-label">04 / Повернення та обробка браку</div>
    <h2 class="poslugy__cat-h">Reverse logistics за 24-48 годин</h2>
    <p>Повернення — найдорожча і найбільш недооцінена частина e-commerce операцій. Середній рівень повернень у одязі і взутті — 18-22%, у косметиці — 4-6%, у техніці — 8-10%. Якщо обробляти повернення повільно (більше 5-7 днів від отримання посилки до повернення товару у продаж), у вас на складі лежить заморожений капітал. Якщо обробляти неточно (товар з пошкодженою упаковкою повертається у продаж замість дисконт-каналу) — отримуєте друге повернення від наступного покупця.</p>
    <p>Наш SLA: повернення обробляється у 24-48 годин від моменту отримання посилки. Що це означає: ваш товар або повертається у продаж (якщо не пошкоджений), або переходить у статус "брак" з фотофіксацією (якщо пошкоджений), або у статус "повторний продаж зі знижкою" (якщо упаковка пошкоджена, але товар цілий). Точність ідентифікації стану — 99,5%. Окремо ведемо звітність по причинах повернень — це дає вам аналітику для покращення продукту.</p>
    <ul class="poslugy__tags">
      <li>Повернення стандарт — 25 грн/одиниця</li>
      <li>Фотофіксація браку — входить у тариф</li>
      <li>Категоризація причин (звіт раз на тиждень)</li>
      <li>Утилізація неремонтопридатного браку</li>
      <li>Повторне пакування для дисконт-продажу</li>
      <li>Refund-контроль через Шериф Платежів</li>
    </ul>
    <p class="poslugy__cat-links">Глибше: <a href="/ua/blog/reduce-product-returns-ecommerce/">Як зменшити повернення</a></p>
