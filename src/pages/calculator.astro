<style is:global>

:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}body{font-family:var(--fb);font-weight:400;color:var(--black);background:var(--white);line-height:1.6;overflow-x:hidden}
a{text-decoration:none;color:inherit}img{max-width:100%;height:auto;display:block}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}


.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:32px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}.badge-dark::before{background:var(--red)}


.hero{position:relative;background:var(--black);color:var(--white);padding:120px 0 80px;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:url('/images/tild3766-3932-4434-b537-333032623963__img_4801.jpg') center/cover;opacity:.12}
.hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero h1{font-family:var(--fd);font-size:clamp(42px,6vw,72px);font-weight:400;line-height:.95;margin-bottom:28px}
.hero-sub{font-size:clamp(16px,1.8vw,20px);color:rgba(255,255,255,.6);line-height:1.7;max-width:520px;margin-bottom:48px}
.hero-stats{display:flex;gap:48px;flex-wrap:wrap}
.hero-stat-val{font-family:var(--fb);font-size:clamp(28px,4vw,48px);font-weight:300;color:var(--white)}
.hero-stat-label{font-size:11px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:2px;margin-top:8px}

.sec-h2{font-family:var(--fd);font-size:clamp(32px,4.5vw,56px);font-weight:400;margin-bottom:48px}

.calc-section{padding:80px 0 100px;background:var(--gray)}
.calc-wrap{display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:48px}
.calc-form{background:var(--white);border-radius:12px;padding:40px;box-shadow:0 2px 24px rgba(0,0,0,.06)}
.calc-form h3{font-family:var(--fd);font-size:24px;font-weight:400;margin-bottom:32px}
.calc-field{margin-bottom:24px}
.calc-field label{display:block;font-size:13px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.calc-field input,.calc-field select{width:100%;padding:14px 16px;border:1px solid #e0e0e0;border-radius:6px;font-size:16px;font-family:var(--fb);outline:none;transition:border-color .3s;background:var(--white);color:var(--black)}
.calc-field input:focus,.calc-field select:focus{border-color:var(--red)}
.calc-field .field-hint{font-size:12px;color:var(--muted);margin-top:4px}

.calc-results{background:var(--black);border-radius:12px;padding:40px;color:var(--white)}
.calc-results h3{font-family:var(--fd);font-size:24px;font-weight:400;margin-bottom:32px;color:var(--white)}
.res-row{display:flex;justify-content:space-between;align-items:center;padding:16px 0;border-bottom:1px solid rgba(255,255,255,.08)}
.res-row:last-of-type{border-bottom:none}
.res-label{font-size:14px;color:rgba(255,255,255,.6)}
.res-value{font-size:16px;font-weight:500;color:var(--white)}
.res-sub{font-size:12px;color:rgba(255,255,255,.35);margin-left:8px;font-weight:300}
.res-total{margin-top:24px;padding:24px;background:var(--red);border-radius:8px}
.res-total .res-row{border-bottom:none;padding:8px 0}
.res-total .res-label{color:rgba(255,255,255,.85);font-size:16px;font-weight:500}
.res-total .res-value{font-family:var(--fd);font-size:28px}
.res-cost-per{margin-top:16px;padding:16px;background:rgba(255,255,255,.06);border-radius:8px;text-align:center}
.res-cost-per .val{font-family:var(--fd);font-size:32px;color:var(--red)}
.res-cost-per .lbl{font-size:13px;color:rgba(255,255,255,.5);margin-top:4px}
.res-compare{margin-top:16px;padding:20px;border:1px solid rgba(255,255,255,.1);border-radius:8px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.6}
.res-compare strong{color:#22c55e;font-weight:500}
.res-compare .compare-title{font-size:13px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;font-weight:500}
.res-compare .compare-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.06)}
.res-compare .compare-row:last-child{border-bottom:none}
.res-compare .compare-total{margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.15);font-weight:500;color:rgba(255,255,255,.8)}
.res-time{margin-top:16px;padding:20px;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.6}
.res-time strong{color:#22c55e;font-weight:500}

.tariff-section{padding:100px 0}
.tariff-table{width:100%;border-collapse:collapse;margin-top:48px}
.tariff-table th,.tariff-table td{padding:16px 24px;text-align:left;border-bottom:1px solid #e0e0e0}
.tariff-table th{font-size:12px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:1px;background:var(--gray)}
.tariff-table td{font-size:15px}
.tariff-table tr:hover td{background:rgba(230,51,41,.03)}
.tariff-table .highlight{background:rgba(230,51,41,.06);font-weight:500}
.tariff-table .rate{font-family:var(--fd);font-size:20px;color:var(--red)}

.addons{padding:100px 0;background:#0a0a0a;color:var(--white)}
.addon-table{width:100%;border-collapse:collapse;margin-top:48px}
.addon-table th,.addon-table td{padding:16px 24px;text-align:left;border-bottom:1px solid rgba(255,255,255,.08)}
.addon-table th{font-size:12px;font-weight:500;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:1px}
.addon-table td{font-size:15px;color:rgba(255,255,255,.7)}
