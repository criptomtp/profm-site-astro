.kv-cmp-note{font-size:13px;color:var(--muted);margin-top:12px;line-height:1.5}
.kv-cmp-saving{margin-top:16px;padding:12px 16px;background:rgba(230,51,41,.06);border-radius:8px;font-size:14px;font-weight:600;color:var(--red);text-align:center}

/* 7. FAQ */
.kv-faq{padding:100px 0;background:var(--black);color:var(--white)}
