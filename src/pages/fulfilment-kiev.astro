.kv-faq .faq-item{border-bottom:1px solid rgba(255,255,255,.08)}
.kv-faq .faq-q{width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:var(--fb);text-align:left}
