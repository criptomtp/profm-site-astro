<script is:inline>
// ROI Calculator
(function(){
var ordersEl=document.getElementById('calcOrders');
var storageEl=document.getElementById('calcStorage');
var itemsEl=document.getElementById('calcItems');
if(!ordersEl)return;

function getRate(n){
if(n>200)return 18;if(n>150)return 19;if(n>100)return 20;
if(n>50)return 22;if(n>20)return 23;if(n>5)return 25;return 26;
}
function calc(){
var orders=parseInt(ordersEl.value);
var storage=parseFloat(storageEl.value);
var items=parseFloat(itemsEl.value);
document.getElementById('calcOrdersVal').textContent=orders;
document.getElementById('calcStorageVal').textContent=storage;
document.getElementById('calcItemsVal').textContent=items;

var rate=getRate(orders);
var days=22;
var totalOrders=orders*days;
var mtpStorage=storage*650;
var mtpShipping=totalOrders*rate;
var mtpExtras=totalOrders*Math.max(0,items-1)*2.5;
var mtp=Math.max(mtpStorage+mtpShipping+mtpExtras,5000);

var own=15000+30000+5000+3000+2000;
var save=own-mtp;
var pct=Math.round(save/own*100);
var per=Math.round(mtp/totalOrders);

document.getElementById('resOwn').textContent=own.toLocaleString('uk');
document.getElementById('resMtp').textContent=Math.round(mtp).toLocaleString('uk');
document.getElementById('resSave').textContent=Math.max(0,save).toLocaleString('uk');
document.getElementById('resPct').textContent=Math.max(0,pct);
document.getElementById('resPer').textContent=per;
}
ordersEl.addEventListener('input',calc);
storageEl.addEventListener('input',calc);
itemsEl.addEventListener('input',calc);
calc();
