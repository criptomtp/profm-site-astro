---
import Base from '../layouts/Base.astro';

const terms = [
  { id: 'fulfillment', name: 'Фулфілмент (Fulfillment)', short: 'Аутсорсинг складської і відправної логістики.' },
  { id: '3pl', name: '3PL (Third-Party Logistics)', short: 'Зовнішній логістичний провайдер для складу і доставки.' },
  { id: 'fba-fbo-fbs', name: 'FBA / FBO / FBS', short: 'Моделі фулфілменту на маркетплейсах.' },
  { id: 'pick-pack', name: 'Pick and Pack (пік-пак)', short: 'Комплектація замовлення зі складу і пакування під відправку.' },
  { id: 'wms', name: 'WMS (Warehouse Management System)', short: 'Система управління складом і залишками.' },
  { id: 'sku', name: 'SKU (Stock Keeping Unit)', short: 'Унікальний обліковий код товарної позиції.' },
  { id: 'sla', name: 'SLA (Service Level Agreement)', short: 'Гарантований рівень сервісу у договорі з оператором.' },
  { id: 'cross-docking', name: 'Cross-docking', search: 'Наскрізне перевантаження без зберігання на складі.' }
];

const definedTermSet = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": "Глосарій фулфілменту і логістики e-commerce",
  "url": "https://www.fulfillmentmtp.com.ua/glosariy/",
  "inLanguage": "uk",
  "hasDefinedTerm": [
    { "@type": "DefinedTerm", "termCode": "fulfillment", "name": "Фулфілмент", "description": "Логістична послуга, що покриває всі операції інтернет-магазину після оформлення замовлення: приймання, зберігання, комплектацію, пакування, відправку і обробку повернень.", "url": "https://www.fulfillmentmtp.com.ua/ua/shcho-take-fulfilment/" },
    { "@type": "DefinedTerm", "termCode": "3PL", "name": "3PL", "description": "Third-Party Logistics — зовнішній логістичний провайдер, який бере на себе складські і відправні функції онлайн-магазину або B2B-продавця.", "url": "https://www.fulfillmentmtp.com.ua/ua/3pl-logistyka/" },
    { "@type": "DefinedTerm", "termCode": "FBA", "name": "FBA", "description": "Fulfillment by Amazon — програма зберігання і відправки товарів продавцями через склади Amazon. Ширше — загальна модель фулфілменту через маркетплейс." },
    { "@type": "DefinedTerm", "termCode": "FBO", "name": "FBO", "description": "Fulfillment by Operator — товар зберігається і відправляється зі складу маркетплейса або 3PL-оператора." },
    { "@type": "DefinedTerm", "termCode": "FBS", "name": "FBS", "description": "Fulfillment by Seller — товар зберігається і відправляється зі складу самого продавця, маркетплейс лише приймає замовлення." },
    { "@type": "DefinedTerm", "termCode": "pick-pack", "name": "Pick and Pack", "description": "Комплектація (picking) замовлення зі складу і пакування (packing) під конкретного клієнта чи маркетплейс. Основна одиниця тарифікації у фулфілменті." },
    { "@type": "DefinedTerm", "termCode": "WMS", "name": "WMS", "description": "Warehouse Management System — програмне забезпечення для управління складськими операціями: адресне зберігання, маршрути комплектації, залишки у реальному часі." },
    { "@type": "DefinedTerm", "termCode": "SKU", "name": "SKU", "description": "Stock Keeping Unit — унікальний обліковий код товарної позиції. Один SKU = один товар у конкретному варіанті (розмір/колір/упаковка)." },
    { "@type": "DefinedTerm", "termCode": "SLA", "name": "SLA", "description": "Service Level Agreement — гарантований рівень сервісу, зафіксований у договорі: швидкість комплектації, точність picking, час відповіді на звернення." },
    { "@type": "DefinedTerm", "termCode": "cross-docking", "name": "Cross-docking", "description": "Модель логістики, коли товар не зберігається на складі, а перевантажується з вхідної машини на вихідну (наскрізне проходження)." }
  ]
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Головна", "item": "https://www.fulfillmentmtp.com.ua/" },
    { "@type": "ListItem", "position": 2, "name": "Глосарій", "item": "https://www.fulfillmentmtp.com.ua/glosariy/" }
  ]
};

const schemaBlob = `<script type="application/ld+json">${JSON.stringify(definedTermSet)}</script><script type="application/ld+json">${JSON.stringify(breadcrumb)}</script>`;
