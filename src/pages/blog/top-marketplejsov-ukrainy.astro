<div style="display:flex;align-items:center;gap:12px"><span style="width:80px;font-size:13px;font-weight:600;text-align:right">Rozetka</span><div style="background:#e63329;height:28px;border-radius:4px;width:60%;display:flex;align-items:center;padding-left:10px;color:#fff;font-size:13px;font-weight:700">5&ndash;27%</div></div>
