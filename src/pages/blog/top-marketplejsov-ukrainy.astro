<div style="display:flex;align-items:center;gap:12px"><span style="width:80px;font-size:13px;font-weight:600;text-align:right">Allo</span><div style="background:#666;height:28px;border-radius:4px;width:30%;display:flex;align-items:center;padding-left:10px;color:#fff;font-size:13px;font-weight:700">5&ndash;12%</div></div>
