<tr style="background:#fafafa"><td style="padding:10px 16px;font-weight:700">Чистая прибыль</td><td style="padding:10px 16px;text-align:right;font-weight:700;color:#e63329;font-size:18px">184.50 грн (37%)</td></tr>
</tbody>
</table>
