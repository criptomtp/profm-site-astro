<tr style="border-bottom:1px solid #eee;"><td style="padding:10px;">UniPost</td><td style="padding:10px;">10 000 грн</td><td style="padding:10px;">25 грн</td><td style="padding:10px;">700 грн/м³</td></tr>
<tr style="border-bottom:1px solid #eee;"><td style="padding:10px;">Fast Lane Group</td><td style="padding:10px;">8 000 грн</td><td style="padding:10px;">22 грн</td><td style="padding:10px;">700 грн/м³</td></tr>
<tr style="border-bottom:1px solid #eee;"><td style="padding:10px;">Логистический Кооператив</td><td style="padding:10px;">6 000 грн</td><td style="padding:10px;">24 грн</td><td style="padding:10px;">680 грн/м³</td></tr>
