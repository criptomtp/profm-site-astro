---
import Base from '../../layouts/Base.astro';
---
<Base
  title="FAQ Fulfillment Questions | MTP Group"
  description="30+ answers about fulfillment pricing, services, integrations, and how to get started with MTP Group in Ukraine."
  canonical="https://www.fulfillmentmtp.com.ua/en/faq/"
  lang="en"
  ogImage="https://www.fulfillmentmtp.com.ua/images/faq-hero.webp"
  schema={`<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is fulfillment?","acceptedAnswer":{"@type":"Answer","text":"Fulfillment is a complete warehouse service: receiving goods, storage, picking orders, and shipping to customers. Instead of managing logistics yourself, you hand it off to us while you focus on marketing and sales."}},{"@type":"Question","name":"What is the minimum monthly payment?","acceptedAnswer":{"@type":"Answer","text":"Minimum monthly payment is 5,000 UAH. If actual service costs are lower, you still pay the minimum. This lets startups begin with MTP without setting up their own warehouse infrastructure."}},{"@type":"Question","name":"How is fulfillment cost calculated?","acceptedAnswer":{"@type":"Answer","text":"Cost has 3 components: (1) storage at 650 UAH/m³/month, (2) shipping from 18-26 UAH per order (varies by volume), (3) add-ons like pick-and-pack, labeling, etc. Total is compared against 5,000 UAH minimum, and you pay whichever is higher."}},{"@type":"Question","name":"What is the average time to pick and ship an order?","acceptedAnswer":{"@type":"Answer","text":"Average picking time is 30 seconds per order. We process shipments 4 times daily, so orders received today can ship the same day."}},{"@type":"Question","name":"How does dynamic shipping pricing work?","acceptedAnswer":{"@type":"Answer","text":"Price per order depends on daily volume: 0-5 orders = 26 UAH, 6-20 = 25 UAH, 21-50 = 23 UAH, 51-100 = 22 UAH, 101-150 = 20 UAH, 151-200 = 19 UAH, 200+ = 18 UAH. Price recalculates monthly based on your volume."}}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","logo":"https://www.fulfillmentmtp.com.ua/images/mtp-logo.webp","sameAs":["https://www.instagram.com/mtp_group/"],"address":{"@type":"PostalAddress","addressLocality":"Boryspil","addressRegion":"Kyiv Region","addressCountry":"UA"},"telephone":"+380501444645"}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.fulfillmentmtp.com.ua/en/"},{"@type":"ListItem","position":2,"name":"FAQ","item":"https://www.fulfillmentmtp.com.ua/en/faq/"}]}</script>`}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/faq/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/faq/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/ua/faq/">
  <link rel="stylesheet" href="/css/fonts.css">
</Fragment>

<!-- HERO -->
<section class="hero">
<div class="container">
<h1>Fulfillment FAQ — Answers to Your Questions</h1>
<div class="hero-line"></div>
<p>30+ questions about pricing, integrations, and how to get started</p>
<form class="hero-form" id="heroForm"><input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="19" required autocomplete="tel" aria-label="Phone"><button type="submit">Send Inquiry &#8594;</button></form>
<div class="hero-note">Most frequently asked questions with complete answers</div>
</div>
</section>

<!-- FAQ SECTIONS -->
<section class="faq-section">
<div class="container">

<!-- GENERAL QUESTIONS -->
<div class="faq-category">
<h2 class="category-title">General About Fulfillment</h2>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">What is fulfillment?</button>
<div class="faq-answer">
<p>Fulfillment is a complete warehouse service: receiving goods, storage, picking orders, and shipping to customers. Instead of managing logistics yourself, you hand it off to us while you focus on marketing and sales.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">What is the average time to pick and ship an order?</button>
<div class="faq-answer">
<p>Average picking time is <strong>30 seconds</strong> per order. We process shipments <strong>4 times daily</strong>, so orders received today can ship the same day.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">What minimum order volume do you need?</button>
<div class="faq-answer">
<p>No minimum order volume. Even 1-2 orders per day work with us. However, minimum monthly payment is 5,000 UAH — if actual costs are lower, you still pay the minimum.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">How does dynamic pricing work?</button>
<div class="faq-answer">
<p>Price per order depends on daily volume:</p>
<ul>
<li><strong>0–5 orders/day</strong> = 26 UAH per order</li>
<li><strong>6–20</strong> = 25 UAH</li>
<li><strong>21–50</strong> = 23 UAH</li>
<li><strong>51–100</strong> = 22 UAH</li>
<li><strong>101–150</strong> = 20 UAH</li>
<li><strong>151–200</strong> = 19 UAH</li>
<li><strong>200+</strong> = 18 UAH</li>
</ul>
<p>Price recalculates monthly based on your actual volume.</p>
</div>
</div>

</div>

<!-- PRICING QUESTIONS -->
<div class="faq-category">
<h2 class="category-title">Pricing & Cost</h2>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">How is fulfillment cost calculated?</button>
<div class="faq-answer">
<p>Cost has 3 components:</p>
<ol>
<li><strong>Storage</strong> — 650 UAH per m³ per month</li>
<li><strong>Shipping</strong> — 18-26 UAH per order (depends on volume)</li>
<li><strong>Add-ons</strong> — labeling (1.25 UAH), FEFO tracking (0.50 UAH), extra items (2.50 UAH), etc.</li>
</ol>
<p>Total is compared to <strong>5,000 UAH minimum monthly</strong>, and you pay whichever is higher.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">What is the cost of pallet storage?</button>
<div class="faq-answer">
<p>Pallet storage is calculated the same way: <strong>650 UAH per m³ per month</strong>. Pallet forming (wrapping) costs <strong>350 UAH</strong> (includes pallet). You can store half a pallet, quarter pallet, etc. — everything calculated by volume.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">What is the cost of pick-and-pack?</button>
<div class="faq-answer">
<p>Pick-and-pack (adding extra items to an order) costs <strong>2.50 UAH per item</strong>. This lets you control costs for adding promotional materials, samples, gifts, etc.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Can we negotiate custom pricing?</button>
<div class="faq-answer">
<p>Yes. For clients with <strong>500+ orders per month</strong>, we can negotiate custom pricing and terms. Contact our manager: <strong>mtpgrouppromo@gmail.com</strong> or +38 (050) 144-46-45.</p>
</div>
</div>

</div>

<!-- TECHNICAL & CAPABILITY QUESTIONS -->
<div class="faq-category">
<h2 class="category-title">Technology & Services</h2>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">How do I check inventory in real time?</button>
<div class="faq-answer">
<p>Two ways:</p>
<ol>
<li><strong>Official MTP dashboard</strong> — see real-time inventory, orders, and billing</li>
<li><strong>Telegram bot</strong> (@MTPGroupFulfillment_bot) — get notifications on new orders, payments, processing status</li>
</ol>
<p>Our API also syncs inventory across all your sales channels automatically.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">How do you ensure accuracy in picking?</button>
<div class="faq-answer">
<p>Our WMS system eliminates human error by <strong>99%</strong>: every item is scanned by barcode, the system guides pickers to the correct location, and final inspection before shipment ensures accuracy. If we make a mistake, we compensate you.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Do you process orders received at night?</button>
<div class="faq-answer">
<p>Yes. We operate <strong>24/7</strong>, including weekends and holidays, even during power outages (we have 3 generators, 2 fiber providers + Starlink). Orders are processed 4 times daily, so overnight orders ship the next morning.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Do you offer FEFO for cosmetics and pharma?</button>
<div class="faq-answer">
<p>Yes. For products with limited shelf life (cosmetics, supplements, medicines), we apply <strong>FEFO control</strong> (First Expiry First Out) at <strong>0.50 UAH per unit</strong>. This ensures products are shipped in order of approaching expiration dates.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Do you handle returns?</button>
<div class="faq-answer">
<p>Yes. Return unpacking and processing is included. Unpacking cost is <strong>50% of (shipping + pick-and-pack)</strong>. Whether to scrap or return items to you is specified in the contract.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Do you provide receipts for orders?</button>
<div class="faq-answer">
<p>Yes. We issue official receipts through our cash register (POS system) for every order. Customers receive a receipt — you operate legally without your own register.</p>
</div>
</div>

</div>

<!-- INTEGRATION QUESTIONS -->
<div class="faq-category">
<h2 class="category-title">Integrations & Technology</h2>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">How easy is integration with my store?</button>
<div class="faq-answer">
<p>We integrate in <strong>2 hours</strong> with any popular platform:</p>
<ul>
<li>Marketplaces: Rozetka, Prom.ua, Kasta, OLX</li>
<li>E-commerce: Shopify, WooCommerce, OpenCart</li>
<li>CRM: 1C, Pipedrive, HubSpot</li>
</ul>
<p>Our API auto-syncs inventory, orders, and shipping status.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Is your system compatible with Zapier?</button>
<div class="faq-answer">
<p>Yes. Our API works with Zapier, so you can automate many processes without coding. Just ask us for setup help.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">How do you handle multi-channel inventory?</button>
<div class="faq-answer">
<p>Inventory syncs centrally: when stock in our warehouse updates, Rozetka, Prom.ua, and your store all see the same numbers in real time. This prevents overselling and customer complaints.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Do you have API docs and webhooks?</button>
<div class="faq-answer">
<p>Yes. We provide full REST API documentation with code examples (Python, PHP, JavaScript). Webhooks send real-time order status updates. Check: <strong>api.fulfillmentmtp.com.ua</strong></p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">How often do I get reports?</button>
<div class="faq-answer">
<p>Real-time dashboard shows orders, costs, inventory. Monthly detailed reports available on request (Excel/CSV with all operations).</p>
</div>
</div>

</div>

<!-- CONTRACT & LOGISTICS QUESTIONS -->
<div class="faq-category">
<h2 class="category-title">Contract & Logistics</h2>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Is there an official contract with SLA and liability?</button>
<div class="faq-answer">
<p>Yes. Official contract with clear SLA: order pickup time, accuracy guarantee, return processing timeline. <strong>We're liable for goods on our warehouse</strong>. All operations logged in WMS — undisputable.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Do you include warranty documentation?</button>
<div class="faq-answer">
<p>Yes. If you provide warranty cards, we fill them out (<strong>5 UAH per card</strong>) and include them in shipments. Essential for tech, gadgets, and warranted goods.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Can I cancel anytime?</button>
<div class="faq-answer">
<p>Yes. Contract allows cancellation anytime with written notice. Remaining goods can be returned to you or shipped to customers — your choice.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Where are your warehouses located?</button>
<div class="faq-answer">
<p>Two operational locations:</p>
<ul>
<li><strong>Boryspil</strong> (near airport) — main facility</li>
<li><strong>Bilohorodka</strong> (Kyiv Region) — backup facility</li>
</ul>
<p>Geographic redundancy means if one location has issues, the other keeps running uninterrupted.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">How do you resolve disputes?</button>
<div class="faq-answer">
<p>Official SLA in the contract specifies the process. If we make a picking error, we compensate. Liability is documented. Conflicts resolved through your account manager (<strong>+38 (093) 827-77-67</strong>).</p>
</div>
</div>

</div>

<!-- GETTING STARTED QUESTIONS -->
<div class="faq-category">
<h2 class="category-title">Getting Started</h2>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Can I use fulfillment as a startup?</button>
<div class="faq-answer">
<p>Yes. Minimum payment is just <strong>5,000 UAH per month</strong>. If costs are lower, you pay the minimum. This lets startups begin without expensive warehouse infrastructure.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">Can I test before committing?</button>
<div class="faq-answer">
<p>Yes. We offer a <strong>free trial period</strong>: process 5-10 test orders to verify quality. Convince yourself before official launch. Request from: <strong>mtpgrouppromo@gmail.com</strong></p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">What do I need to get started?</button>
<div class="faq-answer">
<p>Minimum: your business name, address, contact info, and order structure (how orders arrive — shop, marketplace, manual). For auto-sync, you just grant API access to your system — one click in settings.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">How often do prices change?</button>
<div class="faq-answer">
<p>Pricing is fixed for all of 2026 (from 01.01.2026). If we need to change, we give 30 days notice before new rates take effect.</p>
</div>
</div>

<div class="faq-item">
<button class="faq-question" onclick="toggleFaq(this)">What payment methods do you accept?</button>
<div class="faq-answer">
<p>Bank transfers, cards, business accounts. Month-end invoices issued to your legal entity (individual or company). Terms discussed during contract signing.</p>
</div>
</div>

</div>

</div>
</section>

<!-- CTA SECTION -->
<section class="cta-section">
<div class="container">
<h2>Ready to Get Started?</h2>
<p>Didn't find your answer? Our managers are always ready to help.</p>
<div class="cta-buttons">
<button class="btn btn-primary" onclick="openContactForm()">Send Inquiry</button>
<a href="tel:+380501444645" class="btn btn-secondary">Call Now</a>
</div>
</div>
</section>

<style>
.faq-section {
  padding: 60px 0;
  background: #fff;
}

.faq-category {
  margin-bottom: 50px;
}

.category-title {
  font-size: 28px;
  font-weight: 600;
  color: #000;
  margin-bottom: 30px;
  border-bottom: 2px solid #e63329;
  padding-bottom: 15px;
}

.faq-item {
  margin-bottom: 20px;
  border-left: 3px solid #e63329;
  padding-left: 20px;
}

.faq-question {
  background: none;
  border: none;
  width: 100%;
  text-align: left;
  font-size: 16px;
  font-weight: 500;
  color: #000;
  cursor: pointer;
  padding: 15px 0;
  position: relative;
  padding-right: 30px;
}

.faq-question::after {
  content: '+';
  position: absolute;
  right: 0;
  font-size: 24px;
  color: #e63329;
  transition: transform 0.3s;
}

.faq-question:hover {
  color: #e63329;
}

.faq-item.active .faq-question::after {
  transform: rotate(45deg);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease-out;
}

.faq-item.active .faq-answer {
  max-height: 500px;
}

.faq-answer p, .faq-answer ul, .faq-answer ol {
  font-size: 15px;
  line-height: 1.6;
  color: #555;
  margin-bottom: 12px;
}

.faq-answer ul, .faq-answer ol {
  padding-left: 20px;
  margin-bottom: 16px;
}

.faq-answer li {
  margin-bottom: 8px;
}

.cta-section {
  background: linear-gradient(135deg, #e63329 0%, #cc2820 100%);
  color: white;
  padding: 60px 0;
  text-align: center;
}

.cta-section h2 {
  font-size: 32px;
  margin-bottom: 15px;
}

.cta-section p {
  font-size: 18px;
  margin-bottom: 30px;
  opacity: 0.95;
}

.cta-buttons {
  display: flex;
  gap: 15px;
  justify-content: center;
  flex-wrap: wrap;
}

.btn {
  padding: 12px 30px;
  border-radius: 4px;
  font-weight: 600;
  text-decoration: none;
  display: inline-block;
  cursor: pointer;
  border: none;
  font-size: 16px;
  transition: all 0.3s;
}

.btn-primary {
  background: white;
  color: #e63329;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

.btn-secondary {
  background: transparent;
  color: white;
  border: 2px solid white;
}

.btn-secondary:hover {
  background: white;
  color: #e63329;
}

@media (max-width: 768px) {
  .category-title {
    font-size: 24px;
  }

  .faq-question {
    font-size: 15px;
  }

  .cta-section {
    padding: 40px 0;
  }

  .cta-section h2 {
    font-size: 24px;
  }

  .cta-buttons {
    flex-direction: column;
  }

  .btn {
    width: 100%;
  }
}
</style>

<script>
function toggleFaq(element) {
  const item = element.parentElement;
  item.classList.toggle('active');
}

function openContactForm() {
  const phone = prompt('Enter your phone number:');
  if (phone) {
    const form = document.getElementById('heroForm');
    const input = form.querySelector('input[name="phone"]');
    input.value = phone;
    form.submit();
  }
}

document.addEventListener('DOMContentLoaded', function() {
  const firstQuestion = document.querySelector('.faq-question');
  if (firstQuestion) {
    firstQuestion.parentElement.classList.add('active');
  }
});
</script>

</Base>
