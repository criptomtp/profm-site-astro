---
import Base from '../../layouts/Base.astro';
---
<Base
  title="FAQ Fulfillment Questions | MTP Group"
  description="30+ answers about fulfillment pricing, services, integrations, and how to get started with MTP Group in Ukraine."
  canonical="https://www.fulfillmentmtp.com.ua/en/faq/"
  lang="en"
  showCTA={false}
  ogImage="https://www.fulfillmentmtp.com.ua/images/fulfillment-process-overview.webp"
  schema={`<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is fulfillment?","acceptedAnswer":{"@type":"Answer","text":"Fulfillment is a complete warehouse service: receiving goods, storage, picking orders, and shipping to customers. Instead of managing logistics yourself, you hand it off to us while you focus on marketing and sales."}},{"@type":"Question","name":"What is the minimum monthly payment?","acceptedAnswer":{"@type":"Answer","text":"Minimum monthly payment is 5,000 UAH. If actual service costs are lower, you still pay the minimum."}},{"@type":"Question","name":"How is fulfillment cost calculated?","acceptedAnswer":{"@type":"Answer","text":"Cost has 3 components: (1) storage at 650 UAH/m3/month, (2) shipping from 18-26 UAH per order (varies by volume), (3) add-ons like pick-and-pack, labeling, etc."}},{"@type":"Question","name":"What is the average time to pick and ship an order?","acceptedAnswer":{"@type":"Answer","text":"Average picking time is 30 seconds per order. We process shipments 4 times daily."}},{"@type":"Question","name":"How does dynamic shipping pricing work?","acceptedAnswer":{"@type":"Answer","text":"Price per order depends on daily volume: 0-5 orders = 26 UAH, 6-20 = 25 UAH, 21-50 = 23 UAH, 51-100 = 22 UAH, 101-150 = 20 UAH, 151-200 = 19 UAH, 200+ = 18 UAH."}}]}</script><script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.fulfillmentmtp.com.ua/en/"},{"@type":"ListItem","position":2,"name":"FAQ","item":"https://www.fulfillmentmtp.com.ua/en/faq/"}]}</script>`}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/faq/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/faq/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/faq/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/ua/faq/">
  <link rel="stylesheet" href="/css/fonts.css">
</Fragment>

<!-- HERO -->
<section class="faq-hero">
<div class="faq-hero__inner">
  <span class="faq-hero__label">Frequently Asked Questions</span>
  <h1 class="faq-hero__title">Everything about<br>fulfillment in Ukraine</h1>
  <p class="faq-hero__sub">30+ questions about pricing, integrations, timelines, and getting started with MTP&nbsp;Group. Straight answers, no&nbsp;marketing fluff.</p>
  <div class="faq-hero__actions">
    <a href="/en/calculator/" class="faq-hero__btn faq-hero__btn--primary">Calculate Cost</a>
    <a href="tel:+380501444645" class="faq-hero__btn faq-hero__btn--outline">+38 (050) 144-46-45</a>
  </div>
</div>
</section>

<!-- STATS -->
<section class="faq-stats">
<div class="faq-stats__inner">
  <div class="faq-stats__item">
    <span class="faq-stats__num">60,000+</span>
    <span class="faq-stats__label">shipments / month</span>
  </div>
  <div class="faq-stats__item">
    <span class="faq-stats__num">10+ Years</span>
    <span class="faq-stats__label">market expertise</span>
  </div>
  <div class="faq-stats__item">
    <span class="faq-stats__num">30 sec</span>
    <span class="faq-stats__label">order picking</span>
  </div>
  <div class="faq-stats__item">
    <span class="faq-stats__num">24/7</span>
    <span class="faq-stats__label">warehouse operations</span>
  </div>
</div>
</section>

<!-- CATEGORY NAV -->
<section class="faq-nav">
<div class="faq-nav__inner">
  <a href="#basics" class="faq-nav__link faq-nav__link--active">General</a>
  <a href="#pricing" class="faq-nav__link">Pricing</a>
  <a href="#warehouse" class="faq-nav__link">Warehouse</a>
  <a href="#integrations" class="faq-nav__link">Integrations</a>
  <a href="#contract" class="faq-nav__link">Contract</a>
  <a href="#start" class="faq-nav__link">Getting Started</a>
</div>
</section>

<!-- FAQ SECTIONS -->
<section class="faq-main">
<div class="faq-main__inner">

<!-- GENERAL -->
<div class="faq-block" id="basics">
<div class="faq-block__header">
  <span class="faq-block__num">01</span>
  <h2 class="faq-block__title">General About Fulfillment</h2>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>What is fulfillment?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Fulfillment is a complete warehouse service: receiving goods, storage, picking orders, and shipping to customers. Instead of managing logistics yourself, you hand it off to us while you focus on marketing and sales.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>What is the average time to pick and ship an order?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Average picking time is <strong>30 seconds</strong> per order. We process shipments <strong>4 times daily</strong>, so orders received today can ship the same day.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>What minimum order volume do you need?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>No minimum order volume. Even 1-2 orders per day work with us. However, minimum monthly payment is 5,000 UAH — if actual costs are lower, you still pay the minimum.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>How does dynamic pricing work?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Price per order depends on daily volume:</p>
<ul>
<li><strong>0–5 orders/day</strong> = 26 UAH per order</li>
<li><strong>6–20</strong> = 25 UAH</li>
<li><strong>21–50</strong> = 23 UAH</li>
<li><strong>51–100</strong> = 22 UAH</li>
<li><strong>101–150</strong> = 20 UAH</li>
<li><strong>151–200</strong> = 19 UAH</li>
<li><strong>200+</strong> = 18 UAH</li>
</ul>
<p>Price recalculates monthly based on your actual volume.</p>
</div>
</div>
</div>

<!-- PRICING -->
<div class="faq-block" id="pricing">
<div class="faq-block__header">
  <span class="faq-block__num">02</span>
  <h2 class="faq-block__title">Pricing & Cost</h2>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>How is fulfillment cost calculated?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Cost has 3 components:</p>
<ol>
<li><strong>Storage</strong> — 650 UAH per m&sup3; per month</li>
<li><strong>Shipping</strong> — 18-26 UAH per order (depends on volume)</li>
<li><strong>Add-ons</strong> — labeling (1.25 UAH), FEFO tracking (0.50 UAH), extra items (2.50 UAH), etc.</li>
</ol>
<p>Total is compared to <strong>5,000 UAH minimum monthly</strong>, and you pay whichever is higher.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>What is the cost of pallet storage?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Pallet storage is calculated the same way: <strong>650 UAH per m&sup3; per month</strong>. Pallet forming (wrapping) costs <strong>350 UAH</strong> (includes pallet). You can store half a pallet, quarter pallet, etc. — everything calculated by volume.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>What is the cost of pick-and-pack?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Pick-and-pack (adding extra items to an order) costs <strong>2.50 UAH per item</strong>. This lets you control costs for adding promotional materials, samples, gifts, etc.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Can we negotiate custom pricing?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. For clients with <strong>500+ orders per month</strong>, we can negotiate custom pricing and terms. Contact our manager: <strong>mtpgrouppromo@gmail.com</strong> or +38 (050) 144-46-45.</p>
</div>
</div>
</div>

<!-- WAREHOUSE -->
<div class="faq-block" id="warehouse">
<div class="faq-block__header">
  <span class="faq-block__num">03</span>
  <h2 class="faq-block__title">Technology & Services</h2>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>How do I check inventory in real time?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Two ways:</p>
<ol>
<li><strong>Official MTP dashboard</strong> — see real-time inventory, orders, and billing</li>
<li><strong>Telegram bot</strong> — get notifications on new orders, payments, processing status</li>
</ol>
<p>Our API also syncs inventory across all your sales channels automatically.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>How do you ensure accuracy in picking?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Our WMS system eliminates human error by <strong>99%</strong>: every item is scanned by barcode, the system guides pickers to the correct location, and final inspection before shipment ensures accuracy. If we make a mistake, we compensate you.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Do you process orders received at night?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. We operate <strong>24/7</strong>, including weekends and holidays, even during power outages (we have 3 generators, 2 fiber providers + Starlink). Orders are processed 4 times daily, so overnight orders ship the next morning.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Do you offer FEFO for cosmetics and pharma?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. For products with limited shelf life (cosmetics, supplements, medicines), we apply <strong>FEFO control</strong> (First Expiry First Out) at <strong>0.50 UAH per unit</strong>. This ensures products are shipped in order of approaching expiration dates.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Do you handle returns?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. Return unpacking and processing is included. Unpacking cost is <strong>50% of (shipping + pick-and-pack)</strong>. Whether to scrap or return items to you is specified in the contract.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Do you provide receipts for orders?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. We issue official receipts through our cash register (POS system) for every order. Customers receive a receipt — you operate legally without your own register.</p>
</div>
</div>
</div>

<!-- INTEGRATIONS -->
<div class="faq-block" id="integrations">
<div class="faq-block__header">
  <span class="faq-block__num">04</span>
  <h2 class="faq-block__title">Integrations & Technology</h2>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>How easy is integration with my store?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>We integrate in <strong>2 hours</strong> with any popular platform:</p>
<ul>
<li>Marketplaces: Rozetka, Prom.ua, Kasta, OLX</li>
<li>E-commerce: Shopify, WooCommerce, OpenCart</li>
<li>CRM: KeyCRM, SalesDrive, LP-CRM, 1C, amoCRM</li>
</ul>
<p>Our API auto-syncs inventory, orders, and shipping status.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Is your system compatible with Zapier?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. Our API works with Zapier, so you can automate many processes without coding. Just ask us for setup help.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>How do you handle multi-channel inventory?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Inventory syncs centrally: when stock in our warehouse updates, Rozetka, Prom.ua, and your store all see the same numbers in real time. This prevents overselling and customer complaints.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Do you have API docs and webhooks?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. We provide full REST API documentation with code examples (Python, PHP, JavaScript). Webhooks send real-time order status updates.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>How often do I get reports?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Real-time dashboard shows orders, costs, inventory. Monthly detailed reports available on request (Excel/CSV with all operations).</p>
</div>
</div>
</div>

<!-- CONTRACT -->
<div class="faq-block" id="contract">
<div class="faq-block__header">
  <span class="faq-block__num">05</span>
  <h2 class="faq-block__title">Contract & Logistics</h2>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Is there an official contract with SLA and liability?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. Official contract with clear SLA: order pickup time, accuracy guarantee, return processing timeline. <strong>We're liable for goods in our warehouse</strong>. All operations logged in WMS — undisputable.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Where are your warehouses located?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Two operational locations:</p>
<ul>
<li><strong>Boryspil</strong> (near airport) — main facility</li>
<li><strong>Bilohorodka</strong> (Kyiv Region) — backup facility</li>
</ul>
<p>Geographic redundancy means if one location has issues, the other keeps running uninterrupted.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Can I cancel anytime?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. Contract allows cancellation anytime with written notice. Remaining goods can be returned to you or shipped to customers — your choice.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>How do you resolve disputes?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Official SLA in the contract specifies the process. If we make a picking error, we compensate. Liability is documented. Conflicts resolved through your account manager (<strong>+38 (093) 827-77-67</strong>).</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>What payment methods do you accept?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Bank transfers, cards, business accounts. Month-end invoices issued to your legal entity (individual or company). Terms discussed during contract signing.</p>
</div>
</div>
</div>

<!-- GETTING STARTED -->
<div class="faq-block" id="start">
<div class="faq-block__header">
  <span class="faq-block__num">06</span>
  <h2 class="faq-block__title">Getting Started</h2>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Can I use fulfillment as a startup?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. Minimum payment is just <strong>5,000 UAH per month</strong>. If costs are lower, you pay the minimum. This lets startups begin without expensive warehouse infrastructure.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>Can I test before committing?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Yes. We offer a <strong>free trial period</strong>: process 5-10 test orders to verify quality. Convince yourself before official launch. Request from: <strong>mtpgrouppromo@gmail.com</strong></p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>What do I need to get started?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Minimum: your business name, address, contact info, and order structure (how orders arrive — shop, marketplace, manual). For auto-sync, you just grant API access to your system — one click in settings.</p>
</div>
</div>

<div class="faq-card">
<button class="faq-card__q"><span>How often do prices change?</span><span class="faq-card__icon">+</span></button>
<div class="faq-card__a">
<p>Pricing is fixed for all of 2026 (from 01.01.2026). If we need to change, we give 30 days notice before new rates take effect.</p>
</div>
</div>
</div>

</div>
</section>


<style>
/* ── HERO ── */
.faq-hero{background:#0a0a0a;color:#fff;padding:100px 24px 80px;position:relative;overflow:hidden}
.faq-hero::after{content:'';position:absolute;top:-40%;right:-20%;width:600px;height:600px;background:radial-gradient(circle,rgba(230,51,41,.15) 0%,transparent 70%);pointer-events:none}
.faq-hero__inner{max-width:900px;margin:0 auto;position:relative;z-index:1}
.faq-hero__label{display:inline-block;font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:#e63329;margin-bottom:24px}
.faq-hero__title{font-family:'FuturaPT',sans-serif;font-size:clamp(36px,5vw,64px);font-weight:700;line-height:1.05;margin-bottom:24px;letter-spacing:-.02em}
.faq-hero__sub{font-size:18px;color:rgba(255,255,255,.6);max-width:560px;line-height:1.6;margin-bottom:40px}
.faq-hero__actions{display:flex;gap:16px;flex-wrap:wrap}
.faq-hero__btn{display:inline-flex;align-items:center;padding:14px 32px;font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;text-decoration:none;border-radius:4px;transition:all .3s}
.faq-hero__btn--primary{background:#e63329;color:#fff}
.faq-hero__btn--primary:hover{background:#cc2820;transform:translateY(-2px)}
.faq-hero__btn--outline{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.2)}
.faq-hero__btn--outline:hover{border-color:#fff;background:rgba(255,255,255,.05)}

/* ── STATS ── */
.faq-stats{background:#f5f5f5;padding:48px 24px;border-bottom:1px solid rgba(0,0,0,.06)}
.faq-stats__inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:32px}
.faq-stats__item{display:flex;flex-direction:column;gap:4px}
.faq-stats__num{font-family:'FuturaPT',sans-serif;font-size:clamp(28px,3vw,42px);font-weight:700;color:#e63329;line-height:1}
