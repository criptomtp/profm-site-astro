---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Fulfillment Services Ukraine — Storage & Shipping | MTP"
  description="Full-cycle fulfillment in Ukraine: receiving, storage, packing, shipping. From 18 UAH/shipment. Integrations with Shopify, WooCommerce, Rozetka."
  canonical="https://www.fulfillmentmtp.com.ua/en/services/"
  lang="en"
>
<Fragment slot="head">
<script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","address":[{"@type":"PostalAddress","addressLocality":"Shchaslive, Boryspil district","addressRegion":"Kyiv region","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"Bilohorodka","addressRegion":"Kyiv region","addressCountry":"UA"}],"openingHours":"Mo-Su 08:00-20:00"}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Fulfillment Services","provider":{"@type":"Organization","name":"MTP Group Fulfillment"},"areaServed":{"@type":"Country","name":"UA"}}</script>
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/services/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/services/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/services/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/ua/services/">
</Fragment>

<!-- HERO -->
<section class="hero">
<div class="container">
<h1>E-commerce Fulfillment Services in Ukraine</h1>
<div class="hero-line"></div>
<p>Full-cycle order processing &mdash; from receiving your inventory to delivering it to your customers. Focus on growth while we handle logistics.</p>
<form class="hero-form" id="heroForm">
<input type="tel" name="phone" placeholder="+380 __ ___ __ __" required autocomplete="tel">
<button type="submit">Get a Quote</button>
</form>
<div class="hero-stats">
<div class="hero-stat"><strong>6,000+</strong><span>orders/day capacity</span></div>
<div class="hero-stat"><strong>from 18</strong><span>UAH per shipment</span></div>
<div class="hero-stat"><strong>99.8%</strong><span>accuracy rate</span></div>
</div>
</div>
</section>

<!-- SERVICES GRID -->
<section class="services-section">
<div class="container">
<h2 class="section-heading">What We Offer</h2>
<p class="section-subtitle">Complete fulfillment services tailored for e-commerce businesses operating in Ukraine</p>
<div class="services-grid">

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M20 7l-8-4-8 4v10l8 4 8-4V7zm-8 11L6 14.5V9.5l6 3v5.5zm1-7L7 8l5-2.5L17 8l-4 3zm5 3.5L14 18v-5.5l4-3v5.5z"/></svg></div>
<h3>Warehousing &amp; Storage</h3>
<p>Climate-controlled, cell-based addressed storage with real-time inventory tracking via WMS. Your goods are insured and monitored 24/7.</p>
<span class="service-price">650 UAH/m&#179;/month</span>
</div>

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg></div>
<h3>Order Shipping</h3>
<p>Picking, packing, and dispatching orders 4 times daily via Nova Poshta, UkrPoshta, and Meest Express. Same-day shipping for orders placed before 4 PM.</p>
<span class="service-price">from 18 UAH/shipment</span>
</div>

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg></div>
<h3>24/7 Operations</h3>
<p>Three backup generators, dual fiber-optic internet providers, and Starlink connectivity. Your orders ship on time, even during power outages and blackouts.</p>
<span class="service-price">Uninterrupted service</span>
</div>

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg></div>
<h3>Auto-Callback Robot</h3>
<p>Automated customer callback system that confirms orders within minutes. Proven to increase the buyout rate by 10-15% across our client base.</p>
<span class="service-price">from 0.50 UAH/call</span>
</div>

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.67-.5-.68C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.62 12 11 8.76l1-1.36 1 1.36L15.38 12 17 10.83 14.92 8H20v6z"/></svg></div>
<h3>Co-Packing &amp; Kitting</h3>
<p>Custom inserts, flyers, samples, gift wrap, and promotional materials added to every order. Build your brand with every package that leaves the warehouse.</p>
<span class="service-price">2.50 UAH/item</span>
</div>

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M16 6l2.29 2.29-4.88 4.88-4-4L2 16.59 3.41 18l6-6 4 4 6.3-6.29L22 12V6z"/></svg></div>
<h3>Effortless Scaling</h3>
<p>Go from 5 to 6,000 daily shipments without changing a single process. Our dynamic pricing rewards growth: the more you ship, the less you pay per order.</p>
<span class="service-price">from 18 UAH/shipment</span>
</div>

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12zm-7-1h2V7h-4v2h2z"/></svg></div>
<h3>Barcoding &amp; Labeling</h3>
<p>We print and apply barcodes for untagged products, ensuring every SKU is scannable and properly identified within our warehouse management system.</p>
<span class="service-price">1.25 UAH/unit</span>
</div>

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1H7.32c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg></div>
<h3>Payment Processing</h3>
<p>Real-time monitoring of cash-on-delivery payments from Nova Poshta via Telegram. Full fiscal receipt support through our integrated RRO system.</p>
<span class="service-price">Included</span>
</div>

<div class="service-card fade-in">
<div class="service-icon"><svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/></svg></div>
<h3>Returns Management</h3>
<p>We receive, inspect, and restock returned items. Detailed photo reports for every return. Damaged goods are separated and documented for your review.</p>
<span class="service-price">Included</span>
</div>

</div>
</div>
</section>

<!-- DYNAMIC PRICING TABLE -->
<section class="pricing-section fade-in">
<div class="container">
<h2 class="section-heading">Dynamic Pricing</h2>
<p class="section-subtitle">The more you ship, the lower your cost per order</p>
<div class="pricing-table">
<div class="pricing-row pricing-header"><span>Shipments/day</span><span>Rate</span></div>
<div class="pricing-row"><span>0 &ndash; 5</span><span>26 UAH</span></div>
<div class="pricing-row"><span>6 &ndash; 20</span><span>25 UAH</span></div>
<div class="pricing-row"><span>21 &ndash; 50</span><span>23 UAH</span></div>
<div class="pricing-row"><span>51 &ndash; 100</span><span>22 UAH</span></div>
<div class="pricing-row"><span>101 &ndash; 200</span><span>20 UAH</span></div>
<div class="pricing-row highlight"><span>200+</span><span>18 UAH</span></div>
</div>
<p class="pricing-note">Warehouse storage: <strong>650 UAH/m&#179;/month</strong> &middot; Free Nova Poshta storage for 17 days</p>
</div>
</section>

<!-- INTEGRATIONS -->
<section class="integrations-section fade-in">
<div class="container">
<h2 class="section-heading">Integrations</h2>
<p class="section-subtitle">Seamless connections with the platforms and CRMs you already use</p>
<div class="integrations-row">
<div class="integration-chip">Shopify</div>
<div class="integration-chip">WooCommerce</div>
<div class="integration-chip">Rozetka</div>
<div class="integration-chip">Prom.ua</div>
<div class="integration-chip">KeyCRM</div>
<div class="integration-chip">Custom API</div>
</div>
</div>
</section>

<!-- COMPARISON TABLE -->
<section class="comparison-section fade-in">
<div class="container">
<h2 class="section-heading">MTP vs Your Own Warehouse</h2>
<p class="section-subtitle">Monthly cost comparison based on 50 orders per day</p>
<div class="comparison-table">
<div class="comp-row comp-header"><div class="comp-cell">Cost Item</div><div class="comp-cell">Own Warehouse</div><div class="comp-cell">MTP Fulfillment</div></div>
<div class="comp-row"><div class="comp-cell">Warehouse rent (50 m&#178;)</div><div class="comp-cell">~15,000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row"><div class="comp-cell">Staff (2 people)</div><div class="comp-cell">~30,000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row"><div class="comp-cell">WMS software</div><div class="comp-cell">~5,000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row"><div class="comp-cell">Packing materials</div><div class="comp-cell">~3,000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row"><div class="comp-cell">Utilities</div><div class="comp-cell">~2,000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row comp-total"><div class="comp-cell">TOTAL</div><div class="comp-cell">~55,000 UAH</div><div class="comp-cell">~28,000 UAH</div></div>
</div>
<div class="comp-savings">You save 49%</div>
</div>
</section>

<!-- FAQ -->
<section class="faq-section fade-in">
<div class="container">
<h2 class="section-heading">Frequently Asked Questions</h2>
<p class="section-subtitle">Answers to the most common questions about MTP Group fulfillment</p>
<div class="faq-list">
<div class="faq-item"><button class="faq-question">Is there a minimum order volume to get started?</button><div class="faq-answer"><p>We accept any volume, starting from a single shipment per day. That said, the dynamic pricing model becomes most cost-effective from 20 or more shipments per day.</p></div></div>
<div class="faq-item"><button class="faq-question">How can I track my orders and inventory in real time?</button><div class="faq-answer"><p>Every client receives 24/7 access to a personal dashboard that displays real-time inventory levels, shipment statuses, and return tracking.</p></div></div>
<div class="faq-item"><button class="faq-question">Can I visit the warehouse before signing a contract?</button><div class="faq-answer"><p>Absolutely. We welcome warehouse tours Monday through Friday at our facilities near Kyiv.</p></div></div>
<div class="faq-item"><button class="faq-question">How does MTP handle returns?</button><div class="faq-answer"><p>Returned items are received at our warehouse, inspected, and either restocked into sellable inventory or flagged as damaged. You receive a detailed report with photos for every return.</p></div></div>
<div class="faq-item"><button class="faq-question">Does MTP support international shipping?</button><div class="faq-answer"><p>Yes, we ship internationally via UkrPoshta and partner carriers. Cross-border shipments require customs documentation, and our team assists with preparing all the necessary paperwork.</p></div></div>
</div>
</div>
</section>

<!-- SEO ARTICLE -->
<section class="article-section fade-in">
<div class="container">
<div class="article-body">
<h2>How to Choose a Fulfillment Partner in Ukraine: 7 Key Criteria</h2>
<p>If you run an online store in Ukraine, there comes a point where packing orders at your kitchen table or renting a tiny garage simply cannot keep up with demand. Here are seven criteria that will help you make the right call.</p>
<h3>1. Transparent, Predictable Pricing</h3>
<p>The first thing you should evaluate is how the fulfillment provider structures their pricing. A trustworthy provider publishes their entire price list up front and uses a dynamic or tiered model so your costs decrease as your volume grows.</p>
<h3>2. Warehouse Infrastructure and Reliability</h3>
<p>Ukraine faces unique operational challenges, including rolling blackouts and infrastructure strain. Ask your potential fulfillment partner what happens when the power goes out.</p>
<h3>3. Technology and Integrations</h3>
<p>Your fulfillment partner should slot into your existing tech stack without forcing you to change platforms.</p>
<h3>4. Speed and Shipping Partners</h3>
<p>In Ukrainian e-commerce, delivery speed is a major competitive advantage. The best fulfillment operators dispatch orders multiple times per day.</p>
<h3>5. Scalability Without Disruption</h3>
<p>Your fulfillment partner must be able to absorb volume spikes without delays, errors, or surcharges.</p>
<h3>6. Contract Terms and Accountability</h3>
<p>A professional fulfillment company will offer a formal contract with a clearly defined service-level agreement.</p>
<h3>7. Support and Communication</h3>
<p>The best fulfillment partners treat communication as a core part of the service, not an afterthought.</p>
</div>
</div>
</section>

</Base>

<style is:global>
.faq-item{border-bottom:1px solid rgba(255,255,255,.08)}
.faq-q{width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:inherit;text-align:left}
.faq-q::after{content:'+';font-size:24px;color:#e63329;transition:transform .3s}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.faq-a p{padding:0 0 20px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.7}

:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:24px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}
.reveal{opacity:0;transform:translateY(30px);transition:opacity .7s,transform .7s}.reveal.visible{opacity:1;transform:translateY(0)}
.hero{background:#111;color:#fff;padding:140px 20px 80px;text-align:center}
.hero h1{font-family:var(--font-heading,'DM Serif Display',serif);font-size:clamp(30px,5.5vw,52px);font-weight:400;letter-spacing:1px;margin-bottom:16px;line-height:1.2}
.hero-line{width:60px;height:4px;background:var(--red,#e63329);margin:0 auto 24px}
.hero p{font-size:clamp(16px,2.5vw,20px);color:rgba(255,255,255,.75);font-weight:400;max-width:640px;margin:0 auto 36px}
.hero-form{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;max-width:460px;margin:0 auto 48px}
.hero-form input{flex:1;min-width:200px;padding:14px 20px;border:2px solid rgba(255,255,255,.2);border-radius:8px;background:rgba(255,255,255,.08);color:#fff;font-size:16px;outline:none;transition:border-color .3s}
.hero-form input::placeholder{color:rgba(255,255,255,.4)}.hero-form input:focus{border-color:var(--red,#e63329)}
.hero-form button{padding:14px 32px;background:var(--red,#e63329);color:#fff;border:none;border-radius:8px;font-size:16px;font-weight:700;cursor:pointer;transition:background .3s,box-shadow .3s;box-shadow:0 4px 20px rgba(230,51,41,.35)}
.hero-form button:hover{background:#d41c1c;box-shadow:0 6px 28px rgba(230,51,41,.5)}
.hero-stats{display:flex;justify-content:center;gap:48px;flex-wrap:wrap;margin-top:16px}
.hero-stat{text-align:center}.hero-stat strong{display:block;font-size:32px;font-weight:700;color:var(--red,#e63329)}.hero-stat span{font-size:14px;color:rgba(255,255,255,.55)}
.container{max-width:1200px;margin:0 auto;padding:0 20px}
.services-section{padding:80px 20px;background:#f5f5f5}
.services-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px;max-width:1200px;margin:0 auto}
.service-card{background:#fff;border-radius:10px;padding:32px 28px;box-shadow:0 2px 12px rgba(0,0,0,.06);border-left:4px solid transparent;transition:border-color .3s,transform .3s,box-shadow .3s;display:flex;flex-direction:column;gap:12px}
.service-card:hover{border-left-color:var(--red,#e63329);transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.1)}
.service-icon{width:48px;height:48px;background:var(--red,#e63329);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.service-icon svg{width:24px;height:24px;fill:#fff}
.service-card h3{font-size:18px;font-weight:700;letter-spacing:.5px}.service-card p{font-size:14px;color:#555;line-height:1.6;flex:1}
.service-price{font-size:15px;font-weight:700;color:var(--red,#e63329)}
.fade-in.visible{opacity:1;transform:translateY(0)}
.section-heading{text-align:center;font-family:var(--font-heading,'DM Serif Display',serif);font-size:clamp(24px,4vw,36px);font-weight:400;letter-spacing:1px;margin-bottom:12px}
.section-subtitle{text-align:center;color:#555;font-size:16px;margin-bottom:48px;max-width:600px;margin-left:auto;margin-right:auto}
.pricing-section{padding:80px 20px;background:#fff}
.pricing-table{max-width:600px;margin:0 auto;border-radius:10px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.08)}
.pricing-row{display:flex;justify-content:space-between;padding:16px 28px;font-size:16px;border-bottom:1px solid #eee;transition:background .2s}.pricing-row:last-child{border-bottom:none}
.pricing-header{background:#111;color:#fff;font-weight:700;font-size:14px;letter-spacing:1px;text-transform:uppercase}
.pricing-row.highlight{background:var(--red,#e63329);color:#fff;font-weight:700}
.pricing-row:not(.pricing-header):not(.highlight):hover{background:#f9f9f9}
.pricing-note{text-align:center;margin-top:20px;font-size:15px;color:#555}.pricing-note strong{color:var(--red,#e63329)}
.integrations-section{padding:80px 20px;background:#f5f5f5}
.integrations-row{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:32px;max-width:1000px;margin:0 auto}
.integration-chip{display:flex;align-items:center;justify-content:center;background:#fff;border-radius:10px;padding:18px 28px;font-size:15px;font-weight:600;color:#333;box-shadow:0 2px 10px rgba(0,0,0,.06);transition:transform .2s,box-shadow .2s;min-width:140px;text-align:center}
.integration-chip:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,.1)}
.comparison-section{padding:80px 20px;background:#fff}
.comparison-table{max-width:800px;margin:0 auto;border-radius:10px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,.08)}
.comp-row{display:grid;grid-template-columns:1.4fr 1fr 1fr;border-bottom:1px solid #eee}.comp-row:last-child{border-bottom:none}
.comp-cell{padding:14px 20px;font-size:15px}
.comp-header{background:#111;color:#fff;font-weight:700;font-size:13px;letter-spacing:1px;text-transform:uppercase}.comp-header .comp-cell{padding:16px 20px}
.comp-row.comp-total{background:#f5f5f5;font-weight:700}.comp-row.comp-total .comp-cell:last-child{color:var(--red,#e63329);font-size:17px}
.comp-savings{text-align:center;margin-top:24px;font-size:22px;font-weight:700;color:var(--red,#e63329)}
.faq-section{padding:80px 20px;background:#f5f5f5}
.faq-list{max-width:800px;margin:0 auto}
.faq-item{background:#fff;border-radius:10px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,.06);overflow:hidden}
.faq-question{width:100%;padding:20px 28px;font-size:17px;font-weight:700;background:none;border:none;cursor:pointer;display:flex;justify-content:space-between;align-items:center;text-align:left;color:#000;transition:background .2s}
.faq-question:hover{background:#f9f9f9}
.faq-question::after{content:'+';font-size:24px;font-weight:300;color:var(--red,#e63329);transition:transform .3s}
.faq-item.open .faq-question::after{transform:rotate(45deg)}
.faq-answer{max-height:0;overflow:hidden;transition:max-height .3s ease-out}
.faq-answer p{padding:0 28px 20px;color:#555;font-size:15px;line-height:1.7}
.article-section{padding:80px 20px;background:#fff}
.article-body{max-width:800px;margin:0 auto;font-size:16px;line-height:1.8;color:#333}
.article-body h2{font-family:var(--font-heading,'DM Serif Display',serif);font-size:clamp(24px,4vw,34px);font-weight:400;margin-bottom:20px;text-align:center}
.article-body h3{font-size:20px;font-weight:700;margin:32px 0 12px;color:#000}.article-body p{margin-bottom:16px}
@media(max-width:600px){.comp-cell{padding:10px 12px;font-size:13px}.comp-row{grid-template-columns:1.2fr 1fr 1fr}.hero-form{flex-direction:column}}

.svc-card,.service-card,.num-card,.adv-card,.ben-card,.wh-card,.case-stats,.step{opacity:1!important;transform:none!important}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
document.querySelectorAll('.faq-question').forEach(function(btn){btn.addEventListener('click',function(){var item=btn.parentElement;var answer=item.querySelector('.faq-answer');var isOpen=item.classList.contains('open');document.querySelectorAll('.faq-item.open').forEach(function(el){el.classList.remove('open');el.querySelector('.faq-answer').style.maxHeight=null;});if(!isOpen){item.classList.add('open');answer.style.maxHeight=answer.scrollHeight+'px';}});});
var els=document.querySelectorAll('.fade-in');
if('IntersectionObserver' in window){var obs=new IntersectionObserver(function(entries){entries.forEach(function(entry){if(entry.isIntersecting){entry.target.classList.add('visible');obs.unobserve(entry.target);}});},{threshold:0.15});els.forEach(function(el){obs.observe(el);});}else{els.forEach(function(el){el.classList.add('visible');});}
});
</script>
