  canonical="https://www.fulfillmentmtp.com.ua/en/fulfilment-for-books-and-publishers/"
  lang="en"
  ogImage="https://www.fulfillmentmtp.com.ua/images/fulfilment-knyzhok-hero.jpg"
  schema={schemaJson}
  showCTA={true}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/fulfilment-knyzhok/">
