  { range: '50 – 99', label: 'Growth', price: '$0.52', detail: 'Per order, all-in. Storage $18 / m³ / month. Custom REST API integration included. Free returns processing for first 50 parcels per month.' },
  { range: '100 – 199', label: 'Scale', price: '$0.46', detail: 'Per order, all-in. Storage $16 / m³ / month. Dedicated account manager. Quarterly channel-mix review and inventory rebalancing recommendations.' },
  { range: '200+', label: 'Enterprise', price: '$0.42', detail: 'Per order, all-in. Storage $14 / m³ / month. Dedicated kitting cell. Priority dock for inbound air and sea freight. Custom SLA possible.' },
];

const reasonsHub = [
  { tag: 'COST', label: '50–65% cheaper labour base', detail: 'Ukrainian operating cost vs Poland. Translates to $0.42 per order vs $0.95 EU 3PL baseline.' },
  { tag: 'ACCESS', label: 'Ukrainian-only channels', detail: 'Rozetka, Prom, Kasta, Allo, Hubber require Ukrainian merchant of record — Polish or German 3PLs cannot serve these listings.' },
  { tag: 'DISPATCH', label: 'EU 3-5 day delivery', detail: 'From Kyiv: 1,200km to Berlin, 750km to Warsaw. Nova Poshta International, DHL, UPS at intra-EU lane parity.' },
  { tag: 'CUSTOMS', label: 'EU-Ukraine FTA', detail: 'Zero duty on most consumer goods under Association Agreement. IOSS supported for VAT collection at EU buyer checkout.' },
];
---
<Base
