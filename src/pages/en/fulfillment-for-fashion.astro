---
import Base from '../../layouts/Base.astro';

const title = 'Fashion & Apparel Fulfillment | Size Accuracy 99.99%, Wrinkle-Free, 100% Insurance | MTP';
const description = 'Specialized fulfillment for clothing, footwear, accessories. 99.99% size accuracy, wrinkle-prevention packaging, hygenic storage 45-60% humidity, 100% insurance, 24-hour delivery across Ukraine.';
const ogImage = 'https://profm.ua/images/fulfillment-fashion.jpg';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description: description,
  provider: {
    '@type': 'Organization',
    name: 'MTP Group',
    url: 'https://profm.ua/en/'
  },
  areaServed: {
    '@type': 'Country',
    name: 'UA'
  },
  priceRange: '₴20-₴100'
};
---

<Base title={title} description={description} ogImage={ogImage}>
  <section class="bg-gradient-to-r from-red-600 to-red-500 text-white py-16 sm:py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-6 leading-tight">
        Fashion &amp; Apparel Fulfillment<br />Size Accuracy, Wrinkle-Free, Premium Care
      </h1>
      <p class="text-xl mb-8 opacity-95 leading-relaxed">
        Dresses, shirts, pants, footwear, accessories. 99.99% size accuracy, wrinkle-prevention packaging, hygenic storage, 45-60% humidity control, 100% insurance, 24-hour delivery.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Start Fashion Fulfillment
      </a>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Why Fashion Requires Specialized Fulfillment</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">👗 Size Accuracy Critical</h3>
          <p class="text-gray-700">Wrong size = 90% return rate and negative reviews. XS ≠ S ≠ M. Every SKU must match customer size exactly. One size error costs the sale and damages reputation.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">💧 Hygiene &amp; Cleanliness</h3>
          <p class="text-gray-700">Apparel touches skin directly. Must meet highest cleanliness standards: zero dust, zero mold, zero odors. Staff must wear clean gloves and apparel. Daily warehouse disinfection required.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🧴 Wrinkle Prevention</h3>
          <p class="text-gray-700">Wrinkled clothing on arrival disappoints customers. Dresses crease easily in standard packaging. Requires specialized hangers or tissue wrapping to arrive perfectly pressed.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-3">🌡️ Humidity &amp; Temperature Control</h3>
          <p class="text-gray-700">Delicate fabrics (wool, silk) sensitive to moisture. Must maintain 45-60% humidity to prevent mildew, deformation, odors. Temperature control prevents fiber damage.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Our Fashion Fulfillment Services</h2>
      <div class="space-y-4">
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ 100% Size Accuracy Verification</h3>
          <p class="text-gray-700">Every item size-checked before packing. XS, S, M, L, XL, XXL verified against label and tags. Wrong size flagged immediately. 99.99% accuracy guarantee—zero size mismatches shipped.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Hygenic Storage &amp; Handling</h3>
          <p class="text-gray-700">Dedicated clean zone for apparel. Staff wears clean uniforms and gloves. Daily disinfection protocol. Zero dust, zero odors, zero contamination. Items ready to wear upon arrival.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Wrinkle-Free Packaging</h3>
          <p class="text-gray-700">Dresses hung on special hangers for storage, then folded with tissue paper to prevent creasing. Garments packed on hangers when possible. Delivered perfectly pressed and ready-to-wear.</p>
        </div>
        <div class="bg-white p-6 rounded border-l-4 border-red-600">
          <h3 class="text-lg font-bold mb-2">✓ Climate Control 45-60% Humidity</h3>
          <p class="text-gray-700">Delicate fabrics stored at optimal humidity. Prevents mildew, color fading, fiber deformation. Monitored hourly. Sensitive items (wool, silk) protected from environmental stress.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Pricing for Fashion &amp; Apparel</h2>
      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-lg font-bold mb-4">Picking, Quality Control &amp; Delivery</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex justify-between">
            <span>Picking per order</span>
            <span class="font-bold">20–30 UAH</span>
          </li>
          <li class="flex justify-between">
            <span>100% size verification</span>
            <span class="font-bold">Included</span>
          </li>
          <li class="flex justify-between">
            <span>Wrinkle-prevention packaging</span>
            <span class="font-bold">10–15 UAH</span>
          </li>
          <li class="flex justify-between">
            <span>Climate-controlled storage</span>
            <span class="font-bold">+25 UAH/pallet/mo</span>
          </li>
          <li class="flex justify-between">
            <span>Standard delivery</span>
            <span class="font-bold">50–100 UAH</span>
          </li>
          <li class="flex justify-between">
            <span>100% insurance coverage</span>
            <span class="font-bold">Included</span>
          </li>
        </ul>
      </div>

      <div class="bg-red-50 p-6 rounded border-l-4 border-red-600">
        <h3 class="font-bold mb-3">Example: Online Fashion Store (350 orders/month)</h3>
        <p class="text-gray-700">
          Picking: 350 × 25 = 8,750 UAH<br/>
          Wrinkle-prevention packaging: 350 × 12 = 4,200 UAH<br/>
          Delivery: 350 × 75 = 26,250 UAH<br/>
          Storage (2 pallets): 2 × 25 = 50 UAH/month<br/>
          <strong class="text-lg">TOTAL: 39,250 UAH/month = 112 UAH per order</strong><br/>
          <span class="text-sm text-gray-600">Includes: 99.99% size accuracy, wrinkle-free delivery, hygenic handling, 100% insurance</span>
        </p>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Quality Guarantees</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center bg-white p-6 rounded border border-green-200">
          <p class="text-4xl font-bold text-green-600 mb-2">99.99%</p>
          <p class="text-gray-700 font-bold">Size Accuracy</p>
          <p class="text-sm text-gray-600 mt-2">Critical metric: every size verified before shipping</p>
        </div>
        <div class="text-center bg-white p-6 rounded border border-green-200">
          <p class="text-4xl font-bold text-green-600 mb-2">0%</p>
          <p class="text-gray-700 font-bold">Wrinkles on Arrival</p>
          <p class="text-sm text-gray-600 mt-2">Garments arrive perfectly pressed &amp; ready-to-wear</p>
        </div>
        <div class="text-center bg-white p-6 rounded border border-green-200">
          <p class="text-4xl font-bold text-green-600 mb-2">100%</p>
          <p class="text-gray-700 font-bold">Hygiene Standard</p>
          <p class="text-sm text-gray-600 mt-2">Clean apparel with zero dust, odors, or mold</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-r from-red-600 to-red-500 text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl font-bold mb-6">Ready to Perfect Your Fashion Fulfillment?</h2>
      <p class="text-xl mb-8 opacity-90">
        Size accuracy, wrinkle-free delivery, hygenic handling, 100% insurance. Start today.
      </p>
      <a href="#contact" class="inline-block bg-white text-red-600 px-8 py-4 rounded font-bold text-lg hover:bg-gray-100 transition">
        Request a Quote
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
</Base>
