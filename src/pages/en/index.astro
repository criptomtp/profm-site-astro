.why-grid,.svc-grid{grid-template-columns:1fr}
.steps-row{flex-direction:column;border-top:none}.step{border-right:none;border-bottom:1px solid #e0e0e0;padding:32px 0}
.testi-arrow{display:none}.final-form{flex-direction:column}
}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
/* Intersection Observer for .reveal */
var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.15});
document.querySelectorAll('.reveal').forEach(function(el,i){el.style.transitionDelay=(i%3)*.1+'s';obs.observe(el);});

/* Testimonials slider */
var testimonials=[
{text:"We grew from 100 to 800 shipments per day within 3 months. MTP genuinely solved our logistics bottleneck.",name:"Oleksii R.",company:"Online store owner"},
{text:"We saved over 25,000 UAH per month compared to running our own warehouse. Highly recommend for anyone scaling fast.",name:"Pavlo M.",company:"E-commerce entrepreneur"},
{text:"Handing logistics to MTP freed up 40 hours a month for marketing. A decision I wish I had made sooner.",name:"Anton B.",company:"CEO, BeautyBox"}
];
var track=document.getElementById('testiTrack');
if(track){
track.innerHTML=testimonials.map(function(t){return '<div class="testi-slide"><div class="testi-stars">\u2605\u2605\u2605\u2605\u2605</div><div class="testi-quote">\u201C'+t.text+'\u201D</div><div class="testi-author">'+t.name+'</div><div class="testi-company">'+t.company+'</div></div>';}).join('');
var cs=0,total=testimonials.length,timer;
function slideTo(n){cs=((n%total)+total)%total;track.style.transform='translateX(-'+cs*100+'%)';document.querySelectorAll('.testi-dot').forEach(function(d,i){d.classList.toggle('active',i===cs);});}
var dots=document.getElementById('testiDots');for(var i=0;i<total;i++){var d=document.createElement('div');d.className='testi-dot'+(i===0?' active':'');d.onclick=(function(x){return function(){slideTo(x);resetT();};})(i);dots.appendChild(d);}
document.getElementById('tPrev').addEventListener('click',function(){slideTo(cs-1);resetT();});
document.getElementById('tNext').addEventListener('click',function(){slideTo(cs+1);resetT();});
function resetT(){clearInterval(timer);timer=setInterval(function(){slideTo(cs+1);},6000);}resetT();
}

});
</script>
