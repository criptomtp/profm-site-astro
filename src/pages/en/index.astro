<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
  /* Testimonials slider */
  var testimonials=[
    {text:"We grew from 100 to 800 shipments per day within 3 months. MTP genuinely solved our logistics bottleneck.",name:"Oleksii R.",company:"Online store owner"},
    {text:"We saved over 25,000 UAH per month compared to running our own warehouse. Highly recommend for anyone scaling fast.",name:"Pavlo M.",company:"E-commerce entrepreneur"},
    {text:"Handing logistics to MTP freed up 40 hours a month for marketing. A decision I wish I had made sooner.",name:"Anton B.",company:"CEO, BeautyBox"}
  ];
  var track=document.getElementById('testiTrack');
  if(track){
    track.innerHTML=testimonials.map(function(t){return '<div class="en-testi__slide"><div class="en-testi__stars">\u2605\u2605\u2605\u2605\u2605</div><div class="en-testi__quote">\u201C'+t.text+'\u201D</div><div class="en-testi__author">'+t.name+'</div><div class="en-testi__company">'+t.company+'</div></div>';}).join('');
    var cs=0,total=testimonials.length,timer;
    function slideTo(n){cs=((n%total)+total)%total;track.style.transform='translateX(-'+cs*100+'%)';document.querySelectorAll('.en-testi__dot').forEach(function(d,i){d.classList.toggle('active',i===cs);});}
    var dots=document.getElementById('testiDots');
    for(var i=0;i<total;i++){var d=document.createElement('div');d.className='en-testi__dot'+(i===0?' active':'');d.onclick=(function(x){return function(){slideTo(x);resetT();};})(i);dots.appendChild(d);}
    document.getElementById('tPrev').addEventListener('click',function(){slideTo(cs-1);resetT();});
    document.getElementById('tNext').addEventListener('click',function(){slideTo(cs+1);resetT();});
    function resetT(){clearInterval(timer);timer=setInterval(function(){slideTo(cs+1);},6000);}resetT();
  }

  /* FAQ accordion */
  document.querySelectorAll('.en-faq__q').forEach(function(btn){
    btn.addEventListener('click',function(){
      var item=this.closest('.en-faq__item');
      var wasOpen=item.classList.contains('open');
      document.querySelectorAll('.en-faq__item.open').forEach(function(i){i.classList.remove('open');});
      if(!wasOpen) item.classList.add('open');
    });
  });
});
</script>
