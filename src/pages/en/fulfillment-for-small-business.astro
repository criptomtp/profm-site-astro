<style is:global>
:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
*,*::before,*::after{box-sizing:border-box}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}

/* HERO SPLIT */
.hero-split{background:var(--black);color:var(--white);padding:120px 0 0;overflow:hidden}
.hero-split-inner{display:grid;grid-template-columns:1fr auto 1fr;gap:0;max-width:1200px;margin:0 auto;padding:0 24px;align-items:start}
.hero-left,.hero-right{padding:48px 32px}
.hero-col-label{font-size:11px;text-transform:uppercase;letter-spacing:3px;color:rgba(255,255,255,.35);margin-bottom:20px;font-weight:500}
.hero-col-label--red{color:var(--red)}
.hero-col-h{font-family:var(--fd);font-size:clamp(24px,3vw,38px);font-weight:400;line-height:1.15;margin-bottom:24px}
.hero-left .hero-col-h{color:rgba(255,255,255,.45)}
.hero-right .hero-col-h{color:#fff}
.hero-pain-list,.hero-win-list{list-style:none;padding:0;margin:0}
.hero-pain-list li,.hero-win-list li{padding:8px 0 8px 24px;position:relative;font-size:15px;line-height:1.6}
.hero-pain-list li{color:rgba(255,255,255,.35)}
.hero-pain-list li::before{content:'\2715';position:absolute;left:0;color:rgba(255,255,255,.2);font-size:13px}
.hero-win-list li{color:rgba(255,255,255,.8)}
.hero-win-list li::before{content:'\2713';position:absolute;left:0;color:var(--red);font-weight:700;font-size:14px}
.hero-divider{display:flex;align-items:center;justify-content:center;padding:48px 0}
.hero-vs{display:flex;align-items:center;justify-content:center;width:56px;height:56px;border:2px solid rgba(255,255,255,.15);border-radius:50%;font-size:14px;font-weight:700;letter-spacing:1px;color:rgba(255,255,255,.4)}

.hero-split-bottom{text-align:center;padding:60px 24px 48px;border-top:1px solid rgba(255,255,255,.08)}
.hero-main-h1{font-family:var(--fd);font-size:clamp(32px,5vw,64px);font-weight:400;line-height:1;margin-bottom:20px}
.hero-main-sub{font-size:clamp(15px,1.6vw,18px);color:rgba(255,255,255,.55);line-height:1.7;max-width:600px;margin:0 auto 36px}
.hero-form{display:flex;gap:12px;max-width:460px;margin:0 auto}
.hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;font-family:var(--fb);outline:none}
.hero-form input::placeholder{color:rgba(255,255,255,.25)}
.hero-form input:focus{border-color:rgba(255,255,255,.5)}
.hero-form button{padding:16px 24px;background:transparent;color:#fff;border:2px solid #fff;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:all .3s}
.hero-form button:hover{background:var(--red);border-color:var(--red)}
.hero-note{font-size:13px;color:rgba(255,255,255,.3);margin-top:12px}

.stats-bar{display:flex;justify-content:center;gap:0;border-top:1px solid rgba(255,255,255,.08);margin-top:48px}
.stat-item{flex:1;text-align:center;padding:28px 16px;border-right:1px solid rgba(255,255,255,.06)}
.stat-item:last-child{border-right:none}
.stat-val{display:block;font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;color:#fff}
.stat-lbl{display:block;font-size:11px;color:rgba(255,255,255,.35);text-transform:uppercase;letter-spacing:2px;margin-top:4px}

/* WHY UKRAINE */
.why-ukraine{padding:100px 0;background:var(--white)}
.section-intro{font-size:17px;color:var(--muted);line-height:1.7;max-width:700px;margin-bottom:48px}
.why-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:#e0e0e0;border:1px solid #e0e0e0;border-radius:4px;overflow:hidden}
.why-card{background:#fff;padding:40px 32px;transition:background .3s}
.why-card:hover{background:var(--gray)}
.why-icon{font-family:var(--fd);font-size:36px;color:var(--red);line-height:1;margin-bottom:16px}
.why-card h3{font-size:18px;font-weight:600;margin-bottom:8px;font-family:var(--fb)}
.why-card p{font-size:14px;color:var(--muted);line-height:1.7}

/* ROI TABLE */
.roi-section{padding:100px 0;background:#0a0a0a;color:#fff}
.section-intro-light{font-size:17px;color:rgba(255,255,255,.55);line-height:1.7;max-width:700px;margin-bottom:48px}
.roi-table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}
.roi-table{width:100%;max-width:800px;border-collapse:collapse;font-size:15px}
.roi-table th{background:var(--red);color:#fff;padding:16px 20px;text-align:left;font-weight:600;font-size:14px;text-transform:uppercase;letter-spacing:.5px}
.roi-table td{padding:14px 20px;border-bottom:1px solid rgba(255,255,255,.08)}
.roi-table tr:hover td{background:rgba(255,255,255,.03)}
.roi-table td:first-child{font-weight:500;color:rgba(255,255,255,.9)}
.roi-table td:nth-child(2){color:rgba(255,255,255,.45)}
.roi-table td:nth-child(3){color:#fff;font-weight:500}
.roi-total td{font-weight:700!important;color:#fff!important;border-top:2px solid var(--red);font-size:16px}
.roi-savings td{background:rgba(230,51,41,.12)!important;color:var(--white)!important;font-weight:600;text-align:center;padding:20px}
.roi-note{font-size:13px;color:rgba(255,255,255,.3);margin-top:24px;max-width:800px}

/* WAR-RESILIENT */
.resilient{padding:100px 0;background:var(--white)}
.resilient-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;margin-bottom:60px}
.res-card{text-align:center;padding:32px 20px}
.res-icon-wrap{margin-bottom:20px}
.res-icon{display:inline-flex;align-items:center;justify-content:center;width:72px;height:72px;border:2px solid var(--red);border-radius:50%;font-family:var(--fd);font-size:24px;color:var(--red);font-weight:400}
.res-card h3{font-size:16px;font-weight:600;margin-bottom:8px}
.res-card p{font-size:14px;color:var(--muted);line-height:1.7}
.res-proof{display:flex;gap:40px;align-items:center;background:var(--gray);border-radius:8px;overflow:hidden}
.res-proof img{width:50%;height:auto;object-fit:cover;display:block}
.res-proof-text{padding:40px;flex:1}
.res-proof-text blockquote{font-family:var(--fd);font-size:20px;line-height:1.5;color:#000;border-left:3px solid var(--red);padding-left:20px;margin:0 0 16px}
.res-proof-author{font-size:14px;color:var(--muted)}

/* VIDEO */
.video-section{padding:80px 0;background:#0a0a0a}
.video-layout{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:center}
.video-h2{font-family:var(--fd);font-size:clamp(24px,3vw,36px);font-weight:400;color:#fff;margin-bottom:16px}
.video-desc{color:rgba(255,255,255,.6);line-height:1.7}
.yt-facade{position:relative;aspect-ratio:16/9;border-radius:8px;overflow:hidden;cursor:pointer;background:#000}
.yt-facade img{width:100%;height:100%;object-fit:cover;opacity:.75;transition:opacity .3s}
.yt-facade:hover img{opacity:.5}
.yt-play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer}

/* ONBOARDING */
.onboarding{padding:100px 0;background:var(--white)}
.onb-timeline{max-width:800px;position:relative;padding-left:80px}
.onb-timeline::before{content:'';position:absolute;left:35px;top:0;bottom:0;width:2px;background:#e0e0e0}
.onb-step{position:relative;margin-bottom:48px}
.onb-step:last-child{margin-bottom:0}
.onb-day{position:absolute;left:-80px;top:0;width:70px;height:70px;background:var(--red);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:1px;z-index:1}
.onb-content{padding:8px 0 0 20px}
.onb-content h3{font-size:20px;font-weight:600;margin-bottom:12px}
.onb-content ul{list-style:none;padding:0;margin:0}
.onb-content li{padding:6px 0 6px 20px;position:relative;font-size:15px;color:var(--muted);line-height:1.6}
.onb-content li::before{content:'';position:absolute;left:0;top:14px;width:6px;height:6px;background:var(--red);border-radius:50%}

/* PRICING TIERS */
.pricing-tiers{padding:100px 0;background:#0a0a0a;color:#fff}
.tiers-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-bottom:32px}
.tier-card{background:rgba(255,255,255,.04);padding:40px 32px;border-radius:0;position:relative;transition:background .3s}
.tier-card:first-child{border-radius:8px 0 0 8px}
.tier-card:last-child{border-radius:0 8px 8px 0}
.tier-card:hover{background:rgba(255,255,255,.07)}
.tier-card--popular{background:rgba(230,51,41,.1);border:2px solid var(--red)}
.tier-card--popular:hover{background:rgba(230,51,41,.15)}
.tier-pop-badge{position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--red);color:#fff;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;padding:6px 16px;border-radius:0 0 4px 4px}
.tier-name{font-family:var(--fd);font-size:28px;color:#fff;margin-bottom:4px}
.tier-vol{font-size:14px;color:rgba(255,255,255,.4);margin-bottom:20px}
.tier-price{font-size:16px;color:rgba(255,255,255,.7);margin-bottom:24px;padding-bottom:24px;border-bottom:1px solid rgba(255,255,255,.1)}
.tier-price strong{font-size:36px;color:#fff;font-family:var(--fd);font-weight:400}
.tier-features{list-style:none;padding:0;margin:0}
.tier-features li{padding:8px 0 8px 20px;position:relative;font-size:14px;color:rgba(255,255,255,.6);line-height:1.5}
.tier-features li::before{content:'\2713';position:absolute;left:0;color:var(--red);font-weight:700}
.pricing-note{text-align:center;font-size:14px;color:rgba(255,255,255,.35);max-width:600px;margin:0 auto}

/* FAQ */
.faq{padding:100px 0;background:var(--white)}
.faq-list{max-width:700px;margin:0 auto}
.faq-item{border-bottom:1px solid #e0e0e0}
.faq-q{width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;color:#000;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:var(--fb);text-align:left}
.faq-q::after{content:'+';font-size:24px;color:var(--red);transition:transform .3s;flex-shrink:0;margin-left:16px}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.faq-a p{padding:0 0 20px;font-size:14px;color:var(--muted);line-height:1.7}

/* SEO ARTICLE */
.article-section{background:var(--gray);padding:80px 8vw}
.article-section h2{font-family:var(--fd);font-size:clamp(28px,3.5vw,44px);font-weight:400;margin:20px 0 40px;color:#000}
.article-content{max-width:800px}
.article-content h3{font-family:var(--fd);font-size:clamp(18px,2vw,26px);font-weight:400;margin:36px 0 12px;color:#000}
.article-content h3:first-child{margin-top:0}
.article-content p{font-size:16px;line-height:1.85;color:#444;margin-bottom:8px}

/* CTA */
.final-cta{padding:100px 0;background:var(--red);color:#fff;text-align:center}
.final-cta h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;margin-bottom:16px}
.final-cta .sub{font-size:17px;opacity:.85;max-width:480px;margin:0 auto 36px}
.final-form{display:flex;gap:12px;justify-content:center;max-width:460px;margin:0 auto}
.final-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.35);border-radius:4px;background:rgba(255,255,255,.1);color:#fff;font-size:15px;font-family:var(--fb);outline:none}
.final-form input::placeholder{color:rgba(255,255,255,.45)}
.final-form input:focus{border-color:#fff}
.final-form button{padding:16px 24px;background:#000;color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:background .3s}
.final-form button:hover{background:#222}
.final-checks{display:flex;gap:24px;justify-content:center;flex-wrap:wrap;margin-top:16px;font-size:13px;opacity:.7}

/* BADGES */
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:24px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}
.sec-h2{font-family:var(--fd);font-size:clamp(32px,4.5vw,56px);font-weight:400;margin-bottom:48px}

/* MOBILE */
@media(max-width:968px){
  .hero-split-inner{grid-template-columns:1fr;gap:0}
  .hero-divider{padding:16px 0}
  .hero-vs{width:40px;height:40px;font-size:12px}
  .hero-left,.hero-right{padding:32px 24px}
  .resilient-grid{grid-template-columns:repeat(2,1fr);gap:16px}
  .tiers-grid{grid-template-columns:1fr}
  .tier-card,.tier-card:first-child,.tier-card:last-child{border-radius:8px}
  .tier-card--popular{margin:0}
  .why-grid{grid-template-columns:1fr}
  .video-layout{grid-template-columns:1fr;gap:24px}
}
@media(max-width:768px){
  .hero-form{flex-direction:column}
  .hero-form button{width:100%}
  .stats-bar{flex-wrap:wrap}
  .stat-item{flex:1 1 45%;border-bottom:1px solid rgba(255,255,255,.06)}
  .resilient-grid{grid-template-columns:1fr}
  .res-proof{flex-direction:column}
  .res-proof img{width:100%}
  .onb-timeline{padding-left:60px}
  .onb-day{left:-60px;width:50px;height:50px;font-size:11px}
  .final-form{flex-direction:column}
  .roi-table{font-size:13px}
  .roi-table th,.roi-table td{padding:10px 12px}
}

/* Force visibility (no JS animation dependencies) */
.svc-card,.service-card,.num-card,.adv-card,.ben-card,.wh-card,.case-stats,.step,.why-card,.res-card,.tier-card,.onb-step{opacity:1!important;transform:none!important}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
  /* FAQ accordion */
  document.querySelectorAll('.faq-q').forEach(function(btn){
    btn.addEventListener('click',function(){
      var item=btn.parentElement;
      var a=item.querySelector('.faq-a');
      var open=item.classList.contains('open');
      document.querySelectorAll('.faq-item.open').forEach(function(el){
        el.classList.remove('open');
        el.querySelector('.faq-a').style.maxHeight=null;
      });
      if(!open){
        item.classList.add('open');
        a.style.maxHeight=a.scrollHeight+'px';
      }
    });
  });

  /* YouTube facade */
  document.querySelectorAll('.yt-facade').forEach(function(el){
    el.addEventListener('click',function(){
      var id=el.getAttribute('data-id');
      var iframe=document.createElement('iframe');
      iframe.src='https://www.youtube.com/embed/'+id+'?autoplay=1&rel=0';
      iframe.allow='autoplay;encrypted-media';
      iframe.allowFullscreen=true;
      iframe.style.cssText='position:absolute;inset:0;width:100%;height:100%;border:none';
      el.innerHTML='';
      el.style.position='relative';
      el.appendChild(iframe);
    });
  });

  /* Form handling */
  document.querySelectorAll('#heroForm, #finalForm').forEach(function(form){
    form.addEventListener('submit',function(e){
      e.preventDefault();
      var inp=form.querySelector('input[name="phone"]');
      var ph=inp.value.trim();
      if(ph.length<8)return;

      var leads=JSON.parse(localStorage.getItem('mtp_crm_leads')||'[]');
      leads.push({
        id:Date.now(),
        company:'Fulfillment for Small Business',
        contact:'',
        phone:ph,
        email:'',
        shipments:0,
        type:'small-business',
        source:'SEO landing en/fulfillment-for-small-business',
        status:'new',
        date:new Date().toISOString().split('T')[0],
        comments:[{text:'Form: fulfillment for small business (EN)',date:new Date().toLocaleString('en-GB')}],
        onboarding:[false,false,false,false,false,false,false]
      });
      localStorage.setItem('mtp_crm_leads',JSON.stringify(leads));

      fetch('/api/telegram',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({phone:ph,page:location.pathname})
      }).catch(function(){});

      if(window.mtpSubmitLead)window.mtpSubmitLead(ph);

      form.innerHTML='<div style="text-align:center"><p style="color:#fff;font-size:18px;font-weight:500">Thank you!</p><p style="color:rgba(255,255,255,.5);font-size:14px;margin-top:8px">We will contact you within 15 minutes</p></div>';
    });
  });
});
</script>
