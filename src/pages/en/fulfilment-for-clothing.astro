</style>

<script is:inline>
(function(){
  document.querySelectorAll('.faq-item').forEach(function(item){
    var btn = item.querySelector('.faq-q');
    if(!btn) return;
    btn.setAttribute('aria-expanded','false');
    btn.addEventListener('click', function(){
      var isOpen = item.classList.toggle('open');
      btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });
  });

  // Animated counter for shipments
  var counter = document.querySelector('[data-counter]');
  if(counter){
    var target = parseInt(counter.dataset.counter, 10);
    var current = Math.floor(target * 0.95);
    counter.textContent = current.toLocaleString('en-US');
    var tick = function(){
      if(current < target){
        current += Math.max(1, Math.floor((target - current) / 20));
        counter.textContent = current.toLocaleString('en-US');
        setTimeout(tick, 80);
      }
    };
    var observer = new IntersectionObserver(function(entries){
      if(entries[0].isIntersecting){ tick(); observer.disconnect(); }
    });
    observer.observe(counter);
  }

  // Live pickup countdown
  var pickupNum = document.querySelector('.lo-feed-mono');
  if(pickupNum){
    var pickupTimes = [10, 13, 16, 18]; // hours
    var update = function(){
      var now = new Date();
      var nextH = pickupTimes.find(function(h){ return h > now.getHours() || (h === now.getHours() && now.getMinutes() < 0); });
      if(!nextH) nextH = pickupTimes[0] + 24;
      var nextDate = new Date(now);
      nextDate.setHours(nextH < 24 ? nextH : nextH - 24, 0, 0, 0);
      if(nextH >= 24) nextDate.setDate(nextDate.getDate() + 1);
      var diff = nextDate - now;
      var h = String(Math.floor(diff/3600000)).padStart(2,'0');
      var m = String(Math.floor((diff%3600000)/60000)).padStart(2,'0');
      var s = String(Math.floor((diff%60000)/1000)).padStart(2,'0');
      pickupNum.textContent = h + ':' + m + ':' + s;
    };
    update();
    setInterval(update, 1000);
  }
})();
</script>
