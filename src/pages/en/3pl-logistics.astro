<style>
/* ===== HERO ===== */
.tpl-hero{
  background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);
  color:var(--white);padding:140px 0 60px;position:relative;overflow:hidden;
}
.tpl-hero-inner{display:flex;flex-direction:column;gap:48px}
.tpl-hero-text{max-width:740px}
.tpl-hero h1{font-family:var(--fd);font-size:clamp(32px,5vw,64px);font-weight:400;line-height:1.05;margin-bottom:24px}
.tpl-hero-sub{font-size:clamp(16px,1.6vw,19px);color:rgba(255,255,255,.7);line-height:1.75;margin-bottom:36px;max-width:620px}

/* Flow diagram */
.flow-diagram{
  display:flex;align-items:center;gap:0;margin-bottom:24px;overflow-x:auto;
  padding-bottom:8px;-webkit-overflow-scrolling:touch;
}
.flow-box{
  padding:14px 20px;border:2px solid rgba(255,255,255,.25);border-radius:8px;
  font-size:14px;font-weight:500;white-space:nowrap;flex-shrink:0;
  background:rgba(255,255,255,.04);
}
.flow-box--accent{border-color:var(--red);background:rgba(230,51,41,.12);color:#fff}
.flow-line{
  width:48px;flex-shrink:0;position:relative;display:flex;align-items:center;justify-content:center;
}
.flow-line::before{
  content:'';position:absolute;top:50%;left:4px;right:4px;height:2px;
  border-top:2px dashed rgba(255,255,255,.3);
  animation:dashMove 1.2s linear infinite;
}
.flow-arrow{
  position:relative;z-index:1;color:rgba(255,255,255,.5);font-size:18px;
  background:transparent;display:none;
}
@keyframes dashMove{
  0%{background-position:0 0}
  100%{background-position:48px 0}
}
/* Better dash animation using background */
.flow-line::before{
  border-top:none;
  height:2px;
  background:repeating-linear-gradient(90deg,rgba(255,255,255,.4) 0,rgba(255,255,255,.4) 8px,transparent 8px,transparent 16px);
  background-size:16px 2px;
  animation:dashSlide 0.6s linear infinite;
}
@keyframes dashSlide{
  0%{background-position:0 0}
  100%{background-position:16px 0}
}

/* CRM badges */
.crm-badges{
  display:flex;flex-wrap:wrap;gap:8px;margin-bottom:32px;
}
.crm-badges span{
  font-size:12px;color:rgba(255,255,255,.5);padding:6px 14px;
  border:1px solid rgba(255,255,255,.12);border-radius:100px;white-space:nowrap;
}

/* Hero form */
.tpl-hero-form{display:flex;flex-wrap:wrap;gap:10px;max-width:600px}
.tpl-hero-form input,
.tpl-hero-form select{
  flex:1 1 160px;padding:14px 16px;border:1px solid rgba(255,255,255,.2);border-radius:6px;
  background:rgba(255,255,255,.06);color:#fff;font-size:15px;font-family:var(--fb);outline:none;
}
.tpl-hero-form select{cursor:pointer;appearance:auto}
.tpl-hero-form select option{color:#000;background:#fff}
.tpl-hero-form input::placeholder{color:rgba(255,255,255,.3)}
.tpl-hero-form input:focus,
.tpl-hero-form select:focus{border-color:rgba(255,255,255,.5)}
.tpl-hero-form button{
  flex:1 1 100%;padding:16px 24px;background:var(--red);color:#fff;border:none;
  border-radius:6px;font-size:16px;font-weight:600;cursor:pointer;font-family:var(--fb);
  transition:background .3s;
}
.tpl-hero-form button:hover{background:#c42b22}

/* Hero stats */
.tpl-hero-stats{display:flex;gap:40px}
.tpl-stat{border-left:3px solid var(--red);padding-left:16px}
.tpl-stat strong{display:block;font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400}
.tpl-stat span{font-size:12px;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:1.5px}

/* ===== CASES ===== */
.cases-sec{padding:100px 0;background:var(--white)}
.cases-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.case-card{
  background:var(--gray);border-radius:12px;padding:32px 28px;
  display:flex;flex-direction:column;gap:16px;
}
.case-name{font-family:var(--fd);font-size:22px;font-weight:400}
.case-split{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.case-before,.case-after{padding:16px;border-radius:8px}
.case-before{background:rgba(230,51,41,.06);border:1px solid rgba(230,51,41,.12)}
.case-after{background:rgba(0,0,0,.03);border:1px solid rgba(0,0,0,.08)}
.case-label{
  display:inline-block;font-size:10px;font-weight:700;letter-spacing:2px;
  text-transform:uppercase;margin-bottom:8px;padding:3px 8px;border-radius:4px;
}
.case-label--before{background:rgba(230,51,41,.1);color:#e63329}
.case-label--after{background:rgba(0,0,0,.06);color:#000}
.case-split ul{list-style:none;padding:0;margin:0}
.case-split li{font-size:14px;line-height:1.8;color:var(--muted)}
.case-quote{
  font-style:italic;font-size:14px;color:var(--muted);line-height:1.6;
  border-left:3px solid var(--red);padding-left:12px;margin-top:auto;
}

/* ===== CALCULATOR ===== */
.calc-sec{padding:100px 0;background:var(--gray)}
.calc-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
.calc-sliders{display:flex;flex-direction:column;gap:24px}
.calc-field label{
  display:flex;justify-content:space-between;font-size:15px;margin-bottom:8px;color:var(--black);
}
.calc-field label strong{color:var(--red)}
.calc-field input[type="range"]{
  width:100%;height:6px;border-radius:3px;appearance:none;background:#ddd;outline:none;cursor:pointer;
}
.calc-field input[type="range"]::-webkit-slider-thumb{
  appearance:none;width:22px;height:22px;border-radius:50%;background:var(--red);cursor:pointer;
  border:3px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.15);
}
.calc-field input[type="range"]::-moz-range-thumb{
  width:22px;height:22px;border-radius:50%;background:var(--red);cursor:pointer;
  border:3px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.15);
}
.calc-result{
  background:#fff;border-radius:12px;padding:32px;box-shadow:0 4px 24px rgba(0,0,0,.06);
}
.calc-row{
  display:flex;justify-content:space-between;align-items:center;padding:12px 0;
  font-size:15px;border-bottom:1px solid #eee;
}
.calc-row:last-child{border-bottom:none}
.calc-row--accent strong{color:var(--red)}
.calc-row--big{font-size:18px}
.calc-row--big strong{color:#e63329;font-size:20px}
.calc-row--warn strong{color:var(--red)}
.calc-divider{height:2px;background:var(--red);margin:8px 0;border-radius:1px}

/* ===== INTEGRATIONS ===== */
.integ-sec{padding:100px 0;background:var(--white)}
.integ-grid{
  display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-bottom:48px;
}
.integ-badge{
  display:block;text-align:center;padding:20px 12px;background:var(--gray);border-radius:10px;
  font-size:15px;font-weight:600;border:1px solid #e0e0e0;
  color:var(--black);text-decoration:none;transition:border-color .2s,box-shadow .2s;
}
.integ-badge--ok span{color:#e63329;margin-left:4px}
a.integ-badge:hover{border-color:var(--red);box-shadow:0 2px 8px rgba(230,51,41,.12)}
.integ-flow{display:flex;justify-content:center;align-items:center;gap:12px;margin-bottom:20px}
.integ-step{
  display:flex;align-items:center;gap:8px;padding:12px 20px;
  background:var(--gray);border-radius:8px;font-size:14px;
}
.integ-num{
  display:inline-flex;align-items:center;justify-content:center;
  width:28px;height:28px;border-radius:50%;background:var(--red);color:#fff;
  font-size:13px;font-weight:700;flex-shrink:0;
}
.integ-note{text-align:center;font-size:15px;color:var(--muted)}

/* ===== WHAT'S INCLUDED ===== */
.included-sec{padding:100px 0;background:var(--gray)}
.inc-item{
  display:grid;grid-template-columns:1fr auto;gap:40px;align-items:center;
  padding:40px 0;border-bottom:1px solid #ddd;
}
.inc-item:last-child{border-bottom:none}
.inc-item--reverse{grid-template-columns:auto 1fr}
.inc-text h3{font-family:var(--fd);font-size:clamp(22px,2.5vw,32px);font-weight:400;margin-bottom:8px}
.inc-text p{font-size:16px;color:var(--muted);line-height:1.7;max-width:560px}
.inc-num{
  font-family:var(--fd);font-size:clamp(48px,6vw,96px);font-weight:400;
  color:rgba(0,0,0,.06);line-height:1;
}

/* ===== CARRIERS ===== */
.carriers-sec{padding:80px 0;background:var(--white)}
.carriers-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px}
.carrier-card{
  text-align:center;padding:28px 16px;border:1px solid #e0e0e0;border-radius:10px;
  display:flex;flex-direction:column;gap:4px;
}
.carrier-card strong{font-size:17px}
.carrier-card span{font-size:13px;color:var(--muted)}
.carriers-note{text-align:center;font-size:15px;color:var(--red);font-weight:500}

/* ===== CTA ===== */
.tpl-cta-sec{
  padding:80px 0;color:var(--white);text-align:center;
  background:linear-gradient(135deg,#e63329 0%,#1a1a2e 100%);
}
.tpl-cta-timeline{display:flex;justify-content:center;align-items:center;gap:12px;margin-bottom:32px;flex-wrap:wrap}
.tpl-cta-step{
  font-size:14px;font-weight:500;display:flex;align-items:center;gap:6px;
}
.tpl-cta-step span{
  display:inline-flex;align-items:center;justify-content:center;
  width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,.2);font-weight:700;
}
.tpl-cta-arrow{font-size:18px;color:rgba(255,255,255,.5)}
.tpl-cta-sec h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;margin-bottom:12px}
.tpl-cta-sub{font-size:17px;color:rgba(255,255,255,.75);margin-bottom:32px}
.tpl-cta-form{max-width:640px;margin:0 auto}
.tpl-cta-form-row{display:flex;gap:10px;margin-bottom:10px}
.tpl-cta-form input,
.tpl-cta-form select{
  flex:1;padding:14px 16px;border:1px solid rgba(255,255,255,.25);border-radius:6px;
  background:rgba(255,255,255,.08);color:#fff;font-size:15px;font-family:var(--fb);outline:none;
}
.tpl-cta-form select{cursor:pointer;appearance:auto}
.tpl-cta-form select option{color:#000;background:#fff}
.tpl-cta-form input::placeholder{color:rgba(255,255,255,.35)}
.tpl-cta-form input:focus,
.tpl-cta-form select:focus{border-color:rgba(255,255,255,.6)}
.tpl-cta-form button{
  flex:1;padding:16px 24px;background:#fff;color:var(--red);border:none;border-radius:6px;
  font-size:16px;font-weight:700;cursor:pointer;font-family:var(--fb);transition:all .3s;
}
.tpl-cta-form button:hover{background:rgba(255,255,255,.9)}

/* ===== FAQ ===== */
.faq-sec{padding:100px 0;background:var(--white)}
.faq-list{max-width:700px;margin:0 auto}
.faq-item{border-bottom:1px solid #e0e0e0}
.faq-q{
  width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;
  color:var(--black);cursor:pointer;display:flex;justify-content:space-between;align-items:center;
  font-family:var(--fb);text-align:left;
}
.faq-q::after{content:'+';font-size:24px;color:var(--red);transition:transform .3s;flex-shrink:0;margin-left:12px}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.faq-a p{padding:0 0 20px;font-size:15px;color:var(--muted);line-height:1.7}

/* ===== ARTICLE ===== */
.article-section{background:#fff;padding:80px 8vw}
.article-section h2{font-family:var(--fd);font-size:clamp(32px,4vw,52px);font-weight:400;margin:20px 0 40px}
.article-content{max-width:800px}
.article-content h3{font-family:var(--fd);font-size:clamp(18px,2vw,26px);font-weight:400;margin:36px 0 12px;color:#000}
.article-content h3:first-child{margin-top:0}
.article-content p{font-size:16px;line-height:1.85;color:#444;margin-bottom:8px}

/* ===== RESPONSIVE ===== */
@media(max-width:1024px){
  .integ-grid{grid-template-columns:repeat(3,1fr)}
}
@media(max-width:768px){
  .tpl-hero{padding:120px 0 48px}
  .tpl-hero-form{flex-direction:column}
  .tpl-hero-form input,
  .tpl-hero-form select,
  .tpl-hero-form button{flex:1 1 auto}
  .tpl-hero-stats{flex-direction:column;gap:20px}

  /* Flow diagram vertical */
  .flow-diagram{flex-direction:column;align-items:flex-start;gap:0}
  .flow-line{width:auto;height:32px;flex-direction:column}
  .flow-line::before{
    top:4px;bottom:4px;left:50%;width:2px;height:calc(100% - 8px);
    right:auto;
    background:repeating-linear-gradient(180deg,rgba(255,255,255,.4) 0,rgba(255,255,255,.4) 8px,transparent 8px,transparent 16px);
    background-size:2px 16px;
    animation:dashSlideV 0.6s linear infinite;
  }
  @keyframes dashSlideV{
    0%{background-position:0 0}
    100%{background-position:0 16px}
  }
  .flow-box{align-self:stretch;text-align:center}

  .crm-badges{overflow-x:auto;flex-wrap:nowrap;-webkit-overflow-scrolling:touch;padding-bottom:4px}

  .cases-grid{grid-template-columns:1fr}
  .case-split{grid-template-columns:1fr}
  .calc-grid{grid-template-columns:1fr}
  .integ-grid{grid-template-columns:repeat(2,1fr)}
  .integ-flow{flex-wrap:wrap}

  .inc-item,.inc-item--reverse{grid-template-columns:1fr;gap:8px}
  .inc-num{font-size:48px}
  .inc-item--reverse{direction:ltr}
  .inc-item--reverse .inc-num{order:0}
  .inc-item--reverse .inc-text{order:1}

  .carriers-grid{grid-template-columns:repeat(2,1fr)}

  .tpl-cta-form-row{flex-direction:column}
  .tpl-cta-form button{width:100%}
}

/* ===== REDUCED MOTION ===== */
@media(prefers-reduced-motion:reduce){
  .flow-line::before{animation:none!important}
  *{animation-duration:0.01ms!important;animation-iteration-count:1!important;transition-duration:0.01ms!important}
}
</style>

<script is:inline>
(function(){
  // Hero form handler
  var heroForm = document.getElementById('heroForm');
  if(heroForm && !heroForm.dataset.handled){
    heroForm.dataset.handled = '1';
    heroForm.addEventListener('submit', function(e){
      e.preventDefault();
      var ph = heroForm.querySelector('input[name="phone"]');
      var clean = ph.value.replace(/\D/g, '');
      if(clean.length < 10){ ph.style.borderColor = '#e63329'; return; }
      var nm = heroForm.querySelector('input[name="name"]');
      if(window.mtpSubmitLead) window.mtpSubmitLead(ph.value.trim(), location.pathname, nm ? nm.value.trim() : '');
      heroForm.innerHTML = '<p style="color:#fff;font-size:18px;font-weight:500">&#10004; Thank you! We will call you back.</p>';
      setTimeout(function(){ window.location.href = '/en/thanks/'; }, 1500);
    });
  }

  // CTA form handler
  var ctaForm = document.getElementById('ctaForm');
  if(ctaForm){
    ctaForm.addEventListener('submit', function(e){
      e.preventDefault();
      var ph = ctaForm.querySelector('input[name="phone"]');
      var clean = ph.value.replace(/\D/g, '');
      if(clean.length < 10){ ph.style.borderColor = '#fff'; return; }
      var nm = ctaForm.querySelector('input[name="name"]');
      if(window.mtpSubmitLead) window.mtpSubmitLead(ph.value.trim(), location.pathname, nm ? nm.value.trim() : '');
      ctaForm.innerHTML = '<p style="color:#fff;font-size:18px;font-weight:500">&#10004; Thank you! We will call you back shortly.</p>';
      setTimeout(function(){ window.location.href = '/en/thanks/'; }, 1500);
    });
  }

  // 3PL ROI calculator (vanilla JS)
  (function(){
    var el=document.getElementById('calc3pl');
    if(!el) return;
    function fmt(n){return Math.round(n).toLocaleString('en-US');}
    var sO=document.getElementById('s-orders'),sSal=document.getElementById('s-salary');
    var sR=document.getElementById('s-rent'),sOth=document.getElementById('s-other');
    function update(){
      var ord=parseInt(sO.value),sal=parseInt(sSal.value),rent=parseInt(sR.value),oth=parseInt(sOth.value);
      var daily=Math.round(ord/22);
      var ppo=daily<=7?26:daily<=34?23:daily<=68?21:18;
      var storage=Math.round(ord*0.005*650);
      var yourCost=sal+rent+oth, mtpCost=ord*ppo+storage, saving=yourCost-mtpCost;
      var pct=yourCost>0?Math.round((saving/yourCost)*100):0;
      document.getElementById('v-orders').textContent=fmt(ord);
      document.getElementById('v-salary').textContent=fmt(sal)+' UAH';
      document.getElementById('v-rent').textContent=fmt(rent)+' UAH';
      document.getElementById('v-other').textContent=fmt(oth)+' UAH';
      document.getElementById('r-your-cost').textContent=fmt(yourCost)+' UAH/mo';
      document.getElementById('r-mtp-cost').textContent=fmt(mtpCost)+' UAH/mo';
      document.getElementById('r-price-per').textContent=ppo+' UAH';
      var rSav=document.getElementById('row-saving'),rAnn=document.getElementById('row-annual'),rWarn=document.getElementById('row-warn');
      if(saving>0){
        rSav.style.display='';rAnn.style.display='';rWarn.style.display='none';
        document.getElementById('r-saving').textContent=fmt(saving)+' UAH/mo ('+pct+'%)';
        document.getElementById('r-annual').textContent=fmt(saving*12)+' UAH';
      } else {
        rSav.style.display='none';rAnn.style.display='none';rWarn.style.display='';
        document.getElementById('r-warn-cost').textContent=fmt(mtpCost)+' UAH/mo';
      }
    }
    [sO,sSal,sR,sOth].forEach(function(s){s.addEventListener('input',update);});
    update();
  })();
})();
</script>
