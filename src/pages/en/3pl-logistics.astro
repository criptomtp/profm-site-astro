        <div class="flow-line" aria-hidden="true"><span class="flow-arrow">&rarr;</span></div>
        <div class="flow-box flow-box--accent">MTP Warehouse</div>
        <div class="flow-line" aria-hidden="true"><span class="flow-arrow">&rarr;</span></div>
        <div class="flow-box">Nova Poshta</div>
        <div class="flow-line" aria-hidden="true"><span class="flow-arrow">&rarr;</span></div>
        <div class="flow-box">Customer</div>
