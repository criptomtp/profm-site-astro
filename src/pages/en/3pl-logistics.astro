<!-- ====== SECTION 3 — ROI CALCULATOR ====== -->
<section class="calc-sec" id="calc3pl">
<div class="ctr">
  <div class="badge badge-dark">CALCULATOR</div>
  <h2 class="sec-h2">Calculate your savings with MTP</h2>

  <div class="calc-grid">
    <div class="calc-sliders">
      <div class="calc-field">
        <label>Orders/month: <strong id="v-orders">1,500</strong></label>
        <input type="range" min="100" max="5000" step="50" id="s-orders" value="1500">
      </div>
      <div class="calc-field">
        <label>Logistics salaries: <strong id="v-salary">45,000 UAH</strong></label>
        <input type="range" min="0" max="100000" step="1000" id="s-salary" value="45000">
      </div>
      <div class="calc-field">
        <label>Warehouse rent: <strong id="v-rent">25,000 UAH</strong></label>
        <input type="range" min="0" max="50000" step="1000" id="s-rent" value="25000">
      </div>
      <div class="calc-field">
        <label>Other expenses: <strong id="v-other">10,000 UAH</strong></label>
        <input type="range" min="0" max="30000" step="500" id="s-other" value="10000">
      </div>
    </div>
    <div class="calc-result">
      <div class="calc-row">
        <span>Your costs</span>
        <strong id="r-your-cost">80,000 UAH/mo</strong>
      </div>
      <div class="calc-row calc-row--accent">
        <span>With MTP</span>
        <strong id="r-mtp-cost">36,375 UAH/mo</strong>
      </div>
      <div class="calc-row">
        <span>Price per shipment</span>
        <strong id="r-price-per">21 UAH</strong>
      </div>
      <div class="calc-row calc-row--big" id="row-saving">
        <span>Savings</span>
        <strong id="r-saving">43,625 UAH/mo (55%)</strong>
      </div>
      <div class="calc-row" id="row-annual">
        <span>Per year</span>
        <strong id="r-annual">523,500 UAH</strong>
      </div>
      <div class="calc-row calc-row--warn" id="row-warn" style="display:none">
        <span>MTP cost</span>
        <strong id="r-warn-cost">—</strong>
      </div>
    </div>
  </div>
</div>
