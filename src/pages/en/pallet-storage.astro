.pz-float-label{display:block;font-size:13px;color:rgba(255,255,255,.45);margin-top:4px;letter-spacing:.5px}

/* ========================================
   S2: COMPARISON
   ======================================== */
.pz-compare{padding:100px 0;background:#fff}
.pz-compare-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-bottom:40px}
.pz-compare-col{border-radius:12px;overflow:hidden}
.pz-compare-own{background:#f7f7f7;border:1px solid #e5e5e5}
.pz-compare-mtp{background:#fef5f5;border:1px solid #f0c8c6}
.pz-compare-head{padding:18px 24px;font-size:15px;font-weight:600;text-transform:uppercase;letter-spacing:1px;background:#e8e8e8;color:#333}
.pz-compare-head-green{background:#fde8e7;color:#e63329}
.pz-compare-row{display:flex;justify-content:space-between;align-items:center;padding:14px 24px;border-bottom:1px solid rgba(0,0,0,.05);font-size:15px}
.pz-compare-row:last-of-type{border-bottom:none}
.pz-price-red{color:#e63329;font-weight:600;white-space:nowrap}
.pz-price-green{color:#e63329;font-weight:600;white-space:nowrap}
.pz-compare-total{display:flex;justify-content:space-between;align-items:center;padding:16px 24px;font-size:16px;font-weight:700;background:#e0e0e0;color:#111}
.pz-compare-total-green{background:#fde8e7;color:#c42b22}
.pz-compare-note{padding:8px 24px 12px;font-size:13px;color:#666;text-align:right}

.pz-saving-bar{display:flex;align-items:center;justify-content:space-between;gap:24px;padding:24px 32px;background:#0a0a0a;border-radius:12px;color:#fff}
.pz-saving-text{font-size:18px;color:rgba(255,255,255,.85)}
.pz-saving-text strong{color:#fff;font-size:22px}

/* ========================================
   S3: SVG RACK VISUALIZATION
   ======================================== */
.pz-rack{padding:100px 0;background:var(--gray)}
.pz-rack-wrap{max-width:700px;margin:0 auto}
.pz-rack-svg{width:100%;height:auto}
.pz-rack-legend{display:flex;gap:24px;justify-content:center;margin-top:24px}
.pz-legend-item{display:inline-flex;align-items:center;gap:8px;font-size:14px;color:var(--muted)}
.pz-legend-box{width:18px;height:14px;border-radius:3px;display:inline-block}
