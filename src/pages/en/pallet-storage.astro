.pz-cta-btn{display:inline-flex;align-items:center;gap:8px;padding:16px 32px;background:var(--red);color:#fff;border:none;border-radius:4px;font-size:16px;font-weight:600;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:background .3s;text-decoration:none}
.pz-cta-btn:hover{background:#c42b22}

.hero-form{display:flex;gap:12px;max-width:460px;margin-bottom:12px}
