.hero-form input::placeholder{color:rgba(255,255,255,.25)}.hero-form input:focus{border-color:rgba(255,255,255,.5)}
.hero-form button{padding:16px 24px;background:#e63329;color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:600;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:all .3s}
.hero-form button:hover{background:#c42b22}
.hero-note{font-size:13px;color:rgba(255,255,255,.3);margin-bottom:16px}
.pz-hero-cards{display:flex;flex-direction:column;gap:16px;flex-shrink:0;padding-top:20px}
.pz-float-card{background:rgba(255,255,255,.06);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.1);border-radius:12px;padding:20px 28px;min-width:220px;transition:border-color .3s}
