---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Client Reviews — MTP Group Fulfillment Ukraine"
  description="Read what 150+ clients say about MTP Group Fulfillment. Real case studies: Carter's 5x growth, I.Love.My.Cycle 3x growth, EcoDrive heavy goods."
  canonical="https://www.fulfillmentmtp.com.ua/en/recalls/"
  lang="en"
>
<Fragment slot="head">
<script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","address":[{"@type":"PostalAddress","addressLocality":"Shchaslive, Boryspil district","addressRegion":"Kyiv region","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"Bilohorodka","addressRegion":"Kyiv region","addressCountry":"UA"}],"openingHours":"Mo-Su 08:00-20:00"}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.fulfillmentmtp.com.ua/en/"},{"@type":"ListItem","position":2,"name":"Reviews","item":"https://www.fulfillmentmtp.com.ua/en/recalls/"}]}</script>
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/recalls/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/recalls/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/recalls/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/ua/recalls/">
</Fragment>

<!-- HERO -->
<section class="hero-reviews">
<div class="hero-bg"></div>
<div class="hero-content">
<div class="badge">CLIENT REVIEWS</div>
<h1>What Our Clients Say<br>About MTP Group</h1>
<p class="hero-sub">Real stories from 150+ e-commerce businesses across Ukraine. From startups shipping 10 orders a day to established brands processing thousands &mdash; hear directly from the entrepreneurs who trust us with their logistics.</p>
<form class="hero-form" id="heroForm"><input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="25" required autocomplete="tel" aria-label="Phone"><button type="submit">Get a quote →</button></form>
<div class="hero-note">Free consultation · We call back within 15 min</div>

</div>
<div class="hero-stats">
<div class="hero-stat"><div class="hero-stat-val">150+</div><div class="hero-stat-label">Active clients</div></div>
<div class="hero-stat"><div class="hero-stat-val">10&nbsp;years</div><div class="hero-stat-label">In business</div></div>
<div class="hero-stat"><div class="hero-stat-val">60,000+</div><div class="hero-stat-label">Shipments / month</div></div>
<div class="hero-stat"><div class="hero-stat-val">4.9/5</div><div class="hero-stat-label">Client rating</div></div>
</div>
</section>

<!-- VIDEO REVIEWS -->
<section class="video-reviews"><div class="ctr">
<div class="badge badge-dark">VIDEO TESTIMONIALS</div>
<h2 class="sec-h2">Watch What Our Clients Have to Say</h2>
<p style="font-size:16px;color:var(--muted);line-height:1.7;max-width:640px;margin-bottom:48px">Nothing speaks louder than a client on camera. These entrepreneurs share their firsthand experience of partnering with MTP Group for fulfillment, warehousing, and logistics across Ukraine.</p>
<div class="video-grid">
<div class="video-card"><iframe src="https://www.youtube.com/embed/eP4FYJnyz_8" title="MTP Group client review 1" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
<div class="video-card"><iframe src="https://www.youtube.com/embed/bHY3cFF9SlI" title="MTP Group client review 2" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
<div class="video-card"><iframe src="https://www.youtube.com/embed/mE4N4CHwG7o" title="MTP Group client review 3" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
<div class="video-card"><iframe src="https://www.youtube.com/embed/k7ET02dWB7k" title="The truth about MTP Group Fulfillment — client testimonial" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
<div class="video-card"><iframe src="https://www.youtube.com/embed/bUMM8S91quo" title="Client review: Vlad Savytskyi on MTP Group warehouse" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
<div class="video-card"><iframe src="https://www.youtube.com/embed/nmJulGqRABw" title="4x growth with MTP Group Fulfillment — client case study" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
<div class="video-card"><iframe src="https://www.youtube.com/embed/KhYY0MsjLmU" title="Igor Bakalov on delegating logistics to MTP Group" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
<div class="video-card"><iframe src="https://www.youtube.com/embed/K3KHxItl2nk" title="Client review: Maksym on MTP Group warehouse operations" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></div>
</div>
</div></section>

<!-- CASE STUDIES -->
<section class="case-studies"><div class="ctr">
<div class="badge badge-dark">CASE STUDIES</div>
<h2 class="sec-h2">Real Numbers, Real Growth</h2>
<div class="case-grid">
<div class="case-card">
<div class="case-brand">Carter's</div>
<div class="case-tag">Children's apparel &bull; 5x growth</div>
<div class="case-metrics"><div><div class="case-metric-val">10 &rarr; 72</div><div class="case-metric-label">Shipments per day</div></div><div><div class="case-metric-val">5x</div><div class="case-metric-label">Volume increase</div></div></div>
<p>When Carter's first came to MTP Group, they were handling just 10 shipments per day from a small in-house operation. Within four months, our optimized warehouse processes and seamless Nova Poshta integration helped them scale to 72 daily shipments.</p>
<div class="case-highlight"><div class="case-metric-val">30 &rarr; 14 UAH</div><div class="case-metric-label">Cost per shipment reduced by 53%</div></div>
</div>
<div class="case-card">
<div class="case-brand">I.Love.My.Cycle</div>
<div class="case-tag">Women's health &bull; 3x growth</div>
<div class="case-metrics"><div><div class="case-metric-val">25 &rarr; 73</div><div class="case-metric-label">Shipments per day</div></div><div><div class="case-metric-val">3x</div><div class="case-metric-label">Volume increase</div></div></div>
<p>I.Love.My.Cycle came to us during a period of rapid growth that overwhelmed their internal logistics. Within three months, we tripled their daily throughput from 25 to 73 orders.</p>
<div class="case-highlight"><div class="case-metric-val">90 hrs/mo</div><div class="case-metric-label">Saved on operations</div></div>
</div>
<div class="case-card">
<div class="case-brand">EcoDrive</div>
<div class="case-tag">Heavy goods &bull; 50+ kg items</div>
<div class="case-metrics"><div><div class="case-metric-val">50+&nbsp;kg</div><div class="case-metric-label">Per item weight</div></div><div><div class="case-metric-val">50/day</div><div class="case-metric-label">Heavy shipments</div></div></div>
<p>EcoDrive sells electric scooters, e-bikes, and heavy automotive accessories. MTP Group built a dedicated heavy-goods workflow with forklift-based pick routes and reinforced packaging stations.</p>
<div class="case-highlight"><div class="case-metric-val">0 damages</div><div class="case-metric-label">Zero broken items in transit</div></div>
</div>
</div>
</div></section>

<!-- TEXT REVIEWS -->
<section class="text-reviews"><div class="ctr">
<div class="badge">WHAT CLIENTS SAY</div>
<h2 class="sec-h2" style="color:var(--white)">Reviews from Real Entrepreneurs</h2>
<div class="reviews-grid">
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;We grew from 100 to 800 shipments per day within 3 months. MTP genuinely solved our logistics bottleneck.&rdquo;</div><div class="review-author">Oleksii R.</div><div class="review-company">Online store owner</div></div>
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;We saved over 25,000 UAH per month compared to running our own warehouse. Highly recommend for anyone scaling fast.&rdquo;</div><div class="review-author">Pavlo M.</div><div class="review-company">E-commerce entrepreneur</div></div>
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;Handing logistics to MTP freed up 40 hours a month for marketing. A decision I wish I had made sooner.&rdquo;</div><div class="review-author">Anton B.</div><div class="review-company">CEO, BeautyBox</div></div>
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;The personal dashboard is fantastic &mdash; I can check stock levels, shipments, and returns from my phone at 3 AM if I want.&rdquo;</div><div class="review-author">Yana K.</div><div class="review-company">Founder, GlowSkin</div></div>
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;We were scared of blackouts ruining our operations. MTP has generators, Starlink, the works. Not a single missed shipment since we started.&rdquo;</div><div class="review-author">Dmytro V.</div><div class="review-company">Co-founder, TechGadgets UA</div></div>
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;Their auto-callback service boosted our buyout rate by 15%. That alone paid for the entire fulfillment fee.&rdquo;</div><div class="review-author">Iryna S.</div><div class="review-company">Director, FashionHouse</div></div>
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;I used to spend every morning at the post office. Now I spend every morning planning new product launches.&rdquo;</div><div class="review-author">Maksym H.</div><div class="review-company">Founder, PetJoy</div></div>
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;Returns handling used to be our worst nightmare. MTP inspects, restocks, and updates inventory automatically.&rdquo;</div><div class="review-author">Svitlana P.</div><div class="review-company">Owner, KidStyle</div></div>
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;We ship heavy items (25-40 kg each) and most fulfillment centers turned us away. MTP built a whole workflow around our products.&rdquo;</div><div class="review-author">Roman T.</div><div class="review-company">CEO, FitEquip</div></div>
<div class="review-card"><div class="review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="review-quote">&ldquo;From contract signing to first shipment it took exactly one day. The onboarding was the fastest I have ever experienced.&rdquo;</div><div class="review-author">Taras L.</div><div class="review-company">Founder, DrinkWell</div></div>
</div>
</div></section>

<!-- SEO ARTICLE -->
<section class="seo-article"><div class="ctr">
<h2>How to Evaluate a Fulfillment Partner: What Real Clients Look For</h2>
<h3>Why client reviews matter more than marketing promises</h3>
<p>Choosing a fulfillment partner is one of the most consequential decisions an e-commerce business owner can make. Your logistics provider touches every single order. That is why experienced entrepreneurs seek out real client reviews, measurable case studies, and verifiable performance data before committing.</p>
<h3>The five pillars of a trustworthy fulfillment provider</h3>
<p>The criteria that matter most to real business owners are: operational reliability, transparent pricing, speed of onboarding, real-time visibility, and scalability without friction.</p>
<h3>Making your decision with confidence</h3>
<p>The best way to evaluate a fulfillment partner is to combine three sources of information: published client reviews and video testimonials, verifiable case studies with real numbers, and a direct conversation with the provider's team.</p>
</div></section>

</Base>

<style is:global>
:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:24px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}

.hero-reviews{position:relative;min-height:60vh;background:#000;color:#fff;display:flex;align-items:center;padding:140px 0 80px;overflow:hidden}
.hero-reviews .hero-bg{position:absolute;inset:0;background:url('/images/mtp-fulfillment-warehouse-hero.webp') center/cover;opacity:.15}
.hero-reviews .hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero-reviews h1{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(36px,5vw,64px);font-weight:400;line-height:1.05;margin-bottom:24px}
.hero-reviews .hero-sub{font-size:clamp(16px,1.8vw,20px);color:rgba(255,255,255,.6);line-height:1.7;max-width:600px}
.hero-form{display:flex;gap:12px;max-width:460px;margin-top:32px}
.hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;font-family:var(--fb,'DM Sans',sans-serif);outline:none}
.hero-form input::placeholder{color:rgba(255,255,255,.25)}.hero-form input:focus{border-color:rgba(255,255,255,.5)}
.hero-form button{padding:16px 24px;background:transparent;color:#fff;border:2px solid #fff;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;font-family:var(--fb,'DM Sans',sans-serif);white-space:nowrap;transition:all .3s}
.hero-form button:hover{background:var(--red,#e63329);border-color:var(--red,#e63329)}
.hero-note{font-size:13px;color:rgba(255,255,255,.35);margin-top:12px}
.hero-reviews .hero-stats{position:relative;z-index:2;display:flex;flex-wrap:nowrap;gap:48px;padding:48px 8vw 0;margin-top:40px;border-top:1px solid rgba(255,255,255,.08)}
.hero-stat-val{font-family:var(--fb,'DM Sans',sans-serif);font-size:clamp(28px,3.5vw,44px);font-weight:300;color:#fff}
.hero-stat-label{font-size:11px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:2px;margin-top:6px}
.video-reviews{padding:100px 0;background:var(--gray,#f5f5f5)}
.sec-h2{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(28px,4vw,48px);font-weight:400;margin-bottom:56px}
.video-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.video-grid .video-card{position:relative;border-radius:8px;overflow:hidden;background:#000;aspect-ratio:16/9}
.video-grid .video-card iframe{width:100%;height:100%;border:none}
.case-studies{padding:100px 0}
.case-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.case-card{background:#fff;border:1px solid #e0e0e0;border-radius:8px;padding:40px 32px;transition:box-shadow .3s}.case-card:hover{box-shadow:0 12px 40px rgba(0,0,0,.08)}
.case-brand{font-family:var(--fd,'DM Serif Display',serif);font-size:22px;margin-bottom:6px}
.case-tag{display:inline-block;font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--red,#e63329);margin-bottom:20px}
.case-metrics{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px}
.case-metric-val{font-size:28px;font-weight:300;color:#000}.case-metric-label{font-size:12px;color:var(--muted,#666);margin-top:2px}
.case-card p{font-size:14px;color:var(--muted,#666);line-height:1.7}
.case-highlight{background:var(--gray,#f5f5f5);border-radius:6px;padding:16px;margin-top:16px;text-align:center}
.case-highlight .case-metric-val{font-size:32px;color:var(--red,#e63329)}
.text-reviews{padding:100px 0;background:#000;color:#fff}
.reviews-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
.review-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:32px}
.review-stars{color:var(--red,#e63329);letter-spacing:4px;margin-bottom:14px;font-size:16px}
.review-quote{font-family:var(--fd,'DM Serif Display',serif);font-style:italic;font-size:17px;font-weight:400;line-height:1.6;color:rgba(255,255,255,.85);margin-bottom:20px}
.review-author{font-size:14px;color:rgba(255,255,255,.5)}.review-company{font-size:12px;color:rgba(255,255,255,.3);margin-top:3px}
.seo-article{padding:100px 0}
.seo-article h2{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(28px,3.5vw,42px);font-weight:400;margin-bottom:40px}
.seo-article h3{font-size:20px;font-weight:500;margin:32px 0 12px}
.seo-article p{font-size:15px;color:#444;line-height:1.8;margin-bottom:16px;max-width:780px}
@media(max-width:768px){
.hero-reviews{min-height:auto;padding:110px 0 60px}.hero-reviews .hero-content{padding:0 24px}
.hero-reviews .hero-stats{flex-wrap:wrap;gap:24px;padding:32px 24px 0}.hero-reviews .hero-stats .hero-stat{min-width:calc(50% - 12px)}
.video-grid{grid-template-columns:1fr}.case-grid{grid-template-columns:1fr}.reviews-grid{grid-template-columns:1fr}
.final-form{flex-direction:column}
}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.15});
document.querySelectorAll('.reveal').forEach(function(el,i){el.style.transitionDelay=(i%3)*.1+'s';obs.observe(el);});
});
</script>

<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
  var form=document.getElementById('heroForm');
  if(!form)return;
  form.addEventListener('submit',function(e){
    e.preventDefault();
    var ph=form.querySelector('input[name="phone"]').value.trim();
    if(ph.replace(/\D/g,'').length<10){form.querySelector('input').style.borderColor='#e63329';return;}
    fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});
    form.innerHTML='<p style="color:#22c55e;font-size:18px">\u2705 Дякуємо!</p>';
  });
});
</script>
