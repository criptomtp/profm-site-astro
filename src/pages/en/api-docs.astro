      <a href="/en/faq/" class="apidoc-related__card"><span>General FAQ</span><em>30+ fulfillment answers →</em></a>
      <a href="/en/what-is-fulfillment/" class="apidoc-related__card"><span>What is Fulfillment</span><em>Complete guide for merchants →</em></a>
    </div>
  </div>
</section>

<script type="module" is:inline>
  const link = document.createElement('link');
  link.rel = 'stylesheet';
  link.href = 'https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui.css';
  document.head.appendChild(link);

  const s = document.createElement('script');
  s.src = 'https://unpkg.com/swagger-ui-dist@5.17.14/swagger-ui-bundle.js';
  s.onload = () => {
    window.SwaggerUIBundle({
      url: '/openapi.json',
      dom_id: '#swagger-ui',
      deepLinking: true,
      docExpansion: 'list',
      defaultModelsExpandDepth: -1,
      tryItOutEnabled: true,
      persistAuthorization: true,
    });
  };
  document.body.appendChild(s);

  document.querySelectorAll('[data-copy]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const pre = btn.closest('.apidoc-code').querySelector('pre');
      try {
        await navigator.clipboard.writeText(pre.textContent);
        const o = btn.textContent; btn.textContent = 'Copied ✓';
        setTimeout(() => btn.textContent = o, 1500);
      } catch {}
    });
  });
</script>

<style is:global>
