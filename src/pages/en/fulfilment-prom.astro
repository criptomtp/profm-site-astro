@media (max-width: 640px) {
  .prom-n__hero { padding:48px 0 64px; }
  .prom-n__hero-eyebrow { margin-bottom:32px; gap:8px; font-size:10px; }
  .prom-n__masthead-divider { width:18px; }
  .prom-n__h1 { font-size:clamp(2.4rem, 11vw, 3.6rem); margin-bottom:20px; }
  .prom-n__subhead { font-size:1.3rem; margin-bottom:32px; }
  .prom-n__hero-form { margin-bottom:36px; }
  .prom-n__calc-section, .prom-n__case, .prom-n__pricing, .prom-n__faq { padding:64px 0; }
  .prom-n__calc { padding:24px 18px; }
  .prom-n__calc-results { grid-template-columns:1fr; }
  .prom-n__calc-card { border-right:none; border-bottom:1px solid #ddd; }
  .prom-n__calc-card:last-child { border-bottom:none; }
  .prom-n__calc-output { text-align:left; min-width:0; }
  .prom-n__pricing-grid { grid-template-columns:1fr; }
  .prom-n__tier { border-right:none; border-bottom:1px solid #222; }
  .prom-n__tier:last-child { border-bottom:none; }
}
</style>

<script is:inline>
(function () {
  var slider = document.getElementById('prom-n-orders');
  var out = document.getElementById('prom-n-orders-out');
  var selfEl = document.getElementById('prom-n-self');
  var mtpEl = document.getElementById('prom-n-mtp');
  var saveEl = document.getElementById('prom-n-save');
  var hoursEl = document.getElementById('prom-n-hours');
  if (!slider || !out || !selfEl || !mtpEl || !saveEl || !hoursEl) return;

  function fmt(n) {
    return '$' + Math.round(n).toLocaleString('en-US');
  }

  function calc(orders) {
    // Self-managed warehouse cost model (USD/month, conservative)
    // Rent: 35 m² x $9 = $315 (baseline) + $0.05/order overflow above 1500
    // Staff: 2 operators x $620 = $1,240; +1 operator above 2000 orders
    // Packaging cost: $0.18/order; consumables overhead 12% of packaging
    // Loss / dispute: 1.4% of avg order value $32 = $0.45/order
    var rent = 315 + Math.max(0, orders - 1500) * 0.05;
    var staff = 1240 + (orders > 2000 ? 620 : 0) + (orders > 3500 ? 620 : 0);
    var pack = orders * 0.18 * 1.12;
    var losses = orders * 0.45;
    var overhead = 180; // utilities, software, accounting share
    var selfCost = rent + staff + pack + losses + overhead;

    // MTP cost model (USD/month)
    // Per-shipment fee scales with volume: $0.45 → $0.38
    // Storage: ~$0.04/order equivalent baseline
    // No staff cost on seller side
    var fee;
    if (orders <= 200) fee = 0.45;
    else if (orders <= 1500) fee = 0.42;
    else if (orders <= 8000) fee = 0.38;
    else fee = 0.35;
    var mtpCost = orders * fee + orders * 0.04 + 60;

    var save = Math.max(0, selfCost - mtpCost);
    // Estimated saved staff hours: ~0.18 h/order processed by us
    var hours = Math.round(orders * 0.18);

    return {
      self: selfCost,
      mtp: mtpCost,
      save: save,
      hours: hours
    };
  }

  function update() {
    var v = parseInt(slider.value, 10);
    out.textContent = v.toLocaleString('en-US') + ' orders / month';
    slider.setAttribute('aria-valuenow', v);
    var r = calc(v);
    selfEl.textContent = fmt(r.self);
    mtpEl.textContent = fmt(r.mtp);
    saveEl.textContent = fmt(r.save) + ' / mo';
    hoursEl.textContent = r.hours.toLocaleString('en-US');
  }

  slider.addEventListener('input', update);
  update();
})();
</script>
