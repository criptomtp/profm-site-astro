.prom-n__tier--accent .prom-n__tier-list li { color:rgba(255,255,255,0.95); border-bottom-color:rgba(0,0,0,0.18); }
.prom-n__tier--accent .prom-n__tier-note { color:rgba(0,0,0,0.7); }
.prom-n__tier--enterprise { background:#fff; color:#000; }
.prom-n__tier--enterprise .prom-n__tier-tag { color:var(--mtp-red); }
.prom-n__tier--enterprise .prom-n__tier-price { color:#000; }
.prom-n__tier--enterprise .prom-n__tier-suffix { color:#666; }
.prom-n__tier--enterprise .prom-n__tier-list li { color:#222; border-bottom-color:#ddd; }
.prom-n__tier--enterprise .prom-n__tier-note { color:#666; }
.prom-n__tier-tag { font-size:0.72rem; font-weight:800; letter-spacing:0.18em; color:var(--mtp-red); }
.prom-n__tier-price { font-size:clamp(2rem, 3.2vw, 2.6rem); font-weight:800; line-height:1; letter-spacing:-0.02em; color:#fff; font-family:'Newsreader', Georgia, serif; }
.prom-n__tier-price small { font-size:0.45em; font-weight:600; color:rgba(255,255,255,0.6); margin-left:4px; }
.prom-n__tier-suffix { font-size:0.78rem; color:rgba(255,255,255,0.55); letter-spacing:0.04em; }
.prom-n__tier-list { list-style:none; padding:14px 0 0; margin:0; flex:1; }
.prom-n__tier-list li { font-size:0.88rem; line-height:1.5; padding:8px 0; border-bottom:1px solid #1a1a1a; color:rgba(255,255,255,0.8); }
.prom-n__tier-list li:last-child { border-bottom:none; }
.prom-n__tier-note { font-size:0.78rem; line-height:1.5; color:rgba(255,255,255,0.55); font-style:italic; margin-top:8px; padding-top:14px; border-top:1px solid #1a1a1a; }
.prom-n__pricing-foot { font-size:0.92rem; line-height:1.7; color:rgba(255,255,255,0.6); margin:36px 0 0; max-width:980px; }
.prom-n__pricing-foot a { color:#fff; border-bottom:1.5px solid var(--mtp-red); text-decoration:none; transition:color .15s; }
.prom-n__pricing-foot a:hover { color:var(--mtp-red); }

/* FAQ */
.prom-n__faq { padding:96px 0; background:#fff; }
.prom-n__faq-inner { max-width:1080px; margin:0 auto; padding:0 1.5rem; }
.prom-n__faq-deck { font-size:1.05rem; font-style:italic; line-height:1.7; color:#666; margin:14px 0 32px; max-width:760px; }
.prom-n__faq .s-acc { border-top:1px solid #000; margin-top:24px; }
