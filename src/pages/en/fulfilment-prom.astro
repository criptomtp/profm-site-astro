.prom-n__case-cols { display:grid; grid-template-columns:repeat(3, 1fr); gap:48px; padding-top:36px; border-top:2px solid #000; }
.prom-n__case-col { font-size:0.95rem; line-height:1.7; color:#222; }
.prom-n__case-h3 { font-size:1.25rem; line-height:1.25; font-weight:700; color:#000; margin:0 0 14px; }
.prom-n__case-col p { margin:0 0 14px; }
.prom-n__case-col p:last-child { margin-bottom:0; }
.prom-n__case-col strong { color:var(--mtp-red); font-weight:700; }
.prom-n__case-col a { color:#000; border-bottom:1.5px solid var(--mtp-red); text-decoration:none; }
.prom-n__case-col a:hover { color:var(--mtp-red); }
.prom-n__case-col--quote { padding:0 8px; }
.prom-n__pullquote { font-size:clamp(1.3rem, 1.8vw, 1.55rem); line-height:1.4; font-style:italic; color:#000; margin:0 0 14px; padding:0; position:relative; font-weight:500; }
.prom-n__pullquote-mark { color:var(--mtp-red); font-size:1.6em; line-height:1; vertical-align:-0.05em; font-style:normal; font-weight:800; }
