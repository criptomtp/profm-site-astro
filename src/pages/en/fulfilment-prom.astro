/* Mobile */
@media (max-width: 960px) {
  .prom-n__case-cols { grid-template-columns:1fr; gap:36px; }
  .prom-n__case-col--quote { order:3; padding:0; border-top:1px solid #ddd; padding-top:24px; }
  .prom-n__pricing-grid { grid-template-columns:repeat(2, 1fr); }
  .prom-n__tier { border-right:1px solid #222; border-bottom:1px solid #222; }
  .prom-n__tier:nth-child(2n) { border-right:none; }
  .prom-n__tier:nth-last-child(-n+2) { border-bottom:none; }
