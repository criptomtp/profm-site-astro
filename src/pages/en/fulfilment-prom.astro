.prom-n__calc-card-label { font-size:0.7rem; font-weight:800; letter-spacing:0.14em; text-transform:uppercase; }
.prom-n__calc-card-num { font-size:clamp(1.5rem, 2.6vw, 2rem); font-weight:800; line-height:1.05; letter-spacing:-0.01em; font-variant-numeric:tabular-nums; }
