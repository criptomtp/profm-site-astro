.prom-n__calc-scale { display:flex; justify-content:space-between; margin-top:10px; font-size:11px; color:#999; font-weight:700; letter-spacing:0.06em; }
.prom-n__calc-results { display:grid; grid-template-columns:repeat(3, 1fr); gap:0; border-top:2px solid #000; }
