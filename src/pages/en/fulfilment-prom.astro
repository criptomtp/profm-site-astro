.prom-n__case-figure { margin:64px 0 0; padding:0; }
.prom-n__case-figure img { width:100%; height:auto; display:block; filter:grayscale(100%) contrast(1.05); transition:filter .4s; }
.prom-n__case-figure:hover img { filter:grayscale(0%) contrast(1); }
.prom-n__case-figcaption { font-size:0.82rem; color:#666; line-height:1.5; margin:14px 0 0; padding-top:10px; border-top:1px solid #ddd; font-style:italic; max-width:760px; }

/* PRICING TIERS — dark 4-col */
