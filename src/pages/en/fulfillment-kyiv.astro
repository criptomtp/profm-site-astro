<style is:global>
:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-block;padding:6px 16px;border:1px solid var(--red);color:var(--red);font-size:11px;font-weight:600;letter-spacing:2px;border-radius:2px;text-transform:uppercase}
.badge-dark{border-color:#ccc;color:#666}
.sec-h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;text-align:center;margin:12px 0 48px}

/* HERO — centered Apple-style, unique to EN Kyiv */
.fk-hero{position:relative;min-height:100vh;background:var(--black);color:var(--white);display:flex;align-items:center;justify-content:center;text-align:center;padding:100px 24px 80px;overflow:hidden}
.fk-hero-glow{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 30%,rgba(230,51,41,.08) 0%,transparent 60%),radial-gradient(ellipse at 80% 80%,rgba(255,255,255,.02) 0%,transparent 40%)}
.fk-hero-inner{position:relative;z-index:2;max-width:860px}
.fk-hero-badge{display:inline-block;padding:6px 20px;border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.5);font-size:11px;font-weight:600;letter-spacing:3px;border-radius:2px;margin-bottom:32px}
.fk-hero h1{font-family:var(--fd);font-size:clamp(32px,5.5vw,64px);font-weight:400;line-height:1.1;margin-bottom:28px}
.fk-hero-accent{color:var(--red);display:block;margin-top:4px}
.fk-hero-sub{font-size:clamp(15px,1.6vw,18px);color:rgba(255,255,255,.45);line-height:1.75;max-width:600px;margin:0 auto 40px}
.fk-hero-form{display:flex;gap:12px;max-width:480px;margin:0 auto}
.fk-hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;font-family:var(--fb);outline:none}
.fk-hero-form input::placeholder{color:rgba(255,255,255,.25)}
.fk-hero-form input:focus{border-color:rgba(255,255,255,.5)}
.fk-hero-form button{padding:16px 28px;background:var(--red);color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:600;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:all .3s}
.fk-hero-form button:hover{background:#c42b22}
.fk-hero-note{font-size:13px;color:rgba(255,255,255,.25);margin-top:14px}

/* WHY KYIV — 4 big stat cards */
.fk-stats{padding:120px 0;background:var(--gray)}
.fk-stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.fk-stat-card{padding:40px 28px;background:#fff;border-radius:14px;border:1px solid #e0e0e0;text-align:center;transition:border-color .3s}
.fk-stat-card:hover{border-color:var(--red)}
.fk-stat-num{font-family:var(--fd);font-size:clamp(36px,4vw,56px);font-weight:400;color:var(--red);line-height:1;margin-bottom:4px}
.fk-stat-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:2px;color:var(--muted);margin-bottom:16px}
.fk-stat-card p{font-size:13px;color:var(--muted);line-height:1.65;text-align:left}

/* NO ENTITY — red section */
.fk-no-entity{padding:100px 0;background:var(--red);color:#fff}
.fk-ne-content{max-width:800px;margin:0 auto}
.fk-ne-content h2{font-family:var(--fd);font-size:clamp(32px,5vw,56px);font-weight:400;margin-bottom:12px}
.fk-ne-lead{font-size:clamp(16px,1.6vw,19px);opacity:.8;line-height:1.7;margin-bottom:48px}
.fk-ne-steps{display:flex;flex-direction:column;gap:28px;margin-bottom:48px}
.fk-ne-step{display:flex;gap:20px;align-items:flex-start}
.fk-ne-num{width:40px;height:40px;min-width:40px;border-radius:50%;border:2px solid rgba(255,255,255,.4);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:18px;margin-top:2px}
.fk-ne-step div:last-child{font-size:15px;line-height:1.7}
.fk-ne-step strong{font-size:16px}
.fk-ne-countries{display:flex;flex-wrap:wrap;gap:12px;align-items:center;padding-top:24px;border-top:1px solid rgba(255,255,255,.2)}
.fk-ne-countries>span:first-child{font-size:13px;opacity:.7;text-transform:uppercase;letter-spacing:1px}
.fk-ne-flag{padding:6px 14px;background:rgba(255,255,255,.15);border-radius:4px;font-size:14px;font-weight:500}

/* CALCULATOR */
.fk-calculator{padding:100px 0}
.fk-calc-wrap{display:grid;grid-template-columns:1fr 1fr;gap:48px;max-width:820px;margin:0 auto;align-items:center}
.fk-calc-inputs{display:flex;flex-direction:column;gap:32px}
.fk-calc-inputs label{font-size:14px;font-weight:500;display:block}
.fk-calc-inputs input[type="range"]{width:100%;margin:12px 0 8px;accent-color:var(--red);height:6px}
.fk-calc-val{font-size:13px;color:var(--muted)}
.fk-calc-val span{font-weight:700;color:var(--black);font-size:18px}
.fk-calc-result{background:var(--black);color:#fff;padding:48px 40px;border-radius:16px;text-align:center}
.fk-calc-total{font-family:var(--fd);font-size:48px;line-height:1}
.fk-calc-total small{font-size:18px;opacity:.5;font-family:var(--fb)}
.fk-calc-usd{font-size:24px;color:var(--red);margin:8px 0 16px;font-weight:500}
.fk-calc-breakdown{font-size:12px;color:rgba(255,255,255,.4);margin-bottom:12px}
.fk-calc-note{font-size:11px;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:1px}

/* FACILITY — warehouse tour */
.fk-facility{padding:100px 0;background:#0a0a0a;color:#fff}
.fk-facility-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:60px;align-items:center}
.fk-facility-text h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;margin:16px 0 32px}
.fk-facility-list{list-style:none;padding:0}
.fk-facility-list li{font-size:15px;color:rgba(255,255,255,.7);padding:10px 0;border-bottom:1px solid rgba(255,255,255,.06);line-height:1.5}
.fk-facility-list li strong{color:#fff}
.fk-facility-video{position:relative}
.fk-video-thumb{border-radius:12px;overflow:hidden;position:relative}
.fk-video-thumb img{width:100%;aspect-ratio:16/9;object-fit:cover;filter:brightness(.5);transition:filter .3s}
.fk-video-thumb:hover img{filter:brightness(.7)}
.fk-play-overlay{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
.fk-play-btn{width:72px;height:72px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-size:28px;color:#fff;transition:transform .3s}
.fk-video-thumb:hover .fk-play-btn{transform:scale(1.1)}

/* OPTIONS — comparison table */
.fk-options{padding:100px 0;background:var(--gray)}
.fk-opt-table{max-width:820px;margin:0 auto;border-radius:12px;overflow:hidden;border:1px solid #e0e0e0}
.fk-opt-row{display:grid;grid-template-columns:1.5fr 1fr 1fr 1.2fr;border-bottom:1px solid #eee;font-size:14px}
.fk-opt-row:last-child{border:none}
.fk-opt-row>span{padding:14px 16px}
.fk-opt-header{background:var(--black);color:#fff;font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:.5px}
.fk-opt-hl{background:rgba(230,51,41,.04);color:var(--red);font-weight:600}
.fk-opt-header .fk-opt-hl{background:var(--red);color:#fff}

/* PRICING */
.fk-pricing{padding:100px 0}
.fk-price-table{max-width:820px;margin:0 auto 32px;border-radius:12px;overflow:hidden;border:1px solid #e0e0e0}
.fk-price-row{display:flex;border-bottom:1px solid #eee;font-size:14px}.fk-price-row:last-child{border:none}
.fk-price-row>span{flex:1;padding:14px 16px}
.fk-price-header{background:var(--black);color:#fff;font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:.5px}
.fk-price-row:not(.fk-price-header):hover{background:var(--gray)}
.fk-price-highlight{background:var(--red);color:#fff;font-weight:600}
.fk-price-note{text-align:center;font-size:14px;color:var(--muted);max-width:650px;margin:0 auto}

/* FAQ */
.fk-faq{padding:100px 0;background:var(--black);color:var(--white)}
.fk-faq-list{max-width:700px;margin:0 auto}
.fk-faq-item{border-bottom:1px solid rgba(255,255,255,.08)}
.fk-faq-q{width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:var(--fb);text-align:left}
.fk-faq-q::after{content:'+';font-size:24px;color:var(--red);transition:transform .3s;flex-shrink:0;margin-left:16px}
.fk-faq-item.open .fk-faq-q::after{transform:rotate(45deg)}
.fk-faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.fk-faq-a p{padding:0 0 20px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.7}

/* ARTICLE */
.fk-article{background:#fff;padding:80px 8vw}
.fk-article h2{font-family:var(--fd);font-size:clamp(28px,3.5vw,44px);font-weight:400;margin:20px 0 40px}
.fk-article-content{max-width:800px}
.fk-article-content h3{font-family:var(--fd);font-size:clamp(18px,2vw,26px);font-weight:400;margin:36px 0 12px;color:var(--black)}
.fk-article-content h3:first-child{margin-top:0}
.fk-article-content p{font-size:16px;line-height:1.85;color:#444;margin-bottom:8px}

@media(max-width:768px){
.fk-hero h1{font-size:clamp(26px,7vw,36px)}
.fk-hero-form{flex-direction:column}.fk-hero-form button{width:100%}
.fk-stats-grid{grid-template-columns:1fr 1fr}
.fk-ne-steps{gap:20px}
.fk-ne-countries{flex-direction:column;align-items:flex-start}
.fk-calc-wrap{grid-template-columns:1fr}
.fk-facility-grid{grid-template-columns:1fr}
.fk-options .ctr{overflow-x:auto;-webkit-overflow-scrolling:touch}
.fk-opt-table{min-width:600px}
.fk-price-row{font-size:12px}.fk-price-row>span{padding:10px 10px}
}

@media(max-width:480px){
.fk-stats-grid{grid-template-columns:1fr}
}

.fk-stat-card,.fk-ne-step,.fk-opt-row,.fk-price-row,.fk-faq-item{opacity:1!important;transform:none!important}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
/* FAQ accordion */
document.querySelectorAll('.fk-faq-q').forEach(function(btn){
btn.addEventListener('click',function(){
var item=btn.parentElement;
var a=item.querySelector('.fk-faq-a');
var open=item.classList.contains('open');
document.querySelectorAll('.fk-faq-item.open').forEach(function(el){
el.classList.remove('open');
el.querySelector('.fk-faq-a').style.maxHeight=null;
});
if(!open){
item.classList.add('open');
a.style.maxHeight=a.scrollHeight+'px';
}
});
});

/* Cost Calculator */
var ordersSlider=document.getElementById('fkCalcOrders');
var volumeSlider=document.getElementById('fkCalcVolume');
if(ordersSlider&&volumeSlider){
function fkCalcUpdate(){
var orders=parseInt(ordersSlider.value);
var volume=parseInt(volumeSlider.value);
document.getElementById('fkCalcOrdersVal').textContent=orders;
document.getElementById('fkCalcVolumeVal').textContent=volume;
var rate=orders>=200?18:orders>=100?20:orders>=50?22:26;
var fulfillment=orders*22*rate;
var storage=volume*650;
var total=Math.max(fulfillment+storage,5000);
var minApplied=total===5000&&(fulfillment+storage)<5000;
document.getElementById('fkCalcTotal').textContent=total.toLocaleString('en-US');
document.getElementById('fkCalcUsd').textContent=Math.round(total/44).toLocaleString('en-US');
document.getElementById('fkCalcBreakdown').textContent='Fulfillment: '+fulfillment.toLocaleString('en-US')+' UAH + Storage: '+storage.toLocaleString('en-US')+' UAH'+(minApplied?' (min applied)':'');
}
ordersSlider.addEventListener('input',fkCalcUpdate);
volumeSlider.addEventListener('input',fkCalcUpdate);
fkCalcUpdate();
}

/* Video modal */
window.openVideoModal=function(id){
var m=document.getElementById('videoModal');
m.style.display='flex';
document.getElementById('videoIframe').src='https://www.youtube.com/embed/'+id+'?autoplay=1';
};
window.closeVideoModal=function(){
var m=document.getElementById('videoModal');
m.style.display='none';
document.getElementById('videoIframe').src='';
};
document.getElementById('videoModal').addEventListener('click',function(e){
if(e.target===this) closeVideoModal();
});
});
</script>
