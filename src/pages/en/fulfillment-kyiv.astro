---
import Base from '../../layouts/Base.astro';

const schemaJson = `<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Fulfillment in Kyiv","description":"Kyiv-based fulfillment for international sellers. 3,900 m² warehouse, from $0.41/order, English-speaking team.","provider":{"@type":"Organization","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":"+380501444645"},"areaServed":{"@type":"City","name":"Kyiv"},"offers":{"@type":"Offer","priceCurrency":"UAH","price":"18","description":"From 18 UAH per shipment"}}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.fulfillmentmtp.com.ua/en/"},{"@type":"ListItem","position":2,"name":"Services","item":"https://www.fulfillmentmtp.com.ua/en/services/"},{"@type":"ListItem","position":3,"name":"Fulfillment Kyiv","item":"https://www.fulfillmentmtp.com.ua/en/fulfillment-kyiv/"}]}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Do I need a Ukrainian legal entity?","acceptedAnswer":{"@type":"Answer","text":"Not to start. We handle your test launch. Register a local entity when volumes grow — we help."}},{"@type":"Question","name":"How do I ship goods to your warehouse?","acceptedAnswer":{"@type":"Answer","text":"DHL, FedEx, UPS to our address near Boryspil Airport, Kyiv Oblast. We handle customs-cleared goods."}},{"@type":"Question","name":"What about power outages?","acceptedAnswer":{"@type":"Answer","text":"3 generators, 2 fiber ISPs, Starlink. Zero downtime since Feb 2022."}},{"@type":"Question","name":"What does it cost?","acceptedAnswer":{"@type":"Answer","text":"From $0.41/order. Storage ~$15/m³/mo. Minimum ~$114/mo. All inclusive."}},{"@type":"Question","name":"Does your team speak English?","acceptedAnswer":{"@type":"Answer","text":"Yes. Dedicated English-speaking account managers, dashboard and reports in English."}}]}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","address":[{"@type":"PostalAddress","addressLocality":"Shchaslive, Boryspil district","addressRegion":"Kyiv Oblast","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"Bilohorodka","addressRegion":"Kyiv Oblast","addressCountry":"UA"}],"openingHours":"Mo-Su 08:00-20:00"}</script>`;
---
<Base
  title="Fulfillment in Kyiv — Gateway to Ukraine | MTP Group"
  description="Kyiv-based 3PL for international sellers. 3,900 m² warehouse, from $0.41/order. No local entity needed. English team."
  canonical="https://www.fulfillmentmtp.com.ua/en/fulfillment-kyiv/"
  lang="en"
  ogImage="https://www.fulfillmentmtp.com.ua/images/tild6130-6134-4234-a266-373262373033__img_4798.webp"
  schema={schemaJson}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/fulfilment-kyiv/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/fulfilment-kiev/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/fulfillment-kyiv/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/ua/fulfilment-kyiv/">
</Fragment>

<!-- HERO — clean, statement-driven -->
<section class="ek-hero">
<div class="ek-hero-inner">
<div class="badge">KYIV, UKRAINE</div>
<h1>Your logistics base<br>in Eastern Europe.</h1>
<p class="ek-sub">3,900 m&sup2; warehouse near Kyiv. Ship your products to us &mdash; we store, pack, and deliver to 37M+ Ukrainian consumers. No local team. No local entity. English-speaking support.</p>
<form class="hero-form" id="heroForm"><input type="tel" name="phone" placeholder="Phone or WhatsApp" maxlength="25" required autocomplete="tel" aria-label="Phone"><button type="submit">Get started &#8594;</button></form>
<div class="ek-trust">Sellers from Turkey &middot; EU &middot; UK &middot; US already onboard</div>
</div>
</section>

<!-- WHAT YOU NEED — onboarding checklist, unique to EN -->
<section class="ek-checklist"><div class="ctr">
<h2 class="sec-h2">What you need to start selling in Ukraine</h2>
<div class="ek-cl-grid">
<div class="ek-cl-card ek-cl-yes">
<div class="ek-cl-icon">&#10003;</div>
<h3>Products to ship</h3>
<p>Send via DHL, FedEx, UPS, or freight to our warehouse near Boryspil Airport. We handle customs-cleared goods.</p>
</div>
<div class="ek-cl-card ek-cl-yes">
<div class="ek-cl-icon">&#10003;</div>
<h3>15 minutes for a call</h3>
<p>We discuss your products, volumes, and target marketplaces. Free consultation, no commitment.</p>
</div>
<div class="ek-cl-card ek-cl-yes">
<div class="ek-cl-icon">&#10003;</div>
<h3>Digital signature</h3>
<p>Contract signed electronically. No travel to Ukraine needed. We set up everything remotely.</p>
</div>
<div class="ek-cl-card ek-cl-no">
<div class="ek-cl-icon">&#10007;</div>
<h3>Ukrainian entity</h3>
<p>Not needed to start. We process shipments for your test launch. Register later when volumes justify it.</p>
</div>
<div class="ek-cl-card ek-cl-no">
<div class="ek-cl-icon">&#10007;</div>
<h3>Local staff</h3>
<p>Our team of 30+ handles everything. English-speaking account manager assigned to you.</p>
</div>
<div class="ek-cl-card ek-cl-no">
<div class="ek-cl-icon">&#10007;</div>
<h3>Warehouse knowledge</h3>
<p>We manage WMS, inventory, packing, labeling, shipping. You see results in your dashboard.</p>
</div>
</div>
</div></section>

<!-- VIDEO TOUR — warehouse walkthrough -->
<section class="ek-tour"><div class="ctr">
<div class="ek-tour-grid">
<div class="ek-tour-text">
<div class="badge">FACILITY</div>
<h2>See our Kyiv warehouse</h2>
<p>Two locations in Kyiv Oblast. 15 minutes from Boryspil International Airport. Direct access to M-06/E40 highway connecting to EU via Poland.</p>
<div class="ek-wh-cards">
<div class="ek-wh"><strong>Shchaslive</strong><span>2,800 m&sup2; &middot; Main hub</span></div>
<div class="ek-wh"><strong>Bilohorodka</strong><span>1,100 m&sup2; &middot; FEFO zone</span></div>
</div>
<ul class="ek-facts">
<li><strong>3 diesel generators</strong> &mdash; zero downtime since 2022</li>
<li><strong>2 fiber ISPs + Starlink</strong> &mdash; always connected</li>
<li><strong>4 Nova Poshta pickups/day</strong> &mdash; same-day dispatch</li>
<li><strong>30-second order assembly</strong> &mdash; WMS-driven</li>
</ul>
</div>
<div class="ek-tour-video">
<div class="ek-vthumb" onclick="openVideoModal('bHY3cFF9SlI')" style="cursor:pointer">
<img src="https://img.youtube.com/vi/bHY3cFF9SlI/maxresdefault.jpg" onerror="this.src='https://img.youtube.com/vi/bHY3cFF9SlI/hqdefault.jpg'" alt="MTP Group warehouse tour" width="640" height="360" loading="lazy">
<div class="ek-play">&#9654;</div>
</div>
</div>
</div>
</div></section>

<!-- COMPLIANCE — taxes, entity, customs — unique to EN -->
<section class="ek-compliance"><div class="ctr">
<div class="badge badge-dark">COMPLIANCE</div>
<h2 class="sec-h2">The legal side, simplified</h2>
<div class="ek-comp-grid">
<div class="ek-comp-card">
<h3>Phase 1: Test launch</h3>
<div class="ek-phase">No entity</div>
<p>Ship products to our warehouse. We process orders under our entity. You validate market demand with zero paperwork. Duration: as long as you need.</p>
</div>
<div class="ek-comp-card">
<h3>Phase 2: Growth</h3>
<div class="ek-phase">FOP registration</div>
<p>When you hit 50+ orders/day, register a Ukrainian FOP (sole proprietor). Our legal partners handle it in 2-3 weeks. Simplified tax: 5% of revenue.</p>
</div>
<div class="ek-comp-card">
<h3>Phase 3: Scale</h3>
<div class="ek-phase">LLC (optional)</div>
<p>For larger operations, a Ukrainian LLC gives more flexibility. VAT registration, multiple employees, broader banking access. We connect you with accountants.</p>
</div>
</div>
<p class="ek-comp-note">Customs: we accept customs-cleared goods only. Ship via DHL/FedEx with commercial invoice &mdash; they handle clearance at Boryspil.</p>
</div></section>

<!-- COST — interactive calculator -->
<section class="ek-calc"><div class="ctr">
<div class="badge badge-dark">CALCULATOR</div>
<h2 class="sec-h2">Estimate your monthly cost</h2>
<div class="ek-calc-wrap">
<div class="ek-calc-inputs">
<label>Orders per day<input type="range" id="ekOrders" min="5" max="500" value="50" step="5"><div class="ek-cv"><span id="ekOrdVal">50</span> orders/day</div></label>
<label>Storage volume<input type="range" id="ekVolume" min="1" max="50" value="5" step="1"><div class="ek-cv"><span id="ekVolVal">5</span> m&sup3;</div></label>
</div>
<div class="ek-calc-result">
<div class="ek-calc-uah"><span id="ekTotal">27,550</span> <small>UAH/mo</small></div>
<div class="ek-calc-usd">&asymp; $<span id="ekUsd">626</span>/mo</div>
<div class="ek-calc-detail" id="ekDetail">Fulfillment: 24,200 + Storage: 3,350</div>
<div class="ek-calc-inc">Includes: WMS, packing, labels, Nova Poshta</div>
</div>
</div>
</div></section>

<!-- PRICING TABLE -->
<section class="ek-pricing"><div class="ctr">
<div class="badge badge-dark">PRICING 2026</div>
<h2 class="sec-h2">Transparent pricing. No hidden fees.</h2>
<div class="ek-price-tbl">
<div class="ek-pr ek-pr-h"><span>Service</span><span>Condition</span><span>UAH</span><span>USD</span></div>
<div class="ek-pr"><span>Fulfillment</span><span>200+ orders/day</span><span>18</span><span>$0.41</span></div>
<div class="ek-pr"><span>Fulfillment</span><span>100-199/day</span><span>20</span><span>$0.45</span></div>
<div class="ek-pr"><span>Fulfillment</span><span>50-99/day</span><span>22</span><span>$0.50</span></div>
<div class="ek-pr"><span>Fulfillment</span><span>0-49/day</span><span>26</span><span>$0.59</span></div>
<div class="ek-pr"><span>Storage</span><span>per m&sup3;/mo</span><span>650</span><span>$14.77</span></div>
<div class="ek-pr"><span>Receiving</span><span>per unit</span><span>3</span><span>$0.07</span></div>
<div class="ek-pr ek-pr-hl"><span>Monthly min</span><span></span><span>5,000</span><span>$114</span></div>
</div>
<p class="ek-pr-note">Rate: 1 USD &asymp; 44 UAH. All-inclusive: WMS, materials, Nova Poshta shipping.</p>
</div></section>

<!-- FAQ -->
<section class="ek-faq"><div class="ctr">
<div class="badge">FAQ</div>
<h2 class="sec-h2">Questions international sellers ask</h2>
<div class="ek-faq-list">
<div class="ek-faq-item"><button class="ek-faq-q">Do I need a Ukrainian legal entity?</button><div class="ek-faq-a"><p>Not to start. We handle shipments for your test launch under our entity. When you're ready, our legal partners register a Ukrainian FOP in 2-3 weeks. Sellers from Turkey, EU, US, and UK use this approach.</p></div></div>
<div class="ek-faq-item"><button class="ek-faq-q">How do I get my products to your warehouse?</button><div class="ek-faq-a"><p>Ship via DHL, FedEx, UPS, or freight forwarder to our address near Boryspil Airport, Kyiv Oblast. We accept customs-cleared goods. Once arrived, we unload, inspect, barcode, and shelve within 24 hours.</p></div></div>
<div class="ek-faq-item"><button class="ek-faq-q">Does your team speak English?</button><div class="ek-faq-a"><p>Yes. Dedicated English-speaking account manager. Dashboard, reports, and notifications all in English. Communication via email, Telegram, WhatsApp, or Zoom.</p></div></div>
<div class="ek-faq-item"><button class="ek-faq-q">What about power outages?</button><div class="ek-faq-a"><p>3 industrial diesel generators, 2 fiber-optic ISPs, Starlink satellite backup. Zero days of downtime since February 2022. Orders ship every day, no exceptions.</p></div></div>
<div class="ek-faq-item"><button class="ek-faq-q">How do returns work?</button><div class="ek-faq-a"><p>Buyer returns via Nova Poshta. We receive, inspect with photo documentation, and either restock or isolate per your instructions. All visible in your dashboard.</p></div></div>
<div class="ek-faq-item"><button class="ek-faq-q">What's the minimum to start?</button><div class="ek-faq-a"><p>5,000 UAH/month (~$114). No minimum order volume. Even 5 orders/day works. Cost adjusts based on your volume tier.</p></div></div>
<div class="ek-faq-item"><button class="ek-faq-q">How fast can I launch?</button><div class="ek-faq-a"><p>72 hours. Day 1: contract + API setup. Day 2: receive and shelve your goods. Day 3: first orders shipped via Nova Poshta.</p></div></div>
</div>
</div></section>

<!-- SEO ARTICLE -->
<section class="ek-article">
<div class="ctr">
<div class="badge badge-dark">GUIDE</div>
<h2>Fulfillment in Kyiv: why Ukraine's capital is your best 3PL location</h2>
<div class="ek-article-body">
<h3>Kyiv as a logistics hub</h3>
<p>Kyiv Oblast concentrates 30-40% of Ukraine's total warehouse capacity. The region sits at the intersection of major highways (M-06/E40 to Europe via Poland, M-01 north, M-05 to Odesa's port), railway junctions, and Boryspil International Airport. For e-commerce, this means one thing: an order shipped from Kyiv reaches any buyer in Ukraine within 1-2 days. The 3.5+ million consumers in the Kyiv metro area get next-day delivery. No other region in Ukraine offers this speed advantage.</p>

<h3>The cost advantage: Kyiv vs EU fulfillment</h3>
<p>Fulfillment from Kyiv is 30-50% cheaper than equivalent services in Poland, Germany, or the UK. Order processing starts at $0.41 per order (18 UAH at 200+ daily orders). Storage costs $14.77 per cubic meter per month. The monthly minimum is $114. Compare this to Western European 3PLs where per-order costs range from $2-5 and storage from $30-60/m&sup3;. If your target market is Ukraine and Eastern Europe, Kyiv-based fulfillment is the clear economic choice.</p>

<h3>Starting without a local entity</h3>
<p>The traditional barrier to entering Ukraine was bureaucracy: register a company, open a bank account, hire local staff. Modern fulfillment operators have eliminated this. Ship your inventory to a warehouse in Kyiv. The operator integrates with Ukrainian marketplaces, processes orders, and ships to buyers. For your test phase, no local registration is required. When you hit consistent volumes (typically 50+ orders/day), register a Ukrainian FOP &mdash; a 2-3 week process with a local legal partner. Tax is simplified: 5% of revenue.</p>

<h3>The resilience question</h3>
<p>International sellers always ask about infrastructure reliability. The answer from professional fulfillment operators: it's solved. MTP Group's two warehouses near Kyiv are equipped with 3 industrial diesel generators, dual fiber-optic internet, and Starlink satellite backup. Since February 2022, the facility has maintained zero days of downtime &mdash; even during the most severe nationwide blackouts. For context, Kyiv's power situation has stabilized significantly since 2023, but the backup infrastructure remains essential and fully operational.</p>
</div>
</div>
</section>

<!-- VIDEO MODAL -->
<div id="videoModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:9999;align-items:center;justify-content:center">
<div style="position:relative;width:90%;max-width:900px;aspect-ratio:16/9">
<iframe id="videoIframe" width="100%" height="100%" frameborder="0" allow="autoplay;encrypted-media" allowfullscreen style="border-radius:8px"></iframe>
<button onclick="closeVideoModal()" style="position:absolute;top:-40px;right:0;background:none;border:none;color:#fff;font-size:32px;cursor:pointer">&times;</button>
</div>
</div>

</Base>

<style is:global>
:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-block;padding:6px 16px;border:1px solid var(--red);color:var(--red);font-size:11px;font-weight:600;letter-spacing:2px;border-radius:2px;text-transform:uppercase}
.badge-dark{border-color:#ccc;color:#666}
.sec-h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;text-align:center;margin:12px 0 48px}

/* HERO */
.ek-hero{background:var(--black);color:var(--white);padding:140px 24px 100px;text-align:center;position:relative}
.ek-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 30%,rgba(230,51,41,.04),transparent 60%)}
.ek-hero-inner{position:relative;z-index:2;max-width:760px;margin:0 auto}
.ek-hero h1{font-family:var(--fd);font-size:clamp(40px,7vw,84px);font-weight:400;line-height:.92;margin-bottom:28px}
.ek-sub{font-size:clamp(15px,1.6vw,18px);color:rgba(255,255,255,.5);line-height:1.7;max-width:560px;margin:0 auto 40px}
.ek-hero .hero-form{display:flex;gap:12px;max-width:440px;margin:0 auto}
.ek-hero .hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.15);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;font-family:var(--fb);outline:none}
.ek-hero .hero-form input::placeholder{color:rgba(255,255,255,.25)}
.ek-hero .hero-form button{padding:16px 28px;background:var(--red);color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:600;cursor:pointer;font-family:var(--fb);transition:all .3s}
.ek-hero .hero-form button:hover{background:#c42b22}
.ek-trust{margin-top:20px;font-size:12px;color:rgba(255,255,255,.3);letter-spacing:1px}

/* CHECKLIST — what you need / don't need */
.ek-checklist{padding:100px 0;background:var(--gray)}
.ek-cl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.ek-cl-card{padding:36px 28px;border-radius:12px;background:#fff;border:1px solid #e0e0e0}
.ek-cl-icon{font-size:28px;margin-bottom:12px}
.ek-cl-yes .ek-cl-icon{color:#22c55e}
.ek-cl-no .ek-cl-icon{color:var(--red)}
.ek-cl-card h3{font-size:17px;font-weight:600;margin-bottom:8px}
.ek-cl-card p{font-size:14px;color:var(--muted);line-height:1.6}
.ek-cl-no{background:rgba(230,51,41,.02);border-color:rgba(230,51,41,.15)}
.ek-cl-no h3{text-decoration:line-through;color:var(--muted)}

/* VIDEO TOUR */
.ek-tour{padding:100px 0;background:#0a0a0a;color:#fff}
.ek-tour-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:60px;align-items:center}
.ek-tour-text h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;margin:16px 0 16px}
.ek-tour-text>p{font-size:15px;color:rgba(255,255,255,.5);line-height:1.7;margin-bottom:24px}
.ek-wh-cards{display:flex;gap:16px;margin-bottom:24px}
.ek-wh{padding:12px 20px;border:1px solid rgba(255,255,255,.1);border-radius:8px;font-size:13px}
.ek-wh strong{display:block;color:#fff;margin-bottom:2px}
.ek-wh span{color:rgba(255,255,255,.4);font-size:12px}
.ek-facts{list-style:none;padding:0}
.ek-facts li{font-size:14px;color:rgba(255,255,255,.6);padding:8px 0;border-bottom:1px solid rgba(255,255,255,.05)}
.ek-facts li strong{color:#fff}
.ek-vthumb{border-radius:12px;overflow:hidden;position:relative}
.ek-vthumb img{width:100%;aspect-ratio:16/9;object-fit:cover;filter:brightness(.45);transition:filter .3s}
.ek-vthumb:hover img{filter:brightness(.65)}
.ek-play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:48px;color:#fff;background:rgba(230,51,41,.2);border-radius:50%;width:80px;height:80px;margin:auto;transition:transform .3s}
.ek-vthumb:hover .ek-play{transform:scale(1.1)}

/* COMPLIANCE — phases */
.ek-compliance{padding:100px 0}
.ek-comp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-bottom:24px}
.ek-comp-card{padding:40px 28px;border:1px solid #e0e0e0;border-radius:12px;position:relative}
.ek-comp-card h3{font-size:18px;font-weight:600;margin-bottom:8px}
.ek-phase{display:inline-block;padding:4px 12px;background:var(--red);color:#fff;font-size:11px;font-weight:600;border-radius:4px;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px}
.ek-comp-card p{font-size:14px;color:var(--muted);line-height:1.7}
.ek-comp-note{text-align:center;font-size:14px;color:var(--muted);max-width:600px;margin:0 auto;font-style:italic}

/* CALCULATOR */
.ek-calc{padding:100px 0;background:var(--gray)}
.ek-calc-wrap{display:grid;grid-template-columns:1fr 1fr;gap:48px;max-width:800px;margin:0 auto;align-items:center}
.ek-calc-inputs{display:flex;flex-direction:column;gap:32px}
.ek-calc-inputs label{font-size:14px;font-weight:500}
.ek-calc-inputs input[type="range"]{width:100%;margin:12px 0 8px;accent-color:var(--red)}
.ek-cv{font-size:13px;color:var(--muted)}
.ek-cv span{font-weight:700;color:var(--black);font-size:18px}
.ek-calc-result{background:var(--black);color:#fff;padding:48px 36px;border-radius:16px;text-align:center}
.ek-calc-uah{font-family:var(--fd);font-size:42px;line-height:1}
.ek-calc-uah small{font-size:16px;opacity:.5;font-family:var(--fb)}
.ek-calc-usd{font-size:24px;color:var(--red);margin:8px 0 16px;font-weight:600}
.ek-calc-detail{font-size:12px;color:rgba(255,255,255,.4);margin-bottom:8px}
.ek-calc-inc{font-size:11px;color:rgba(255,255,255,.25);text-transform:uppercase;letter-spacing:1px}

/* PRICING */
.ek-pricing{padding:100px 0}
.ek-price-tbl{max-width:750px;margin:0 auto 32px;border-radius:12px;overflow:hidden;border:1px solid #e0e0e0}
.ek-pr{display:grid;grid-template-columns:1.5fr 1fr 0.5fr 0.5fr;border-bottom:1px solid #eee;font-size:14px}
.ek-pr:last-child{border:none}
.ek-pr>span{padding:14px 16px}
.ek-pr-h{background:var(--black);color:#fff;font-weight:600;font-size:12px;text-transform:uppercase}
.ek-pr:not(.ek-pr-h):hover{background:var(--gray)}
.ek-pr-hl{background:var(--red);color:#fff;font-weight:600}
.ek-pr-note{text-align:center;font-size:13px;color:var(--muted)}

/* FAQ */
.ek-faq{padding:100px 0;background:var(--black);color:var(--white)}
.ek-faq-list{max-width:700px;margin:0 auto}
.ek-faq-item{border-bottom:1px solid rgba(255,255,255,.08)}
.ek-faq-q{width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:var(--fb);text-align:left}
.ek-faq-q::after{content:'+';font-size:24px;color:var(--red);transition:transform .3s;flex-shrink:0;margin-left:16px}
.ek-faq-item.open .ek-faq-q::after{transform:rotate(45deg)}
.ek-faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.ek-faq-a p{padding:0 0 20px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.7}

/* ARTICLE */
.ek-article{background:#fff;padding:80px 8vw}
.ek-article h2{font-family:var(--fd);font-size:clamp(28px,3.5vw,44px);font-weight:400;margin:20px 0 40px}
.ek-article-body{max-width:800px}
.ek-article-body h3{font-family:var(--fd);font-size:clamp(18px,2vw,26px);font-weight:400;margin:36px 0 12px;color:var(--black)}
.ek-article-body h3:first-child{margin-top:0}
.ek-article-body p{font-size:16px;line-height:1.85;color:#444;margin-bottom:8px}

@media(max-width:768px){
.ek-hero h1{font-size:clamp(32px,9vw,48px)}
.ek-hero .hero-form{flex-direction:column}.ek-hero .hero-form button{width:100%}
.ek-cl-grid{grid-template-columns:1fr}
.ek-tour-grid{grid-template-columns:1fr}
.ek-wh-cards{flex-direction:column}
.ek-comp-grid{grid-template-columns:1fr}
.ek-calc-wrap{grid-template-columns:1fr}
.ek-pr{grid-template-columns:1.2fr 1fr .6fr .6fr;font-size:12px}
.ek-pr>span{padding:10px 8px}
}

.ek-cl-card,.ek-comp-card,.ek-wh{opacity:1!important;transform:none!important}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
/* FAQ */
document.querySelectorAll('.ek-faq-q').forEach(function(btn){btn.addEventListener('click',function(){var item=btn.parentElement;var a=item.querySelector('.ek-faq-a');var open=item.classList.contains('open');document.querySelectorAll('.ek-faq-item.open').forEach(function(el){el.classList.remove('open');el.querySelector('.ek-faq-a').style.maxHeight=null;});if(!open){item.classList.add('open');a.style.maxHeight=a.scrollHeight+'px';}});});

/* Calculator */
var oSlider=document.getElementById('ekOrders');
var vSlider=document.getElementById('ekVolume');
if(oSlider&&vSlider){
function ekCalc(){
var o=parseInt(oSlider.value),v=parseInt(vSlider.value);
document.getElementById('ekOrdVal').textContent=o;
document.getElementById('ekVolVal').textContent=v;
var r=o>=200?18:o>=100?20:o>=50?22:26;
var f=o*22*r,s=v*650,t=Math.max(f+s,5000);
document.getElementById('ekTotal').textContent=t.toLocaleString('en-US');
document.getElementById('ekUsd').textContent=Math.round(t/44).toLocaleString('en-US');
document.getElementById('ekDetail').textContent='Fulfillment: '+f.toLocaleString('en-US')+' + Storage: '+s.toLocaleString('en-US');
}
oSlider.addEventListener('input',ekCalc);vSlider.addEventListener('input',ekCalc);ekCalc();
}

/* Video modal */
window.openVideoModal=function(id){var m=document.getElementById('videoModal');m.style.display='flex';document.getElementById('videoIframe').src='https://www.youtube.com/embed/'+id+'?autoplay=1';};
window.closeVideoModal=function(){document.getElementById('videoModal').style.display='none';document.getElementById('videoIframe').src='';};
document.getElementById('videoModal').addEventListener('click',function(e){if(e.target===this)closeVideoModal();});
});
</script>
