.final-form{display:flex;gap:12px;justify-content:center;max-width:460px;margin:0 auto}
.final-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.35);border-radius:4px;background:rgba(255,255,255,.1);color:#fff;font-size:15px;font-family:var(--fb);outline:none}
.final-form input::placeholder{color:rgba(255,255,255,.45)}.final-form input:focus{border-color:#fff}
.final-form button{padding:16px 24px;background:#000;color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:background .3s}
.final-form button:hover{background:#222}
.final-checks{display:flex;gap:24px;justify-content:center;flex-wrap:wrap;margin-top:16px;font-size:13px;opacity:.7}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:24px}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}


@media(max-width:768px){
.hero-content::before{left:0;width:2px}.hero-form{flex-direction:column}.hero-form button{width:100%}
.hero-stats{flex-wrap:wrap;gap:24px;padding:32px 24px 0}
.ben-grid{grid-template-columns:1fr}
.case-inner{flex-direction:column;gap:40px}
.final-form{flex-direction:column}
}

.svc-card,.service-card,.num-card,.adv-card,.ben-card,.wh-card,.case-stats,.step{opacity:1!important;transform:none!important}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
