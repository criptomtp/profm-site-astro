.price-cta button{padding:16px 32px;background:var(--red);color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:600;cursor:pointer;font-family:var(--fb);transition:background .3s}
.price-cta button:hover{background:#c42b22}
.faq{padding:100px 0;background:#0a0a0a;color:#fff}
