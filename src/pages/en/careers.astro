---
import Base from '../../layouts/Base.astro';
import HeroCTA from '../../components/HeroCTA.astro';

const today = '2026-05-13';
const validThrough = '2026-07-13';

const orgSchema = {
  "@type": "Organization",
  "name": "MTP Group Fulfillment",
  "sameAs": "https://www.fulfillmentmtp.com.ua",
  "logo": "https://www.fulfillmentmtp.com.ua/images/logo.svg"
};

const locShchaslyve = {
  "@type": "Place",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Shchaslyve",
    "addressRegion": "Kyiv Oblast",
    "addressCountry": "UA",
    "postalCode": "08322"
  }
};

const jobs = [
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Warehouse Worker",
    "description": "Work at a modern fulfillment warehouse in Shchaslyve (Boryspil district). Receiving, slotting, WMS-driven inventory management. Salary from 30,000 UAH/month (~$725) + performance bonuses.",
    "datePosted": today, "validThrough": validThrough, "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema, "jobLocation": locShchaslyve,
    "baseSalary": {"@type":"MonetaryAmount","currency":"UAH","value":{"@type":"QuantitativeValue","value":30000,"unitText":"MONTH","minValue":30000}}
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Order Picker",
    "description": "Pick orders for e-commerce stores and B2B clients per WMS route. Barcode scanning at 2 stages, packaging, quality control. Salary from 30,000 UAH/month + per-order productivity bonuses.",
    "datePosted": today, "validThrough": validThrough, "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema, "jobLocation": locShchaslyve,
    "baseSalary": {"@type":"MonetaryAmount","currency":"UAH","value":{"@type":"QuantitativeValue","value":30000,"unitText":"MONTH","minValue":30000}}
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Inbound Receiver",
    "description": "Receive incoming shipments from clients, verify against invoice, photo-document condition, post to WMS. Salary from 30,000 UAH/month + volume bonuses.",
    "datePosted": today, "validThrough": validThrough, "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema, "jobLocation": locShchaslyve,
    "baseSalary": {"@type":"MonetaryAmount","currency":"UAH","value":{"@type":"QuantitativeValue","value":30000,"unitText":"MONTH","minValue":30000}}
  },
  {
    "@context": "https://schema.org",
    "@type": "JobPosting",
    "title": "Forklift Operator",
    "description": "Operate an electric forklift in our warehouse. Pallet movement up to 2 tons, truck loading/unloading, rack stacking. Category II forklift license required. Salary from 30,000 UAH/month.",
    "datePosted": today, "validThrough": validThrough, "employmentType": "FULL_TIME",
    "hiringOrganization": orgSchema, "jobLocation": locShchaslyve,
    "baseSalary": {"@type":"MonetaryAmount","currency":"UAH","value":{"@type":"QuantitativeValue","value":30000,"unitText":"MONTH","minValue":30000}}
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.fulfillmentmtp.com.ua/en/" },
    { "@type": "ListItem", "position": 2, "name": "Careers", "item": "https://www.fulfillmentmtp.com.ua/en/careers/" }
  ]
};

const schemaJson = jobs.map(j => `<script type="application/ld+json">${JSON.stringify(j)}</script>`).join('') +
  `<script type="application/ld+json">${JSON.stringify(breadcrumbSchema)}</script>`;
---
<Base
  title="Careers at MTP Group — Warehouse Jobs in Kyiv Region from 30,000 UAH"
  description="Hiring warehouse workers, pickers, receivers, forklift operators at our Shchaslyve facility (Boryspil district, Kyiv Oblast). From 30,000 UAH/month + performance bonuses. Open to Ukrainian diaspora returnees."
  canonical="https://www.fulfillmentmtp.com.ua/en/careers/"
  lang="en"
  ogImage="https://www.fulfillmentmtp.com.ua/images/vakansiyi-hero.jpg"
  schema={schemaJson}
  showCTA={true}
>
<Fragment slot="head">
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/vakansiyi/">
  <link rel="alternate" hreflang="ru" href="https://www.fulfillmentmtp.com.ua/ru/vakansii/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/careers/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/vakansiyi/">
</Fragment>

<section class="vk-hero">
  <img class="vk-hero-bg" src="/images/vakansiyi-hero.jpg" alt="MTP Group fulfillment warehouse team in Shchaslyve — pickers, forklift operators, receivers at work" width="1200" height="630" loading="eager" fetchpriority="high" data-md-skip>
  <div class="vk-hero-overlay"></div>
  <div class="ctr">
    <div class="vk-hero-grid">
      <div class="vk-hero-left">
        <div class="vk-chip">MTP GROUP · CAREERS · SHCHASLYVE + BILOHORODKA</div>
        <h1>Warehouse Careers at MTP Group — from 30,000 UAH/month + productivity bonuses</h1>
        <p class="vk-hero-sub">4 open positions at our main facility in Shchaslyve (Boryspil district, Kyiv Oblast) and secondary site in Bilohorodka. Stable 5/2 or 2/2 schedules, paid training, relocation help for Ukrainian diaspora returnees and IDPs from eastern regions.</p>
      </div>
      <div class="vk-hero-right">
        <div class="vk-form-card">
          <div class="vk-form-title">Apply for a position</div>
          <HeroCTA lang="en" theme="light" button="Apply now →" microCopy="✓ We'll call back within 1-2 business hours · mention desired position when we reach you" sourceTag="hero /en/careers/" />
        </div>
      </div>
    </div>
    <div class="vk-hero-stats">
      <div class="vk-stat"><div class="vk-stat-num">30,000+ UAH</div><div class="vk-stat-lbl">STARTING SALARY</div></div>
      <div class="vk-stat"><div class="vk-stat-num">5/2 · 2/2</div><div class="vk-stat-lbl">SHIFT OPTIONS</div></div>
      <div class="vk-stat"><div class="vk-stat-num">3,700 m²</div><div class="vk-stat-lbl">2 FACILITIES</div></div>
      <div class="vk-stat"><div class="vk-stat-num">0 days</div><div class="vk-stat-lbl">DOWNTIME SINCE 2022</div></div>
    </div>
  </div>
</section>

<section class="vk-sec">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">WHY MTP</div>
    <h2 class="vk-h2">6 reasons to join our warehouse operations team</h2>
    <div class="vk-why-grid">
      <div class="vk-why-card">
        <h3>Stable salary + performance bonuses</h3>
        <p>30,000 UAH/month base from day one. Performance bonuses based on output — top performers earn 40,000-50,000 UAH/month. Payroll twice monthly without delays. 3,000 UAH referral bonus if your friend completes 1 month.</p>
      </div>
      <div class="vk-why-card">
        <h3>Relocation support for diaspora returnees</h3>
        <p>Ukrainian citizens returning from PL/CZ/DE/CA/US? We assist with rental search near the warehouse (Shchaslyve, Boryspil, Kyiv left-bank). First month — 50% rent coverage from the company for IDPs from east-Ukraine.</p>
      </div>
      <div class="vk-why-card">
        <h3>Zero operational downtime since 2022</h3>
        <p>3 diesel generators + Starlink — we operate through any blackout. Both warehouses 35-45 km from Kyiv center, outside primary missile impact zones. Salary guaranteed regardless of strikes or power cuts.</p>
      </div>
      <div class="vk-why-card">
        <h3>Modern technology stack</h3>
        <p>WMS system, RF terminals, barcode scanners — European-grade logistics technology. Less manual routine, more tech-assisted operations. Not a Soviet-era warehouse.</p>
      </div>
      <div class="vk-why-card">
        <h3>Paid training from day one</h3>
        <p>First week — paid training on WMS and scanners. No forklift license? We cover certification courses after the probation period. Investment in your skills is our investment.</p>
      </div>
      <div class="vk-why-card">
        <h3>Growth path</h3>
        <p>6-12 months — shift supervisor (+5-10K UAH). 1.5-2 years — assistant warehouse manager. Many of our current managers started as line operators.</p>
      </div>
    </div>
  </div>
</section>

<section class="vk-sec vk-sec-light" id="positions">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">OPEN POSITIONS</div>
    <h2 class="vk-h2">4 vacancies currently open</h2>

    <article class="vk-job">
      <header class="vk-job-head">
        <div><h3 id="warehouse-worker">Warehouse Worker</h3><div class="vk-job-meta">Shchaslyve · Bilohorodka · 5/2 or 2/2 · Full-time</div></div>
        <div class="vk-job-salary">from 30,000 UAH</div>
      </header>
      <div class="vk-job-body">
        <p>The heart of MTP operations. Without accurate warehouse tracking, nothing works — your role keeps the whole system honest.</p>
        <div class="vk-job-cols">
          <div><h4>Responsibilities</h4><ul><li>Receive incoming goods from clients and suppliers</li><li>Slot into racks per WMS-directed routes</li><li>Track operations via barcode scanner and RF terminal</li><li>Cycle counting 1-2 times per week</li><li>Maintain workspace cleanliness and organization</li></ul></div>
          <div><h4>Requirements</h4><ul><li>Attention to detail — we run 99.98% pick accuracy</li><li>Basic PC skills (WMS training provided)</li><li>Physical fitness — lots of walking, lifting up to 15 kg</li><li>Accountability — we sign material responsibility agreements</li><li>Warehouse/logistics experience — bonus, not required</li></ul></div>
          <div><h4>What we offer</h4><ul><li>From 30,000 UAH + productivity bonus</li><li>Bi-weekly guaranteed payroll</li><li>Free meals on-site</li><li>Shuttle bus from metro (for Shchaslyve)</li><li>Paid training first week</li></ul></div>
        </div>
      </div>
    </article>

    <article class="vk-job">
      <header class="vk-job-head">
        <div><h3 id="order-picker">Order Picker</h3><div class="vk-job-meta">Shchaslyve · 5/2 · Full-time · Speed bonus</div></div>
        <div class="vk-job-salary">from 30,000 UAH</div>
      </header>
      <div class="vk-job-body">
        <p>You pick orders for e-commerce stores and distributors. Faster and more accurate = bigger bonus. Our top picker earns 45,000+ UAH/month.</p>
        <div class="vk-job-cols">
          <div><h4>Responsibilities</h4><ul><li>Pick orders per WMS pick lists</li><li>Barcode scanning at 2 stages (pick + pack)</li><li>Quality control before sealing</li><li>Damage-protective packaging</li><li>Handover to outbound shipping</li></ul></div>
          <div><h4>Requirements</h4><ul><li>Speed + accuracy — two parallel skills</li><li>Basic scanner and PC familiarity</li><li>Physical stamina — many pick routes per shift</li><li>Results-oriented — pay-for-performance model</li><li>Bonus: prior picking/warehouse experience</li></ul></div>
          <div><h4>What we offer</h4><ul><li>From 30,000 UAH + bonus per order above target</li><li>Top pickers earn 40,000-50,000 UAH</li><li>Free meals + coffee</li><li>5/2 schedule, optional peak-time overtime</li><li>Train new hires (+5,000 UAH)</li></ul></div>
        </div>
      </div>
    </article>

    <article class="vk-job">
      <header class="vk-job-head">
        <div><h3 id="inbound-receiver">Inbound Receiver</h3><div class="vk-job-meta">Shchaslyve · 5/2 · Full-time · QC role</div></div>
        <div class="vk-job-salary">from 30,000 UAH</div>
      </header>
      <div class="vk-job-body">
        <p>First line of defense — what you miss reaches client orders as errors. Position for attentive, accountable people.</p>
        <div class="vk-job-cols">
          <div><h4>Responsibilities</h4><ul><li>Receive incoming shipments from clients</li><li>Verify completeness against invoice/packing list</li><li>Photo-document condition</li><li>Post to WMS with batch and document binding</li><li>Discrepancy report if numbers don't match</li></ul></div>
          <div><h4>Requirements</h4><ul><li>High attention to detail — critical</li><li>Basic PC and scanner skills</li><li>Document workflow comfort (invoices, packing lists)</li><li>Accountability — material responsibility agreement</li><li>Composure in client discrepancy conversations</li></ul></div>
          <div><h4>What we offer</h4><ul><li>From 30,000 UAH + volume bonus</li><li>Bi-weekly guaranteed payroll</li><li>Free meals</li><li>Climate-controlled receiving area (not on your feet all day)</li><li>Growth to senior receiver (+8,000 UAH)</li></ul></div>
        </div>
      </div>
    </article>

    <article class="vk-job">
      <header class="vk-job-head">
        <div><h3 id="forklift-operator">Forklift Operator</h3><div class="vk-job-meta">Shchaslyve · 5/2 or 2/2 · Full-time · License required</div></div>
        <div class="vk-job-salary">from 30,000 UAH</div>
      </header>
      <div class="vk-job-body">
        <p>Operate the electric forklift on our warehouse floor. Without you, pallets don't move, trucks don't unload, racks don't stock.</p>
        <div class="vk-job-cols">
          <div><h4>Responsibilities</h4><ul><li>Electric forklift operation</li><li>Move pallets up to 2 tons between zones</li><li>Truck loading and unloading</li><li>Stack racks up to 6 meters high</li><li>Basic forklift maintenance (charging, inspection)</li></ul></div>
          <div><h4>Requirements</h4><ul><li>Forklift license Category II (mandatory!)</li><li>1+ year electric forklift experience</li><li>Attention — valuable goods in racks</li><li>12-hour shift readiness if choosing 2/2</li><li>No license? We cover the course after probation</li></ul></div>
          <div><h4>What we offer</h4><ul><li>From 30,000 UAH + shift volume bonus</li><li>Bi-weekly guaranteed payroll</li><li>Free meals</li><li>5/2 or 2/2 schedule — your choice</li><li>Regular forklift maintenance — no work on junk equipment</li></ul></div>
        </div>
      </div>
    </article>
  </div>
</section>

<section class="vk-sec">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">HOW TO APPLY</div>
    <h2 class="vk-h2">3 simple steps to interview</h2>
    <ol class="vk-flow">
      <li><strong>1. Submit application.</strong> Fill the form at the top of the page — only phone number needed. Mention desired position in the call.</li>
      <li><strong>2. We call back within 1-2 business hours.</strong> HR asks a few questions, answers yours, schedules interview at your convenience.</li>
      <li><strong>3. Interview + paid trial shift.</strong> Meet at the warehouse (Shchaslyve or Bilohorodka). Tour the facility. If we click — paid trial shift the next day.</li>
    </ol>
  </div>
</section>

<section class="vk-sec vk-sec-light">
  <div class="ctr">
    <div class="vk-chip vk-chip-dark">FAQ</div>
    <h2 class="vk-h2">Common questions from candidates</h2>
    <div class="vk-faq">
      <details><summary>How does the productivity bonus work?</summary><p>Each position has a productivity target. Anything above target — bonus of 5-30 UAH per unit depending on role. Top performers add 10,000-15,000 UAH monthly to base salary. Details discussed at interview.</p></details>
      <details><summary>Is employment official (with tax records)?</summary><p>Yes — by your choice. We can work via FOP (sole proprietorship) contract, or hire through our LLC (TOV) into your trudova knyzhka. No discrimination toward unofficial setup, but official gives you social package.</p></details>
      <details><summary>Diaspora returnees from PL/CZ/DE/CA/US — special considerations?</summary><p>Yes. We understand returning from EU/North America is a transition. We help with rental search near the warehouse, walk you through Ukrainian payroll documentation, and accommodate language preferences (some team members speak English). Many of our team are returnees themselves.</p></details>
      <details><summary>How to get to Shchaslyve warehouse?</summary><p>From Kyiv — marshrutka from "Boryspilska" metro station or electric train to "Shchaslyve" station. 40-60 min from center. Corporate shuttle from metro morning + evening. To Bilohorodka — marshrutka from "Akademmistechko" metro or your own transport via Zhytomyr highway.</p></details>
      <details><summary>What about meals?</summary><p>Free hot meals on-site — we have our own kitchen. Unlimited coffee, tea, water. Fridge for personal lunches. Break room with microwave.</p></details>
      <details><summary>Safety during wartime?</summary><p>Both facilities 35-45 km from Kyiv center — outside primary impact zones. 3 diesel generators, Starlink connectivity, fire suppression, reinforced perimeter. Zero operational downtime since February 2022. Salary guaranteed regardless of strikes or power cuts.</p></details>
      <details><summary>What if I fail the trial period?</summary><p>14-day probation paid in full (not as trainee). If we don't click — we part ways without conflict. Honest conversation on day 7 about continuation.</p></details>
    </div>
  </div>
</section>

</Base>

<style is:global>
.vk-hero{position:relative;color:#fff;padding:64px 0 48px;overflow:hidden;background:#0a0a0a;border-bottom:6px solid #e63329}
.vk-hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;z-index:0}
.vk-hero-overlay{position:absolute;inset:0;background:linear-gradient(90deg,rgba(10,10,10,.95) 0%,rgba(10,10,10,.78) 50%,rgba(230,51,41,.45) 100%);z-index:1}
.vk-hero .ctr{position:relative;z-index:2;max-width:1280px}
.vk-hero-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:48px;align-items:center;margin-bottom:36px}
.vk-hero-left{min-width:0}
.vk-chip{display:inline-block;background:#e63329;color:#fff;font-family:'DM Sans',sans-serif;font-weight:700;font-size:11px;letter-spacing:.18em;padding:8px 14px;text-transform:uppercase;margin-bottom:20px}
.vk-chip-dark{background:#000}
.vk-hero h1{font-family:Unbounded,sans-serif;font-weight:900;font-size:clamp(26px,3.4vw,46px);line-height:1.06;letter-spacing:-0.025em;margin:0 0 20px;color:#fff}
.vk-hero-sub{font-family:'DM Sans',sans-serif;font-size:17px;line-height:1.55;color:rgba(255,255,255,.92);max-width:680px;margin:0}
.vk-form-card{background:#fff;color:#000;padding:24px;border:3px solid #e63329;box-shadow:8px 8px 0 rgba(0,0,0,.4)}
.vk-form-title{font-family:Unbounded,sans-serif;font-weight:800;font-size:18px;margin-bottom:16px;color:#000;text-transform:uppercase;letter-spacing:.02em;line-height:1.2}
.vk-hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:0;background:rgba(0,0,0,.85);border:2px solid #000}
.vk-stat{padding:18px 16px;border-right:1px solid rgba(255,255,255,.12);text-align:center}
.vk-stat:last-child{border-right:0}
.vk-stat-num{font-family:Unbounded,sans-serif;font-weight:900;font-size:clamp(16px,1.6vw,22px);color:#fff;letter-spacing:-0.02em;line-height:1.1}
.vk-stat-lbl{font-family:'DM Sans',sans-serif;font-weight:700;font-size:10px;letter-spacing:.14em;color:rgba(255,255,255,.7);margin-top:6px;text-transform:uppercase}
.vk-sec{padding:80px 0;background:#fff}
.vk-sec-light{background:#f3f3f3}
.vk-h2{font-family:Unbounded,sans-serif;font-weight:800;font-size:clamp(24px,3vw,38px);line-height:1.15;letter-spacing:-0.02em;margin:16px 0 32px;color:#000}
.vk-why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.vk-why-card{background:#fff;border:1px solid #ddd;border-left:4px solid #e63329;padding:28px 24px}
.vk-why-card h3{font-family:Unbounded,sans-serif;font-weight:800;font-size:17px;color:#000;margin:0 0 12px;line-height:1.25}
.vk-why-card p{font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.55;color:#333;margin:0}
.vk-job{background:#fff;border:2px solid #000;margin-bottom:24px;overflow:hidden}
.vk-job-head{display:flex;justify-content:space-between;align-items:center;background:#0a0a0a;color:#fff;padding:24px 28px;gap:24px;flex-wrap:wrap}
.vk-job-head h3{font-family:Unbounded,sans-serif;font-weight:900;font-size:22px;color:#fff;margin:0 0 6px;letter-spacing:-0.02em}
.vk-job-meta{font-family:'DM Sans',sans-serif;font-size:12px;color:rgba(255,255,255,.75);letter-spacing:.05em}
.vk-job-salary{font-family:Unbounded,sans-serif;font-weight:900;font-size:22px;color:#e63329;letter-spacing:-0.02em;background:#fff;padding:8px 16px;border:2px solid #e63329;flex-shrink:0}
.vk-job-body{padding:28px}
.vk-job-body > p{font-family:'DM Sans',sans-serif;font-size:16px;line-height:1.5;color:#333;margin:0 0 24px}
.vk-job-cols{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
.vk-job-cols h4{font-family:'DM Sans',sans-serif;font-weight:700;font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#e63329;margin:0 0 12px;padding-bottom:8px;border-bottom:2px solid #e63329}
.vk-job-cols ul{list-style:none;padding:0;margin:0;font-family:'DM Sans',sans-serif;font-size:14px;line-height:1.5;color:#333}
.vk-job-cols li{padding:6px 0 6px 20px;position:relative}
.vk-job-cols li:before{content:"▸";color:#e63329;font-weight:700;position:absolute;left:0;top:6px}
.vk-flow{list-style:none;padding:0;margin:0;counter-reset:f}
.vk-flow li{padding:24px 0 24px 64px;border-bottom:1px solid #eee;position:relative;font-family:'DM Sans',sans-serif;font-size:16px;line-height:1.55;color:#333;counter-increment:f}
.vk-flow li:before{content:counter(f);position:absolute;left:0;top:22px;width:44px;height:44px;background:#e63329;color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:Unbounded,sans-serif;font-weight:800;font-size:18px}
.vk-flow li strong{color:#000;font-weight:700;display:block;margin-bottom:4px}
.vk-faq{display:flex;flex-direction:column;gap:8px}
.vk-faq details{background:#fff;border:1px solid #ddd;padding:0}
.vk-faq summary{padding:18px 24px;cursor:pointer;font-family:Unbounded,sans-serif;font-weight:700;font-size:16px;color:#000;list-style:none;position:relative}
.vk-faq summary::after{content:"+";position:absolute;right:24px;top:18px;color:#e63329;font-size:24px;line-height:1}
.vk-faq details[open] summary::after{content:"−"}
.vk-faq summary::-webkit-details-marker{display:none}
.vk-faq details p{padding:0 24px 18px;margin:0;font-family:'DM Sans',sans-serif;font-size:15px;line-height:1.6;color:#333}
@media (max-width:980px){.vk-hero-grid{grid-template-columns:1fr;gap:28px}.vk-form-card{max-width:none}}
@media (max-width:900px){.vk-hero{padding:40px 0 32px}.vk-hero-stats{grid-template-columns:repeat(2,1fr)}.vk-stat:nth-child(2){border-right:0}.vk-stat:nth-child(1),.vk-stat:nth-child(2){border-bottom:1px solid rgba(255,255,255,.12)}.vk-why-grid{grid-template-columns:1fr;gap:16px}.vk-job-cols{grid-template-columns:1fr;gap:24px}.vk-job-head{flex-direction:column;align-items:flex-start}}
</style>
