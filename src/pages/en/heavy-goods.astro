---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Heavy Goods Fulfillment Ukraine — 3PL Warehouse | MTP Group"
  description="Specialized fulfillment for heavy and oversized goods in Ukraine. Pallet storage from 450 UAH/mo. Forklifts, special carriers, blackout-proof warehouse."
  canonical="https://fulfillmentmtp.com.ua/en/heavy-goods/"
  lang="en"
>
<Fragment slot="head">
<script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","address":[{"@type":"PostalAddress","addressLocality":"Shchaslive, Boryspil district","addressRegion":"Kyiv region","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"Bilohorodka","addressRegion":"Kyiv region","addressCountry":"UA"}],"openingHours":"Mo-Su 08:00-20:00"}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Heavy Goods Fulfillment","provider":{"@type":"Organization","name":"MTP Group"}}</script>
  <link rel="alternate" hreflang="uk" href="https://fulfillmentmtp.com.ua/ua/fulfilment-vazhkykh-tovariv/">
  <link rel="alternate" hreflang="ru" href="https://fulfillmentmtp.com.ua/fulfilment-vazhkykh-tovariv/">
  <link rel="alternate" hreflang="en" href="https://fulfillmentmtp.com.ua/en/heavy-goods/">
  <link rel="alternate" hreflang="x-default" href="https://fulfillmentmtp.com.ua/ua/fulfilment-vazhkykh-tovariv/">
</Fragment>

<section class="hero">
<div class="hero-bg"></div>
<div class="hero-content">
<div class="badge">HEAVY GOODS</div>
<h1>Heavy &amp; Oversized<br>Goods Fulfillment<br>in Ukraine<span style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)"> — 3PL warehouse for heavy and oversized items</span></h1>
<p class="hero-sub">Specialized storage and delivery for items from 30 kg to 1 ton per pallet. Solar panels, construction materials, appliances — we receive, store, and ship it all.</p>
<form class="hero-form" id="heroForm"><input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="13" required autocomplete="tel"><button type="submit">Get a quote &#8594;</button></form>
<div class="hero-note">Free consultation &#183; Custom pricing</div>
</div>
<div class="hero-stats">
<div class="hero-stat"><div class="hero-stat-val">500 kg</div><div class="hero-stat-label">max per unit</div></div>
<div class="hero-stat"><div class="hero-stat-val">Pallet</div><div class="hero-stat-label">storage available</div></div>
<div class="hero-stat"><div class="hero-stat-val">Specialist</div><div class="hero-stat-label">carriers network</div></div>
</div>
</section>

<section class="cats"><div class="ctr">
<div class="badge badge-dark">PRODUCT TYPES</div>
<h2 class="sec-h2">What kind of heavy goods we handle</h2>
<div class="cats-grid">
<div class="cat-card"><div class="cat-icon">&#9728;</div><h3>Solar Panels &amp; Inverters</h3><p>Panels, inverters, battery systems. Weight from 20 kg per unit. Pallet storage with address tracking in WMS.</p></div>
<div class="cat-card"><div class="cat-icon">&#x1F9F1;</div><h3>Construction Materials</h3><p>Tools, fittings, hardware, fixtures. Weight from 10 kg. Bulk receiving and individual order picking.</p></div>
<div class="cat-card"><div class="cat-icon">&#9889;</div><h3>Home Appliances</h3><p>Washing machines, boilers, air conditioners. Weight from 30 kg. Careful handling with forklifts and pallet jacks.</p></div>
<div class="cat-card"><div class="cat-icon">&#x1F3CB;</div><h3>Sports Equipment</h3><p>Treadmills, dumbbells, benches. Weight from 15 kg. Reinforced shelving and secure pallet zones.</p></div>
<div class="cat-card"><div class="cat-icon">&#x1FA91;</div><h3>Furniture &amp; Decor</h3><p>Chairs, tables, shelves in flat-pack or assembled. Weight from 10 kg. Oversized item handling available.</p></div>
<div class="cat-card"><div class="cat-icon">&#x1F3ED;</div><h3>Industrial B2B</h3><p>Spare parts, components, industrial equipment. Bulk B2B shipments and full-truck deliveries across Ukraine.</p></div>
</div>
</div></section>

<section class="case"><div class="ctr">
<div class="badge">CASE STUDY</div>
<h2 class="sec-h2">How EcoDrive Reduced Logistics Costs by 34%</h2>
<div class="case-inner">
<div class="case-text">
<p>EcoDrive sells solar panels and energy storage systems across Ukraine. Each unit weighs 40-60 kg, and a full pallet reaches up to 800 kg. Before partnering with MTP Group, they rented their own warehouse and hired loaders, spending over 40,000 UAH monthly on overhead alone.</p>
<blockquote>"Standard fulfillment providers either refused our cargo or lacked the equipment to handle heavy goods safely"</blockquote>
<p><strong>MTP Solution:</strong> dedicated pallet storage zones, WMS pallet tracking with weight control, shipping through Nova Poshta Cargo and specialist freight carriers. Result: 34% reduction in total logistics costs, zero damage incidents, and the EcoDrive team fully refocused on sales and marketing.</p>
</div>
<div class="case-stats">
<div class="case-stat"><div class="case-stat-val">50+</div><div class="case-stat-label">shipments / day</div></div>
<div class="case-stat"><div class="case-stat-val">0</div><div class="case-stat-label">damages</div></div>
<div class="case-stat"><div class="case-stat-val">1 day</div><div class="case-stat-label">onboarding</div></div>
</div>
</div>
</div></section>

<section class="adv"><div class="ctr">
<div class="badge badge-dark">WHY MTP GROUP</div>
<h2 class="sec-h2">Benefits of heavy goods fulfillment with us</h2>
<div class="adv-grid">
<div class="adv-card"><h3>Specialized Equipment</h3><p>Electric forklifts, reinforced pallet racks rated to 1,000 kg per tier, and hydraulic pallet jacks for safe handling of every shipment.</p></div>
<div class="adv-card"><h3>Pallet Storage from 450 UAH/mo</h3><p>Address-based pallet tracking in our WMS system with weight control. Each pallet has its own cell, accessible at any time.</p></div>
<div class="adv-card"><h3>Specialist Carriers Network</h3><p>Nova Poshta Cargo, Meest Cargo, and direct B2B freight partners. Carrier selection depends on weight, dimensions, and destination.</p></div>
<div class="adv-card"><h3>Blackout-Proof Operations</h3><p>3 generators, Starlink, 2 fiber-optic ISPs. Zero downtime days since 2022. Your orders ship on schedule regardless of power grid status.</p></div>
</div>
</div></section>

<section class="pricing"><div class="ctr">
<div class="badge badge-dark">TARIFFS</div>
<h2 class="sec-h2">Heavy goods pricing</h2>
<div class="price-table">
<div class="price-row price-header"><span>Service</span><span>Weight</span><span>Price</span></div>
<div class="price-row"><span>Receiving (per unit)</span><span>up to 10 kg</span><span>from 3 UAH</span></div>
<div class="price-row"><span>Receiving (per unit)</span><span>10-30 kg</span><span>from 7 UAH</span></div>
<div class="price-row"><span>Receiving (per unit)</span><span>30-50 kg</span><span>from 12 UAH</span></div>
<div class="price-row"><span>Receiving (per unit)</span><span>50+ kg</span><span>individual</span></div>
<div class="price-row price-highlight"><span>Pallet storage</span><span>up to 1 ton</span><span>from 450 UAH/mo</span></div>
<div class="price-row"><span>Shipping</span><span>any weight</span><span>carrier rate</span></div>
</div>
<p class="price-note">Exact calculation is free. Leave your number and we will calculate the cost for your specific products.</p>
<div class="price-cta"><button onclick="document.getElementById('finalForm').querySelector('input').focus();window.scrollTo({top:document.getElementById('ctaSection').offsetTop,behavior:'smooth'})">Calculate my cost &#8594;</button></div>
</div></section>

<section class="faq"><div class="ctr">
<div class="badge">FAQ</div>
<h2 class="sec-h2">Frequently asked questions</h2>
<div class="faq-list">
<div class="faq-item"><button class="faq-q">What is the maximum weight per item you accept?</button><div class="faq-a"><p>We handle items up to 50 kg per unit as standard fulfillment. For heavier goods, we offer pallet storage supporting up to 1 ton per pallet.</p></div></div>
<div class="faq-item"><button class="faq-q">Do you have forklifts for pallet handling?</button><div class="faq-a"><p>Yes, both of our warehouses in Kyiv Oblast are equipped with electric forklifts and manual hydraulic pallet jacks.</p></div></div>
<div class="faq-item"><button class="faq-q">How much does pallet storage cost?</button><div class="faq-a"><p>Pallet storage starts from 450 UAH per month for pallets up to 1 ton. The exact price depends on the total number of pallets, storage duration, and turnover frequency.</p></div></div>
<div class="faq-item"><button class="faq-q">Do you handle B2B bulk shipments?</button><div class="faq-a"><p>Absolutely. We organize full-truck and partial-load B2B deliveries across Ukraine through Nova Poshta Cargo, Meest Cargo, and direct freight partners.</p></div></div>
<div class="faq-item"><button class="faq-q">Is cargo insured during storage and shipping?</button><div class="faq-a"><p>All goods stored in our warehouses are covered by warehouse liability insurance. Additional cargo insurance for shipping can be arranged through our carrier partners upon request.</p></div></div>
</div>
</div></section>

<section class="article-section">
<div class="ctr">
<div class="badge badge-dark">KNOWLEDGE BASE</div>
<h2>Heavy Goods Fulfillment in Ukraine: What You Need to Know</h2>
<div class="article-content">
<h3>What qualifies as a heavy item in fulfillment?</h3>
<p>In the logistics industry, a heavy item is generally defined as any single product weighing 30 kg or more, or a pallet load exceeding 200 kg. These goods require specialized handling equipment such as pallet forklifts, reinforced shelving, and dedicated storage zones.</p>
<h3>How heavy goods storage works at a modern warehouse</h3>
<p>Storing heavy goods is fundamentally different from handling standard e-commerce products. The first requirement is pallet-based storage with address tracking. Our racking systems support up to 1,000 kg per tier.</p>
<h3>Cost savings through outsourced heavy fulfillment</h3>
<p>A typical self-managed setup for heavy goods costs 40,000-80,000 UAH per month. By switching to a specialized fulfillment provider, businesses typically reduce their total logistics costs by 25-40 percent.</p>
</div>
</div>
</section>

</Base>

<style is:global>
:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:24px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}

.hero{position:relative;min-height:90vh;background:#000;color:#fff;display:flex;flex-direction:column;justify-content:center;padding:140px 0 0;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:linear-gradient(105deg,rgba(0,0,0,.88) 0%,rgba(0,0,0,.65) 55%,rgba(0,0,0,.45) 100%),url('https://img.youtube.com/vi/bHY3cFF9SlI/maxresdefault.jpg') center/cover no-repeat}
.hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero-content::before{content:'';position:absolute;left:calc(8vw - 40px);top:0;height:100%;width:3px;background:var(--red,#e63329)}
.hero h1{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(48px,6vw,90px);font-weight:400;line-height:.9;margin-bottom:28px}
.hero-sub{font-size:clamp(16px,1.8vw,19px);color:rgba(255,255,255,.6);line-height:1.7;max-width:560px;margin-bottom:40px}
.hero-form{display:flex;gap:12px;max-width:460px}
.hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;outline:none}
.hero-form input::placeholder{color:rgba(255,255,255,.25)}.hero-form input:focus{border-color:rgba(255,255,255,.5)}
.hero-form button{padding:16px 24px;background:transparent;color:#fff;border:2px solid #fff;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;white-space:nowrap;transition:all .3s}
.hero-form button:hover{background:var(--red,#e63329);border-color:var(--red,#e63329);color:#fff}
.hero-note{font-size:13px;color:rgba(255,255,255,.3);margin-top:12px}
.hero-stats{display:flex;gap:32px;padding:48px 8vw 0;margin-top:auto;position:relative;z-index:2}
.hero-stat{border-top:3px solid var(--red,#e63329);padding:20px 0;flex:1}
.hero-stat-val{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(36px,5vw,64px);font-weight:400;color:#fff;white-space:nowrap}
.hero-stat-label{font-size:11px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:2px;margin-top:4px}
.sec-h2{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(32px,4.5vw,56px);font-weight:400;margin-bottom:48px}
.cats{padding:100px 0}
.cats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#e0e0e0;border:1px solid #e0e0e0;border-radius:4px;overflow:hidden}
.cat-card{background:#fff;padding:36px 28px;transition:background .3s}.cat-card:hover{background:var(--gray,#f5f5f5)}
.cat-icon{font-size:32px;margin-bottom:12px}.cat-card h3{font-size:17px;font-weight:500;margin-bottom:6px}.cat-card p{font-size:14px;color:var(--muted,#666)}
.case{padding:100px 0;background:#0a0a0a;color:#fff}
.case-inner{display:flex;gap:80px;align-items:center}
.case-text{flex:1.2}.case-text blockquote{font-family:var(--fd,'DM Serif Display',serif);font-style:italic;font-size:18px;color:rgba(255,255,255,.5);line-height:1.5;border-left:3px solid var(--red,#e63329);padding-left:20px;margin:20px 0}
.case-text p{font-size:15px;color:rgba(255,255,255,.7);line-height:1.7;margin-bottom:16px}
.case-stats{flex:.8;display:flex;flex-direction:column;gap:32px}
.case-stat{text-align:center;padding:28px;border:1px solid rgba(255,255,255,.08);border-radius:8px}
.case-stat-val{font-size:36px;font-weight:300;margin-bottom:4px}.case-stat-label{font-size:12px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:1px}
.adv{padding:100px 0;background:var(--gray,#f5f5f5)}
.adv-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.adv-card{background:#fff;padding:32px;border-radius:8px;border-top:3px solid var(--red,#e63329)}
.adv-card h3{font-size:16px;font-weight:500;margin-bottom:8px}.adv-card p{font-size:14px;color:var(--muted,#666);line-height:1.6}
.pricing{padding:100px 0}
.price-table{max-width:700px;margin:0 auto 32px;border-radius:8px;overflow:hidden;border:1px solid #e0e0e0}
.price-row{display:flex;border-bottom:1px solid #eee;font-size:15px}.price-row:last-child{border:none}
.price-row>span{flex:1;padding:14px 20px}
.price-header{background:#000;color:#fff;font-weight:600;font-size:13px;text-transform:uppercase;letter-spacing:.5px}
.price-row:not(.price-header):hover{background:var(--gray,#f5f5f5)}
.price-highlight{background:var(--red,#e63329);color:#fff;font-weight:600}
.price-note{text-align:center;font-size:15px;color:var(--muted,#666);margin-bottom:24px;max-width:500px;margin-left:auto;margin-right:auto}
.price-cta{text-align:center}.price-cta button{padding:16px 32px;background:var(--red,#e63329);color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:600;cursor:pointer;transition:background .3s}.price-cta button:hover{background:#c42a22}
.faq{padding:100px 0;background:#0a0a0a;color:#fff}
.faq-list{max-width:700px;margin:0 auto}
.faq-item{border-bottom:1px solid rgba(255,255,255,.08)}
.faq-q{width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;text-align:left}
.faq-q::after{content:'+';font-size:24px;color:var(--red,#e63329);transition:transform .3s}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.faq-a p{padding:0 0 20px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.7}
.article-section{background:#f5f5f5;padding:80px 8vw}
.article-section h2{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(32px,4vw,52px);font-weight:400;margin:20px 0 40px}
.article-content{max-width:800px}
.article-content h3{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(18px,2vw,26px);font-weight:400;margin:36px 0 12px;color:#000}.article-content h3:first-child{margin-top:0}
.article-content p{font-size:16px;line-height:1.85;color:#444;margin-bottom:8px}
@media(max-width:768px){
.hero-content::before{left:0;width:2px}.hero-form{flex-direction:column}.hero-form button{width:100%}
.hero-stats{flex-wrap:wrap;gap:24px;padding:32px 24px 0}
.cats-grid,.adv-grid{grid-template-columns:1fr}
.case-inner{flex-direction:column;gap:40px}
.final-form{flex-direction:column}
}

.svc-card,.service-card,.num-card,.adv-card,.ben-card,.wh-card,.case-stats,.step{opacity:1!important;transform:none!important}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.15});
document.querySelectorAll('.reveal').forEach(function(el,i){el.style.transitionDelay=(i%3)*.1+'s';obs.observe(el);});
document.querySelectorAll('.faq-q').forEach(function(btn){btn.addEventListener('click',function(){var item=btn.parentElement;var a=item.querySelector('.faq-a');var open=item.classList.contains('open');document.querySelectorAll('.faq-item.open').forEach(function(el){el.classList.remove('open');el.querySelector('.faq-a').style.maxHeight=null;});if(!open){item.classList.add('open');a.style.maxHeight=a.scrollHeight+'px';}});});
);inp.addEventListener('focus',function(){if(!this.value)this.value='+38 (';});inp.addEventListener('blur',function(){if(this.value==='+38 (')this.value='';});}
var leads=JSON.parse(localStorage.getItem('mtp_crm_leads')||'[]');leads.push({id:Date.now(),company:'Heavy Goods EN',contact:'',phone:ph,email:'',shipments:0,type:'heavy',source:'Heavy goods page (EN)',status:'new',date:new Date().toISOString().split('T')[0],comments:[{text:'Form: heavy goods (EN)',date:new Date().toLocaleString('uk-UA')}],onboarding:[false,false,false,false,false,false,false]});localStorage.setItem('mtp_crm_leads',JSON.stringify(leads));fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});form.innerHTML='<div style="text-align:center"><p style="color:#22c55e;font-size:18px;font-weight:500">\u2705 Thank you!</p><p style="color:rgba(255,255,255,.5);font-size:14px;margin-top:8px">We will call you back shortly</p></div>';setTimeout(function(){window.location.href='/en/thanks/';},1500);});}
});
</script>
