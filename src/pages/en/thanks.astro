---
import Base from '../../layouts/Base.astro';
---
<Base title="Thank you for your request | MTP Group" lang="en" showCTA={false}>
<Fragment slot="head">
<script is:inline>
if(typeof gtag==='function'){gtag('event','conversion',{'send_to':'AW-614588275/guFqCI665pYcEPO-h6UC','value':1.0,'currency':'UAH'});}
</script>
</Fragment>

<section class="thanks-hero">
<h1>Thank you!</h1>
<p>We will get back to you within the day</p>
<p class="sub">Meanwhile, check out the main benefits of working with us</p>
</section>

<section class="thanks-videos">
<iframe src="https://www.youtube.com/embed/eP4FYJnyz_8" title="MTP Group interview on Europa Plus" loading="lazy" allowfullscreen></iframe>
<iframe src="https://www.youtube.com/embed/bHY3cFF9SlI" title="MTP Group warehouse tour" loading="lazy" allowfullscreen></iframe>
<iframe src="https://www.youtube.com/embed/mE4N4CHwG7o" title="MTP Group client testimonial" loading="lazy" allowfullscreen></iframe>
</section>

<section class="thanks-blog">
<h2>Read something useful</h2>
<div class="thanks-blog-grid">
<a href="/en/blog/post/fulfillment-vs-own-warehouse-2025/" class="thanks-blog-card">
<img src="/images/blog/ecommerce-fulfillment-pricing.webp" alt="Fulfillment vs Own Warehouse" loading="lazy">
<div class="card-text"><h3>Fulfillment vs Own Warehouse in 2025</h3></div>
</a>
<a href="/en/blog/post/how-fulfillment-works-ukraine-2025/" class="thanks-blog-card">
<img src="/images/blog/yak-pratsiuie-fulfil.webp" alt="How Fulfillment Works" loading="lazy">
<div class="card-text"><h3>How Fulfillment Works in Ukraine — 2025</h3></div>
</a>
<a href="/en/blog/post/top-5-logistics-mistakes-ecommerce/" class="thanks-blog-card">
<img src="/images/blog/ecommerce-logistics-guide.webp" alt="Top 5 Logistics Mistakes" loading="lazy">
<div class="card-text"><h3>Top 5 Logistics Mistakes in E-commerce</h3></div>
</a>
<a href="/en/blog/post/how-to-choose-fulfillment-operator/" class="thanks-blog-card">
<img src="/images/blog/fulfillment-operator-selection.webp" alt="How to Choose a Fulfillment Operator" loading="lazy">
<div class="card-text"><h3>How to Choose a Fulfillment Operator</h3></div>
</a>
</div>
</section>
</Base>

<style is:global>
.thanks-hero{background:#000;color:#fff;text-align:center;padding:80px 24px 60px}
.thanks-hero h1{font-family:'DM Serif Display',serif;font-size:clamp(36px,5vw,56px);font-weight:400;margin-bottom:16px}
.thanks-hero p{color:rgba(255,255,255,.7);font-size:18px;max-width:500px;margin:0 auto}
.thanks-hero .sub{font-size:15px;color:rgba(255,255,255,.5);margin-top:12px}
.thanks-videos{display:flex;gap:20px;padding:60px 24px;max-width:1200px;margin:0 auto;flex-wrap:wrap}
.thanks-videos iframe{flex:1;min-width:280px;aspect-ratio:16/9;border:none;border-radius:12px}
.thanks-blog{padding:60px 24px;max-width:1200px;margin:0 auto}
.thanks-blog h2{font-family:'DM Serif Display',serif;font-size:32px;font-weight:400;margin-bottom:24px}
.thanks-blog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:20px}
.thanks-blog-card{border:1px solid #e0e0e0;border-radius:10px;overflow:hidden;text-decoration:none;color:inherit;transition:box-shadow .3s}
.thanks-blog-card:hover{box-shadow:0 4px 20px rgba(0,0,0,.1)}
.thanks-blog-card img{width:100%;height:180px;object-fit:cover}
.thanks-blog-card .card-text{padding:16px}
.thanks-blog-card h3{font-size:16px;font-weight:500;line-height:1.4}
</style>
