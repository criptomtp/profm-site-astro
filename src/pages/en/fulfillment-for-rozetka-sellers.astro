    </div>
  </div>
</section>

<!-- FAQ -->
<section class="rze-faq">
  <div class="rze-faq__inner">
    <LabelChip text="06 · FREQUENTLY ASKED" variant="muted" />
    <h2 class="rze-h2">12 questions international brands ask before entering Ukraine</h2>
    <AccordionGroup items={faq} />
  </div>
</section>

<!-- BOTTOM DARK CTA -->
<DarkCTA
  title="Get a quote for entering Ukraine through MTP"
  sub="Free quote tailored to your SKUs, volumes, and target marketplaces. Includes a savings comparison versus Rozetka FBO and EU hubs (Poland, Czechia)."
  primary={{ label: 'Request a quote →', href: '#heroLeadForm' }}
  secondary={{ label: 'Cost calculator', href: '/en/calculator/' }}
/>

</Base>

<style is:global>
:root { --mtp-red:#e63329; }
.rze-bc { background:#f6f6f4; padding:14px 0; font-size:13px; }
.rze-bc__inner { max-width:1180px; margin:0 auto; padding:0 1.5rem; display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
.rze-bc a { color:#666; text-decoration:none; } .rze-bc a:hover { color:#000; }
.rze-bc__current { color:#000; font-weight:600; }
.rze-bc span[aria-hidden] { color:#bbb; }

/* HERO — VARIANT B: split + 4 stat cards stack */
.rze { background:#fff; border-bottom:1px solid #ededed; padding:56px 0 0; }
.rze__inner { max-width:1180px; margin:0 auto; padding:0 1.5rem; display:grid; grid-template-columns:60% 40%; gap:48px; align-items:start; }
.rze__main { padding-right:24px; }
.rze__h1 { font-size:clamp(2rem, 4.4vw, 3.4rem); line-height:1.05; letter-spacing:-0.015em; margin:18px 0 22px; font-weight:800; color:#000; }
.rze__accent { color:var(--mtp-red); }
.rze__lead { font-size:clamp(1.05rem, 1.4vw, 1.18rem); line-height:1.6; color:#333; margin:0 0 30px; max-width:640px; }
.rze__form { max-width:560px; }
.rze__links { margin-top:18px; font-size:14px; display:flex; gap:10px; flex-wrap:wrap; align-items:center; color:#666; }
.rze__links a { color:#000; text-decoration:none; border-bottom:1.5px solid #000; padding-bottom:1px; transition:color .15s, border-color .15s; }
.rze__links a:hover { color:var(--mtp-red); border-color:var(--mtp-red); }

/* 4 stat cards stack right */
.rze__cards { display:grid; grid-template-columns:1fr; gap:0; padding-top:32px; }
.rze__card { padding:22px 22px 24px; background:#fff; border:1.5px solid #1a1a1a; border-bottom-width:0; }
.rze__card:last-child { border-bottom-width:1.5px; }
.rze__card-num { display:block; font-size:clamp(1.6rem, 2.4vw, 2rem); font-weight:800; line-height:1.05; color:#000; letter-spacing:-0.01em; }
.rze__card-label { display:block; font-size:0.86rem; line-height:1.45; color:#444; margin-top:8px; letter-spacing:0.01em; }

.rze__logos { max-width:1180px; margin:48px auto 0; padding:24px 1.5rem 36px; border-top:1px solid #ededed; }
.rze__logos-label { display:block; font-size:11px; font-weight:700; letter-spacing:0.16em; color:#999; margin-bottom:14px; }
.rze__logos-row { display:flex; gap:18px 24px; flex-wrap:wrap; align-items:center; font-size:14px; font-weight:700; letter-spacing:0.04em; color:#1a1a1a; }
.rze__logos-row span[aria-hidden] { color:#ddd; font-weight:400; }
.rze-byline { max-width:1180px; margin:32px auto 0; padding:0 1.5rem; }
@media(max-width:880px) {
  .rze__inner { grid-template-columns:1fr; gap:36px; }
  .rze__main { padding-right:0; }
  .rze__cards { padding-top:0; }
}

/* SECTIONS */
.rze-intro, .rze-pillars, .rze-cats, .rze-int, .rze-faq { padding:72px 0; border-top:1px solid #ededed; }
.rze-intro__inner, .rze-pillars__inner, .rze-cats__inner, .rze-int__inner, .rze-faq__inner, .rz-compare__inner { max-width:1180px; margin:0 auto; padding:0 1.5rem; }
.rze-h2 { font-size:clamp(1.6rem, 2.6vw, 2.2rem); line-height:1.15; letter-spacing:-0.01em; margin:14px 0 24px; font-weight:800; color:#000; }
.rze-intro p { font-size:1.05rem; line-height:1.75; color:#222; margin:0 0 18px; max-width:880px; }
.rze-intro p:last-child { margin-bottom:0; }
.rze-intro a, .rz-compare a { color:#000; border-bottom:1.5px solid var(--mtp-red); text-decoration:none; }
.rze-intro a:hover, .rz-compare a:hover { color:var(--mtp-red); }

/* 4 PILLARS GRID */
.rze-pillars__grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:0; border-top:1px solid #1a1a1a; }
.rze-pillars__card { padding:32px 24px; border-right:1px solid #ededed; border-bottom:1px solid #ededed; background:#fff; }
.rze-pillars__num { display:inline-block; font-size:13px; font-weight:800; letter-spacing:0.08em; color:var(--mtp-red); margin-bottom:8px; }
.rze-pillars__card h3 { font-size:1.18rem; font-weight:800; color:#000; margin:0 0 10px; line-height:1.25; }
.rze-pillars__card p { font-size:0.96rem; line-height:1.65; color:#333; margin:0; }

/* COMPARISON TABLE */
.rz-compare { padding:72px 0; border-top:1px solid #1a1a1a; background:#0a0a0a; color:#fff; }
.rz-compare .rze-h2 { color:#fff; }
.rz-compare__lead { font-size:1.05rem; line-height:1.7; color:#aaa; max-width:760px; margin:0 0 32px; }
.rz-compare__scroll { overflow-x:auto; -webkit-overflow-scrolling:touch; }
.rz-compare__t { width:100%; border-collapse:collapse; font-size:0.95rem; min-width:760px; }
.rz-compare__t th, .rz-compare__t td { text-align:left; padding:14px 16px; border-bottom:1px solid #222; vertical-align:top; }
.rz-compare__t thead th { font-size:0.78rem; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:#999; border-bottom:1px solid #fff; padding-bottom:12px; }
.rz-compare__t .rz-compare__th-mtp { color:var(--mtp-red); }
.rz-compare__t .rz-compare__th-row { color:#fff; }
.rz-compare__t tbody td:first-child { color:#fff; font-weight:600; }
.rz-compare__t tbody td { color:#ccc; }
.rz-v { color:var(--mtp-red); font-weight:700; margin-right:6px; }
.rz-x { color:#666; font-weight:700; margin-right:6px; }
.rz-compare__note { color:#999; margin:24px 0 0; font-size:0.95rem; }
.rz-compare__note a { color:#fff; border-bottom:1.5px solid var(--mtp-red); text-decoration:none; }
.rz-compare__note a:hover { color:var(--mtp-red); }

/* CATEGORIES */
.rze-cats__grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:0; border-top:1px solid #1a1a1a; }
.rze-cats__card { padding:28px 24px; border-right:1px solid #ededed; border-bottom:1px solid #ededed; background:#fff; }
.rze-cats__card h3 { font-size:1.16rem; font-weight:800; color:#000; margin:0 0 10px; line-height:1.25; }
.rze-cats__card p { font-size:0.96rem; line-height:1.65; color:#333; margin:0; }

/* INTEGRATIONS */
.rze-int__cols { display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:32px; border-top:1px solid #1a1a1a; padding-top:36px; }
.rze-int__cols h3 { font-size:0.95rem; font-weight:800; letter-spacing:0.04em; color:#000; margin:0 0 14px; }
.rze-int__cols ul { list-style:none; padding:0; margin:0; }
.rze-int__cols li { font-size:0.95rem; line-height:1.7; color:#333; padding:6px 0; border-bottom:1px solid #ededed; }
.rze-int__cols li:last-child { border-bottom:0; }
.rze-int__cols li a { color:var(--mtp-red); text-decoration:underline; text-decoration-thickness:1px; text-underline-offset:3px; transition:color .15s, text-decoration-thickness .15s; }
.rze-int__cols li a:hover { color:#000; text-decoration-thickness:2px; }

/* FAQ */
.rze-faq .s-acc { border-top:1px solid #1a1a1a; margin-top:24px; }
</style>
</content>
</invoke>