.en-hero .hero-form button{padding:16px 28px;background:var(--red);color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:600;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:all .3s}
.en-hero .hero-form button:hover{background:#c42b22}
.en-hero .hero-note{font-size:13px;color:rgba(255,255,255,.3);margin-top:12px}

/* Journey — 5 steps with connectors */
.journey{padding:120px 0;background:var(--gray)}
.j-track{display:flex;align-items:flex-start;gap:0;overflow-x:auto;padding-bottom:16px}
.j-step{flex:1;min-width:180px;text-align:center;padding:0 16px;position:relative}
.j-icon{font-size:32px;margin-bottom:8px}
.j-num{font-family:var(--fd);font-size:48px;color:rgba(0,0,0,.06);line-height:1}
.j-step h3{font-size:15px;font-weight:600;margin:8px 0 6px}
.j-step p{font-size:13px;color:var(--muted);line-height:1.6}
.j-connector{width:40px;min-width:40px;height:2px;background:var(--red);margin-top:50px;flex-shrink:0}

/* Calculator — interactive, unique to EN */
.calculator{padding:100px 0}
.calc-wrap{display:grid;grid-template-columns:1fr 1fr;gap:48px;max-width:800px;margin:0 auto;align-items:center}
.calc-inputs{display:flex;flex-direction:column;gap:32px}
.calc-inputs label{font-size:14px;font-weight:500;display:block}
.calc-inputs input[type="range"]{width:100%;margin:12px 0 8px;accent-color:var(--red);height:6px}
.calc-val{font-size:13px;color:var(--muted)}
.calc-val span{font-weight:700;color:var(--black);font-size:18px}
.calc-result{background:var(--black);color:#fff;padding:48px 40px;border-radius:16px;text-align:center}
.calc-total{font-family:var(--fd);font-size:48px;line-height:1}
.calc-total small{font-size:18px;opacity:.5;font-family:var(--fb)}
.calc-usd{font-size:24px;color:var(--red);margin:8px 0 16px;font-weight:500}
.calc-breakdown{font-size:12px;color:rgba(255,255,255,.4);margin-bottom:12px}
.calc-note{font-size:11px;color:rgba(255,255,255,.3);text-transform:uppercase;letter-spacing:1px}

/* Tour */
.tour{padding:100px 0;background:#0a0a0a;color:#fff}
.tour-grid{display:grid;grid-template-columns:1fr 1.2fr;gap:60px;align-items:center}
.tour-text h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;margin:16px 0 32px}
.tour-facts{list-style:none;padding:0}
.tour-facts li{font-size:15px;color:rgba(255,255,255,.7);padding:10px 0;border-bottom:1px solid rgba(255,255,255,.06);line-height:1.5}
.tour-facts li strong{color:#fff}
.tour-video{position:relative}
.video-thumb{border-radius:12px;overflow:hidden;position:relative}
.video-thumb img{width:100%;aspect-ratio:16/9;object-fit:cover;filter:brightness(.5);transition:filter .3s}
.video-thumb:hover img{filter:brightness(.7)}
.play-overlay{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
.play-btn-lg{width:72px;height:72px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-size:28px;color:#fff;transition:transform .3s}
.video-thumb:hover .play-btn-lg{transform:scale(1.1)}

/* Sellers from — country trust badges */
.sellers-from{padding:100px 0;background:var(--gray)}
.sf-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.sf-card{padding:32px 28px;background:#fff;border-radius:12px;border:1px solid #e0e0e0;text-align:center}
.sf-flag{font-size:40px;margin-bottom:12px}
.sf-card h3{font-size:17px;font-weight:600;margin-bottom:6px}
.sf-card p{font-size:13px;color:var(--muted);line-height:1.5}

/* Options comparison table */
.options{padding:100px 0}
.opt-table{max-width:800px;margin:0 auto;border-radius:12px;overflow:hidden;border:1px solid #e0e0e0}
.opt-row{display:grid;grid-template-columns:1.5fr 1fr 1fr 1.2fr;border-bottom:1px solid #eee;font-size:14px}
.opt-row:last-child{border:none}
.opt-row>span{padding:14px 16px}
.opt-header{background:var(--black);color:#fff;font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:.5px}
.opt-highlight{background:rgba(230,51,41,.04);color:var(--red);font-weight:600}
.opt-header .opt-highlight{background:var(--red);color:#fff}

/* Marketplace auto-scroll marquee */
.mp-section{padding:80px 0;overflow:hidden}
.mp-marquee{overflow:hidden;width:100%;padding:16px 0}
.mp-marquee-track{display:flex;gap:20px;animation:mpScroll 30s linear infinite;width:max-content}
.mp-marquee-track:hover{animation-play-state:paused}
@keyframes mpScroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
.mp-m-card{flex-shrink:0;width:220px;padding:24px 20px;background:var(--gray);border-radius:10px;border:1px solid #e0e0e0;text-decoration:none;color:inherit;display:block;transition:border-color .3s}
.mp-m-card:hover{border-color:var(--red)}
.mp-m-card h3{font-family:var(--fd);font-size:20px;font-weight:400;margin-bottom:4px;color:var(--black)}
.mp-m-card span{font-size:11px;color:var(--red);font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.mp-m-any{border-style:dashed}

/* Pricing */
.pricing{padding:100px 0;background:var(--gray)}
.price-table{max-width:800px;margin:0 auto 32px;border-radius:12px;overflow:hidden;border:1px solid #e0e0e0}
.price-row{display:flex;border-bottom:1px solid #eee;font-size:14px}.price-row:last-child{border:none}
.price-row>span{flex:1;padding:14px 16px}
.price-header{background:var(--black);color:#fff;font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:.5px}
.price-row:not(.price-header):hover{background:#fff}
.price-highlight{background:var(--red);color:#fff;font-weight:600}
.price-note{text-align:center;font-size:14px;color:var(--muted);max-width:600px;margin:0 auto}

/* FAQ */
.faq{padding:100px 0;background:var(--black);color:var(--white)}
.faq-list{max-width:700px;margin:0 auto}
.faq-item{border-bottom:1px solid rgba(255,255,255,.08)}
.faq-q{width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:var(--fb);text-align:left}
.faq-q::after{content:'+';font-size:24px;color:var(--red);transition:transform .3s;flex-shrink:0;margin-left:16px}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.faq-a p{padding:0 0 20px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.7}

/* Article */
.article-section{background:#fff;padding:80px 8vw}
.article-section h2{font-family:var(--fd);font-size:clamp(28px,3.5vw,44px);font-weight:400;margin:20px 0 40px}
.article-content{max-width:800px}
.article-content h3{font-family:var(--fd);font-size:clamp(18px,2vw,26px);font-weight:400;margin:36px 0 12px;color:var(--black)}
.article-content h3:first-child{margin-top:0}
.article-content p{font-size:16px;line-height:1.85;color:#444;margin-bottom:8px}

@media(max-width:768px){
.en-hero h1{font-size:clamp(28px,8vw,40px)}
.h1-big{font-size:clamp(40px,14vw,72px)}
.en-hero .hero-form{flex-direction:column}.en-hero .hero-form button{width:100%}
.j-track{flex-direction:column;align-items:stretch}
.j-connector{width:2px;height:24px;margin:0 auto}
.calc-wrap{grid-template-columns:1fr}
.tour-grid{grid-template-columns:1fr}
.sf-grid{grid-template-columns:1fr}
.options .ctr{overflow-x:auto;-webkit-overflow-scrolling:touch}
.opt-table{min-width:600px}
}

.j-step,.sf-card,.mp-m-card,.opt-row{opacity:1!important;transform:none!important}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
/* Calculator */
var ordersSlider=document.getElementById('calcOrders');
var volumeSlider=document.getElementById('calcVolume');
if(ordersSlider&&volumeSlider){
function calcUpdate(){
var orders=parseInt(ordersSlider.value);
var volume=parseInt(volumeSlider.value);
document.getElementById('calcOrdersVal').textContent=orders;
document.getElementById('calcVolumeVal').textContent=volume;
var rate=orders>=200?18:orders>=100?20:orders>=50?22:26;
var fulfillment=orders*22*rate;
var storage=volume*650;
var total=Math.max(fulfillment+storage,5000);
var minApplied=total===5000&&(fulfillment+storage)<5000;
document.getElementById('calcTotal').textContent=total.toLocaleString('en-US');
document.getElementById('calcUsd').textContent=Math.round(total/44).toLocaleString('en-US');
document.getElementById('calcBreakdown').textContent='Fulfillment: '+fulfillment.toLocaleString('en-US')+' UAH + Storage: '+storage.toLocaleString('en-US')+' UAH'+(minApplied?' (min applied)':'');
}
ordersSlider.addEventListener('input',calcUpdate);
volumeSlider.addEventListener('input',calcUpdate);
calcUpdate();
}

/* Video modal */
window.openVideoModal=function(id){var m=document.getElementById('videoModal');m.style.display='flex';document.getElementById('videoIframe').src='https://www.youtube.com/embed/'+id+'?autoplay=1';};
window.closeVideoModal=function(){var m=document.getElementById('videoModal');m.style.display='none';document.getElementById('videoIframe').src='';};
document.getElementById('videoModal').addEventListener('click',function(e){if(e.target===this)closeVideoModal();});
});
</script>
