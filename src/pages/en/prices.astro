---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Fulfillment Prices 2026 | MTP Group Ukraine"
  description="Fulfillment pricing in Ukraine 2026: shipping from 18 UAH per order, storage 650 UAH/m³. Volume-based dynamic rates. No hidden fees."
  canonical="https://www.fulfillmentmtp.com.ua/en/prices/"
  lang="en"
>
<Fragment slot="head">
<script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","address":[{"@type":"PostalAddress","addressLocality":"Shchaslive, Boryspil district","addressRegion":"Kyiv region","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"Bilohorodka","addressRegion":"Kyiv region","addressCountry":"UA"}],"openingHours":"Mo-Su 08:00-20:00"}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"Service","name":"Fulfillment Pricing","provider":{"@type":"Organization","name":"MTP Group"},"offers":{"@type":"AggregateOffer","lowPrice":"18","highPrice":"650","priceCurrency":"UAH"}}</script>
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/ua/tsiny/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/en/prices/">
</Fragment>

<!-- HERO -->
<section class="hero">
<div class="hero-content">
<div class="badge">PRICING 2026</div>
<h1>Fulfillment Pricing<br>for E-commerce</h1>
<p class="hero-sub">Transparent pricing with no hidden fees. Dynamic volume-based rates &mdash; the more you ship, the lower the cost per order. Packing materials included.</p>
<form class="hero-form" id="heroForm"><input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="25" required autocomplete="tel" aria-label="Phone"><button type="submit">Calculate cost &#8594;</button></form>
<div class="hero-note">Custom quote in 15 minutes &#183; No obligations</div>
</div>
<div class="hero-stats">
<div class="hero-stat"><div class="hero-stat-val">from 18&#8372;</div><div class="hero-stat-label">per shipment</div></div>
<div class="hero-stat"><div class="hero-stat-val">650&#8372;</div><div class="hero-stat-label">m&sup3;/month</div></div>
<div class="hero-stat"><div class="hero-stat-val">5 000&#8372;</div><div class="hero-stat-label">min/month</div></div>
</div>
</section>

<!-- TARIFF TABLE -->
<section class="pricing"><div class="ctr">
<div class="badge badge-dark">SHIPPING</div>
<h2 class="sec-h2">Rate per shipment</h2>
<div class="price-table">
<div class="price-row price-header"><span>Shipments per day</span><span>Rate per order</span></div>
<div class="price-row"><span>0 &ndash; 5</span><span>26 UAH</span></div>
<div class="price-row"><span>6 &ndash; 20</span><span>25 UAH</span></div>
<div class="price-row"><span>21 &ndash; 50</span><span>23 UAH</span></div>
<div class="price-row"><span>51 &ndash; 100</span><span>22 UAH</span></div>
<div class="price-row"><span>101 &ndash; 150</span><span>20 UAH</span></div>
<div class="price-row"><span>151 &ndash; 200</span><span>19 UAH</span></div>
<div class="price-row price-highlight"><span>Over 200</span><span>18 UAH</span></div>
</div>

<div class="badge badge-dark">STORAGE &amp; RECEIVING</div>
<h2 class="sec-h2" style="margin-top:20px">Storage and inventory receiving</h2>
<div class="price-table">
<div class="price-row price-header"><span>Service</span><span>Rate</span></div>
<div class="price-row"><span>Product storage (bin-level)</span><span class="price-accent">650 UAH/m&sup3;/mo</span></div>
<div class="price-row"><span>Promo materials storage</span><span>300 UAH/m&sup3;/mo</span></div>
<div class="price-row"><span>Receiving (up to 2 kg)</span><span>3 UAH/unit</span></div>
<div class="price-row"><span>Receiving (2&ndash;10 kg)</span><span>5 UAH/unit</span></div>
<div class="price-row"><span>Receiving (10&ndash;30 kg)</span><span>10 UAH/unit</span></div>
<div class="price-row"><span>Receiving (30+ kg)</span><span>20 UAH/unit</span></div>
<div class="price-row"><span>Box unloading</span><span>20 UAH</span></div>
<div class="price-row"><span>Pallet unloading</span><span>80 UAH</span></div>
<div class="price-row price-highlight"><span>Minimum monthly payment</span><span>5 000 UAH</span></div>
</div>
</div></section>

<!-- EXTRAS -->
<section class="extras"><div class="ctr">
<div class="badge badge-dark">ADDITIONAL</div>
<h2 class="sec-h2">Additional services</h2>
<div class="extras-grid">
<div class="extra-card"><div class="extra-price">2.50&#8372;</div><h3>Extra item pick</h3><p>Each additional item in order</p></div>
<div class="extra-card"><div class="extra-price">2&#8372;</div><h3>Sales receipt</h3><p>Adding receipt to order</p></div>
<div class="extra-card"><div class="extra-price">1.25&#8372;</div><h3>Barcode sticker</h3><p>Print and apply barcode</p></div>
<div class="extra-card"><div class="extra-price">1.50&#8372;</div><h3>Custom label</h3><p>Print and apply custom label</p></div>
<div class="extra-card"><div class="extra-price">0.50&#8372;</div><h3>FEFO control</h3><p>Expiry date tracking for cosmetics, pharma</p></div>
<div class="extra-card"><div class="extra-price">2&#8372;</div><h3>Document printing</h3><p>Waybills, invoices (up to 3 A4 pages)</p></div>
<div class="extra-card"><div class="extra-price">5&#8372;</div><h3>Warranty card</h3><p>Filling warranty card</p></div>
<div class="extra-card"><div class="extra-price">350&#8372;</div><h3>Palletizing</h3><p>Pallet building and stretch wrapping</p></div>
</div>
</div></section>

<!-- COMPARISON -->
<section class="compare"><div class="ctr">
<div class="badge">COMPARISON</div>
<h2 class="sec-h2">Fulfillment vs In-house warehouse</h2>
<p style="text-align:center;color:rgba(255,255,255,.5);margin-top:-32px;margin-bottom:40px;font-size:15px">Calculation for a store with 50 orders/day and 2 m&sup3; storage</p>
<div class="comp-table">
<div class="comp-row comp-header"><div class="comp-cell">Cost item</div><div class="comp-cell">In-house</div><div class="comp-cell">MTP Fulfillment</div></div>
<div class="comp-row"><div class="comp-cell">Warehouse rent (50 m&sup2;)</div><div class="comp-cell">~15 000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row"><div class="comp-cell">Staff (2 people)</div><div class="comp-cell">~30 000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row"><div class="comp-cell">WMS system</div><div class="comp-cell">~5 000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row"><div class="comp-cell">Packing materials</div><div class="comp-cell">~3 000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row"><div class="comp-cell">Utilities</div><div class="comp-cell">~2 000 UAH</div><div class="comp-cell">Included</div></div>
<div class="comp-row"><div class="comp-cell">Shipping</div><div class="comp-cell">&mdash;</div><div class="comp-cell">~25 300 UAH</div></div>
<div class="comp-row"><div class="comp-cell">Storage (2 m&sup3;)</div><div class="comp-cell">&mdash;</div><div class="comp-cell">1 300 UAH</div></div>
<div class="comp-row comp-total"><div class="comp-cell">TOTAL per month</div><div class="comp-cell">~55 000 UAH</div><div class="comp-cell">~28 000 UAH</div></div>
</div>
<div class="comp-savings">Savings: ~27,000 UAH/mo (49%)</div>
</div></section>

<!-- CALCULATOR CTA -->
<section class="calc-cta">
<h2>Calculate cost for your store</h2>
<p>Online calculator shows estimated fulfillment cost in 30 seconds</p>
<a href="/en/calculator/">Open calculator &#8594;</a>
</section>

<!-- FAQ -->
<section class="faq"><div class="ctr">
<div class="badge">FAQ</div>
<h2 class="sec-h2">Pricing FAQ</h2>
<div class="faq-list">
<div class="faq-item"><button class="faq-q">What is the minimum payment?</button><div class="faq-a"><p>The minimum monthly payment is 5,000 UAH. It covers basic storage and order processing. If your monthly usage exceeds 5,000 UAH, you only pay for actual usage with no surcharges.</p></div></div>
<div class="faq-item"><button class="faq-q">What is included in the shipping rate?</button><div class="faq-a"><p>The per-shipment rate (from 18 UAH) includes: order picking from the warehouse, packing into a box or bag, waybill labeling with barcode, scanning, and carrier handoff. Packing materials are included.</p></div></div>
<div class="faq-item"><button class="faq-q">Are there volume discounts?</button><div class="faq-a"><p>Yes. Rates are dynamic: 200+ orders/day = 18 UAH, 101-150 = 20 UAH, 51-100 = 22 UAH, 21-50 = 23 UAH. Recalculated automatically at the end of each month.</p></div></div>
<div class="faq-item"><button class="faq-q">How much does storage cost?</button><div class="faq-a"><p>Storage is 650 UAH per m&sup3; per month (bin-level with WMS address tracking). Promo materials &mdash; 300 UAH/m&sup3;/mo.</p></div></div>
<div class="faq-item"><button class="faq-q">Do I pay for returns?</button><div class="faq-a"><p>Unpacking and inspecting returns &mdash; 50% of the shipping rate. If the item is OK, it goes back on the shelf automatically.</p></div></div>
<div class="faq-item"><button class="faq-q">How do I calculate cost for my store?</button><div class="faq-a"><p>Two options: use the <a href="/en/calculator/" style="color:var(--red);text-decoration:underline">online calculator</a> for a quick estimate in 30 seconds, or leave your number &mdash; we will prepare a detailed custom quote for your business within 15 minutes.</p></div></div>
</div>
</div></section>

<!-- SEO ARTICLE -->
<section class="article-section">
<div class="ctr">
<div class="badge badge-dark">LEARN MORE</div>
<h2>How Fulfillment Pricing Works in Ukraine</h2>
<div class="article-content">
<h3>What makes up the fulfillment price?</h3>
<p>Fulfillment costs for an online store consist of three main components: shipping orders, storing inventory, and receiving new stock. All services have fixed, transparent rates &mdash; no hidden fees.</p>
<h3>Why are dynamic rates better than fixed?</h3>
<p>MTP Group uses a dynamic scale: the more shipments per day, the lower the cost per order. At 200+ orders/day the rate is 18 UAH &mdash; 28% less than a typical flat rate.</p>
<h3>Fulfillment vs in-house: which is cheaper?</h3>
<p>At 50 orders per day, running your own warehouse costs at least 55,000 UAH. Fulfillment at the same volume &mdash; ~28,000 UAH. Difference &mdash; 27,000 UAH per month or 49% savings.</p>
</div>
</div>
</section>

</Base>

<style is:global>
:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:24px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}

.hero{position:relative;min-height:70vh;background:#000;color:#fff;display:flex;flex-direction:column;justify-content:center;padding:140px 0 80px;overflow:hidden}
.hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero-content::before{content:'';position:absolute;left:calc(8vw - 40px);top:0;height:100%;width:3px;background:var(--red,#e63329)}
.hero h1{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(42px,5.5vw,80px);font-weight:400;line-height:.95;margin-bottom:28px}
.hero-sub{font-size:clamp(16px,1.8vw,19px);color:rgba(255,255,255,.6);line-height:1.7;max-width:600px;margin-bottom:40px}
.hero-form{display:flex;gap:12px;max-width:460px}
.hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;outline:none}
.hero-form input::placeholder{color:rgba(255,255,255,.25)}.hero-form input:focus{border-color:rgba(255,255,255,.5)}
.hero-form button{padding:16px 24px;background:transparent;color:#fff;border:2px solid #fff;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;white-space:nowrap;transition:all .3s}
.hero-form button:hover{background:var(--red,#e63329);border-color:var(--red,#e63329)}
.hero-note{font-size:13px;color:rgba(255,255,255,.3);margin-top:12px}
.hero-stats{display:flex;gap:32px;padding:48px 8vw 0;position:relative;z-index:2}
.hero-stat{border-top:3px solid var(--red,#e63329);padding:20px 0;flex:1}
.hero-stat-val{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(32px,4vw,56px);font-weight:400;color:#fff;white-space:nowrap}
.hero-stat-label{font-size:11px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:2px;margin-top:4px}
.sec-h2{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(32px,4.5vw,56px);font-weight:400;margin-bottom:48px}
.pricing{padding:100px 0}
.price-table{max-width:750px;margin:0 auto 48px;border-radius:8px;overflow:hidden;border:1px solid #e0e0e0}
.price-row{display:flex;border-bottom:1px solid #eee;font-size:15px}.price-row:last-child{border:none}
.price-row>span{flex:1;padding:14px 20px}
.price-header{background:#000;color:#fff;font-weight:600;font-size:13px;text-transform:uppercase;letter-spacing:.5px}
.price-row:not(.price-header):hover{background:var(--gray,#f5f5f5)}
.price-highlight{background:var(--red,#e63329);color:#fff;font-weight:600}
.price-accent{font-weight:600;color:var(--red,#e63329)}
.extras{padding:80px 0;background:var(--gray,#f5f5f5)}
.extras-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.extra-card{background:#fff;padding:28px 24px;border-radius:8px;text-align:center}
.extra-price{font-family:var(--fd,'DM Serif Display',serif);font-size:28px;color:var(--red,#e63329);margin-bottom:8px}
.extra-card h3{font-size:15px;font-weight:500;margin-bottom:4px}.extra-card p{font-size:13px;color:var(--muted,#666)}
.compare{padding:100px 0;background:#0a0a0a;color:#fff}
.comp-table{max-width:800px;margin:0 auto;border-radius:8px;overflow:hidden;border:1px solid rgba(255,255,255,.1)}
.comp-row{display:grid;grid-template-columns:1.4fr 1fr 1fr;border-bottom:1px solid rgba(255,255,255,.06)}.comp-row:last-child{border:none}
.comp-cell{padding:14px 20px;font-size:14px;color:rgba(255,255,255,.7)}
.comp-header{background:rgba(255,255,255,.05)}.comp-header .comp-cell{font-weight:600;font-size:13px;text-transform:uppercase;letter-spacing:.5px;color:#fff}
.comp-total{background:rgba(255,255,255,.08)}.comp-total .comp-cell{font-weight:600;color:#fff;font-size:15px}.comp-total .comp-cell:last-child{color:var(--red,#e63329)}
.comp-savings{text-align:center;margin-top:32px;font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(24px,3vw,36px);color:var(--red,#e63329)}
.calc-cta{padding:80px 0;background:var(--gray,#f5f5f5);text-align:center}
.calc-cta h2{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(28px,4vw,44px);font-weight:400;margin-bottom:16px}
.calc-cta p{font-size:17px;color:var(--muted,#666);max-width:500px;margin:0 auto 32px}
.calc-cta a{display:inline-block;padding:18px 40px;background:var(--red,#e63329);color:#fff;border-radius:4px;font-size:16px;font-weight:600;transition:background .3s}.calc-cta a:hover{background:#c42b22}
.faq{padding:100px 0;background:#0a0a0a;color:#fff}
.faq-list{max-width:700px;margin:0 auto}
.faq-item{border-bottom:1px solid rgba(255,255,255,.08)}
.faq-q{width:100%;padding:20px 0;font-size:16px;font-weight:500;background:none;border:none;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;text-align:left}
.faq-q::after{content:'+';font-size:24px;color:var(--red,#e63329);transition:transform .3s}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.faq-a p{padding:0 0 20px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.7}
.article-section{background:#fff;padding:80px 8vw}
.article-section h2{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(32px,4vw,52px);font-weight:400;margin:20px 0 40px}
.article-content{max-width:800px}
.article-content h3{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(18px,2vw,26px);font-weight:400;margin:36px 0 12px;color:#000}.article-content h3:first-child{margin-top:0}
.article-content p{font-size:16px;line-height:1.85;color:#444;margin-bottom:8px}
@media(max-width:768px){
.hero-content::before{left:0;width:2px}.hero-form{flex-direction:column}.hero-form button{width:100%}
.hero-stats{flex-wrap:wrap;gap:24px;padding:32px 24px 0}
.extras-grid{grid-template-columns:1fr 1fr}
.comp-row{grid-template-columns:1fr}.comp-cell{padding:10px 16px}
.final-form{flex-direction:column}
}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.15});
document.querySelectorAll('.reveal').forEach(function(el,i){el.style.transitionDelay=(i%3)*.1+'s';obs.observe(el);});
document.querySelectorAll('.faq-q').forEach(function(btn){btn.addEventListener('click',function(){var item=btn.parentElement;var a=item.querySelector('.faq-a');var open=item.classList.contains('open');document.querySelectorAll('.faq-item.open').forEach(function(el){el.classList.remove('open');el.querySelector('.faq-a').style.maxHeight=null;});if(!open){item.classList.add('open');a.style.maxHeight=a.scrollHeight+'px';}});});
);inp.addEventListener('focus',function(){if(!this.value)this.value='+38 (';});inp.addEventListener('blur',function(){if(this.value==='+38 (')this.value='';});}
var leads=JSON.parse(localStorage.getItem('mtp_crm_leads')||'[]');leads.push({id:Date.now(),company:'Fulfillment Prices',contact:'',phone:ph,email:'',shipments:0,type:'pricing',source:'SEO landing prices EN',status:'new',date:new Date().toISOString().split('T')[0],comments:[{text:'Form: fulfillment prices EN',date:new Date().toLocaleString('uk-UA')}],onboarding:[false,false,false,false,false,false,false]});localStorage.setItem('mtp_crm_leads',JSON.stringify(leads));fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});form.innerHTML='<div style="text-align:center"><p style="color:#22c55e;font-size:18px;font-weight:500">\u2705 Thank you!</p><p style="color:rgba(255,255,255,.5);font-size:14px;margin-top:8px">We will call you back shortly</p></div>';setTimeout(function(){window.location.href='/en/thanks/';},1500);});}
});
</script>
