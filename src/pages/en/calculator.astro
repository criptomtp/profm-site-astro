---
import Base from '../../layouts/Base.astro';
---
<Base
  title="Fulfillment Cost Calculator | MTP Group"
  description="Calculate fulfillment costs in 30 seconds. Dynamic rates from 18 UAH/order. MTP Group calculator with actual 2026 prices. Warehouse in Shchaslyve, Boryspil district."
  canonical="https://www.fulfillmentmtp.com.ua/en/calculator/"
  lang="en"
>
<Fragment slot="head">
<script type="application/ld+json">{"@context":"https://schema.org","@type":"LocalBusiness","name":"MTP Group Fulfillment","url":"https://www.fulfillmentmtp.com.ua","telephone":["+380501444645","+380938277767"],"email":"mtpgrouppromo@gmail.com","address":[{"@type":"PostalAddress","addressLocality":"Shchaslive, Boryspil district","addressRegion":"Kyiv region","addressCountry":"UA"},{"@type":"PostalAddress","addressLocality":"Bilohorodka","addressRegion":"Kyiv region","addressCountry":"UA"}],"openingHours":"Mo-Su 08:00-20:00"}</script>
<script type="application/ld+json">{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https://www.fulfillmentmtp.com.ua/en/"},{"@type":"ListItem","position":2,"name":"Calculator","item":"https://www.fulfillmentmtp.com.ua/en/calculator/"}]}</script>
  <link rel="alternate" hreflang="uk" href="https://www.fulfillmentmtp.com.ua/ua/calculator/">
  <link rel="alternate" hreflang="en" href="https://www.fulfillmentmtp.com.ua/en/calculator/">
  <link rel="alternate" hreflang="x-default" href="https://www.fulfillmentmtp.com.ua/ua/calculator/">
</Fragment>

<!-- HERO -->
<section class="hero">
<div class="hero-bg"></div>
<div class="hero-content">
<div class="badge">CALCULATOR</div>
<h1>Fulfillment<br>Cost Calculator</h1>
<p class="hero-sub">Calculate fulfillment costs in 30 seconds. Actual 2026 rates with dynamic volume discounts.</p>
<form class="hero-form" id="heroForm"><input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="25" required autocomplete="tel" aria-label="Phone"><button type="submit">Get a quote →</button></form>
<div class="hero-note">Free consultation · We call back within 15 min</div>

<div class="hero-stats">
<div><div class="hero-stat-val">from 18 UAH</div><div class="hero-stat-label">per shipment</div></div>
<div><div class="hero-stat-val">650 UAH</div><div class="hero-stat-label">m&sup3;/mo storage</div></div>
<div><div class="hero-stat-val">5,000 UAH</div><div class="hero-stat-label">monthly minimum</div></div>
</div>
</div>
</section>

<!-- CALCULATOR -->
<section class="calc-section">
<div class="ctr">
<div class="badge badge-dark">ESTIMATE</div>
<h2 class="sec-h2">Calculate costs for your business</h2>
<div class="calc-wrap">
<div class="calc-form">
<h3>Business Parameters</h3>
<div class="calc-field"><label>Shipments per day</label><input type="number" id="calcOrders" value="50" min="1" max="10000" step="1" aria-label="Orders per day"><div class="field-hint">Average number of orders you ship daily</div></div>
<div class="calc-field"><label>Average item weight</label><select id="calcWeight" aria-label="Weight category"><option value="2" selected>up to 2 kg</option><option value="5">2-5 kg</option><option value="10">5-10 kg</option><option value="30">10-30 kg</option><option value="50">30+ kg</option></select><div class="field-hint">Weight of one item for receiving calculation</div></div>
<div class="calc-field"><label>Storage volume, m&sup3;</label><input type="number" id="calcVolume" value="5" min="0" max="1000" step="0.5" aria-label="Storage volume"><div class="field-hint">How many cubic meters your products occupy in the warehouse</div></div>
<div class="calc-field"><label>Average items per order</label><input type="number" id="calcItems" value="1.5" min="1" max="50" step="0.1" aria-label="Items per order"><div class="field-hint">If more than 1 &mdash; co-packing fee applies</div></div>
</div>
<div class="calc-results">
<h3>Calculation Results</h3>
<div class="res-row"><span class="res-label">Shipping</span><span><span class="res-value" id="resShipping">28 600</span> UAH/mo <span class="res-sub" id="resShippingRate">(26 UAH/order)</span></span></div>
<div class="res-row"><span class="res-label">Storage</span><span><span class="res-value" id="resStorage">3 250</span> UAH/mo</span></div>
<div class="res-row"><span class="res-label">Receiving</span><span><span class="res-value" id="resReceiving">3 300</span> UAH/mo</span></div>
<div class="res-row"><span class="res-label">Co-packing</span><span><span class="res-value" id="resCopacking">1 375</span> UAH/mo</span></div>
<div class="res-total"><div class="res-row"><span class="res-label">TOTAL</span><span class="res-value" id="resTotal">36 525</span> <span style="font-size:14px;opacity:.8">UAH/mo</span></div></div>
<div class="res-cost-per"><div class="val" id="resCostPer">33.2</div><div class="lbl">Cost per shipment, UAH</div></div>
<div class="res-compare" id="resCompare">
<div class="compare-title">Own warehouse (estimate)</div>
<div class="compare-row"><span>Rent</span><span id="ownRent">15 000</span> UAH</div>
<div class="compare-row"><span>Staff</span><span id="ownStaff">30 000</span> UAH</div>
<div class="compare-row"><span>WMS + software</span><span id="ownWms">5 000</span> UAH</div>
<div class="compare-row"><span>Utilities</span><span id="ownUtils">2 000</span> UAH</div>
<div class="compare-row"><span>Materials</span><span id="ownMaterials">1 650</span> UAH</div>
<div class="compare-total">Total: <span id="ownTotal">53 650</span> UAH/mo</div>
<div style="text-align:center;margin-top:12px">Savings with MTP: <strong id="resSaving">34%</strong></div>
</div>
<div class="res-time" id="resTime"><strong>Time saved:</strong> <span id="timeFreed">132</span> hours/mo freed up<br>&#8594; <span id="timeMarketing">79</span> hrs for marketing & sales<br>&#8594; <span id="timePersonal">40</span> hrs for product development</div>
</div>
</div>
</div>
</section>

<!-- TARIFF TABLE -->
<section class="tariff-section">
<div class="ctr">
<div class="badge badge-dark">RATES 2026</div>
<h2 class="sec-h2">Full Rate Schedule</h2>
<p style="font-size:17px;color:var(--muted);line-height:1.7;max-width:600px;margin-bottom:16px">Dynamic rates: the more shipments, the lower the cost per unit.</p>
<table class="tariff-table">
<thead><tr><th>Shipments per day</th><th>Rate per shipment</th></tr></thead>
<tbody>
<tr><td>0 &ndash; 5</td><td class="rate">26 UAH</td></tr>
<tr><td>6 &ndash; 10</td><td class="rate">25 UAH</td></tr>
<tr><td>11 &ndash; 20</td><td class="rate">24 UAH</td></tr>
<tr><td>21 &ndash; 50</td><td class="rate">23 UAH</td></tr>
<tr><td>51 &ndash; 75</td><td class="rate">22 UAH</td></tr>
<tr class="highlight"><td>76 &ndash; 100</td><td class="rate">21 UAH</td></tr>
<tr><td>101 &ndash; 150</td><td class="rate">20 UAH</td></tr>
<tr><td>151 &ndash; 200</td><td class="rate">19 UAH</td></tr>
<tr><td>200+</td><td class="rate">18 UAH</td></tr>
</tbody>
</table>
<p style="font-size:13px;color:var(--muted);margin-top:16px">* Storage: 650 UAH/m&sup3;/mo. Receiving: 3 UAH/item (up to 2 kg) + 0.5 UAH per each kg over 2. Minimum payment: 5,000 UAH/mo.</p>
</div>
</section>

<!-- ADDITIONAL SERVICES -->
<section class="addons">
<div class="ctr">
<div class="badge">ADDITIONAL SERVICES</div>
<h2 class="sec-h2">Additional Services</h2>
<table class="addon-table">
<thead><tr><th>Service</th><th>Cost</th><th>Description</th></tr></thead>
<tbody>
<tr><td>Co-packing</td><td class="price">2.5 UAH/unit</td><td>Assembling multiple items into one order. Charged for each item starting from the second.</td></tr>
<tr><td>Rozetka delivery</td><td class="price">4 UAH/order</td><td>Preparation and shipping of orders through Rozetka marketplace per platform standards.</td></tr>
<tr><td>SMS notifications</td><td class="price">2 UAH/SMS</td><td>Automatic SMS notification to buyer about shipment dispatch or status change.</td></tr>
<tr><td>Sales receipt</td><td class="price">2 UAH/receipt</td><td>Printing and enclosing a sales receipt for legal entities and individuals.</td></tr>
</tbody>
</table>
</div>
</section>

<!-- SEO ARTICLE -->
<section class="seo-article">
<div class="ctr">
<h2>How to Calculate Fulfillment Costs: A Complete Guide</h2>
<p>Calculating fulfillment costs is the first step to optimizing your online store's logistics expenses. In this guide, we break down all fulfillment cost components and show how to properly evaluate the economics of outsourcing logistics.</p>
<h3>Components of Fulfillment Costs</h3>
<p>Fulfillment costs consist of several components: shipping, storage, receiving, and additional services. At MTP Group, the main rate is dynamic: from 26 UAH at low volumes down to 18 UAH at 200+ shipments per day.</p>
<h3>MTP Group Pricing Formula</h3>
<p>Total fulfillment cost = (shipments per day x 22 working days x rate by tier) + (storage volume x 650 UAH/m&sup3;) + (shipments x 22 x receiving cost) + kitting. The minimum monthly payment is 5,000 UAH.</p>
</div>
</section>

</Base>

<style is:global>
:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:24px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}

.hero{position:relative;background:#000;color:#fff;padding:120px 0 80px;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:url('/images/mtp-warehouse-interior.webp') center/cover;opacity:.12}
.hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero h1{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(42px,6vw,72px);font-weight:400;line-height:.95;margin-bottom:28px}
.hero-sub{font-size:clamp(16px,1.8vw,20px);color:rgba(255,255,255,.6);line-height:1.7;max-width:520px;margin-bottom:48px}
.hero-stats{display:flex;gap:48px;flex-wrap:wrap}
.hero-stat-val{font-family:var(--fb,'DM Sans',sans-serif);font-size:clamp(28px,4vw,48px);font-weight:300;color:#fff}
.hero-stat-label{font-size:11px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:2px;margin-top:8px}
.sec-h2{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(32px,4.5vw,56px);font-weight:400;margin-bottom:48px}
.calc-section{padding:80px 0 100px;background:var(--gray,#f5f5f5)}
.calc-wrap{display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:48px}
.calc-form{background:#fff;border-radius:12px;padding:40px;box-shadow:0 2px 24px rgba(0,0,0,.06)}
.calc-form h3{font-family:var(--fd,'DM Serif Display',serif);font-size:24px;font-weight:400;margin-bottom:32px}
.calc-field{margin-bottom:24px}
.calc-field label{display:block;font-size:13px;font-weight:500;color:var(--muted,#666);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.calc-field input,.calc-field select{width:100%;padding:14px 16px;border:1px solid #e0e0e0;border-radius:6px;font-size:16px;outline:none;transition:border-color .3s;background:#fff;color:#000}
.calc-field input:focus,.calc-field select:focus{border-color:var(--red,#e63329)}
.calc-field .field-hint{font-size:12px;color:var(--muted,#666);margin-top:4px}
.calc-results{background:#000;border-radius:12px;padding:40px;color:#fff}
.calc-results h3{font-family:var(--fd,'DM Serif Display',serif);font-size:24px;font-weight:400;margin-bottom:32px;color:#fff}
.res-row{display:flex;justify-content:space-between;align-items:center;padding:16px 0;border-bottom:1px solid rgba(255,255,255,.08)}.res-row:last-of-type{border-bottom:none}
.res-label{font-size:14px;color:rgba(255,255,255,.6)}.res-value{font-size:16px;font-weight:500;color:#fff}
.res-sub{font-size:12px;color:rgba(255,255,255,.35);margin-left:8px;font-weight:300}
.res-total{margin-top:24px;padding:24px;background:var(--red,#e63329);border-radius:8px}.res-total .res-row{border-bottom:none;padding:8px 0}.res-total .res-label{color:rgba(255,255,255,.85);font-size:16px;font-weight:500}.res-total .res-value{font-family:var(--fd,'DM Serif Display',serif);font-size:28px}
.res-cost-per{margin-top:16px;padding:16px;background:rgba(255,255,255,.06);border-radius:8px;text-align:center}.res-cost-per .val{font-family:var(--fd,'DM Serif Display',serif);font-size:32px;color:var(--red,#e63329)}.res-cost-per .lbl{font-size:13px;color:rgba(255,255,255,.5);margin-top:4px}
.res-compare{margin-top:16px;padding:20px;border:1px solid rgba(255,255,255,.1);border-radius:8px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.6}.res-compare strong{color:#22c55e;font-weight:500}
.res-compare .compare-title{font-size:13px;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:1px;margin-bottom:12px;font-weight:500}
.res-compare .compare-row{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.06)}.res-compare .compare-row:last-child{border-bottom:none}
.res-compare .compare-total{margin-top:12px;padding-top:12px;border-top:1px solid rgba(255,255,255,.15);font-weight:500;color:rgba(255,255,255,.8)}
.res-time{margin-top:16px;padding:20px;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px;font-size:14px;color:rgba(255,255,255,.6);line-height:1.6}.res-time strong{color:#22c55e;font-weight:500}
.tariff-section{padding:100px 0}
.tariff-table{width:100%;border-collapse:collapse;margin-top:48px}
.tariff-table th,.tariff-table td{padding:16px 24px;text-align:left;border-bottom:1px solid #e0e0e0}
.tariff-table th{font-size:12px;font-weight:500;color:var(--muted,#666);text-transform:uppercase;letter-spacing:1px;background:var(--gray,#f5f5f5)}
.tariff-table td{font-size:15px}.tariff-table tr:hover td{background:rgba(230,51,41,.03)}
.tariff-table .highlight{background:rgba(230,51,41,.06);font-weight:500}
.tariff-table .rate{font-family:var(--fd,'DM Serif Display',serif);font-size:20px;color:var(--red,#e63329)}
.addons{padding:100px 0;background:#0a0a0a;color:#fff}
.addon-table{width:100%;border-collapse:collapse;margin-top:48px}
.addon-table th,.addon-table td{padding:16px 24px;text-align:left;border-bottom:1px solid rgba(255,255,255,.08)}
.addon-table th{font-size:12px;font-weight:500;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:1px}
.addon-table td{font-size:15px;color:rgba(255,255,255,.7)}.addon-table .price{font-family:var(--fd,'DM Serif Display',serif);font-size:20px;color:var(--red,#e63329)}
.seo-article{padding:100px 0;background:var(--gray,#f5f5f5)}
.seo-article h2{font-family:var(--fd,'DM Serif Display',serif);font-size:clamp(28px,3.5vw,40px);font-weight:400;margin-bottom:32px}
.seo-article h3{font-size:20px;font-weight:500;margin:32px 0 16px}
.seo-article p{font-size:16px;color:var(--muted,#666);line-height:1.8;margin-bottom:16px;max-width:800px}
@media(max-width:768px){
.hero{padding:100px 0 60px}.hero-content{padding:0 24px}.hero h1{font-size:clamp(36px,9vw,48px)}
.hero-stats{gap:24px}.hero-stats>div{min-width:calc(50% - 12px)}
.calc-wrap{grid-template-columns:1fr}
.tariff-table,.addon-table{font-size:13px}.tariff-table th,.tariff-table td,.addon-table th,.addon-table td{padding:12px 16px}
.final-form{flex-direction:column}
}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function(){
var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.15});
document.querySelectorAll('.reveal').forEach(function(el,i){el.style.transitionDelay=(i%3)*.1+'s';obs.observe(el);});

function getRate(n){if(n>200)return 18;if(n>150)return 19;if(n>100)return 20;if(n>75)return 21;if(n>50)return 22;if(n>20)return 23;if(n>10)return 24;if(n>5)return 25;return 26;}
function fmt(n){return Math.round(n).toLocaleString('en-US');}
function calculate(){
var ordersPerDay=parseFloat(document.getElementById('calcOrders').value)||0;
var weight=parseFloat(document.getElementById('calcWeight').value)||2;
var volumeM3=parseFloat(document.getElementById('calcVolume').value)||0;
var avgItems=parseFloat(document.getElementById('calcItems').value)||1;
var rate=getRate(ordersPerDay);var totalOrders=ordersPerDay*22;var shipping=totalOrders*rate;var storage=volumeM3*650;
var receiveCost=3;if(weight>2)receiveCost+=((weight-2)*0.5);var receiving=totalOrders*receiveCost;
var copacking=0;if(avgItems>1){copacking=totalOrders*(avgItems-1)*2.5;}
var total=shipping+storage+receiving+copacking;if(total<5000)total=5000;
var ownRent=Math.max(Math.ceil(ordersPerDay/50),1)*15000;var ownStaff=Math.max(Math.ceil(ordersPerDay/30),2)*15000;var ownWms=5000;var ownUtils=2000;var ownMaterials=Math.round(ordersPerDay*22*1.5);var ownTotal=ownRent+ownStaff+ownWms+ownUtils+ownMaterials;
var timeOwnHours=Math.round(ordersPerDay*0.15*22);var timeFreed=Math.min(timeOwnHours,160);var timeMarketing=Math.round(timeFreed*0.6);var timePersonal=Math.round(timeFreed*0.3);
var costPerOrder=totalOrders>0?(total/totalOrders):0;
document.getElementById('resShipping').textContent=fmt(shipping);document.getElementById('resShippingRate').textContent='('+rate+' UAH/order)';
document.getElementById('resStorage').textContent=fmt(storage);document.getElementById('resReceiving').textContent=fmt(receiving);
document.getElementById('resCopacking').textContent=fmt(copacking);document.getElementById('resTotal').textContent=fmt(total);
document.getElementById('resCostPer').textContent=costPerOrder.toFixed(1);
document.getElementById('ownRent').textContent=fmt(ownRent);document.getElementById('ownStaff').textContent=fmt(ownStaff);
document.getElementById('ownWms').textContent=fmt(ownWms);document.getElementById('ownUtils').textContent=fmt(ownUtils);
document.getElementById('ownMaterials').textContent=fmt(ownMaterials);document.getElementById('ownTotal').textContent=fmt(ownTotal);
var saving=ownTotal>0?Math.max(0,Math.round((1-total/ownTotal)*100)):0;document.getElementById('resSaving').textContent=saving+'%';
document.getElementById('timeFreed').textContent=timeFreed;document.getElementById('timeMarketing').textContent=timeMarketing;document.getElementById('timePersonal').textContent=timePersonal;
}
['calcOrders','calcWeight','calcVolume','calcItems'].forEach(function(id){document.getElementById(id).addEventListener('input',calculate);document.getElementById(id).addEventListener('change',calculate);});
calculate();

function {}
var leads=JSON.parse(localStorage.getItem('mtp_crm_leads')||'[]');leads.push({id:Date.now(),company:'Lead from Calculator (EN)',contact:'',phone:ph,email:'',shipments:document.getElementById('calcOrders').value||0,type:'other',source:'Calculator EN',status:'new',date:new Date().toISOString().split('T')[0],comments:[{text:'Calculator EN: '+document.getElementById('calcOrders').value+' ship/day, '+document.getElementById('calcVolume').value+' m3, total ~'+document.getElementById('resTotal').textContent+' UAH/mo',date:new Date().toLocaleString('en-US')}],onboarding:[false,false,false,false,false,false,false]});localStorage.setItem('mtp_crm_leads',JSON.stringify(leads));fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});form.innerHTML='<div style="text-align:center;padding:20px"><p style="color:#22c55e;font-size:18px;font-weight:500">\u2705 Thank you!</p><p style="color:rgba(255,255,255,0.5);font-size:14px;margin-top:8px">Our manager will call back with a personalized quote</p></div>';setTimeout(function(){window.location.href='/en/thanks/';},1500);});}
});
</script>

<script is:inline>
document.addEventListener('DOMContentLoaded',function(){
  var form=document.getElementById('heroForm');
  if(!form)return;
  form.addEventListener('submit',function(e){
    e.preventDefault();
    var ph=form.querySelector('input[name="phone"]').value.trim();
    if(ph.replace(/\D/g,'').length<10){form.querySelector('input').style.borderColor='#e63329';return;}
    fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});
    form.innerHTML='<p style="color:#22c55e;font-size:18px">\u2705 Дякуємо!</p>';
  });
});
</script>
