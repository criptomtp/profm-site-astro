---
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  lang?: 'uk' | 'ru' | 'en';
  ogImage?: string;
  ogType?: string;
  schema?: string;
  showCTA?: boolean;
}

const {
  title,
  description = '',
  canonical = '',
  lang = 'uk',
  ogImage = 'https://fulfillmentmtp.com.ua/images/tild6331-3130-4038-a230-386232353066__img_4897.webp',
  ogType = 'website',
  schema = '',
  showCTA = true,
} = Astro.props;

const locale = lang === 'uk' ? 'uk_UA' : lang === 'ru' ? 'ru_RU' : 'en_US';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={ogType}>
  <meta property="og:locale" content={locale}>
  <meta property="og:image" content={ogImage}>
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"></noscript>
  {schema && <Fragment set:html={schema} />}
  <script is:inline>window.dataLayer=window.dataLayer||[];setTimeout(function(){(function(w,d,s,l,i){w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-MV5WZT5');},3000);</script>
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/page-components.css">
  <slot name="head" />
</head>
<body>
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MV5WZT5" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <Header lang={lang} />
  <main>
    <slot />
  </main>
  {showCTA && <CTA lang={lang} />}
  <Footer lang={lang} />
  <script is:inline src="/js/lang-switcher.js"></script>
  <script is:inline>
  // FAQ accordion — handled per-page (each FAQ page has its own handler)
  // Hero form handler — universal for all pages
  var heroForm = document.getElementById('heroForm');
  if(heroForm && !heroForm.dataset.handled){
    heroForm.dataset.handled = '1';
    heroForm.addEventListener('submit', function(e){
      e.preventDefault();
      var inp = heroForm.querySelector('input[name="phone"]');
      var ph = inp.value.trim();
      var clean = ph.replace(/\D/g,'');
      if(clean.length < 10){ inp.style.borderColor='#e63329'; return; }
      fetch('/api/telegram',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname})}).catch(function(){});
      fetch('/api/leads',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({phone:ph,page:location.pathname,source:'site',comments:[{text:'Hero форма: '+location.pathname,date:new Date().toLocaleString('uk-UA')}]})}).catch(function(){});
      var lang = document.documentElement.lang;
      var msg = lang === 'en' ? 'Thank you! We will call back.' : lang === 'ru' ? 'Спасибо! Перезвоним.' : 'Дякуємо! Передзвонимо.';
      var url = lang === 'en' ? '/en/thanks/' : lang === 'ru' ? '/thanks/' : '/ua/thanks/';
      heroForm.innerHTML='<p style="color:#22c55e;font-size:18px;font-weight:500">\u2705 ' + msg + '</p>';
      setTimeout(function(){ window.location.href = url; }, 1500);
    });
  }
  // Reveal animation
  if(typeof IntersectionObserver!=='undefined'){
    var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.1});
    document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el);});
  }
  </script>
</body>
</html>
