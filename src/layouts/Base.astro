---
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  lang?: 'uk' | 'ru' | 'en';
  ogImage?: string;
  ogType?: string;
  schema?: string;
  showCTA?: boolean;
}

const {
  title,
  description = '',
  canonical = '',
  lang = 'uk',
  ogImage = 'https://fulfillmentmtp.com.ua/images/mtp-founder-nikolai-warehouse.webp',
  ogType = 'website',
  schema = '',
  showCTA = true,
} = Astro.props;

const locale = lang === 'uk' ? 'uk_UA' : lang === 'ru' ? 'ru_RU' : 'en_US';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={ogType}>
  <meta property="og:locale" content={locale}>
  <meta property="og:image" content={ogImage}>
  {ogType === 'article' && <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":title.slice(0,110),"description":description,"author":{"@type":"Organization","name":"MTP Group Fulfillment"},"publisher":{"@type":"Organization","name":"MTP Group","url":"https://www.fulfillmentmtp.com.ua"},"image":ogImage})} />}
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="dns-prefetch" href="https://fonts.googleapis.com">
  <link rel="dns-prefetch" href="https://fonts.gstatic.com">
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  {ogImage && <link rel="preload" as="image" href={ogImage.replace('https://www.fulfillmentmtp.com.ua', '').replace('https://fulfillmentmtp.com.ua', '')} fetchpriority="high" />}
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@400;500&display=swap&subset=latin,cyrillic" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@400;500&display=swap&subset=latin,cyrillic" rel="stylesheet"></noscript>
  {schema && <Fragment set:html={schema} />}
  <script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}
setTimeout(function(){var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id=AW-614588275';document.head.appendChild(s);s.onload=function(){gtag('js',new Date());gtag('config','AW-614588275');};},1500);
setTimeout(function(){(function(w,d,s,l,i){w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-MV5WZT5');},3000);</script>
  <style>
/* INLINED: design-system.css + page-components.css */
:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--fb);font-weight:400;color:var(--black);background:var(--white);line-height:1.6;overflow-x:hidden;margin:0;min-height:100vh}
a{text-decoration:none;color:inherit}
img{max-width:100%;height:auto;display:block}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:32px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}.badge-dark::before{background:var(--red)}
.sec-h2{font-family:var(--fd);font-size:clamp(32px,4.5vw,56px);font-weight:400;margin-bottom:48px}
.hero{position:relative;min-height:90vh;background:var(--black);color:var(--white);display:flex;flex-direction:column;justify-content:center;padding:80px 0 0;overflow:hidden}
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;opacity:.2}
.hero-bg img{width:100%;height:100%;object-fit:cover}
.hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero h1{font-family:var(--fd);font-size:clamp(42px,6vw,80px);font-weight:400;line-height:.95;margin-bottom:28px}
.hero-sub{font-size:clamp(16px,1.8vw,19px);color:rgba(255,255,255,.65);line-height:1.7;max-width:580px;margin-bottom:40px}
.hero-form{display:flex;gap:12px;max-width:460px}
.hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;font-family:var(--fb);outline:none}
.hero-form input::placeholder{color:rgba(255,255,255,.3)}.hero-form input:focus{border-color:rgba(255,255,255,.5)}
.hero-form button{padding:16px 24px;background:transparent;color:#fff;border:2px solid #fff;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:all .3s}
.hero-form button:hover{background:var(--red);border-color:var(--red)}
.hero-note{font-size:13px;color:rgba(255,255,255,.35);margin-top:12px}
.hero-stats{display:flex;gap:32px;padding:48px 8vw 0;margin-top:auto;position:relative;z-index:2}
.hero-stat{border-top:3px solid var(--red);padding:20px 0;flex:1}
.hero-stat-val{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;color:#fff;white-space:nowrap}
.hero-stat-label{font-size:11px;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:2px;margin-top:4px}
.footer{background:#111;color:rgba(255,255,255,.7);padding:60px 24px 30px}
.footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:40px;max-width:1200px;margin:0 auto}
.footer h3{color:#fff;font-size:14px;font-weight:500;letter-spacing:1px;text-transform:uppercase;margin-bottom:16px}
.footer p,.footer a{font-size:14px;line-height:2;color:rgba(255,255,255,.55);transition:color .2s}.footer a:hover{color:#fff}
.footer-bottom{text-align:center;margin-top:40px;padding-top:20px;border-top:1px solid rgba(255,255,255,.06);font-size:13px;color:rgba(255,255,255,.35);max-width:1200px;margin-left:auto;margin-right:auto}
.final-cta{padding:100px 0;background:var(--red);color:var(--white);text-align:center}
.final-cta h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;margin-bottom:16px}
.final-cta .sub{font-size:17px;opacity:.85;max-width:480px;margin:0 auto 36px}
.final-form{display:flex;gap:12px;justify-content:center;max-width:460px;margin:0 auto}
.final-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.35);border-radius:4px;background:rgba(255,255,255,.1);color:#fff;font-size:15px;outline:none}
.final-form input::placeholder{color:rgba(255,255,255,.45)}
.final-form button{padding:16px 24px;background:#000;color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;white-space:nowrap;transition:background .3s}.final-form button:hover{background:#222}
.final-checks{display:flex;gap:24px;justify-content:center;flex-wrap:wrap;margin-top:16px;font-size:13px;opacity:.7}
input:-webkit-autofill,input:-webkit-autofill:hover,input:-webkit-autofill:focus{-webkit-box-shadow:0 0 0 1000px rgba(255,255,255,.1) inset!important;-webkit-text-fill-color:#fff!important;transition:background-color 5000s ease-in-out 0s;caret-color:#fff}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
.svc-card,.service-card,.num-card,.adv-card,.ben-card,.wh-card,.case-stats,.case-stat,.case-card,.step,.prob-card,.rev-card,.vid-card,.extra-card,.price-card,.feature-card,.fade-in,.slide-up,.animate-in,.reveal{opacity:1!important;transform:none!important}
@media(max-width:768px){.hero-content{padding:0 24px}.hero h1{font-size:clamp(32px,8vw,48px)}.hero-form{flex-direction:column}.hero-form button{width:100%}.hero-stats{flex-wrap:wrap;gap:20px;padding:32px 24px 0}.hero-stat{min-width:calc(50% - 10px)}.final-form{flex-direction:column}}
  </style>
  <slot name="head" />
</head>
<body>
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MV5WZT5" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <Header lang={lang} />
  <main>
    <slot />
  </main>
  {showCTA && <CTA lang={lang} />}
  <Footer lang={lang} />
  <script is:inline src="/js/lang-switcher.js" defer></script>
  <script is:inline>
  // Global lead submit function — used by all forms across the site
  window.mtpSubmitLead = function(phone, page) {
    var pg = page || location.pathname;
    var ref = document.referrer || '';
    var params = new URLSearchParams(location.search);
    var utm = {
      source: params.get('utm_source') || '',
      medium: params.get('utm_medium') || '',
      campaign: params.get('utm_campaign') || '',
      term: params.get('utm_term') || '',
      gclid: params.get('gclid') || ''
    };
    var leadData = {
      phone: phone,
      page: pg,
      source: utm.gclid ? 'ads' : (utm.source || (ref.indexOf('google') > -1 ? 'google' : 'site')),
      comments: [{
        text: 'Форма: ' + pg +
          (ref ? '\nРеферер: ' + ref : '') +
          (utm.source ? '\nUTM: ' + utm.source + '/' + utm.medium + '/' + utm.campaign : '') +
          (utm.term ? '\nЗапит: ' + utm.term : '') +
          (utm.gclid ? '\nGCLID: ' + utm.gclid : ''),
        date: new Date().toLocaleString('uk-UA')
      }]
    };
    fetch('/api/telegram', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({phone: phone, page: pg})}).catch(function(){});
    fetch('/api/leads', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(leadData)}).catch(function(){});
  };

  // FAQ accordion — handled per-page (each FAQ page has its own handler)
  // Hero form handler — universal for all pages
  var heroForm = document.getElementById('heroForm');
  if(heroForm && !heroForm.dataset.handled){
    heroForm.dataset.handled = '1';
    heroForm.addEventListener('submit', function(e){
      e.preventDefault();
      var inp = heroForm.querySelector('input[name="phone"]');
      var ph = inp.value.trim();
      var clean = ph.replace(/\D/g,'');
      if(clean.length < 10){ inp.style.borderColor='#e63329'; return; }
      window.mtpSubmitLead(ph, location.pathname);
      var lang = document.documentElement.lang;
      var msg = lang === 'en' ? 'Thank you! We will call back.' : lang === 'ru' ? 'Спасибо! Перезвоним.' : 'Дякуємо! Передзвонимо.';
      var url = lang === 'en' ? '/en/thanks/' : lang === 'ru' ? '/thanks/' : '/ua/thanks/';
      heroForm.innerHTML='<p style="color:#22c55e;font-size:18px;font-weight:500">\u2705 ' + msg + '</p>';
      setTimeout(function(){ window.location.href = url; }, 1500);
    });
  }
  // Reveal animation
  if(typeof IntersectionObserver!=='undefined'){
    var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.1});
    document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el);});
  }

  // YouTube facade click handler — load iframe on click
  document.addEventListener('click',function(e){
    var facade=e.target.closest('.yt-facade');
    if(!facade||facade.querySelector('iframe'))return;
    var id=facade.dataset.id;
    var iframe=document.createElement('iframe');
    iframe.src='https://www.youtube.com/embed/'+id+'?autoplay=1&rel=0';
    iframe.allow='accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture';
    iframe.allowFullscreen=true;
    iframe.title=facade.querySelector('img').alt;
    facade.appendChild(iframe);
  });
  </script>
  <style>
  .yt-facade{position:relative;width:100%;padding-bottom:56.25%;height:0;border-radius:12px;overflow:hidden;background:#000;cursor:pointer}
  .yt-facade img{position:absolute;top:50%;left:50%;width:100%;height:auto;min-height:100%;transform:translate(-50%,-50%);object-fit:cover}
  .yt-facade .yt-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:none;border:none;cursor:pointer;opacity:.85;transition:opacity .2s;z-index:1}
  .yt-facade:hover .yt-play{opacity:1}
  .yt-facade iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none;z-index:2}
  </style>
</body>
</html>
