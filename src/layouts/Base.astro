---
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  lang?: 'uk' | 'ru' | 'en';
  ogImage?: string;
  ogType?: string;
  schema?: string;
  showCTA?: boolean;
  preloadHero?: boolean;
}

const {
  title,
  description = '',
  canonical = '',
  lang = 'uk',
  ogImage = 'https://www.fulfillmentmtp.com.ua/images/mtp-founder-nikolai-warehouse.webp',
  ogType = 'website',
  schema = '',
  showCTA = true,
  preloadHero = true,
} = Astro.props;

const locale = lang === 'uk' ? 'uk_UA' : lang === 'ru' ? 'ru_RU' : 'en_US';

// Build the .md alternate href from canonical (fallback to current pathname).
// Dual-file Markdown negotiation — LLM/AI clients can fetch clean .md version.
// .md files are advertised via HTML <link rel=alternate> + HTTP Link header +
// served with X-Robots-Tag: noindex to prevent duplicate content in Google index.
const mdHref = (() => {
  try {
    const path = canonical ? new URL(canonical).pathname : Astro.url.pathname;
    if (path === '/' || path === '') return '/index.md';
    return path.endsWith('/') ? `${path}index.md` : `${path}/index.md`;
  } catch { return null; }
})();

// Hreflang is provided by each page via Fragment slot="head".
// Auto-generation removed 2026-04-20 because the URL layout is non-uniform
// (UA home at /, UA subpages at /ua/*, RU/EN at /ru/* and /en/*, blog posts
// use different slugs per language) and auto-mapping produced wrong URLs
// that duplicated the correct manual hreflangs.
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{title}</title>
  <meta name="description" content={description}>
  {canonical && <link rel="canonical" href={canonical} />}
  {mdHref && <link rel="alternate" type="text/markdown" href={mdHref} />}
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={ogType}>
  <meta property="og:locale" content={locale}>
  <meta property="og:image" content={ogImage}>
  {canonical && <meta property="og:url" content={canonical}>}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>
  {ogType === 'article' && !schema.includes('"@type":"Article"') && <script type="application/ld+json" set:html={JSON.stringify({"@context":"https://schema.org","@type":"Article","headline":title.slice(0,110),"description":description,"author":{"@type":"Organization","name":"MTP Group Fulfillment"},"publisher":{"@type":"Organization","name":"MTP Group","url":"https://www.fulfillmentmtp.com.ua"},"image":ogImage})} />}
  <link rel="shortcut icon" href="/favicon.ico">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#e63329">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="dns-prefetch" href="https://www.googletagmanager.com">
  {/* Font preload removed: the TTF URLs here don't match what Google Fonts
      actually serves modern browsers (WOFF2), so the preload was wasted bandwidth
      and pushed LCP ~150ms. Fonts now load via the stylesheet below with
      `display=swap`, which is fine for DM Sans body + DM Serif headings. */}
  {preloadHero && ogImage && <link rel="preload" as="image" href={ogImage.replace('https://www.fulfillmentmtp.com.ua', '').replace('https://fulfillmentmtp.com.ua', '')} fetchpriority="high" />}
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@400;500&display=swap&subset=latin,cyrillic" rel="stylesheet" media="print" onload="this.media='all'">
  <noscript><link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@400;500&display=swap&subset=latin,cyrillic" rel="stylesheet"></noscript>
  <link rel="stylesheet" href="/css/stitch-tokens.css" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="/css/stitch-tokens.css"></noscript>
  {schema && <Fragment set:html={schema} />}
  <script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}
setTimeout(function(){var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id=G-ELBRCEFL41';document.head.appendChild(s);s.onload=function(){gtag('js',new Date());gtag('config','G-ELBRCEFL41');gtag('config','AW-614588275');};},1500);
setTimeout(function(){(function(w,d,s,l,i){w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-MV5WZT5');},3000);
document.addEventListener('click',function(e){var link=e.target.closest('a[href^="tel:"]');if(link&&typeof gtag==='function'){gtag('event','conversion',{'send_to':'AW-614588275/eh2qCJenw5kcEPO-h6UC','value':1.0,'currency':'UAH'});}});</script>
