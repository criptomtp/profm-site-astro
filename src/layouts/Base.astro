/* INLINED: design-system.css + page-components.css */
:root{--black:#000;--white:#fff;--red:#e63329;--gray:#f5f5f5;--muted:#666;--fd:'DM Serif Display',serif;--fb:'DM Sans',sans-serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--fb);font-weight:400;color:var(--black);background:var(--white);line-height:1.6;overflow-x:hidden;margin:0;min-height:100vh}
a{text-decoration:none;color:inherit}
img{max-width:100%;height:auto;display:block}
.ctr{max-width:1200px;margin:0 auto;padding:0 24px}
.badge{display:inline-flex;align-items:center;gap:8px;border:1px solid rgba(255,255,255,.25);border-radius:100px;padding:8px 20px;font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:32px}
.badge::before{content:'';width:6px;height:6px;background:var(--red);border-radius:50%}
.badge-dark{border-color:rgba(0,0,0,.15);color:var(--muted)}.badge-dark::before{background:var(--red)}
.sec-h2{font-family:var(--fd);font-size:clamp(32px,4.5vw,56px);font-weight:400;margin-bottom:48px}
.hero{position:relative;min-height:90vh;background:var(--black);color:var(--white);display:flex;flex-direction:column;justify-content:center;padding:80px 0 0;overflow:hidden}
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;opacity:.2}
.hero-bg img{width:100%;height:100%;object-fit:cover}
.hero-content{position:relative;z-index:2;padding:0 8vw;width:100%}
.hero h1{font-family:var(--fd);font-size:clamp(42px,6vw,80px);font-weight:400;line-height:.95;margin-bottom:28px}
.hero-sub{font-size:clamp(16px,1.8vw,19px);color:rgba(255,255,255,.75);line-height:1.7;max-width:580px;margin-bottom:40px}
.hero-form{display:flex;gap:12px;max-width:460px}
.hero-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.2);border-radius:4px;background:rgba(255,255,255,.04);color:#fff;font-size:15px;font-family:var(--fb);outline:none}
.hero-form input::placeholder{color:rgba(255,255,255,.3)}.hero-form input:focus{border-color:rgba(255,255,255,.5)}
.hero-form button{padding:16px 24px;background:#e63329;color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:600;cursor:pointer;font-family:var(--fb);white-space:nowrap;transition:all .3s}
.hero-form button:hover{background:#c42b22}
.hero-note{font-size:13px;color:rgba(255,255,255,.35);margin-top:12px}
.hero-stats{display:flex;gap:32px;padding:48px 8vw 0;margin-top:auto;position:relative;z-index:2}
.hero-stat{border-top:3px solid var(--red);padding:20px 0;flex:1}
.hero-stat-val{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;color:#fff;white-space:nowrap}
.hero-stat-label{font-size:11px;color:rgba(255,255,255,.45);text-transform:uppercase;letter-spacing:2px;margin-top:4px}
.footer{background:#111;color:rgba(255,255,255,.7);padding:60px 24px 30px}
.footer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:40px;max-width:1200px;margin:0 auto}
.footer h3{color:#fff;font-size:14px;font-weight:500;letter-spacing:1px;text-transform:uppercase;margin-bottom:16px}
.footer p,.footer a{font-size:14px;line-height:2;color:rgba(255,255,255,.55);transition:color .2s}.footer a:hover{color:#fff}
.footer-bottom{text-align:center;margin-top:40px;padding-top:20px;border-top:1px solid rgba(255,255,255,.06);font-size:13px;color:rgba(255,255,255,.35);max-width:1200px;margin-left:auto;margin-right:auto}
.final-cta{padding:100px 0;background:var(--red);color:var(--white);text-align:center}
.final-cta h2{font-family:var(--fd);font-size:clamp(28px,4vw,48px);font-weight:400;margin-bottom:16px}
.final-cta .sub{font-size:17px;opacity:.85;max-width:480px;margin:0 auto 36px}
.final-form{display:flex;gap:12px;justify-content:center;max-width:460px;margin:0 auto}
.final-form input{flex:1;padding:16px 20px;border:1px solid rgba(255,255,255,.35);border-radius:4px;background:rgba(255,255,255,.1);color:#fff;font-size:15px;outline:none}
.final-form input::placeholder{color:rgba(255,255,255,.45)}
.final-form button{padding:16px 24px;background:#000;color:#fff;border:none;border-radius:4px;font-size:15px;font-weight:500;cursor:pointer;white-space:nowrap;transition:background .3s}.final-form button:hover{background:#222}
.final-checks{display:flex;gap:24px;justify-content:center;flex-wrap:wrap;margin-top:16px;font-size:13px;opacity:.7}
input:-webkit-autofill,input:-webkit-autofill:hover,input:-webkit-autofill:focus{-webkit-box-shadow:0 0 0 1000px rgba(255,255,255,.1) inset!important;-webkit-text-fill-color:#fff!important;transition:background-color 5000s ease-in-out 0s;caret-color:#fff}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s}
/* YouTube facade — used by YouTubeEmbed.astro component */
.yt-facade{position:relative;aspect-ratio:16/9;border-radius:12px;overflow:hidden;cursor:pointer;background:#000}
.yt-facade img{width:100%;height:100%;object-fit:cover;opacity:.8;transition:opacity .3s;display:block}
.yt-facade:hover img{opacity:.6}
.yt-play{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer}
.yt-play::before{content:'';width:72px;height:72px;background:rgba(230,51,41,.92);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:transform .3s,background .3s;position:absolute}
.yt-facade:hover .yt-play::before{transform:scale(1.1);background:#e63329}
.yt-play svg{position:relative;z-index:1;margin-left:5px}
.svc-card,.service-card,.num-card,.adv-card,.ben-card,.wh-card,.case-stats,.case-stat,.case-card,.step,.prob-card,.rev-card,.vid-card,.extra-card,.price-card,.feature-card,.fade-in,.slide-up,.animate-in,.reveal{opacity:1!important;transform:none!important}
@media(max-width:768px){.hero{min-height:auto;padding:100px 0 40px}.hero-content{padding:0 24px}.hero h1{font-size:clamp(32px,8vw,48px)}.hero-form{flex-direction:column}.hero-form button{width:100%}.hero-stats{flex-wrap:wrap;gap:20px;padding:24px 24px 0}.hero-stat{min-width:calc(50% - 10px)}.final-form{flex-direction:column}}
/* Warehouse tour — video section (used on all pages) */
.warehouse-tour{background:#000;padding:100px 8vw}
.tour-inner{display:flex;align-items:center;gap:80px;max-width:1200px;margin:0 auto}
.tour-text{flex:1}
.tour-text h2{font-family:var(--fd);font-size:clamp(40px,5vw,64px);color:#fff;line-height:.95;margin:20px 0 24px;font-weight:400}
.tour-text p{font-size:17px;color:rgba(255,255,255,.75);line-height:1.7;margin-bottom:36px;max-width:400px}
.tour-btn{display:inline-flex;align-items:center;gap:10px;font-size:15px;font-weight:500;color:#fff;background:transparent;border:1.5px solid rgba(255,255,255,.4);padding:14px 28px;border-radius:100px;letter-spacing:.5px;transition:all .3s;cursor:pointer;font-family:var(--fb)}
.tour-btn:hover{background:#fff;color:#000;border-color:#fff}
.tour-video{flex:1.2}
.video-thumb{display:block;position:relative;border-radius:12px;overflow:hidden;cursor:pointer}
.video-thumb img{width:100%;aspect-ratio:16/9;object-fit:cover;filter:brightness(.6);transition:filter .4s,transform .4s}
.video-thumb:hover img{filter:brightness(.8);transform:scale(1.02)}
.play-overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px}
.play-btn-large{width:80px;height:80px;background:rgba(230,51,41,.9);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;color:#fff;transition:transform .3s;padding-left:6px}
.video-thumb:hover .play-btn-large{transform:scale(1.1)}
.play-overlay span{font-size:14px;color:rgba(255,255,255,.8);letter-spacing:1px;text-transform:uppercase}
@media(max-width:768px){.tour-inner{flex-direction:column;gap:40px}.tour-video{width:100%}}
.skip-link{position:absolute;top:-100%;left:50%;transform:translateX(-50%);background:var(--red);color:#fff;padding:12px 24px;border-radius:0 0 8px 8px;font-size:14px;font-weight:600;z-index:100000;transition:top .2s}
.skip-link:focus{top:0}
:focus-visible{outline:2px solid var(--red);outline-offset:2px}
input:focus-visible,button:focus-visible,a:focus-visible{outline:2px solid var(--red);outline-offset:2px}
.hero-guar{font-size:12px;color:rgba(255,255,255,.5);margin-top:14px;letter-spacing:.3px}
.hero-tg{display:inline-flex;align-items:center;gap:8px;color:#0088cc;font-size:13px;text-decoration:none;margin-top:8px;transition:color .2s}
.hero-tg:hover{color:#00aaee}
.hero-tg svg{flex-shrink:0;fill:#0088cc}
.hero-guarantees{display:flex;justify-content:center;gap:24px;flex-wrap:wrap;padding:16px 24px;background:rgba(230,51,41,.08);border-top:1px solid rgba(230,51,41,.15)}
.hero-guarantees span{font-size:13px;color:#e63329;font-weight:500;white-space:nowrap}
@media(max-width:768px){.hero-guarantees{gap:12px;padding:12px 16px}.hero-guarantees span{font-size:12px}}
@media(prefers-reduced-motion:reduce){*,*::before,*::after{animation-duration:0.01ms!important;animation-iteration-count:1!important;transition-duration:0.01ms!important;scroll-behavior:auto!important}}
/* Sticky mobile CTA */
.sticky-cta{display:none}
@media(max-width:768px){
.sticky-cta{display:flex;position:fixed;bottom:0;left:0;right:0;z-index:9998;gap:8px;padding:8px;background:#000;border-top:1px solid rgba(255,255,255,.1);padding-bottom:calc(8px + env(safe-area-inset-bottom))}
.sticky-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:14px 12px;border-radius:8px;font-size:15px;font-weight:600;text-decoration:none;text-align:center}
.sticky-phone{background:#e63329;color:#fff}
.sticky-tg{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.15)}
.sticky-tg:hover{background:rgba(255,255,255,.15)}
body{padding-bottom:64px}
.footer{padding-bottom:80px}
}
  </style>
