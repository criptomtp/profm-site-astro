</head>
<body>
  <a href="#main-content" class="skip-link">Перейти до змісту</a>
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MV5WZT5" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <Header lang={lang} />
  <main id="main-content" data-md-root data-md-title={title} data-md-description={description} data-md-lang={lang} data-md-canonical={canonical}>
    <slot />
  </main>
  {showCTA && <CTA lang={lang} />}
  <Footer lang={lang} />
  <script is:inline src="/js/lang-switcher.js" defer></script>
  <script is:inline src="/js/faq.js" defer></script>
  <script is:inline>
  // YouTube facade click handler — used by YouTubeEmbed.astro
  document.addEventListener('DOMContentLoaded', function(){
    document.querySelectorAll('.yt-facade').forEach(function(el){
      el.addEventListener('click', function(){
        var id = el.dataset.id;
        if(!id) return;
        var iframe = document.createElement('iframe');
        iframe.src = 'https://www.youtube.com/embed/' + id + '?autoplay=1&rel=0';
        iframe.width = '100%';
        iframe.height = '100%';
        iframe.style.cssText = 'position:absolute;inset:0;border:none';
        iframe.allow = 'accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture';
        iframe.allowFullscreen = true;
        el.style.position = 'relative';
        el.innerHTML = '';
        el.appendChild(iframe);
      });
    });
  });
  </script>
  <script is:inline>
  // Global lead submit function — used by all forms across the site
  window.mtpSubmitLead = function(phone, page, name) {
    var pg = page || location.pathname;
    var nm = name || '';
    var ref = document.referrer || '';
    var params = new URLSearchParams(location.search);
    var utm = {
      source: params.get('utm_source') || '',
      medium: params.get('utm_medium') || '',
      campaign: params.get('utm_campaign') || '',
      term: params.get('utm_term') || '',
      gclid: params.get('gclid') || ''
    };
    var leadData = {
      phone: phone,
      contact: nm,
      page: pg,
      source: utm.gclid ? 'ads' : (utm.source || (ref.indexOf('google') > -1 ? 'google' : 'site')),
      comments: [{
        text: 'Форма: ' + pg +
          (nm ? '\nІм\'я: ' + nm : '') +
          (ref ? '\nРеферер: ' + ref : '') +
          (utm.source ? '\nUTM: ' + utm.source + '/' + utm.medium + '/' + utm.campaign : '') +
          (utm.term ? '\nЗапит: ' + utm.term : '') +
          (utm.gclid ? '\nGCLID: ' + utm.gclid : ''),
        date: new Date().toLocaleString('uk-UA')
      }]
    };
    fetch('/api/telegram', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({phone: phone, page: pg, name: nm})}).catch(function(){});
    fetch('/api/leads', {method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify(leadData)}).catch(function(){});
    // GA4 form_submit event
    if(typeof gtag==='function'){
      gtag('event','form_submit',{event_category:'leads',event_label:pg,page_location:location.href,utm_source:utm.source,utm_medium:utm.medium,utm_campaign:utm.campaign});
      gtag('event','generate_lead',{currency:'UAH',value:1.0});
    }
    // GTM dataLayer push
    window.dataLayer=window.dataLayer||[];
    window.dataLayer.push({event:'form_submit',event_category:'leads',event_label:pg,phone_masked:phone.slice(0,6)+'****'});
  };

  // Auto-insert Telegram link after hero-note
  var heroNote = document.querySelector('.hero-note');
  if(heroNote && !heroNote.nextElementSibling?.classList?.contains('hero-tg')){
    var lang = document.documentElement.lang;
    var tgTexts = {uk:'Або напишіть в Telegram →',ru:'Или напишите в Telegram →',en:'Or message us on Telegram →'};
    var tgUrls = {
      uk:'https://t.me/nikolay_mtp?text=%D0%9F%D1%80%D0%B8%D0%B2%D1%96%D1%82!%20%D0%A6%D1%96%D0%BA%D0%B0%D0%B2%D0%B8%D1%82%D1%8C%20%D1%84%D1%83%D0%BB%D1%84%D1%96%D0%BB%D0%BC%D0%B5%D0%BD%D1%82.%20%D0%9C%D0%BE%D0%B6%D0%B5%D1%82%D0%B5%20%D1%80%D0%BE%D0%B7%D1%80%D0%B0%D1%85%D1%83%D0%B2%D0%B0%D1%82%D0%B8%20%D0%B2%D0%B0%D1%80%D1%82%D1%96%D1%81%D1%82%D1%8C%3F',
      ru:'https://t.me/nikolay_mtp?text=%D0%97%D0%B4%D1%80%D0%B0%D0%B2%D1%81%D1%82%D0%B2%D1%83%D0%B9%D1%82%D0%B5!%20%D0%98%D0%BD%D1%82%D0%B5%D1%80%D0%B5%D1%81%D1%83%D0%B5%D1%82%20%D1%84%D1%83%D0%BB%D1%84%D0%B8%D0%BB%D0%BC%D0%B5%D0%BD%D1%82.%20%D0%9C%D0%BE%D0%B6%D0%B5%D1%82%D0%B5%20%D1%80%D0%B0%D1%81%D1%81%D1%87%D0%B8%D1%82%D0%B0%D1%82%D1%8C%20%D1%81%D1%82%D0%BE%D0%B8%D0%BC%D0%BE%D1%81%D1%82%D1%8C%3F',
      en:'https://t.me/nikolay_mtp?text=Hi!%20Interested%20in%20fulfillment%20services.%20Can%20you%20calculate%20the%20cost%3F'
    };
    var tgLink = document.createElement('a');
    tgLink.href = tgUrls[lang] || tgUrls.uk;
    tgLink.target = '_blank';
    tgLink.rel = 'noopener';
    tgLink.className = 'hero-tg';
    tgLink.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12s5.37 12 12 12 12-5.37 12-12S18.63 0 12 0zm5.94 8.13l-1.97 9.28c-.15.67-.54.83-1.1.52l-3.03-2.24-1.46 1.41c-.16.16-.3.3-.61.3l.22-3.05 5.56-5.02c.24-.22-.05-.34-.37-.13l-6.87 4.33-2.96-.92c-.64-.2-.66-.64.14-.95l11.58-4.47c.53-.2 1-.05.87.94z"/></svg> ' + (tgTexts[lang] || tgTexts.uk);
    // Guarantees block
    var guarTexts = {
      uk:'✅ Без довгострокового контракту · ✅ Тестовий період · ✅ Вихід за 1 день',
      ru:'✅ Без долгосрочного контракта · ✅ Тестовый период · ✅ Выход за 1 день',
      en:'✅ No long-term contract · ✅ Trial period · ✅ Exit in 1 day'
    };
    var guarDiv = document.createElement('div');
    guarDiv.className = 'hero-guar';
    guarDiv.textContent = guarTexts[lang] || guarTexts.uk;
    heroNote.after(guarDiv, tgLink);
  }

  // Hero form handler — universal for all pages
  var heroForm = document.getElementById('heroForm');
  if(heroForm && !heroForm.dataset.handled){
    heroForm.dataset.handled = '1';
    heroForm.addEventListener('submit', function(e){
      e.preventDefault();
      var inp = heroForm.querySelector('input[name="phone"]');
      var errEl = document.getElementById('heroFormError');
      var ph = inp.value.trim();
      var clean = ph.replace(/\D/g,'');
      if(clean.length < 10){
        inp.classList.add('input-error');
        if(errEl){ errEl.style.display='block'; }
        return;
      }
      inp.classList.remove('input-error');
      if(errEl){ errEl.style.display='none'; }
      window.mtpSubmitLead(ph, location.pathname);
      var lang = document.documentElement.lang;
      var msg = lang === 'en' ? 'Thank you! We will call back.' : lang === 'ru' ? 'Спасибо! Перезвоним.' : 'Дякуємо! Передзвонимо.';
      var url = lang === 'en' ? '/en/thanks/' : lang === 'ru' ? '/thanks/' : '/ua/thanks/';
      heroForm.innerHTML='<p style="color:#fff;font-size:18px;font-weight:500">\u2705 ' + msg + '</p>';
      setTimeout(function(){ window.location.href = url; }, 2500);
    });
    // Clear error on input
    heroForm.querySelector('input[name="phone"]').addEventListener('input', function(){
      this.classList.remove('input-error');
      var errEl = document.getElementById('heroFormError');
      if(errEl){ errEl.style.display='none'; }
    });
  }
  // Reveal animation
  if(typeof IntersectionObserver!=='undefined'){
    var obs=new IntersectionObserver(function(en){en.forEach(function(e){if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}});},{threshold:.1});
    document.querySelectorAll('.reveal').forEach(function(el){obs.observe(el);});
  }

  // Video modal — identical to homepage
  window.openVideoModal=function(id){
    var m=document.getElementById('videoModal');
    if(!m){
      m=document.createElement('div');m.id='videoModal';
      m.style.cssText='display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:99999;align-items:center;justify-content:center';
      m.innerHTML='<div style="position:relative;width:90%;max-width:900px;aspect-ratio:16/9"><iframe id="videoIframe" width="100%" height="100%" frameborder="0" allow="autoplay;encrypted-media" allowfullscreen style="border-radius:8px"></iframe><button onclick="closeVideoModal()" style="position:absolute;top:-40px;right:0;background:none;border:none;color:#fff;font-size:32px;cursor:pointer">&times;</button></div>';
      document.body.appendChild(m);
      m.addEventListener('click',function(e){if(e.target===m)closeVideoModal();});
    }
    document.getElementById('videoIframe').src='https://www.youtube.com/embed/'+id+'?autoplay=1&rel=0';
    m.style.display='flex';document.body.style.overflow='hidden';
  };
  window.closeVideoModal=function(){
    var m=document.getElementById('videoModal');if(!m)return;
    document.getElementById('videoIframe').src='';m.style.display='none';document.body.style.overflow='';
  };
  document.addEventListener('keydown',function(e){if(e.key==='Escape'){closeVideoModal();var ep=document.getElementById('exitPopup');if(ep)ep.style.display='none';}});

  // Telegram click conversion tracking
  document.addEventListener('click',function(e){var link=e.target.closest('a[href*="t.me/"]');if(link&&typeof gtag==='function'){gtag('event','conversion',{'send_to':'AW-614588275/fKOICMvozZocEPO-h6UC','value':1.0,'currency':'UAH'});}});

  // Exit-intent popup (desktop only, 1x per session, not on /thanks/, 15s delay)
  if(window.innerWidth>768 && !location.pathname.includes('/thanks')){
    var exitReady=false;
    setTimeout(function(){exitReady=true;},15000);
    document.addEventListener('mouseout',function(e){
      if(e.clientY<10 && exitReady && !sessionStorage.getItem('exitShown')){
        sessionStorage.setItem('exitShown','1');
        var lang=document.documentElement.lang;
        var titles={uk:'Зачекайте! Отримайте безкоштовний аудит логістики',ru:'Подождите! Получите бесплатный аудит логистики',en:'Wait! Get a free logistics audit'};
        var subs={uk:'Порахуємо скільки ви зекономите з фулфілментом за 15 хвилин',ru:'Посчитаем сколько вы сэкономите с фулфилментом за 15 минут',en:'We\'ll calculate your savings with fulfillment in 15 minutes'};
        var btns={uk:'Порахувати економію',ru:'Рассчитать экономию',en:'Calculate savings'};
        var ep=document.createElement('div');ep.id='exitPopup';
        ep.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:100000;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px)';
        ep.innerHTML='<div style="background:#fff;border-radius:16px;padding:48px 40px;max-width:480px;width:90%;text-align:center;position:relative"><button onclick="document.getElementById(\'exitPopup\').style.display=\'none\'" style="position:absolute;top:16px;right:16px;background:none;border:none;font-size:24px;cursor:pointer;color:#999">&times;</button><h2 style="font-family:\'DM Serif Display\',serif;font-size:clamp(24px,4vw,32px);font-weight:400;margin-bottom:12px;color:#000">'+(titles[lang]||titles.uk)+'</h2><p style="font-size:15px;color:#666;margin-bottom:24px;line-height:1.6">'+(subs[lang]||subs.uk)+'</p><form id="exitForm" style="display:flex;align-items:center;gap:8px"><input type="tel" name="phone" placeholder="+380XXXXXXXXX" maxlength="19" required autocomplete="tel" aria-label="Phone" style="flex:1;height:48px;padding:0 16px;border:2px solid #e0e0e0;border-radius:8px;font-size:15px;outline:none;box-sizing:border-box"><button type="submit" style="height:48px;padding:0 24px;background:#e63329;color:#fff;border:none;border-radius:8px;font-size:15px;font-weight:600;cursor:pointer;white-space:nowrap;box-sizing:border-box">'+(btns[lang]||btns.uk)+'</button></form><p style="font-size:12px;color:#999;margin-top:12px">✅ Без зобов\'язань · Результат за 15 хвилин</p></div>';
        document.body.appendChild(ep);
        ep.addEventListener('click',function(ev){if(ev.target===ep)ep.style.display='none';});
        document.getElementById('exitForm').addEventListener('submit',function(ev){
          ev.preventDefault();var ph=this.querySelector('input').value.trim();
          if(ph.replace(/\D/g,'').length<10)return;
          if(window.mtpSubmitLead)window.mtpSubmitLead(ph);
          this.innerHTML='<p style="color:#e63329;font-size:18px;font-weight:600">✅ '+(lang==='en'?'Thank you!':lang==='ru'?'Спасибо!':'Дякуємо!')+'</p>';
          setTimeout(function(){ep.style.display='none';},2000);
        });
      }
    });
  }
  </script>
  <!-- Sticky mobile CTA bar -->
  {!canonical?.includes('/thanks') && <div class="sticky-cta" id="stickyCta">
    <a href="tel:+380501444645" class="sticky-btn sticky-phone">📞 {lang === 'en' ? 'Call' : 'Подзвонити'}</a>
    <a href={lang === 'en' ? 'https://t.me/nikolay_mtp?text=Hi!%20Interested%20in%20fulfillment%20services.%20Can%20you%20calculate%20the%20cost%3F' : lang === 'ru' ? 'https://t.me/nikolay_mtp?text=%D0%97%D0%B4%D1%80%D0%B0%D0%B2%D1%81%D1%82%D0%B2%D1%83%D0%B9%D1%82%D0%B5!%20%D0%98%D0%BD%D1%82%D0%B5%D1%80%D0%B5%D1%81%D1%83%D0%B5%D1%82%20%D1%84%D1%83%D0%BB%D1%84%D0%B8%D0%BB%D0%BC%D0%B5%D0%BD%D1%82.%20%D0%9C%D0%BE%D0%B6%D0%B5%D1%82%D0%B5%20%D1%80%D0%B0%D1%81%D1%81%D1%87%D0%B8%D1%82%D0%B0%D1%82%D1%8C%20%D1%81%D1%82%D0%BE%D0%B8%D0%BC%D0%BE%D1%81%D1%82%D1%8C%3F' : 'https://t.me/nikolay_mtp?text=%D0%9F%D1%80%D0%B8%D0%B2%D1%96%D1%82!%20%D0%A6%D1%96%D0%BA%D0%B0%D0%B2%D0%B8%D1%82%D1%8C%20%D1%84%D1%83%D0%BB%D1%84%D1%96%D0%BB%D0%BC%D0%B5%D0%BD%D1%82.%20%D0%9C%D0%BE%D0%B6%D0%B5%D1%82%D0%B5%20%D1%80%D0%BE%D0%B7%D1%80%D0%B0%D1%85%D1%83%D0%B2%D0%B0%D1%82%D0%B8%20%D0%B2%D0%B0%D1%80%D1%82%D1%96%D1%81%D1%82%D1%8C%3F'} target="_blank" rel="noopener" class="sticky-btn sticky-tg">💬 Telegram</a>
  </div>}
